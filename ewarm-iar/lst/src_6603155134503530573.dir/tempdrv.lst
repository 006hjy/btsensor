    519          /***************************************************************************//**
    520           * @brief
    521           *   Prepare calibration values for temperature conversion.
    522           ******************************************************************************/
    523          static void calibration(void)
    524          {
    525          #if defined(_DEVINFO_CAL_TEMP_MASK)
    526            uint32_t DItemp, DIemu;
    527          
    528            // Retrieve calibration data from DI page
    529            DItemp = ((DEVINFO->CAL & _DEVINFO_CAL_TEMP_MASK) >> _DEVINFO_CAL_TEMP_SHIFT);
    530            DIemu = ((DEVINFO->EMUTEMP & _DEVINFO_EMUTEMP_EMUTEMPROOM_MASK) >> _DEVINFO_EMUTEMP_EMUTEMPROOM_SHIFT);
    531          
    532            if ((DItemp == (_DEVINFO_CAL_TEMP_MASK >> _DEVINFO_CAL_TEMP_SHIFT))
    533                || (DIemu == (_DEVINFO_EMUTEMP_EMUTEMPROOM_MASK >> _DEVINFO_EMUTEMP_EMUTEMPROOM_SHIFT))) {
    534              // Missing DI page calibration data, substitute fixed values
    535              DItemp = fallbackTEMP;
    536              DIemu = fallbackEMU;
    537            }
    538          
    539            // calculate conversion offsets. Based on assumed slope of 5/8
    540            calibrationEMU = (DIemu) + ((5 * (DItemp)) / 8);
    541          #endif
    542          }
