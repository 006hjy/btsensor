    168          /* Errata */
    169          typedef enum ErrataState {
    170            ERRATA_LOW     = 0, /**< Low temperature <65&deg;C. */
    171            ERRATA_MID     = 1, /**< Medium temperature >65&deg;C and <80&deg;C. */
    172            ERRATA_HIGH    = 2  /**< High temperature >80&deg;C. */
    173          } ErrataState_t;
    174          
    175          // These are the temperature limits in degrees Celsius
    176          #define ERRATA_MID_LIMIT   65
    177          #define ERRATA_HIGH_LIMIT  80
    178          #define ERRATA_HYSTERESIS   8
