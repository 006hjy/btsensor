    374          
    375          /***************************************************************************//**
    376           * @brief
    377           *   Check if another callback has registered the same temperature
    378           *
    379           * @param[in] set
    380           *   Callback set to search
    381           *
    382           * @param[in] temp
    383           *   Temperature to match
    384           *
    385           * @return
    386           *    @c true if a duplicate is found, @c false if no duplicates is found.
    387           ******************************************************************************/
    388          static bool checkForDuplicates(TEMPDRV_CallbackSet_t *set, int8_t temp)
    389          {
    390            uint8_t index;
    391            uint16_t emu = convertToEmu(temp);
    392            for (index = TEMPDRV_CUSTOM_CALLBACK_INDEX; index < TEMPDRV_CALLBACK_DEPTH; index++) {
    393              // filter out only entries with valid callbacks
    394              if (set[index].callback != NULL) {
    395                // if duplicate temperature, return true
    396                if (set[index].temp == emu) {
    397                  return true;
    398                }
    399              }
    400            }
    401            // return false if no duplicate temperatures found
    402            return false;
    403          }
    404          
    405          /***************************************************************************//**
    406           * @brief
    407           *   Convert a temperature in &deg;C to an EMU sensor value
    408           *
    409           * @param[in] temp
    410           *   Temperature to convert in degrees Celsius
    411           *
    412           * @return
    413           *   EMU temperature sensor value that represents the given temperature
    414           ******************************************************************************/
    415          static uint16_t convertToEmu(int temp)
    416          {
    417          #if defined(_SILICON_LABS_32B_SERIES_2) || defined (_SILICON_LABS_32B_SERIES_3)
    418            return (uint16_t)((temp + 273) & 0x1FF); // Convert from Celsius to Kelvin (9 bits)
    419          #else
    420            int32_t res = (int32_t) calibrationEMU -  ((temp * 5) >> 3);
    421            // Cap conversion results at uint8_t bounds
    422            if (res > 255) {
    423              res = 255;
    424            } else if (res < 0) {
    425              res = 0;
    426            }
    427            return (uint8_t) res;
    428          #endif
    429          }
