    812          // ******** THE REST OF THE FILE IS DOCUMENTATION ONLY !***********************
    813          /// @brief Temperature Sensor Driver
    814          /// @{
    815          ///
    816          ///   @details
    817          ///
    818          ///   The source files for the TEMP driver library resides in the
    819          ///   emdrv/tempdrv folder, and consists of tempdrv.c and tempdrv.h.
    820          ///
    821          ///
    822          ///   @n @section tempdrv_intro_1 Introduction
    823          ///
    824          ///   TEMPDRV gives the user a nice interface to the EMU internal temperature sensor
    825          ///   which is present on the EFR32 and some EFM32 devices. The TEMPDRV supports
    826          ///   application specific callbacks at given temperature thresholds. The EMU
    827          ///   internal temperature sensor is running in EM0-EM4H and is capable of waking
    828          ///   up the core on temperature change. The EMU temperature sensor is running
    829          ///   continuously and measurements are taken every 250 ms.
    830          ///
    831          ///   @note The TEMPDRV is using the EMU peripheral and not the ADC peripheral.
    832          ///   The ADC contains another internal temperature sensor which is not touched
    833          ///   by the TEMPDRV.
    834          ///
    835          ///   The TEMPDRV also provides an important errata fix for the EFR32 first
    836          ///   generation devices when operating at high temperature environments (above
    837          ///   50&deg;C). The errata document for the EFR32 describes the errata which is
    838          ///   called "EMU_E201 - High Temperature Operation". To implement the errata fix
    839          ///   in a user application it is enough to include the TEMPDRV and call
    840          ///   @ref TEMPDRV_Init() at the start of the program. This will activate the errata
    841          ///   fix code which is modifying registers based on changes in the EMU temperature.
    842          ///
    843          ///   @n @section tempdrv_conf Configuration Options
    844          ///
    845          ///   Some properties of the TEMPDRV driver are compile-time configurable. These
    846          ///   properties are set in a file named tempdrv_config.h. A template for this
    847          ///   file, containing default values, resides in the emdrv/tempdrv/config folder.
    848          ///   To configure TEMPDRV for your application, provide your own configuration file.
    849          ///   These are the available configuration parameters with default values defined.
    850          ///   @code{.c}
    851          ///
    852          ///  // Callback table depth (for high and low callbacks each)
    853          ///  #define TEMPDRV_CALLBACK_DEPTH 5
    854          ///
    855          ///  // Allow temperature sensor to wake the device up from EM4
    856          ///  #define TEMPDRV_EM4WAKEUP false
    857          ///
    858          ///  // Allow TEMPDRV to define the EMU_IRQ_Handler. Enable if EMU_IRQ_Handler is
    859          ///  // defined elsewhere.
    860          ///  #define EMU_CUSTOM_IRQ_HANDLER false
    861          ///   @endcode
    862          ///
    863          ///   Callback table depth determines the number of concurrent callbacks that can be
    864          ///   registered at a single time. The depth applies to each limit, so depth of 5
    865          ///   allows up to 5 high and 5 low callbacks to be registered.
    866          ///   There are no run-time configuration options for TEMPDRV.
    867          ///
    868          ///   @n @section tempdrv_api The API
    869          ///
    870          ///   This section contain brief descriptions of the functions in the API. You will
    871          ///   find detailed information on input and output parameters and return values by
    872          ///   clicking on the function names. Most functions return an error
    873          ///   code, @ref ECODE_EMDRV_TEMPDRV_OK is returned on success,
    874          ///   see ecode.h and tempdrv.h for other error codes.
    875          ///
    876          ///   Your application code must include one header file: @em tempdrv.h.
    877          ///
    878          ///   @ref TEMPDRV_Init(), @ref TEMPDRV_DeInit() @n
    879          ///    These functions initializes or deinitializes the TEMPDRV driver. This will
    880          ///    erase any registered callbacks and disabled all interrupts. Typically
    881          ///    TEMPDRV_Init() is called once in your startup code.
    882          ///
    883          ///   @ref TEMPDRV_Enable() @n
    884          ///    Enable or disable the temperature driver without losing any registered
    885          ///    callbacks.
    886          ///
    887          ///   @ref TEMPDRV_GetTemp() @n
    888          ///    Get the current temperature in degrees Celsius. This measurement is based on
    889          ///    a conversion from the EMU temperature sensor and calibration data that is
    890          ///    stored in the DI page.
    891          ///
    892          ///   @ref TEMPDRV_RegisterCallback(), @ref TEMPDRV_UnregisterCallback() @n
    893          ///    Callbacks can be registered for rising or falling thresholds and will called
    894          ///    as soon as the temperature matches the specified threshold. Multiple
    895          ///    callbacks at the same temperature are not permitted, nor are mismatches
    896          ///    between temperature and limit (e. g temperature is lower than current but
    897          ///    the limit is set to high). Additionally, unregistering a callback will remove
    898          ///    all entries of matching callbacks.
    899          ///
    900          ///   @n @section tempdrv_example Example
    901          ///   @code{.c}
    902          ///#include "tempdrv.h"
    903          ///
    904          ///boolean flag = false;
    905          ///
    906          ///void callback(int8_t temp, TEMPDRV_LimitType_t limit)
    907          ///{
    908          ///  flag = true;
    909          ///}
    910          ///
    911          ///int main(void)
    912          ///{
    913          ///  TEMPDRV_Init();
    914          ///
    915          ///  // Register a callback at 10 degrees above current temperature
    916          ///  TEMPDRV_RegisterCallback(TEMPDRV_GetTemp()+10, TEMPDRV_LIMIT_HIGH, callback);
    917          ///
    918          ///  while (flag==false) {};
    919          ///}
    920          ///   @endcode
    921          ///
    922          /// @}  *******************************************************
    923          
    924          /** @} (end addtogroup tempdrv) */

