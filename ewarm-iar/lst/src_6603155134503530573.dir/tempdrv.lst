    189           *
    190           * @details
    191           *   This function is called by the TEMPDRV_IRQHandler and will change the
    192           *   state depending on the current temperature.
    193           ******************************************************************************/
    194          static void errataCallback(int8_t temp, TEMPDRV_LimitType_t limit)
    195          {
    196            (void) limit; // unused
    197            errataStateUpdate(temp);
    198          }
    199          
    200          /***************************************************************************//**
    201           * @brief
    202           *   Errata State Update
    203           *
    204           * @details
    205           *   Updates registers based on the current temperature
    206           ******************************************************************************/
    207          static void errataStateUpdate(int8_t temp)
    208          {
    209            ErrataState_t errataState;
    210            bool emuLocked = (EMU->LOCK == EMU_LOCK_LOCKKEY_LOCKED);
    211          
    212            // Figure out the current state based on temperature
    213            if (temp < ERRATA_MID_LIMIT) {
    214              errataState = ERRATA_LOW;
    215            } else if (temp < ERRATA_HIGH_LIMIT) {
    216              errataState = ERRATA_MID;
    217            } else {
    218              errataState = ERRATA_HIGH;
    219            }
    220          
    221            // Activate callback and thresholds for the current state
    222            tempdrvHighCallbacks[0] = errataHighTemp[errataState];
    223            tempdrvLowCallbacks[0] = errataLowTemp[errataState];
    224          
    225            if (emuLocked) {
    226              EMU->LOCK = EMU_LOCK_LOCKKEY_UNLOCK;
    227            }
    228          
    229            switch (errataState) {
    230              case ERRATA_LOW:
    231                EMU_SetBiasMode(emuBiasMode_1KHz);
    232                break;
    233              case ERRATA_MID:
    234                EMU_SetBiasMode(emuBiasMode_4KHz);
    235                break;
    236              case ERRATA_HIGH:
    237                EMU_SetBiasMode(emuBiasMode_Continuous);
    238                break;
    239            }
    240          
    241            if (emuLocked) {
    242              EMU->LOCK = EMU_LOCK_LOCKKEY_LOCK;
    243            }
    244          }
    245          
    246          /***************************************************************************//**
    247           * @brief
    248           *   Errata Initialization
    249           *
    250           * @details
    251           *   Initialize the temperature thresholds based on calibration values and
    252           *   initializes the errata fix based on the current temperature.
    253           ******************************************************************************/
    254          static void errataInit(void)
    255          {
    256            SYSTEM_ChipRevision_TypeDef rev;
    257            SYSTEM_ChipRevisionGet(&rev);
    258          
    259            /* Rev A temp errata handling */
    260            if (rev.major == 0x01) {
    261              uint16_t limitLow;
    262              uint16_t limitHigh;
    263          
    264              // Initialize Low temperature state [*, 65]
    265              limitHigh = convertToEmu(ERRATA_MID_LIMIT);
    266              errataHighTemp[ERRATA_LOW].temp = limitHigh;
    267              errataHighTemp[ERRATA_LOW].callback = errataCallback;
    268          
    269              // Initialize Mid temperature state [57, 80]
    270              limitLow  = convertToEmu(ERRATA_MID_LIMIT - ERRATA_HYSTERESIS);
    271              limitHigh = convertToEmu(ERRATA_HIGH_LIMIT);
    272              errataLowTemp[ERRATA_MID].temp = limitLow;
    273              errataLowTemp[ERRATA_MID].callback = errataCallback;
    274              errataHighTemp[ERRATA_MID].temp = limitHigh;
    275              errataHighTemp[ERRATA_MID].callback = errataCallback;
    276          
    277              // Initialize High temperature state [72, *]
    278              limitLow = convertToEmu(ERRATA_HIGH_LIMIT - ERRATA_HYSTERESIS);
    279              errataLowTemp[ERRATA_HIGH].temp = limitLow;
    280              errataLowTemp[ERRATA_HIGH].callback = errataCallback;
    281          
    282              errataStateUpdate(TEMPDRV_GetTemp());
    283            }
    284          }
    285          #else // TEMPDRV_ERRATA_FIX
    286          
    287          #define errataInit()
    288          
    289          #endif // TEMPDRV_ERRATA_FIX
    290          
    291          /* Internal Functions */
    292          /***************************************************************************//**
    293           * @brief
    294           *   Find an empty spot for callback in set
    295           *
    296           * @param[in] set
    297           *   Callback set to search
    298           *
    299           * @return
    300           *   index of empty space if found, -1 if none
    301           ******************************************************************************/
    302          static int8_t findCallbackSpace(TEMPDRV_CallbackSet_t *set)
    303          {
    304            uint8_t index;
    305            for (index = TEMPDRV_CUSTOM_CALLBACK_INDEX; index < TEMPDRV_CALLBACK_DEPTH; index++) {
    306              if (set[index].callback == NULL) {
    307                return index;
    308              }
    309            }
    310            // no empty space, return -1
    311            return -1;
    312          }
    313          
    314          /***************************************************************************//**
    315           * @brief
    316           *   Attempt to add a callback to a set
    317           *
    318           * @param[in] set
    319           *   Callback set to add callback to
    320           *
    321           * @param[in] temp
    322           *   Temperature to register callback at
    323           *
    324           * @param[in] callback
    325           *   Callback function
    326           *
    327           * @return
    328           *    @li @ref ECODE_EMDRV_TEMPDRV_OK on success.
    329           *    @li @ref ECODE_EMDRV_TEMPDRV_NO_SPACE if there is no space left for
    330           *        callbacks.
    331           ******************************************************************************/
    332          static Ecode_t addCallback(TEMPDRV_CallbackSet_t *set,
    333                                     int8_t temp,
    334                                     TEMPDRV_Callback_t callback)
    335          {
    336            int8_t index = findCallbackSpace(set);
    337            if (index < 0) {
    338              return ECODE_EMDRV_TEMPDRV_NO_SPACE;
    339            }
    340            set[index].temp = convertToEmu(temp);
    341            set[index].callback = callback;
    342            updateInterrupts();
    343            return ECODE_EMDRV_TEMPDRV_OK;
    344          }
    345          
    346          /***************************************************************************//**
