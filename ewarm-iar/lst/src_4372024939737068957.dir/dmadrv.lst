   1603          /***************************************************************************//**
   1604           * @brief
   1605           *  Start an LDMA transfer.
   1606           ******************************************************************************/
   1607          static Ecode_t StartTransfer(DmaMode_t             mode,
   1608                                       DmaDirection_t        direction,
   1609                                       unsigned int          channelId,
   1610                                       DMADRV_PeripheralSignal_t
   1611                                       peripheralSignal,
   1612                                       void                  *buf0,
   1613                                       void                  *buf1,
   1614                                       void                  *buf2,
   1615                                       bool                  bufInc,
   1616                                       int                   len,
   1617                                       DMADRV_DataSize_t     size,
   1618                                       DMADRV_Callback_t     callback,
   1619                                       void                  *cbUserParam)
   1620          {
   1621            ChTable_t *ch;
   1622            sl_hal_ldma_transfer_config_t xfer;
   1623            sl_hal_ldma_descriptor_t *desc;
   1624          
   1625            if ( !initialized ) {
   1626              return ECODE_EMDRV_DMADRV_NOT_INITIALIZED;
   1627            }
   1628          
   1629            if ( (channelId >= EMDRV_DMADRV_DMA_CH_COUNT)
   1630                 || (buf0 == NULL)
   1631                 || (buf1 == NULL)
   1632                 || (len > DMADRV_MAX_XFER_COUNT)
   1633                 || ((mode == dmaModePingPong) && (buf2 == NULL)) ) {
   1634              return ECODE_EMDRV_DMADRV_PARAM_ERROR;
   1635            }
   1636          
   1637            ch = &chTable[channelId];
   1638            if ( ch->allocated == false ) {
   1639              return ECODE_EMDRV_DMADRV_CH_NOT_ALLOCATED;
   1640            }
   1641          
   1642            xfer = xferCfgPeripheral;
   1643            desc = &dmaXfer[channelId].desc[0];
   1644          
   1645            if ( direction == dmaDirectionMemToPeripheral ) {
   1646              *desc = m2p;
   1647              if ( !bufInc ) {
   1648                desc->xfer.src_inc = SL_HAL_LDMA_CTRL_SRC_INC_NONE;
   1649              }
   1650            } else {
   1651              *desc = p2m;
   1652              if ( !bufInc ) {
   1653                desc->xfer.dst_inc = SL_HAL_LDMA_CTRL_DST_INC_NONE;
   1654              }
   1655            }
   1656          
   1657            xfer.request_sel      = peripheralSignal;
   1658            desc->xfer.xfer_count = len - 1;
   1659            desc->xfer.dst_addr   = (uint32_t)(uint8_t *)buf0;
   1660            desc->xfer.src_addr   = (uint32_t)(uint8_t *)buf1;
   1661            desc->xfer.size       = size;
   1662          
   1663            if ( mode == dmaModePingPong ) {
   1664              desc->xfer.link_mode = SL_HAL_LDMA_LINK_MODE_REL;
   1665              desc->xfer.link      = 1;
   1666              desc->xfer.link_addr = 4;      /* Refer to the "pong" descriptor. */
   1667          
   1668              /* Set the "pong" descriptor equal to the "ping" descriptor. */
   1669              dmaXfer[channelId].desc[1] = *desc;
   1670              /* Refer to the "ping" descriptor. */
   1671              dmaXfer[channelId].desc[1].xfer.link_addr = -4;
   1672              dmaXfer[channelId].desc[1].xfer.src_addr = (uint32_t)(uint8_t *)buf2;
   1673          
   1674              if ( direction == dmaDirectionPeripheralToMem ) {
   1675                dmaXfer[channelId].desc[1].xfer.dst_addr = (uint32_t)(uint8_t *)buf1;
   1676                desc->xfer.src_addr = (uint32_t)(uint8_t *)buf2;
   1677              }
   1678            }
   1679          
   1680            /* Whether an interrupt is needed. */
   1681            if ( (callback == NULL) && (mode == dmaModeBasic) ) {
   1682              desc->xfer.done_ifs = 0;
   1683            }
   1684          
   1685            ch->callback      = callback;
   1686            ch->userParam     = cbUserParam;
   1687            ch->callbackCount = 0;
   1688            ch->mode          = mode;
   1689          
   1690            sl_hal_ldma_init_transfer(LDMA0, channelId, &xfer, desc);
   1691            sl_hal_ldma_start_transfer(LDMA0, channelId);
   1692            if (channelId < 16) {
   1693              sl_hal_ldma_enable_interrupts(LDMA0, (0x1UL << channelId));
   1694            }
   1695          #if defined(_LDMA_IFH_MASK)
   1696            else {
   1697              sl_hal_ldma_enable_high_interrupts(LDMA0, (0x1UL << (channelId - 16)));
   1698            }
   1699          #endif
   1700          
   1701            return ECODE_EMDRV_DMADRV_OK;
   1702          }
   1703          #endif /* defined( EMDRV_DMADRV_LDMA_S3 ) */
