   1087          /***************************************************************************//**
   1088           * @brief
   1089           *  Default interrupt handler for LDMA common to all interrupt channel lines.
   1090           *
   1091           * @param[in] chnum
   1092           *  The channel ID responsible for the interrupt signal trigger.
   1093           ******************************************************************************/
   1094          static void LDMA_IRQHandlerDefault(uint8_t chnum)
   1095          {
   1096            bool stop;
   1097            ChTable_t *ch;
   1098            uint32_t pending;
   1099            uint32_t pending_done;
   1100            uint32_t pending_error;
   1101            uint32_t chmask = 1 << chnum;
   1102          
   1103            /* Get all pending and enabled interrupts. */
   1104            pending = sl_hal_ldma_get_enabled_pending_interrupts(LDMA0);
   1105            pending_done = pending & 0xFFFF;
   1106            pending_error = (pending & 0xFFFF0000) >> 16;
   1107          #if defined(_LDMA_IFH_MASK)
   1108            uint32_t pending_high = sl_hal_ldma_get_enabled_pending_high_interrupts(LDMA0);
   1109            pending_done |= ((pending_high & 0xFFFF) << 16);
   1110            pending_error |= (pending_high & 0xFFFF0000);
   1111          #endif
   1112          
   1113            /* Check for LDMA error. */
   1114            if ( pending_error & chmask ) {
   1115              /* Loop to enable debugger to see what has happened. */
   1116              while (true) {
   1117                /* Wait forever. */
   1118              }
   1119            }
   1120          
   1121            if ( pending_done & chmask ) {
   1122              /* Clear the interrupt flag. */
   1123              if (chnum < 16) {
   1124                sl_hal_ldma_clear_interrupts(LDMA0, chmask);
   1125              }
   1126          #if defined(_LDMA_IFH_MASK)
   1127              else {
   1128                sl_hal_ldma_clear_high_interrupts(LDMA0, chmask);
   1129              }
   1130          #endif
   1131          
   1132              /* Callback called if it was provided for the given channel. */
   1133              ch = &chTable[chnum];
   1134              if ( ch->callback != NULL ) {
   1135                ch->callbackCount++;
   1136                stop = !ch->callback(chnum, ch->callbackCount, ch->userParam);
   1137          
   1138                /* Continue or not a ping-pong transfer. */
   1139                if ( (ch->mode == dmaModePingPong) && stop ) {
   1140                  dmaXfer[chnum].desc[0].xfer.link = 0;
   1141                  dmaXfer[chnum].desc[1].xfer.link = 0;
   1142                }
   1143              }
   1144            }
   1145          }
