   1330          #if defined(EMDRV_DMADRV_UDMA)
   1331          /***************************************************************************//**
   1332           * @brief
   1333           *  A callback function for UDMA basic transfers.
   1334           ******************************************************************************/
   1335          static void DmaBasicCallback(unsigned int channel, bool primary, void *user)
   1336          {
   1337            ChTable_t *ch = &chTable[channel];
   1338            (void)user;
   1339            (void)primary;
   1340          
   1341            if ( ch->callback != NULL ) {
   1342              ch->callbackCount++;
   1343              ch->callback(channel, ch->callbackCount, ch->userParam);
   1344            }
   1345          }
   1346          #endif
   1347          
   1348          #if defined(EMDRV_DMADRV_UDMA)
   1349          /***************************************************************************//**
   1350           * @brief
   1351           *  A callback function for UDMA ping-pong transfers.
   1352           ******************************************************************************/
   1353          static void DmaPingPongCallback(unsigned int channel, bool primary, void *user)
   1354          {
   1355            bool stop = true;
   1356            ChTable_t *ch = &chTable[channel];
   1357          
   1358            (void)user;
   1359          
   1360            if ( ch->callback != NULL ) {
   1361              ch->callbackCount++;
   1362              stop = !ch->callback(channel, ch->callbackCount, ch->userParam);
   1363            }
   1364          
   1365            DMA_RefreshPingPong(channel,
   1366                                primary,
   1367                                false,
   1368                                NULL,
   1369                                NULL,
   1370                                ch->length - 1,
   1371                                stop);
   1372          }
   1373          #endif
   1374          
   1375          #if defined(EMDRV_DMADRV_UDMA)
   1376          /***************************************************************************//**
   1377           * @brief
   1378           *  Start a UDMA transfer.
   1379           ******************************************************************************/
   1380          static Ecode_t StartTransfer(DmaMode_t             mode,
   1381                                       DmaDirection_t        direction,
   1382                                       unsigned int          channelId,
   1383                                       DMADRV_PeripheralSignal_t
   1384                                       peripheralSignal,
   1385                                       void                  *buf0,
   1386                                       void                  *buf1,
   1387                                       void                  *buf2,
   1388                                       bool                  bufInc,
   1389                                       int                   len,
   1390                                       DMADRV_DataSize_t     size,
   1391                                       DMADRV_Callback_t     callback,
   1392                                       void                  *cbUserParam)
   1393          {
   1394            ChTable_t *ch;
   1395            DMA_CfgChannel_TypeDef chCfg;
   1396            DMA_CfgDescr_TypeDef   descrCfg;
   1397          
   1398            if ( !initialized ) {
   1399              return ECODE_EMDRV_DMADRV_NOT_INITIALIZED;
   1400            }
   1401          
   1402            if ( (channelId >= EMDRV_DMADRV_DMA_CH_COUNT)
   1403                 || (buf0 == NULL)
   1404                 || (buf1 == NULL)
   1405                 || (len > DMADRV_MAX_XFER_COUNT)
   1406                 || ((mode == dmaModePingPong) && (buf2 == NULL)) ) {
   1407              return ECODE_EMDRV_DMADRV_PARAM_ERROR;
   1408            }
   1409          
   1410            ch = &chTable[channelId];
   1411            if ( ch->allocated == false ) {
   1412              return ECODE_EMDRV_DMADRV_CH_NOT_ALLOCATED;
   1413            }
   1414          
   1415            /* Se tup the interrupt callback routine. */
   1416            if ( mode == dmaModeBasic ) {
   1417              dmaCallBack[channelId].cbFunc  = DmaBasicCallback;
   1418            } else {
   1419              dmaCallBack[channelId].cbFunc  = DmaPingPongCallback;
   1420            }
   1421            dmaCallBack[channelId].userPtr = NULL;
   1422          
   1423            /* Set up the channel */
   1424            chCfg.highPri = false;              /* Can't use hi pri with peripherals. */
   1425          
   1426            /* Whether the interrupt is needed. */
   1427            if ( (callback != NULL) || (mode == dmaModePingPong) ) {
   1428              chCfg.enableInt = true;
   1429            } else {
   1430              chCfg.enableInt = false;
   1431            }
   1432            chCfg.select = peripheralSignal;
   1433            chCfg.cb     = &dmaCallBack[channelId];
   1434            DMA_CfgChannel(channelId, &chCfg);
   1435          
   1436            /* Set up the channel descriptor. */
   1437            if ( direction == dmaDirectionMemToPeripheral ) {
   1438              if ( bufInc ) {
   1439                if ( size == dmadrvDataSize1 ) {
   1440                  descrCfg.srcInc = dmaDataInc1;
   1441                } else if ( size == dmadrvDataSize2 ) {
   1442                  descrCfg.srcInc = dmaDataInc2;
   1443                } else { /* dmadrvDataSize4 */
   1444                  descrCfg.srcInc = dmaDataInc4;
   1445                }
   1446              } else {
   1447                descrCfg.srcInc = dmaDataIncNone;
   1448              }
   1449              descrCfg.dstInc = dmaDataIncNone;
   1450            } else {
   1451              if ( bufInc ) {
   1452                if ( size == dmadrvDataSize1 ) {
   1453                  descrCfg.dstInc = dmaDataInc1;
   1454                } else if ( size == dmadrvDataSize2 ) {
   1455                  descrCfg.dstInc = dmaDataInc2;
   1456                } else { /* dmadrvDataSize4 */
   1457                  descrCfg.dstInc = dmaDataInc4;
   1458                }
   1459              } else {
   1460                descrCfg.dstInc = dmaDataIncNone;
   1461              }
   1462              descrCfg.srcInc = dmaDataIncNone;
   1463            }
   1464            descrCfg.size    = (DMA_DataSize_TypeDef)size;
   1465            descrCfg.arbRate = dmaArbitrate1;
   1466            descrCfg.hprot   = 0;
   1467            DMA_CfgDescr(channelId, true, &descrCfg);
   1468            if ( mode == dmaModePingPong ) {
   1469              DMA_CfgDescr(channelId, false, &descrCfg);
   1470            }
   1471          
   1472            ch->callback      = callback;
   1473            ch->userParam     = cbUserParam;
   1474            ch->callbackCount = 0;
   1475            ch->length        = len;
   1476          
   1477            DMA->IFC = 1 << channelId;
   1478          
   1479            /* Start the DMA cycle. */
   1480            if ( mode == dmaModeBasic ) {
   1481              DMA_ActivateBasic(channelId, true, false, buf0, buf1, len - 1);
   1482            } else {
   1483              if ( direction == dmaDirectionMemToPeripheral ) {
   1484                DMA_ActivatePingPong(channelId,
   1485                                     false,
   1486                                     buf0,                              /* dest */
   1487                                     buf1,                              /* src  */
   1488                                     len - 1,
   1489                                     buf0,                              /* dest */
   1490                                     buf2,                              /* src  */
   1491                                     len - 1);
   1492              } else {
   1493                DMA_ActivatePingPong(channelId,
   1494                                     false,
   1495                                     buf0,                              /* dest */
   1496                                     buf2,                              /* src  */
   1497                                     len - 1,
   1498                                     buf1,                              /* dest */
   1499                                     buf2,                              /* src  */
   1500                                     len - 1);
   1501              }
   1502            }
   1503          
   1504            return ECODE_EMDRV_DMADRV_OK;
   1505          }
   1506          #endif /* defined( EMDRV_DMADRV_UDMA ) */
   1507          
   1508          #if defined(EMDRV_DMADRV_LDMA)
