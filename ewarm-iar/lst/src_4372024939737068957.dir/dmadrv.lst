   1706          
   1707          // ******** THE REST OF THE FILE IS DOCUMENTATION ONLY !***********************
   1708          /// @addtogroup dmadrv DMADRV - DMA Driver
   1709          /// @brief Direct Memory Access Driver
   1710          /// @{
   1711          ///
   1712          ///   @details
   1713          ///
   1714          ///
   1715          ///   @n @section dmadrv_intro Introduction
   1716          ///
   1717          ///   The DMADRV driver supports writing code using DMA which will work
   1718          ///   regardless of the type of the DMA controller on the underlying microcontroller.
   1719          ///   Additionally, DMA can be used in several modules that are
   1720          ///   completely unaware of each other.
   1721          ///   The driver does not preclude use of the native emlib or peripheral API of the
   1722          ///   underlying DMA controller. On the contrary, it will often result in more efficient
   1723          ///   code and is necessary for complex DMA operations. The housekeeping
   1724          ///   functions of this driver are valuable even in this use-case.
   1725          ///
   1726          ///   The dmadrv.c and dmadrv.h source files are in the
   1727          ///   emdrv/dmadrv folder.
   1728          ///
   1729          ///   @note DMA transfer completion callback functions are called from within the
   1730          ///   DMA interrupt handler. On versions of the DMA controller with one interrupt per
   1731          ///   channel, the callback function is called from its respective channel interrupt
   1732          ///   handler.
   1733          ///
   1734          ///   @n @section dmadrv_conf Configuration Options
   1735          ///
   1736          ///   Some properties of the DMADRV driver are compile-time configurable. These
   1737          ///   properties are stored in a file named dmadrv_config.h. A template for this
   1738          ///   file, containing default values, is in the emdrv/config folder. IC specific
   1739          ///   versions of dmadrv_config.h files are available in config/sx_xch directories.
   1740          ///   Currently the configuration options are as follows:
   1741          ///   @li The interrupt priority of the DMA peripheral.
   1742          ///   @li A number of DMA channels to support.
   1743          ///   @li Use the native emlib/peripheral API belonging to the underlying DMA hardware in
   1744          ///      combination with the DMADRV API.
   1745          ///
   1746          ///   Both configuration options will help reduce the driver's RAM footprint.
   1747          ///
   1748          ///   To configure DMADRV, provide a custom configuration file. This is an
   1749          ///   example dmadrv_config.h file:
   1750          ///   @code{.c}
   1751          /// #ifndef __SILICON_LABS_DMADRV_CONFIG_H__
   1752          /// #define __SILICON_LABS_DMADRV_CONFIG_H__
   1753          ///
   1754          ///   // DMADRV DMA interrupt priority configuration option.
   1755          ///   // Set DMA interrupt priority. Range is 0..7, 0 is the highest priority.
   1756          /// #define EMDRV_DMADRV_DMA_IRQ_PRIORITY 4
   1757          ///
   1758          ///   // DMADRV channel count configuration option.
   1759          ///   // A number of DMA channels to support. A lower DMA channel count will reduce
   1760          ///   // RAM footprint.
   1761          /// #define EMDRV_DMADRV_DMA_CH_COUNT 4
   1762          ///
   1763          /// #endif
   1764          ///   @endcode
   1765          ///
   1766          ///   @n @section dmadrv_api The API
   1767          ///
   1768          ///   This section contains brief descriptions of the API functions.
   1769          ///   For more information about input and output parameters and return values,
   1770          ///   click on the hyperlinked function names. Most functions return an error
   1771          ///   code, @ref ECODE_EMDRV_DMADRV_OK is returned on success,
   1772          ///   see @ref ecode and @ref dmadrv_error_codes for other error codes.
   1773          ///
   1774          ///   The application code must include @em dmadrv.h header file.
   1775          ///
   1776          ///   @ref DMADRV_Init(), @ref DMADRV_DeInit() @n
   1777          ///    These functions initialize or deinitialize the DMADRV driver. Typically,
   1778          ///    DMADRV_Init() is called once in the startup code.
   1779          ///
   1780          ///   @ref DMADRV_AllocateChannel(), @ref DMADRV_AllocateChannelById(),
   1781          ///   @ref DMADRV_FreeChannel() @n
   1782          ///    DMA channel reserve and release functions. It is recommended that
   1783          ///    application code checks that DMADRV_AllocateChannel()
   1784          ///    returns ECODE_EMDRV_DMADRV_OK before starting a DMA
   1785          ///    transfer.
   1786          ///
   1787          ///   @ref DMADRV_MemoryPeripheral() @n
   1788          ///    Start a DMA transfer from memory to a peripheral.
   1789          ///
   1790          ///   @ref DMADRV_PeripheralMemory() @n
   1791          ///    Start a DMA transfer from a peripheral to memory.
   1792          ///
   1793          ///   @ref DMADRV_MemoryPeripheralPingPong() @n
   1794          ///    Start a DMA ping-pong transfer from memory to a peripheral.
   1795          ///
   1796          ///   @ref DMADRV_PeripheralMemoryPingPong() @n
   1797          ///    Start a DMA ping-pong transfer from a peripheral to memory.
   1798          ///
   1799          ///   @ref DMADRV_LdmaStartTransfer() @n
   1800          ///    Start a DMA transfer on an LDMA controller.
   1801          ///
   1802          ///   @ref DMADRV_PauseTransfer() @n
   1803          ///    Pause an ongoing DMA transfer.
   1804          ///
   1805          ///   @ref DMADRV_ResumeTransfer() @n
   1806          ///    Resume paused DMA transfer.
   1807          ///
   1808          ///   @ref DMADRV_StopTransfer() @n
   1809          ///    Stop an ongoing DMA transfer.
   1810          ///
   1811          ///   @ref DMADRV_TransferActive() @n
   1812          ///    Check if a transfer is ongoing.
   1813          ///
   1814          ///   @ref DMADRV_TransferCompletePending() @n
   1815          ///    Check if a transfer completion is pending.
   1816          ///
   1817          ///   @ref DMADRV_TransferDone() @n
   1818          ///    Check if a transfer has completed.
   1819          ///
   1820          ///   @ref DMADRV_TransferRemainingCount() @n
   1821          ///    Get number of items remaining in a transfer.
   1822          ///
   1823          ///   @n @section dmadrv_example Example
   1824          ///   Transfer a text string to USART1.
   1825          ///   @code{.c}
   1826          /// #include "dmadrv.h"
   1827          ///
   1828          ///   char str[] = "Hello DMA !";
   1829          ///   unsigned int channel;
   1830          ///
   1831          ///   int main( void )
   1832          ///   {
   1833          ///   // Initialize DMA.
   1834          ///   DMADRV_Init();
   1835          ///
   1836          ///   // Request a DMA channel.
   1837          ///   DMADRV_AllocateChannel( &channel, NULL );
   1838          ///
   1839          ///   // Start the DMA transfer.
   1840          ///   DMADRV_MemoryPeripheral( channel,
   1841          ///                           dmadrvPeripheralSignal_USART1_TXBL,
   1842          ///                           (void*)&(USART1->TXDATA),
   1843          ///                           str,
   1844          ///                           true,
   1845          ///                           sizeof( str ),
   1846          ///                           dmadrvDataSize1,
   1847          ///                           NULL,
   1848          ///                           NULL );
   1849          ///
   1850          ///   return 0;
   1851          ///   }
   1852          ///   @endcode
   1853          ///
   1854          /// @} end group dmadrv ********************************************************

