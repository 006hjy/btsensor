    480          
    481          #if defined(RFFPLL_PRESENT) \
    482            && defined(SL_CLOCK_MANAGER_HFXO_EN) && (SL_CLOCK_MANAGER_HFXO_EN == 1)
    483          /***************************************************************************//**
    484           * Initializes RFFPLL Oscillator.
    485           ******************************************************************************/
    486          FUNCTION_SCOPE void init_rffpll(void)
    487          {
    488            CMU_RFFPLL_Init_TypeDef rffpll_init = CMU_RFFPLL_DEFAULT;
    489          
    490            // Overwrite default configurations.
    491          #if (SL_CLOCK_MANAGER_RFFPLL_CUSTOM_BAND == 1)
    492            // Custom settings provided by the user.
    493            rffpll_init.frequency = SL_CLOCK_MANAGER_RFFPLL_FREQ;
    494            rffpll_init.dividerY = SL_CLOCK_MANAGER_RFFPLL_DIV_Y;
    495            rffpll_init.dividerX = SL_CLOCK_MANAGER_RFFPLL_DIV_X;
    496            rffpll_init.dividerN = SL_CLOCK_MANAGER_RFFPLL_DIV_N;
    497          #elif (SL_CLOCK_MANAGER_RFFPLL_BAND == 7) && defined(RADIO_CONFIG_RFFPLL_CONFIG_PRESENT)
    498            // Settings from the RAIL lib.
    499            rffpll_init.frequency = radioConfigRffpllConfig->sysclkFreqHz;
    500            rffpll_init.dividerY = ((radioConfigRffpllConfig->dividers & RAIL_RFFPLL_DIVIDERY_MASK) >> RAIL_RFFPLL_DIVIDERY_SHIFT);
    501            rffpll_init.dividerX = ((radioConfigRffpllConfig->dividers & RAIL_RFFPLL_DIVIDERX_MASK) >> RAIL_RFFPLL_DIVIDERX_SHIFT);
    502            rffpll_init.dividerN = ((radioConfigRffpllConfig->dividers & RAIL_RFFPLL_DIVIDERN_MASK) >> RAIL_RFFPLL_DIVIDERN_SHIFT);
    503          #else
    504            // Pre-determined settings.
    505            rffpll_init.frequency = rffpll_band_config_39MHz[SL_CLOCK_MANAGER_RFFPLL_BAND].frequency;
    506            rffpll_init.dividerY = rffpll_band_config_39MHz[SL_CLOCK_MANAGER_RFFPLL_BAND].divider_y;
    507            rffpll_init.dividerX = rffpll_band_config_39MHz[SL_CLOCK_MANAGER_RFFPLL_BAND].divider_x;
    508            rffpll_init.dividerN = rffpll_band_config_39MHz[SL_CLOCK_MANAGER_RFFPLL_BAND].divider_n;
    509          #endif
    510          
    511            // Initialize RFFPLL.
    512            CMU_RFFPLLInit(&rffpll_init);
    513          
    514            // Update RFFPLL frequency in System file
    515            SystemRFFPLLClockSet(rffpll_init.frequency);
    516          
    517            // At this point, RFFPLL has been initialized. The clock source for SYSCLK can be
    518            // RFFPLLSYS input clock. If you want RFFPLLSYS, configure SL_CLOCK_MANAGER_SYSCLK_SOURCE
    519            // to CMU_SYSCLKCTRL_CLKSEL_RFFPLL0SYS.
    520          }
    521          #endif
    522          
    523          #if defined(USBPLL_PRESENT) \
    524            && defined(SL_CLOCK_MANAGER_HFXO_EN) && (SL_CLOCK_MANAGER_HFXO_EN == 1)
    525          /***************************************************************************//**
    526           * Initializes USBPLL Oscillator.
    527           ******************************************************************************/
    528          FUNCTION_SCOPE void init_usbpll(void)
    529          {
    530            CMU_USBPLL_Init_TypeDef usbpll_config = { 0 };
    531            uint32_t hfxo_freq = SystemHFXOClockGet();
    532          
    533            // Validate that HFXO frequency is adequate for USB PLL and set the right frequency.
    534            switch (hfxo_freq) {
    535              case 38000000:
    536                usbpll_config.hfxoRefFreq = cmuHFXORefFreq_38M0Hz;
    537                break;
    538          
    539              case 38400000:
    540                usbpll_config.hfxoRefFreq = cmuHFXORefFreq_38M4Hz;
    541                break;
    542          
    543              case 39000000:
    544                usbpll_config.hfxoRefFreq = cmuHFXORefFreq_39M0Hz;
    545                break;
    546          
    547              case 40000000:
    548                usbpll_config.hfxoRefFreq = cmuHFXORefFreq_40M0Hz;
    549                break;
    550          
    551              default:
    552                EFM_ASSERT(false);
    553                break;
    554            }
    555          
    556            // Set additional configurations.
    557            usbpll_config.shuntRegEn = false;
    558            usbpll_config.disOnDemand = false;
    559            usbpll_config.regLock = true;
    560          
    561            // Set Force Enable feature at first to force the PLL to start and validate it works.
    562            usbpll_config.forceEn = true;
    563          
    564            // Initialize USB PLL and wait for it to be ready.
    565            CMU_USBPLLInit(&usbpll_config);
    566          
    567            // Remove the Force Enable feature to let PLL module on-demand.
    568            usbpll_config.forceEn = false;
    569          
    570            // Re-initialized without the Force Enable feature.
    571            CMU_USBPLLInit(&usbpll_config);
    572          }
    573          #endif
    574          
    575          /***************************************************************************//**
    576           * Initializes Clock branches.
    577           ******************************************************************************/
    578          FUNCTION_SCOPE void init_clock_branches(void)
    579          {
    580            // Initialize SYSCLK clock branch.
    581          #if defined(SL_CLOCK_MANAGER_SYSCLK_SOURCE)
    582            sli_em_cmu_SYSCLKInitPreClockSelect();
    583          #if (SL_CLOCK_MANAGER_SYSCLK_SOURCE == SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE)
    584            CLOCK_MANAGER_CLOCK_SELECT_SET(SYSCLK, CLOCK_MANAGER_GET_DEFAULT_CLOCK_SOURCE(SYSCLK, SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE_CONCATENATION));
    585          #else
    586            CLOCK_MANAGER_CLOCK_SELECT_SET(SYSCLK, SL_CLOCK_MANAGER_SYSCLK_SOURCE);
    587          #endif
    588            sli_em_cmu_SYSCLKInitPostClockSelect(false);
    589          
    590            // Set HCLK and PCLK dividers
    591            CMU->SYSCLKCTRL = (CMU->SYSCLKCTRL & ~(_CMU_SYSCLKCTRL_HCLKPRESC_MASK | _CMU_SYSCLKCTRL_PCLKPRESC_MASK))
    592                              | SL_CLOCK_MANAGER_HCLK_DIVIDER
    593                              | SL_CLOCK_MANAGER_PCLK_DIVIDER;
    594          #else
    595            EFM_ASSERT(false);
    596          #endif
    597          
    598            // Initialize TRACECLK clock branch.
    599          #if defined(CoreDebug_DEMCR_TRCENA_Msk)
    600            // Disable the Core Debug module if already enabled
    601            bool trace_on = CoreDebug->DEMCR & CoreDebug_DEMCR_TRCENA_Msk;
    602            if (trace_on) {
    603              CoreDebug->DEMCR &= ~CoreDebug_DEMCR_TRCENA_Msk;
    604            }
    605          #endif
    606          #if defined(SL_CLOCK_MANAGER_TRACECLK_SOURCE)
    607            CLOCK_MANAGER_CLOCK_SELECT_SET(TRACECLK, SL_CLOCK_MANAGER_TRACECLK_SOURCE);
    608          #endif
    609          #if defined(SL_CLOCK_MANAGER_TRACECLK_DIVIDER)
    610            CMU->TRACECLKCTRL_SET = SL_CLOCK_MANAGER_TRACECLK_DIVIDER;
    611          #endif
    612          #if defined(CoreDebug_DEMCR_TRCENA_Msk)
    613            // Enable back the Core Debug module if it was already enabled
    614            if (trace_on) {
    615              CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
    616            }
    617          #endif
    618            // Ensure TraceClk configs are defined if TraceClk is present.
    619          #if defined(_CMU_TRACECLKCTRL_MASK) && !(defined(SL_CLOCK_MANAGER_TRACECLK_SOURCE) || defined(SL_CLOCK_MANAGER_TRACECLK_DIVIDER))
    620            EFM_ASSERT(false);
    621          #endif
    622          
    623            // Initialize EM01GRPACLK clock branch.
    624          #if defined(SL_CLOCK_MANAGER_EM01GRPACLK_SOURCE)
    625          #if (SL_CLOCK_MANAGER_EM01GRPACLK_SOURCE == SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE)
    626            CLOCK_MANAGER_CLOCK_SELECT_SET(EM01GRPACLK, CLOCK_MANAGER_GET_DEFAULT_CLOCK_SOURCE(EM01GRPACLK, SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE_CONCATENATION));
    627          #else
    628            CLOCK_MANAGER_CLOCK_SELECT_SET(EM01GRPACLK, SL_CLOCK_MANAGER_EM01GRPACLK_SOURCE);
    629          #endif
    630          #else
    631            EFM_ASSERT(false);
    632          #endif
    633          
    634            // Initialize EM01GRPBCLK clock branch.
    635          #if defined(_CMU_EM01GRPBCLKCTRL_MASK)
    636          #if defined(SL_CLOCK_MANAGER_EM01GRPBCLK_SOURCE)
    637          #if (SL_CLOCK_MANAGER_EM01GRPBCLK_SOURCE == SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE)
    638            CLOCK_MANAGER_CLOCK_SELECT_SET(EM01GRPBCLK, CLOCK_MANAGER_GET_DEFAULT_CLOCK_SOURCE(EM01GRPBCLK, SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE_CONCATENATION));
    639          #else
    640            CLOCK_MANAGER_CLOCK_SELECT_SET(EM01GRPBCLK, SL_CLOCK_MANAGER_EM01GRPBCLK_SOURCE);
    641          #endif
    642          #else
    643            EFM_ASSERT(false);
    644          #endif
    645          #endif
    646          
    647            // Initialize EM01GRPCCLK clock branch.
    648          #if defined(_CMU_EM01GRPCCLKCTRL_MASK)
    649          #if defined(SL_CLOCK_MANAGER_EM01GRPCCLK_SOURCE)
    650          #if (SL_CLOCK_MANAGER_EM01GRPCCLK_SOURCE == SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE)
    651            CLOCK_MANAGER_CLOCK_SELECT_SET(EM01GRPCCLK, CLOCK_MANAGER_GET_DEFAULT_CLOCK_SOURCE(EM01GRPCCLK, SL_CLOCK_MANAGER_DEFAULT_HF_CLOCK_SOURCE_CONCATENATION));
    652          #else
    653            CLOCK_MANAGER_CLOCK_SELECT_SET(EM01GRPCCLK, SL_CLOCK_MANAGER_EM01GRPCCLK_SOURCE);
    654          #endif
    655          #else
    656            EFM_ASSERT(false);
    657          #endif
    658          #endif
    659          
    660            // Initialize IADCCLK clock branch.
    661          #if defined(_CMU_IADCCLKCTRL_MASK)
    662          #if defined(SL_CLOCK_MANAGER_IADCCLK_SOURCE)
    663            CLOCK_MANAGER_CLOCK_SELECT_SET(IADCCLK, SL_CLOCK_MANAGER_IADCCLK_SOURCE);
    664          #else
    665            EFM_ASSERT(false);
    666          #endif
