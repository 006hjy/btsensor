    143          #if defined(HFXO_PRESENT) \
    144            && defined(SL_CLOCK_MANAGER_HFXO_EN) && SL_CLOCK_MANAGER_HFXO_EN == 1
    145          /***************************************************************************//**
    146           * Initializes HFXO Oscillator.
    147           ******************************************************************************/
    148          FUNCTION_SCOPE void init_hfxo(void)
    149          {
    150            CMU_HFXOInit_TypeDef clock_manager_hfxo_init = CMU_HFXOINIT_DEFAULT;
    151            clock_manager_hfxo_init.mode = SLI_CLOCK_MANAGER_HFXO_MODE >> _HFXO_CFG_MODE_SHIFT;
    152          
    153            if (SLI_CLOCK_MANAGER_HFXO_MODE == cmuHfxoOscMode_ExternalSine) {
    154              clock_manager_hfxo_init = (CMU_HFXOInit_TypeDef)CMU_HFXOINIT_EXTERNAL_SINE;
    155          #if defined(_HFXO_CFG_MODE_EXTCLKPKDET)
    156            } else if (SLI_CLOCK_MANAGER_HFXO_MODE == cmuHfxoOscMode_ExternalSinePkDet) {
    157              clock_manager_hfxo_init = (CMU_HFXOInit_TypeDef)CMU_HFXOINIT_EXTERNAL_SINEPKDET;
    158          #endif
    159            }
    160          #if defined (SL_CLOCK_MANAGER_HFXO_ENXIDCBIASANA)
    161            clock_manager_hfxo_init.enXiDcBiasAna = SL_CLOCK_MANAGER_HFXO_ENXIDCBIASANA;
    162          #endif
    163          
    164            int ctune = -1;
    165          
    166          #if defined(SL_CLOCK_MANAGER_HFXO_SEPARATE_CTUNEXIANA_CTUNEXOANA_EN) && (SL_CLOCK_MANAGER_HFXO_SEPARATE_CTUNEXIANA_CTUNEXOANA_EN == 1)
    167            ctune = SL_CLOCK_MANAGER_HFXO_CTUNEXIANA;
    168            CMU_HFXOCTuneDeltaSet(SL_CLOCK_MANAGER_HFXO_CTUNEXOANA - SL_CLOCK_MANAGER_HFXO_CTUNEXIANA);
    169          #endif
    170          
    171          #if defined(_DEVINFO_MODXOCAL_HFXOCTUNEXIANA_MASK)
    172            // Use HFXO tuning value from DEVINFO if available (PCB modules)
    173            if ((ctune == -1) && ((DEVINFO->MODULEINFO & _DEVINFO_MODULEINFO_HFXOCALVAL_MASK) == 0)) {
    174              ctune = DEVINFO->MODXOCAL & _DEVINFO_MODXOCAL_HFXOCTUNEXIANA_MASK;
    175            }
    176          #endif
    177          
    178            // Use HFXO tuning value from MFG token in UD page if not already set
    179            if ((ctune == -1)
    180          #if defined(SL_CLOCK_MANAGER_CTUNE_MFG_HFXO_EN)
    181                && (SL_CLOCK_MANAGER_CTUNE_MFG_HFXO_EN == 1)
    182          #endif
    183                && (MFG_CTUNE_HFXO_VAL <= (_HFXO_XTALCTRL_CTUNEXIANA_MASK >> _HFXO_XTALCTRL_CTUNEXIANA_SHIFT))) {
    184              ctune = MFG_CTUNE_HFXO_VAL;
    185            }
    186          
    187            // Use HFXO tuning value from configurations as fallback
    188            if (ctune == -1) {
    189              ctune = SL_CLOCK_MANAGER_HFXO_CTUNE;
    190            }
    191          
    192            // Configure CTUNE XI and XO.
    193            if (ctune != -1) {
    194              clock_manager_hfxo_init.ctuneXiAna = (uint8_t)ctune;
    195          
    196              // Ensure CTUNE XO plus a delta is within the correct range. The delta accounts for internal chip
    197              // load imbalance on some series 2 chips.
    198              ctune += CMU_HFXOCTuneDeltaGet();
    199              if (ctune < 0) {
    200                ctune = 0;
    201              } else if (ctune > ((int)(_HFXO_XTALCTRL_CTUNEXOANA_MASK >> _HFXO_XTALCTRL_CTUNEXOANA_SHIFT))) {
    202                ctune = (int)(_HFXO_XTALCTRL_CTUNEXOANA_MASK >> _HFXO_XTALCTRL_CTUNEXOANA_SHIFT);
    203              }
    204              clock_manager_hfxo_init.ctuneXoAna = (uint8_t)ctune;
    205            }
    206          
    207          #if defined(SLI_CLOCK_MANAGER_RUNTIME_CONFIGURATION)
    208            if (SLI_CLOCK_MANAGER_HFXO_CTUNE_FIXED_STEADY != SLI_CLOCK_MANAGER_HFXO_CTUNE_FIXED_STEADY_DEFAULT) {
    209              clock_manager_hfxo_init.ctuneFixAna = SLI_CLOCK_MANAGER_HFXO_CTUNE_FIXED_STEADY;
    210            }
    211          #endif
    212          
    213          #if defined(SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_EN) && (SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_EN == 1)
    214            // Set port and pin.
    215            sl_status_t status;
    216            GPIO_Port_TypeDef port = SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_GPIO_PORT;
    217            unsigned int pin = SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_GPIO_PIN;
    218          
    219            // Enable HFXO and GPIO bus clocks.
    220            status = sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_HFXO0);
    221            EFM_ASSERT(status == SL_STATUS_OK);
    222            status = sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_GPIO);
    223            EFM_ASSERT(status == SL_STATUS_OK);
    224          #if defined(SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_FOLLOWER_EN) && (SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_FOLLOWER_EN == 1)
    225            // Initialize Crystal sharing follower.
    226            status = sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_PRS);
    227            EFM_ASSERT(status == SL_STATUS_OK);
    228          
    229            EFM_ASSERT(GPIO_PORT_PIN_VALID(port, pin));
    230          
    231            uint32_t mask = 0U, value = 0U;
    232          
    233            bool was_locked = HFXO0->STATUS & HFXO_STATUS_LOCK_LOCKED ? true : false;
    234          
    235            // Unlock register interface.
    236            HFXO0->LOCK = HFXO_LOCK_LOCKKEY_UNLOCK;
    237            HFXO0->IEN_SET = HFXO_IEN_BUFOUTRDY;
    238          
    239            BUS_RegMaskedWrite(&HFXO0->CTRL, _HFXO_CTRL_PRSSTATUSSEL0_MASK, (_HFXO_CTRL_PRSSTATUSSEL0_ENS << _HFXO_CTRL_PRSSTATUSSEL0_SHIFT));
    240          
    241            if (was_locked) {
    242              HFXO0->LOCK = ~HFXO_LOCK_LOCKKEY_UNLOCK;
    243            }
    244          
    245            value = _PRS_ASYNC_CH_CTRL_AUXSEL_DEFAULT     << _PRS_ASYNC_CH_CTRL_AUXSEL_SHIFT
    246                    | _PRS_ASYNC_CH_CTRL_FNSEL_A          << _PRS_ASYNC_CH_CTRL_FNSEL_SHIFT
    247                    | _PRS_ASYNC_CH_CTRL_SOURCESEL_HFXO0L << _PRS_ASYNC_CH_CTRL_SOURCESEL_SHIFT
    248                    | _PRS_ASYNC_CH_CTRL_SIGSEL_HFXO0LSTATUS << _PRS_ASYNC_CH_CTRL_SIGSEL_SHIFT;
    249          
    250            mask = _PRS_ASYNC_CH_CTRL_AUXSEL_MASK
    251                   | _PRS_ASYNC_CH_CTRL_FNSEL_MASK
    252                   | _PRS_ASYNC_CH_CTRL_SOURCESEL_MASK
    253                   | _PRS_ASYNC_CH_CTRL_SIGSEL_MASK;
    254          
    255            BUS_RegMaskedWrite(&(PRS->ASYNC_CH[HFXO_CRYSTSAL_SHARING_PRS_CHANNEL].CTRL), mask, value);
    256          
    257            GPIO_PinModeSet(port, pin, gpioModeWiredOrPullDown, 0U);
    258          
    259            (&(GPIO->PRSROUTE[0].ASYNCH0ROUTE))[HFXO_CRYSTSAL_SHARING_PRS_CHANNEL] = pin << _GPIO_PRS_ASYNCH0ROUTE_PIN_SHIFT
    260                                                                                     | port << _GPIO_PRS_ASYNCH0ROUTE_PORT_SHIFT;
    261            GPIO->PRSROUTE[0].ROUTEEN = 1U << (_GPIO_PRS_ROUTEEN_ASYNCH0PEN_SHIFT + HFXO_CRYSTSAL_SHARING_PRS_CHANNEL);
    262          
    263            //sl_clock_manager_disable_bus_clock(SL_BUS_CLOCK_PRS);
    264          #elif defined(SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_LEADER_EN) && (SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_LEADER_EN == 1)
    265            EFM_ASSERT(GPIO_PORT_PIN_VALID(port, pin));
    266          
    267            // Configure Bufout request GPIO.
    268            GPIO_PinModeSet(port, pin, gpioModeInput, 0U);
    269          
    270            GPIO->SYXOROUTE[0].BUFOUTREQINASYNCROUTE = pin << _GPIO_SYXO_BUFOUTREQINASYNCROUTE_PIN_SHIFT
    271                                                       | port << _GPIO_SYXO_BUFOUTREQINASYNCROUTE_PORT_SHIFT;
    272          
    273            bool was_locked = HFXO0->STATUS & HFXO_STATUS_LOCK_LOCKED ? true : false;
    274          
    275            // Unlock register interface.
    276            HFXO0->LOCK = HFXO_LOCK_LOCKKEY_UNLOCK;
    277          
    278            HFXO0->CTRL_CLR = _HFXO_CTRL_BUFOUTFREEZE_MASK | _HFXO_CTRL_DISONDEMANDBUFOUT_MASK;
    279          
    280            BUS_RegMaskedWrite(&HFXO0->BUFOUTCTRL,
    281                               _HFXO_BUFOUTCTRL_MINIMUMSTARTUPDELAY_MASK
    282                               | _HFXO_BUFOUTCTRL_TIMEOUTSTARTUP_MASK,
    283                               ((uint32_t)SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_LEADER_MIN_STARTUP_DELAY_EN)  << _HFXO_BUFOUTCTRL_MINIMUMSTARTUPDELAY_SHIFT
    284                               | SL_CLOCK_MANAGER_HFXO_CRYSTAL_SHARING_LEADER_TIMEOUT_STARTUP);
    285          
    286            if (was_locked) {
    287              HFXO0->LOCK = ~HFXO_LOCK_LOCKKEY_UNLOCK;
    288            }
    289          #endif
    290          #endif
    291          
    292            SystemHFXOClockSet(SLI_CLOCK_MANAGER_HFXO_FREQ);
    293            CMU_HFXOInit(&clock_manager_hfxo_init);
    294            CMU_HFXOPrecisionSet(SL_CLOCK_MANAGER_HFXO_PRECISION);
    295          
    296          #if defined(SLI_CLOCK_MANAGER_RUNTIME_CONFIGURATION)
    297            if (SLI_CLOCK_MANAGER_HFXO_CTUNE_FIXED_STEADY == SLI_CLOCK_MANAGER_HFXO_CTUNE_FIXED_STEADY_DEFAULT) {
    298              SLI_CLOCK_MANAGER_HFXO_CTUNE_FIXED_STEADY = (HFXO0->XTALCTRL & _HFXO_XTALCTRL_CTUNEFIXANA_MASK) >> _HFXO_XTALCTRL_CTUNEFIXANA_SHIFT;
    299            }
    300          #endif
    301          }
    302          #endif
    303          
    304          #if defined(LFXO_PRESENT) \
    305            && defined(SL_CLOCK_MANAGER_LFXO_EN) && SL_CLOCK_MANAGER_LFXO_EN == 1
    306          /***************************************************************************//**
    307           * Initializes LFXO Oscillator.
    308           ******************************************************************************/
    309          FUNCTION_SCOPE void init_lfxo(void)
    310          {
    311            CMU_LFXOInit_TypeDef clock_manager_lfxo_init = CMU_LFXOINIT_DEFAULT;
    312          #ifdef SL_CLOCK_MANAGER_LFXO_GAIN
    313            clock_manager_lfxo_init.gain = SL_CLOCK_MANAGER_LFXO_GAIN;
    314          #endif
    315          
    316            clock_manager_lfxo_init.mode = SL_CLOCK_MANAGER_LFXO_MODE >> _LFXO_CFG_MODE_SHIFT;
    317            clock_manager_lfxo_init.timeout = SL_CLOCK_MANAGER_LFXO_TIMEOUT >> _LFXO_CFG_TIMEOUT_SHIFT;
    318            clock_manager_lfxo_init.capTune = 0xFF;
    319          
    320          #if !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) && !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_11) && !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_14)
    321          #if defined(_DEVINFO_MODXOCAL_LFXOCAPTUNE_MASK)
    322            // Use LFXO tuning value from DEVINFO if available (PCB modules)
    323            if ((DEVINFO->MODULEINFO & _DEVINFO_MODULEINFO_LFXOCALVAL_MASK) == _DEVINFO_MODULEINFO_LFXOCALVAL_VALID) {
    324              clock_manager_lfxo_init.capTune = DEVINFO->MODXOCAL & _DEVINFO_MODXOCAL_LFXOCAPTUNE_MASK;
    325            }
    326          #endif
    327          #endif
    328          
    329            if ((clock_manager_lfxo_init.capTune == 0xFF)
    330          #if defined(SL_CLOCK_MANAGER_CTUNE_MFG_LFXO_EN)
    331                && (SL_CLOCK_MANAGER_CTUNE_MFG_LFXO_EN == 1)
    332          #endif
    333                && (MFG_CTUNE_LFXO_VAL <= (_LFXO_CAL_CAPTUNE_MASK >> _LFXO_CAL_CAPTUNE_SHIFT))) {
    334              clock_manager_lfxo_init.capTune = MFG_CTUNE_LFXO_VAL;
    335            }
    336          
    337            if (clock_manager_lfxo_init.capTune == 0xFF) {
    338              clock_manager_lfxo_init.capTune = SL_CLOCK_MANAGER_LFXO_CTUNE;
    339            }
    340          
    341            CMU_LFXOInit(&clock_manager_lfxo_init);
    342            CMU_LFXOPrecisionSet(SL_CLOCK_MANAGER_LFXO_PRECISION);
    343          }
    344          #endif
    345          
    346          /***************************************************************************//**
    347           * Initializes Clock Input CLKIN0.
    348           ******************************************************************************/
    349          static void init_clkin0(void)
    350          {
    351          #if (defined(SL_CLOCK_MANAGER_SYSCLK_SOURCE) && (SL_CLOCK_MANAGER_SYSCLK_SOURCE == CMU_SYSCLKCTRL_CLKSEL_CLKIN0))  \
    352            || (defined(SL_CLOCK_MANAGER_DPLL_REFCLK) && (SL_CLOCK_MANAGER_DPLL_REFCLK == CMU_DPLLREFCLKCTRL_CLKSEL_CLKIN0)) \
    353            || (defined(SL_CLOCK_MANAGER_EM01GRPBCLK_SOURCE) && (SL_CLOCK_MANAGER_EM01GRPBCLK_SOURCE == CMU_EM01GRPBCLKCTRL_CLKSEL_CLKIN0))
    354          
    355          #if !defined(SL_CLOCK_MANAGER_CLKIN0_PORT) || !defined(SL_CLOCK_MANAGER_CLKIN0_PIN)
    356          #error "Invalid configuration: CLKIN0 reference can't be use without configuring SL_CLOCK_MANAGER_CLKIN0 with a valid port and pin."
    357          #endif
    358          
    359            sl_status_t status;
    360            sl_gpio_t clkin0_gpio = { SL_CLOCK_MANAGER_CLKIN0_PORT, SL_CLOCK_MANAGER_CLKIN0_PIN };
    361          
    362            status = sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_GPIO);
    363            EFM_ASSERT(status == SL_STATUS_OK);
    364          
    365            status = sl_gpio_set_pin_mode(&clkin0_gpio, SL_GPIO_MODE_INPUT, false);
    366            EFM_ASSERT(status == SL_STATUS_OK);
    367            GPIO->CMUROUTE.CLKIN0ROUTE = (clkin0_gpio.port << _GPIO_CMU_CLKIN0ROUTE_PORT_SHIFT)
    368                                         | (clkin0_gpio.pin << _GPIO_CMU_CLKIN0ROUTE_PIN_SHIFT);
    369          #endif
    370          }
    371          
    372          #if defined(HFRCO_PRESENT)
    373          /***************************************************************************//**
    374           * Initializes HFRCODPLL Oscillator.
    375           ******************************************************************************/
    376          FUNCTION_SCOPE void init_hfrcodpll(void)
    377          {
    378          #if defined(SLI_CLOCK_MANAGER_RUNTIME_CONFIGURATION) \
    379            || (defined(SL_CLOCK_MANAGER_HFRCO_DPLL_EN) && (SL_CLOCK_MANAGER_HFRCO_DPLL_EN == 1))
    380          
    381          #if defined(SLI_CLOCK_MANAGER_RUNTIME_CONFIGURATION)
    382            if (SLI_CLOCK_MANAGER_HFRCO_DPLL_EN)
    383          #endif
    384            {
    385              sl_status_t status;
    386          
    387              CMU_DPLLInit_TypeDef clock_manager_dpll_init = {
    388                .frequency = SLI_CLOCK_MANAGER_DPLL_FREQ,
    389                .n = SLI_CLOCK_MANAGER_DPLL_N,
    390                .m = SLI_CLOCK_MANAGER_DPLL_M,
    391                .edgeSel = SL_CLOCK_MANAGER_DPLL_EDGE,
    392                .lockMode = SL_CLOCK_MANAGER_DPLL_LOCKMODE,
    393                .autoRecover = SL_CLOCK_MANAGER_DPLL_AUTORECOVER,
    394                .ditherEn = SL_CLOCK_MANAGER_DPLL_DITHER
    395              };
    396          
    397              // Convert the DPLL Reference clock configuration to emlib CMU_Select_TypeDef type.
    398              switch (SL_CLOCK_MANAGER_DPLL_REFCLK) {
    399                case CMU_DPLLREFCLKCTRL_CLKSEL_HFXO:
    400                  clock_manager_dpll_init.refClk = cmuSelect_HFXO;
    401                  break;
    402                case CMU_DPLLREFCLKCTRL_CLKSEL_LFXO:
    403                  clock_manager_dpll_init.refClk = cmuSelect_LFXO;
    404                  break;
    405                case CMU_DPLLREFCLKCTRL_CLKSEL_CLKIN0:
    406                  clock_manager_dpll_init.refClk = cmuSelect_CLKIN0;
    407                  break;
    408                default:
    409                  EFM_ASSERT(false);
    410                  break;
    411              }
    412          
    413              CMU_Select_TypeDef selected_sysclk = CMU_ClockSelectGet(cmuClock_SYSCLK);
    414          
    415              if (selected_sysclk == cmuSelect_HFRCODPLL) {
    416                // The CMU should not be running from the HFRCO. If necessary, the CMU
    417                // should switch to the FSRCO until after the DPLL has locked to avoid
    418                // over-clocking due to overshoot.
    419                CMU->SYSCLKCTRL = (CMU->SYSCLKCTRL & ~_CMU_SYSCLKCTRL_CLKSEL_MASK) | CMU_SYSCLKCTRL_CLKSEL_FSRCO;
    420              }
    421          
    422              status = sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_DPLL0);
    423              EFM_ASSERT(status == SL_STATUS_OK);
    424          
    425              bool success = CMU_DPLLLock(&clock_manager_dpll_init);
    426          
    427              // If CMU was initially running from HFRCO switch back from FSRCO.
    428              if (selected_sysclk == cmuSelect_HFRCODPLL) {
    429                CMU->SYSCLKCTRL = (CMU->SYSCLKCTRL & ~_CMU_SYSCLKCTRL_CLKSEL_MASK) | CMU_SYSCLKCTRL_CLKSEL_HFRCODPLL;
    430              }
    431          
    432              // Assert if DPLL lock was unsuccessful.
    433              EFM_ASSERT(success == true);
    434            }
    435          #endif
    436          #if defined(SLI_CLOCK_MANAGER_RUNTIME_CONFIGURATION) \
    437            || (defined(SL_CLOCK_MANAGER_HFRCO_DPLL_EN) && (SL_CLOCK_MANAGER_HFRCO_DPLL_EN == 0))
    438          
    439          #if defined(SLI_CLOCK_MANAGER_RUNTIME_CONFIGURATION)
    440            else
    441          #else
    442            if (true)
    443          #endif
    444            {
    445              CMU_HFRCODPLLBandSet(SLI_CLOCK_MANAGER_HFRCO_BAND);
    446            }
    447          #endif
    448          }
    449          #endif
    450          
    451          #if defined(HFRCOEM23_PRESENT)
    452          /***************************************************************************//**
    453           * Initializes HFRCOEM23 Oscillator.
    454           ******************************************************************************/
    455          FUNCTION_SCOPE void init_hfrcoem23(void)
    456          {
    457            CMU_HFRCOEM23BandSet(SL_CLOCK_MANAGER_HFRCOEM23_BAND);
    458          }
    459          #endif
    460          
    461          #if defined(LFRCO_PRESENT)
    462          /***************************************************************************//**
    463           * Initializes LFRCO Oscillator.
    464           ******************************************************************************/
    465          FUNCTION_SCOPE void init_lfrco(void)
    466          {
    467            sl_status_t status;
    468          
    469            status = sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_LFRCO);
    470            EFM_ASSERT(status == SL_STATUS_OK);
    471          
    472          #if defined(PLFRCO_PRESENT)
    473          #if !(defined(SL_CLOCK_MANAGER_HFXO_EN) && (SL_CLOCK_MANAGER_HFXO_EN == 1))
    474            EFM_ASSERT(SL_CLOCK_MANAGER_LFRCO_PRECISION != cmuPrecisionHigh);
    475          #endif
