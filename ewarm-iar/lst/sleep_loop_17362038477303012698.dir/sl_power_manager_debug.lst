     31          #include "sl_power_manager.h"
     32          #include "sl_power_manager_config.h"
     33          #include "sl_power_manager_debug.h"
     34          #include "sli_power_manager_private.h"
     35          
     36          #if (SL_POWER_MANAGER_DEBUG == 1)
     37          #include <stdio.h>
     38          #include <stdlib.h>
     39          #include <stdint.h>
     40          #include <string.h>
     41          
     42          static sl_slist_node_t *power_manager_debug_requirement_em1;
     43          static sli_power_debug_requirement_entry_t  power_debug_entry_table[SL_POWER_MANAGER_DEBUG_POOL_SIZE];
     44          static sl_slist_node_t *power_debug_free_entry_list = NULL;
     45          static bool power_debug_ran_out_of_entry = false;
     46          
     47          static void power_manager_log_add_requirement(sl_slist_node_t **p_list,
     48                                                        bool            add,
     49                                                        const char      *name);
     50          
     51          /***************************************************************************//**
     52           * Print a fancy table that describes the current requirements on each energy
     53           * mode and their owner.
     54           ******************************************************************************/
     55          void sl_power_manager_debug_print_em_requirements(void)
     56          {
     57            sli_power_debug_requirement_entry_t *entry;
     58          
     59            if (power_debug_ran_out_of_entry) {
     60              printf("WARNING: The system ran out of Debug Entry; This report is likely to be incomplete. Increase SL_POWER_MANAGER_DEBUG_POOL_SIZE\n\n");
     61            }
     62            printf("------------------------------------------\n");
     63            printf("| EM requirements\n");
     64            printf("------------------------------------------\n");
     65            if (power_manager_debug_requirement_em1 != NULL) {
     66              printf("| EM1 requirement module owners:\n");
     67            }
     68            SL_SLIST_FOR_EACH_ENTRY(power_manager_debug_requirement_em1, entry, sli_power_debug_requirement_entry_t, node) {
     69              printf("|     %s\n", entry->module_name);
     70            }
     71            if (power_manager_debug_requirement_em1 != NULL) {
     72              printf("------------------------------------------\n");
     73            }
     74          }
     75          
     76          /***************************************************************************//**
     77           * Initialize debugging feature.
     78           ******************************************************************************/
     79          void sli_power_manager_debug_init(void)
     80          {
     81            uint32_t i;
     82          
     83            for (i = 0; i < SL_POWER_MANAGER_DEBUG_POOL_SIZE; i++) {
     84              sli_power_debug_requirement_entry_t  *entry = &power_debug_entry_table[i];
     85              sl_slist_push(&power_debug_free_entry_list, &entry->node);
     86            }
     87          }
     88          
     89          /***************************************************************************//**
     90           * Log requirement to a list
     91           *
     92           * @param p_list  List where to push or remove the requirement.
     93           *
     94           * @param add     Add (true) or remove (false) the requirement.
     95           *
     96           * @param name    Module name that acquired or remove the requirement.
     97           ******************************************************************************/
     98          static void power_manager_log_add_requirement(sl_slist_node_t **p_list,
     99                                                        bool            add,
    100                                                        const char      *name)
    101          {
    102            sl_slist_node_t *node;
    103            sli_power_debug_requirement_entry_t  *entry;
    104          
    105            if (add == true) {
    106              // Get entry from free list
    107              node = sl_slist_pop(&power_debug_free_entry_list);
    108              if (node == NULL) {
    109                power_debug_ran_out_of_entry = true;
    110                return;
    111              }
    112          
    113              // Push entry to the EMx requirement debug list
    114              entry = SL_SLIST_ENTRY(node, sli_power_debug_requirement_entry_t, node);
    115              entry->module_name = name;
    116              sl_slist_push(p_list, &entry->node);
    117            } else {
    118              sli_power_debug_requirement_entry_t  *entry_remove = NULL;
    119          
    120              // Search in the EMx requirement debug list
    121              SL_SLIST_FOR_EACH_ENTRY(*p_list, entry, sli_power_debug_requirement_entry_t, node) {
    122                // Current module name and entry module name
    123                if (strcmp(entry->module_name, name) == 0) {
    124                  entry_remove = entry;
    125                  break;
    126                }
    127              }
    128          
    129              if (entry_remove == NULL) {
    130                return;
    131              }
    132          
    133              sl_slist_remove(p_list, &entry_remove->node);
    134              sl_slist_push(&power_debug_free_entry_list, &entry_remove->node);
    135            }
    136          }
    137          #endif // SL_POWER_MANAGER_DEBUG
    138          
    139          #undef sli_power_manager_debug_log_em_requirement
    140          /***************************************************************************//**
    141           * Log energy mode (EM) requirement
    142           *
    143           * @param em    Energy mode added or removed.
    144           *
    145           * @param add   Add (true) or remove (false) the requirement.
    146           *
    147           * @param name  Module name that adds or removes the requirement.
    148           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    149          void sli_power_manager_debug_log_em_requirement(sl_power_manager_em_t em,
    150                                                          bool                  add,
    151                                                          const char            *name)
    152          {
    153          #if (SL_POWER_MANAGER_DEBUG == 1)
    154            if (em == SL_POWER_MANAGER_EM1) {
    155              power_manager_log_add_requirement(&power_manager_debug_requirement_em1, add, name);
    156            }
    157          #else
    158            (void)em;
    159            (void)add;
    160            (void)name;
    161          #endif
