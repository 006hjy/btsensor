   \        0x8                      DS8 1
   \        0x9                      DS8 1
   \        0xA                      DS8 1
   \        0xB                      DS8 1
   \        0xC                      DS8 1
   \        0xD                      DS8 3
   \       0x10                      DS8 4
    111          
    112          // Threshold delay in sleeptimer ticks indicating the minimum time required
