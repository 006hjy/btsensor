   \                                 In section .text, align 2, keep-with-next
    178          sl_status_t sl_power_manager_init(void)
    179          {
   \                     sl_power_manager_init: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
    180            CORE_DECLARE_IRQ_STATE;
    181          
    182            CORE_ENTER_CRITICAL();
   \        0x2   0x.... 0x....      BL       CORE_EnterCritical
   \        0x6   0x4604             MOV      R4,R0
    183          
    184            // Initialize GPIO bus clock module if it hasn't been initialized
    185            sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_GPIO);
   \        0x8   0x....             LDR.N    R0,??DataTable10
   \        0xA   0x.... 0x....      BL       sl_clock_manager_enable_bus_clock
    186          
    187            if (!is_initialized) {
   \        0xE   0x....             LDR.N    R5,??DataTable10_1
   \       0x10   0x7828             LDRB     R0,[R5, #+0]
   \       0x12   0xB978             CBNZ.N   R0,??sl_power_manager_init_0
    188          #if !defined(SL_CATALOG_POWER_MANAGER_NO_DEEPSLEEP_PRESENT) \
    189              && !defined(SL_CATALOG_POWER_MANAGER_DEEPSLEEP_BLOCKING_HFXO_RESTORE_PRESENT)
    190              // Additional Sleeptimer HW configuration if the "power_manager_deepsleep" component is used
    191              sli_sleeptimer_hal_power_manager_integration_init();
    192          #endif
    193          
    194            #if (SL_POWER_MANAGER_DEBUG == 1)
    195              sli_power_manager_debug_init();
    196            #endif
    197              sli_power_manager_em_transition_event_list_init();
   \       0x14   0x.... 0x....      BL       sli_power_manager_em_transition_event_list_init
    198          
    199          #if !defined(SL_CATALOG_POWER_MANAGER_NO_DEEPSLEEP_PRESENT)
    200              // If lowest energy mode is not restricted to EM1, determine and set lowest energy mode
    201              sli_sleeptimer_set_pm_em_requirement();
   \       0x18   0x.... 0x....      BL       sli_sleeptimer_set_pm_em_requirement
    202              // Set the default wake-up overhead value
    203              wakeup_time_config_overhead_tick = SCHEDULE_WAKEUP_DEFAULT_RESTORE_TIME_OVERHEAD_TICK;
   \       0x1C   0x2000             MOVS     R0,#+0
   \       0x1E   0x61A8             STR      R0,[R5, #+24]
    204          
    205              // Get the sleeptimer frequency
    206              sleeptimer_frequency = sl_sleeptimer_get_timer_frequency();
   \       0x20   0x.... 0x....      BL       sl_sleeptimer_get_timer_frequency
   \       0x24   0x6128             STR      R0,[R5, #+16]
    207          #endif
    208          
    209          #if defined(_EMU_CTRL_EM2DBGEN_MASK) && defined(SL_POWER_MANAGER_INIT_EMU_EM2_DEBUG_ENABLE)
    210              // EM2 set debug enable
    211              EMU->CTRL = (EMU->CTRL & ~_EMU_CTRL_EM2DBGEN_MASK)
    212                          | (SL_POWER_MANAGER_INIT_EMU_EM2_DEBUG_ENABLE << _EMU_CTRL_EM2DBGEN_SHIFT);
   \       0x26   0x....             LDR.N    R0,??DataTable10_2
   \       0x28   0x6801             LDR      R1,[R0, #+0]
