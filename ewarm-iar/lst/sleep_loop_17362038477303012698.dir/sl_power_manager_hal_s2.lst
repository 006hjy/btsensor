    110          /*******************************************************************************
    111           *******************************  MACROS   *************************************
    112           ******************************************************************************/
    113          
    114          /*******************************************************************************
    115          * DPLL lock time can be approximately calculated by the equation:
    116          *   COARSECOUNT * (M + 1) * Tref
    117          * Where
    118          *   - COARSECOUNT is calibration value in a hidden register. Its default value
    119          *     is 5 and should not change with calibration.
    120          *   - M is one the DPLL configuration parameter.
    121          *   - Tref is the reference clock period.
    122          *******************************************************************************/
    123          #define DPLL_LOCKING_DELAY_US_FUNCTION(M, freq_ref) \
    124            (uint32_t)(((uint64_t)(DPLL_COARSECOUNT_VALUE * ((M) +1)) * 1000000 + ((freq_ref) - 1)) / (freq_ref))
    125          
