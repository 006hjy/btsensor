    104          static bool comp_int_disabled = true;
    105          
    106          __STATIC_INLINE uint32_t get_time_diff(uint32_t a,
    107                                                 uint32_t b);
    108          
    109          /******************************************************************************
    110           * Initializes TIMER sleep timer.
    111           *****************************************************************************/
    112          void sleeptimer_hal_init_timer(void)
    113          {
    114            sl_clock_manager_enable_bus_clock(SLEEPTIMER_TIMER_CLK);
    115          
    116          #if defined(_SILICON_LABS_32B_SERIES_2)
    117            TIMER_Init_TypeDef init_config = TIMER_INIT_DEFAULT;
    118            TIMER_InitCC_TypeDef init_config_cc = TIMER_INITCC_DEFAULT;
    119            init_config_cc.mode = timerCCModeCompare;
    120            init_config.prescale = timerPrescale1024;
    121          #if (SL_SLEEPTIMER_DEBUGRUN == 1)
    122            init_config.debugRun = true;
    123          #endif
    124          
    125            TIMER_InitCC(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_CHANNEL, &init_config_cc);
    126            TIMER_TopSet(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_TOP_MAX);
    127          
    128            TIMER_Init(SLEEPTIMER_TIMER_INSTANCE, &init_config);
    129          #if defined(TIMER_STATUS_SYNCBUSY)
    130            TIMER_SyncWait(SLEEPTIMER_TIMER_INSTANCE);
    131          #endif
    132          
    133            TIMER_IntDisable(SLEEPTIMER_TIMER_INSTANCE, _TIMER_IEN_MASK);
    134            TIMER_IntClear(SLEEPTIMER_TIMER_INSTANCE, _TIMER_IEN_MASK);
    135          
    136            TIMER_CompareSet(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_CHANNEL, 0UL);
    137          
    138          #elif defined(_SILICON_LABS_32B_SERIES_3)
    139            sl_hal_timer_config_t init_config = SL_HAL_TIMER_CONFIG_DEFAULT;
    140            sl_hal_timer_channel_config_t init_config_cc = SL_HAL_TIMER_CHANNEL_CONFIG_DEFAULT;
    141            init_config_cc.channel_mode = SL_HAL_TIMER_CHANNEL_MODE_COMPARE;
    142            init_config.prescaler = SL_HAL_TIMER_PRESCALER_DIV1024;
    143          #if (SL_SLEEPTIMER_DEBUGRUN == 1)
    144            init_config.debugRun = true;
    145          #endif
    146          
    147            sl_hal_timer_channel_init(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_CHANNEL, &init_config_cc);
    148            sl_hal_timer_init(SLEEPTIMER_TIMER_INSTANCE, &init_config);
    149            sl_hal_timer_disable_interrupts(SLEEPTIMER_TIMER_INSTANCE, _TIMER_IEN_MASK);
    150            sl_hal_timer_clear_interrupts(SLEEPTIMER_TIMER_INSTANCE, _TIMER_IEN_MASK);
    151            sl_hal_timer_enable(SLEEPTIMER_TIMER_INSTANCE);
    152            sl_hal_timer_wait_sync(SLEEPTIMER_TIMER_INSTANCE);
    153            sl_hal_timer_set_top(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_TOP_MAX);
    154            sl_hal_timer_channel_set_compare(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_CHANNEL, 0UL);
    155            sl_hal_timer_start(SLEEPTIMER_TIMER_INSTANCE);
    156          #endif
    157          
    158            sl_interrupt_manager_clear_irq_pending(SLEEPTIMER_TIMER_IRQ);
    159            sl_interrupt_manager_enable_irq(SLEEPTIMER_TIMER_IRQ);
    160          }
    161          
    162          /******************************************************************************
    163           * Gets TIMER counter value.
    164           *****************************************************************************/
    165          uint32_t sleeptimer_hal_get_counter(void)
    166          {
    167            return sleeptimer_hal_timer_get_counter(SLEEPTIMER_TIMER_INSTANCE);
    168          }
    169          
    170          /******************************************************************************
    171           * Gets TIMER compare value.
    172           *****************************************************************************/
    173          uint32_t sleeptimer_hal_get_compare(void)
    174          {
    175            return sleeptimer_hal_timer_get_compare(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_CHANNEL);
    176          }
    177          
    178          /******************************************************************************
    179           * Sets TIMER compare value.
    180           *
    181           * @note Compare match value is set to the requested value - 1. This is done
    182           * to compensate for the fact that the TIMER compare match interrupt always
    183           * triggers at the end of the requested ticks and that the IRQ handler is
    184           * executed when current tick count == compare_value + 1.
    185           *****************************************************************************/
    186          void sleeptimer_hal_set_compare(uint32_t value)
    187          {
    188            CORE_DECLARE_IRQ_STATE;
    189            uint32_t counter;
    190            uint32_t compare;
    191            uint32_t compare_value = value;
    192          
    193            CORE_ENTER_CRITICAL();
    194            counter = sleeptimer_hal_get_counter();
    195            compare = sleeptimer_hal_get_compare();
    196          
    197            if (((sleeptimer_hal_timer_get_interrupt(SLEEPTIMER_TIMER_INSTANCE) & SLEEPTIMER_TIMER_IEN_COMPARE) != 0)
    198                || get_time_diff(compare, counter) > SLEEPTIMER_COMPARE_MIN_DIFF
    199                || compare == counter) {
    200              // Add margin if necessary
    201              if (get_time_diff(compare_value, counter) < SLEEPTIMER_COMPARE_MIN_DIFF) {
    202                compare_value = counter + SLEEPTIMER_COMPARE_MIN_DIFF;
    203              }
    204              compare_value %= SLEEPTIMER_TMR_WIDTH;
    205          
    206              sleeptimer_hal_timer_set_compare(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_CHANNEL, compare_value - 1);
    207              sleeptimer_hal_enable_int(SLEEPTIMER_EVENT_COMP);
    208              comp_int_disabled = false;
    209            }
    210            CORE_EXIT_CRITICAL();
    211          }
    212          
    213          /******************************************************************************
    214           * Enables TIMER interrupts.
    215           *****************************************************************************/
    216          void sleeptimer_hal_enable_int(uint8_t local_flag)
    217          {
    218            uint32_t timer_ien = 0UL;
    219          
    220            if (local_flag & SLEEPTIMER_EVENT_OF) {
    221              timer_ien |= TIMER_IEN_OF;
    222            }
    223          
    224            if (local_flag & SLEEPTIMER_EVENT_COMP) {
    225              if (comp_int_disabled == true) {
    226                sleeptimer_hal_timer_clear_interrupt(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_IEN_COMPARE);
    227                comp_int_disabled = false;
    228              }
    229              timer_ien |= SLEEPTIMER_TIMER_IEN_COMPARE;
    230            }
    231          
    232            sleeptimer_hal_timer_enable_interrupt(SLEEPTIMER_TIMER_INSTANCE, timer_ien);
    233          }
    234          
    235          /******************************************************************************
    236           * Disables TIMER interrupts.
    237           *****************************************************************************/
    238          void sleeptimer_hal_disable_int(uint8_t local_flag)
    239          {
    240            uint32_t timer_int_dis = 0UL;
    241          
    242            if (local_flag & SLEEPTIMER_EVENT_OF) {
    243              timer_int_dis |= TIMER_IEN_OF;
    244            }
    245          
    246            if (local_flag & SLEEPTIMER_EVENT_COMP) {
    247              timer_int_dis |= SLEEPTIMER_TIMER_IEN_COMPARE;
    248          
    249              comp_int_disabled = true;
    250            }
    251          
    252            sleeptimer_hal_timer_disable_interrupt(SLEEPTIMER_TIMER_INSTANCE, timer_int_dis);
    253          }
    254          
    255          /*******************************************************************************
    256           * Hardware Abstraction Layer to set timer interrupts.
    257           ******************************************************************************/
    258          void sleeptimer_hal_set_int(uint8_t local_flag)
    259          {
    260            if (local_flag & SLEEPTIMER_EVENT_COMP) {
    261              sleeptimer_hal_timer_set_interrupt(SLEEPTIMER_TIMER_INSTANCE, SLEEPTIMER_TIMER_IEN_COMPARE);
    262            }
    263          }
    264          
    265          /******************************************************************************
    266           * Gets status of specified interrupt.
    267           *
    268           * Note: This function must be called with interrupts disabled.
    269           *****************************************************************************/
    270          bool sli_sleeptimer_hal_is_int_status_set(uint8_t local_flag)
    271          {
    272            bool int_is_set = false;
    273            uint32_t irq_flag = sleeptimer_hal_timer_get_interrupt(SLEEPTIMER_TIMER_INSTANCE);
    274          
    275            switch (local_flag) {
    276              case SLEEPTIMER_EVENT_COMP:
    277                int_is_set = ((irq_flag & SLEEPTIMER_TIMER_IEN_COMPARE) == SLEEPTIMER_TIMER_IEN_COMPARE);
    278                break;
    279          
    280              case SLEEPTIMER_EVENT_OF:
    281                int_is_set = ((irq_flag & TIMER_IEN_OF) == TIMER_IEN_OF);
    282                break;
    283          
    284              default:
    285                break;
    286            }
    287          
    288            return int_is_set;
    289          }
    290          
    291          /*******************************************************************************
    292           * TIMER interrupt handler.
    293           ******************************************************************************/
    294          void SLEEPTIMER_TIMER_IRQHandler(void)
    295          {
    296            CORE_DECLARE_IRQ_STATE;
    297            uint8_t local_flag = 0;
    298            uint32_t irq_flag;
    299          
    300            CORE_ENTER_ATOMIC();
    301            irq_flag = sleeptimer_hal_timer_get_interrupt(SLEEPTIMER_TIMER_INSTANCE);
    302          
    303            if (irq_flag & TIMER_IEN_OF) {
    304              local_flag |= SLEEPTIMER_EVENT_OF;
    305            }
    306          
    307            if (irq_flag & SLEEPTIMER_TIMER_IEN_COMPARE) {
    308              local_flag |= SLEEPTIMER_EVENT_COMP;
    309            }
    310            sleeptimer_hal_timer_clear_interrupt(SLEEPTIMER_TIMER_INSTANCE, irq_flag & (TIMER_IEN_OF | SLEEPTIMER_TIMER_IEN_COMPARE));
    311          
    312            process_timer_irq(local_flag);
    313          
    314            CORE_EXIT_ATOMIC();
    315          }
    316          
    317          /*******************************************************************************
    318           * Gets TIMER timer frequency.
    319           ******************************************************************************/
    320          uint32_t sleeptimer_hal_get_timer_frequency(void)
    321          {
    322            // Returns source frequency divided by max prescaler value 1024.
    323            uint32_t freq;
    324            sl_clock_branch_t clock_branch;
    325          
    326            clock_branch = sl_device_peripheral_get_clock_branch(SLEEPTIMER_PERIPHERAL_TIMER);
    327            sl_clock_manager_get_clock_branch_frequency(clock_branch, &freq);
    328            return (freq >> 10UL);
    329          }
    330          
    331          /*******************************************************************************
    332           * Computes difference between two times taking into account timer wrap-around.
    333           *
    334           * @param a Time.
    335           * @param b Time to substract from a.
    336           *
    337           * @return Time difference.
    338           ******************************************************************************/
    339          __STATIC_INLINE uint32_t get_time_diff(uint32_t a,
    340                                                 uint32_t b)
    341          {
    342            return (a - b);
    343          }
    344          
    345          /*******************************************************************************
    346           * @brief
    347           *   Gets the precision (in PPM) of the sleeptimer's clock.
    348           *
    349           * @return
    350           *   Clock accuracy, in PPM.
    351           *
    352           ******************************************************************************/
    353          uint16_t sleeptimer_hal_get_clock_accuracy(void)
    354          {
    355            uint16_t precision;
    356            sl_clock_manager_get_clock_branch_precision(SL_CLOCK_BRANCH_EM01GRPACLK, &precision);
    357            return precision;
    358          }
