     59          #define _CONCAT_TWO_TOKENS(token_1, token_2)                     token_1 ## token_2
     60          #define _CONCAT_THREE_TOKENS(token_1, token_2, token_3)          token_1 ## token_2 ## token_3
     61          #define CONCAT_TWO_TOKENS(token_1, token_2)                      _CONCAT_TWO_TOKENS(token_1, token_2)
     62          #define CONCAT_THREE_TOKENS(token_1, token_2, token_3)           _CONCAT_THREE_TOKENS(token_1, token_2, token_3)
     63          
     64          #if defined(TIMER_PRESENT)                        \
     65            && (SL_SLEEPTIMER_TIMER_INSTANCE < TIMER_COUNT) \
     66            && (TIMER_CNTWIDTH(SL_SLEEPTIMER_TIMER_INSTANCE) == 0x20)
     67            #define SLEEPTIMER_TIMER_INSTANCE    TIMER(SL_SLEEPTIMER_TIMER_INSTANCE)
     68            #define SLEEPTIMER_TIMER_CHANNEL     0
     69            #define SLEEPTIMER_PERIPHERAL_TIMER  CONCAT_TWO_TOKENS(SL_PERIPHERAL_TIMER, SL_SLEEPTIMER_TIMER_INSTANCE)
     70            #define SLEEPTIMER_TIMER_IRQ         CONCAT_THREE_TOKENS(TIMER, SL_SLEEPTIMER_TIMER_INSTANCE, _IRQn)
     71            #define SLEEPTIMER_TIMER_IRQHandler  CONCAT_THREE_TOKENS(TIMER, SL_SLEEPTIMER_TIMER_INSTANCE, _IRQHandler)
     72            #define SLEEPTIMER_TIMER_IEN_COMPARE TIMER_IEN_CC0
     73            #define SLEEPTIMER_TIMER_CLK         CONCAT_TWO_TOKENS(SL_BUS_CLOCK_TIMER, SL_SLEEPTIMER_TIMER_INSTANCE)
     74            #define SLEEPTIMER_TIMER_TOP_MAX     _TIMER_TOP_MASK
     75            #define SLEEPTIMER_TMR_WIDTH         _TIMER_CNT_MASK
     76          #else
     77            #define TIMER_UNSUPORTED
     78          #endif
