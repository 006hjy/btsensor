     53          // Minimum difference between current count value and what the comparator of the timer can be set to.
     54          // 1 tick is added to the minimum diff for the algorithm of compensation for the IRQ handler that
     55          // triggers when CNT == compare_value + 1. For more details refer to sleeptimer_hal_set_compare() function's header.
     56          #define SLEEPTIMER_COMPARE_MIN_DIFF  (1 + 1)
     57          
