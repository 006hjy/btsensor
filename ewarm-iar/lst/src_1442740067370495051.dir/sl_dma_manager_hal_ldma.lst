    314          /***************************************************************************//**
    315           *  Generic interrupt handler for every LDMA channel.
    316           *
    317           * @param channel_nbr      The channel number to handle.
    318           ******************************************************************************/
    319          static void ldma_irq_channel_handler(uint8_t channel_nbr)
    320          {
    321            uint32_t pending;
    322            uint32_t pending_done;
    323            uint32_t pending_error;
    324            uint32_t channel_mask = (1 << channel_nbr);
    325          
    326            // Get all pending and enabled interrupts.
    327            pending = sl_hal_ldma_get_enabled_pending_interrupts(LDMA0);
    328            sl_hal_ldma_clear_interrupts(LDMA0, channel_mask | (channel_mask << 16));
    329            pending_done = pending & 0xFFFF;
    330            pending_error = (pending & 0xFFFF0000) >> 16;
    331          #if defined(_LDMA_IFH_MASK)
    332            uint32_t pending_high = sl_hal_ldma_get_enabled_pending_high_interrupts(LDMA0);
    333            pending_done |= ((pending_high & 0xFFFF) << 16);
    334            pending_error |= (pending_high & 0xFFFF0000);
    335            sl_hal_ldma_clear_high_interrupts(LDMA0, channel_mask | (channel_mask >> 16));
    336          #endif
    337          
    338            if (pending_error) {
    339              // Store pending error for the channel
    340              sli_dma_manager_pending_errors[channel_nbr] = pending_error & channel_mask;
    341              // Call the interrupt callback
    342              sli_dma_manager_interrupt_handler((uint32_t)LDMA0, channel_nbr);
    343              return;
    344            }
    345          
    346            if (pending_done & channel_mask) {
    347              // Call the interrupt callback
    348              sli_dma_manager_interrupt_handler((uint32_t)LDMA0, channel_nbr);
    349            }
    350          }
    351          
