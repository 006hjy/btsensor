    107           ******************************************************************************/
    108          static void enable_interrupt(int32_t irqn);
    109          static void disable_interrupt(int32_t irqn);
    110          static void set_priority(int32_t irqn, uint32_t priority);
    111          static uint32_t get_priority(int32_t irqn);
