    122          /*******************************************************************************
    123           *****************************   VARIABLES   ***********************************
    124           ******************************************************************************/
    125          
    126          // Initialization flag.

   \                                 In section .bss, align 1
    127          static bool is_interrupt_manager_initialized = false;
   \                     is_interrupt_manager_initialized:
   \        0x0                      DS8 1
    128          
    129          #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
    130          static volatile uint32_t interrupt_nesting_counter SL_FAST_DATA = 0U;
    131          #endif
    132          
    133          /*******************************************************************************
    134           *****************************   FUNCTIONS   ***********************************
    135           ******************************************************************************/
    136          
    137          #if defined(VECTOR_TABLE_IN_RAM)
    138          #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
    139          
    140          static void sli_interrupt_manager_isr_wrapper(void)
    141          {
    142            // Grab the current active interrupt
    143            uint32_t irqn = (SCB->ICSR & SCB_ICSR_VECTACTIVE_Msk);
    144          
    145            sli_interrupt_manager_irq_enter_hook();
    146          
    147            __disable_irq();
    148            interrupt_nesting_counter++;
    149            __enable_irq();
    150          
    151            // Call the interrupt function
    152            wrapped_vector_table[irqn]();
    153          
    154            __disable_irq();
    155            interrupt_nesting_counter--;
    156            __enable_irq();
    157          
    158            sli_interrupt_manager_irq_exit_hook();
    159          
    160          #if defined(SL_CATALOG_POWER_MANAGER_ARM_SLEEP_ON_EXIT_PRESENT)
    161            if (SCB->SCR & SCB_SCR_SLEEPONEXIT_Msk && interrupt_nesting_counter == 0U) {
    162              __DSB();
    163              __ISB();
    164            }
    165          #endif
    166          }
    167          
    168          #endif /* SL_INTERRUPT_MANAGER_ENABLE_HOOKS */
    169          
    170          /***************************************************************************//**
    171           * @brief
    172           *   Set a new RAM based interrupt vector table.
    173           ******************************************************************************/
    174          sl_interrupt_manager_irq_handler_t *sli_interrupt_manager_set_irq_table(sl_interrupt_manager_irq_handler_t *table,
    175                                                                                  uint32_t handler_count)
    176          {
    177            sl_interrupt_manager_irq_handler_t * current;
    178          
    179            // ASSERT if misaligned with respect to the VTOR register implementation.
    180            EFM_ASSERT(((uint32_t)table & ~SCB_VTOR_TBLOFF_Msk) == 0U);
    181          
    182            // ASSERT if misaligned with respect to the vector table size.
    183            // The vector table address must be aligned at its size rounded up to nearest 2^n.
    184            EFM_ASSERT(((uint32_t)table
    185                        & ((1UL << (32UL - __CLZ((handler_count * 4UL) - 1UL))) - 1UL))
    186                       == 0UL);
    187          
    188            // Disable all interrupts while updating the vector table.
    189            sl_interrupt_manager_disable_interrupts();
    190          
    191            current = (sl_interrupt_manager_irq_handler_t*)SCB->VTOR;
    192          
    193            SCB->VTOR = (uint32_t)table;
    194          
    195            // DSB and ISB are required after VTOR updates to ensure
    196            // the new vector table is used by subsequent instruction fetches.
    197            __DSB();
    198            __ISB();
    199          
    200            sl_interrupt_manager_enable_interrupts();
    201          
    202            return current;
    203          }
    204          
    205          #endif /* VECTOR_TABLE_IN_RAM */
