     50          /*******************************************************************************
     51           *********************************   DEFINES   *********************************
     52           ******************************************************************************/
     53          #define CORTEX_INTERRUPTS       (16)
     54          #define TOTAL_INTERRUPTS        (CORTEX_INTERRUPTS + EXT_IRQ_COUNT)
     55          
     56          #define LOWEST_NVIC_PRIORITY    ((1U << __NVIC_PRIO_BITS) - 1U)
     57          #define SL_INTERRUPT_MANAGER_DEFAULT_PRIORITY 5U
     58          
     59          // Use same alignement as IAR
     60          #define VECTOR_TABLE_ALIGNMENT  (512)
     61          
     62          // Interrupt vector placement is in RAM
     63          #if defined(SL_CATALOG_INTERRUPT_MANAGER_VECTOR_TABLE_IN_RAM_PRESENT)
     64          #define VECTOR_TABLE_IN_RAM (1)
     65          #endif
     66          
     67          #if defined(SL_CATALOG_INTERRUPT_MANAGER_HOOKS_PRESENT)
     68          #define SL_INTERRUPT_MANAGER_ENABLE_HOOKS (1)
     69          #endif
     70          
     71          #if defined(_SILICON_LABS_32B_SERIES_3)
     72          #if defined(__GNUC__)
     73          #define VECTOR_TABLE_SECTION  __attribute__((section(".vector_table_ram")))
     74          #else
     75          #define VECTOR_TABLE_SECTION  _Pragma("location =\".vector_table_ram\"")
     76          #endif
     77          #else
     78          #define VECTOR_TABLE_SECTION
     79          #endif
     80          
     81          #if defined(VECTOR_TABLE_IN_RAM)
     82          
     83          #if defined(__GNUC__)
     84          // Create a vector table in RAM aligned to 512.
     85          static sl_interrupt_manager_irq_handler_t vector_table_ram[TOTAL_INTERRUPTS] __attribute__((aligned(VECTOR_TABLE_ALIGNMENT) )) VECTOR_TABLE_SECTION;
     86          #elif defined(__ICCARM__)
     87          #pragma data_alignment = VECTOR_TABLE_ALIGNMENT
     88          VECTOR_TABLE_SECTION static sl_interrupt_manager_irq_handler_t vector_table_ram[TOTAL_INTERRUPTS];
     89          #endif /* defined(__GNUC__) */
     90          
     91          #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
     92          // When interrupt manager hooks are enabled, the actual vector table (either in
     93          // ram or in flash) will call an ISR wrapper. The actual ISRs will be registered
     94          // and called from the wrapped_vector_table.
     95          #if defined(__GNUC__)
     96          static sl_interrupt_manager_irq_handler_t wrapped_vector_table[TOTAL_INTERRUPTS] __attribute__((aligned(VECTOR_TABLE_ALIGNMENT) )) VECTOR_TABLE_SECTION;
     97          #elif defined(__ICCARM__)
     98          #pragma data_alignment = VECTOR_TABLE_ALIGNMENT
     99          VECTOR_TABLE_SECTION static sl_interrupt_manager_irq_handler_t wrapped_vector_table[TOTAL_INTERRUPTS];
    100          #endif /* defined(__GNUC__) */
    101          #endif /* SL_INTERRUPT_MANAGER_ENABLE_HOOKS */
    102          
    103          #endif /* VECTOR_TABLE_IN_RAM */
