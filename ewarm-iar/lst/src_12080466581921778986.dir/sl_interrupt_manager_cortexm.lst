    415          {
    416          #if defined(VECTOR_TABLE_IN_RAM)
    417          
    418            uint32_t interrupt_status;
    419            sl_interrupt_manager_irq_handler_t *table;
    420          
    421            CORE_DECLARE_IRQ_STATE;
    422          
    423            if ((irqn < 0) || (irqn >= EXT_IRQ_COUNT)) {
    424              return SL_STATUS_INVALID_PARAMETER;
    425            }
    426          
    427            if (!is_interrupt_manager_initialized) {
    428              return SL_STATUS_NOT_INITIALIZED;
    429            }
    430          
    431            CORE_ENTER_CRITICAL();
    432          
    433            #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
    434            table = wrapped_vector_table;
    435            #else
    436            table = (sl_interrupt_manager_irq_handler_t*)SCB->VTOR;
