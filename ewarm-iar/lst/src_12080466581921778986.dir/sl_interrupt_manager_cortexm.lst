    207          /***************************************************************************//**
    208           * @brief
    209           *   Initialize interrupt controller hardware and initialise vector table in RAM.
    210           *
    211           * @note
    212           *   The interrupt manager init function will perform the initialization only
    213           *   once even if it's called multiple times.
    214           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    215          void sl_interrupt_manager_init(void)
    216          {
   \                     sl_interrupt_manager_init: (+1)
   \        0x0   0xB510             PUSH     {R4,LR}
    217            CORE_DECLARE_IRQ_STATE;
    218          
    219            CORE_ENTER_ATOMIC();
   \        0x2   0x.... 0x....      BL       CORE_EnterAtomic
    220          
    221            if (!is_interrupt_manager_initialized) {
   \        0x6   0x....             LDR.N    R2,??DataTable12
   \        0x8   0x7811             LDRB     R1,[R2, #+0]
   \        0xA   0xB971             CBNZ.N   R1,??sl_interrupt_manager_init_0
    222              is_interrupt_manager_initialized = true;
   \        0xC   0x2301             MOVS     R3,#+1
   \        0xE   0x7013             STRB     R3,[R2, #+0]
    223              CORE_EXIT_ATOMIC();
   \       0x10   0x.... 0x....      BL       CORE_ExitAtomic
    224            } else {
    225              CORE_EXIT_ATOMIC();
    226              return;
    227            }
    228          
    229            #if defined(VECTOR_TABLE_IN_RAM)
    230          
    231            sl_interrupt_manager_irq_handler_t* current;
    232          
    233            CORE_ENTER_CRITICAL();
    234          
    235          #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
    236            interrupt_nesting_counter = 0U;
    237          #endif
    238          
    239            current = (sl_interrupt_manager_irq_handler_t*)SCB->VTOR;
    240          
    241            // copy ROM vector table to RAM table
    242            for (uint32_t i = 0; i < TOTAL_INTERRUPTS; i++) {
    243              #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
    244              wrapped_vector_table[i] = current[i];
    245              if ( i >= CORTEX_INTERRUPTS ) {
    246                vector_table_ram[i] = sli_interrupt_manager_isr_wrapper;
    247              } else {
    248                vector_table_ram[i] = current[i];
    249              }
    250              #else
    251              vector_table_ram[i] = current[i];
    252              #endif
    253            }
    254          
    255            // Set RAM table as irq table.
    256            sli_interrupt_manager_set_irq_table(vector_table_ram, TOTAL_INTERRUPTS);
    257          
    258            CORE_EXIT_CRITICAL();
    259          
    260            #endif /* VECTOR_TABLE_IN_RAM */
    261          
    262            for (IRQn_Type i = SVCall_IRQn; i < EXT_IRQ_COUNT; i++) {
   \       0x14   0xF06F 0x0404      MVN      R4,#+4
    263              sl_interrupt_manager_set_irq_priority(i, SL_INTERRUPT_MANAGER_DEFAULT_PRIORITY);
   \                     ??sl_interrupt_manager_init_1: (+1)
   \       0x18   0x2105             MOVS     R1,#+5
   \       0x1A   0xB260             SXTB     R0,R4
   \       0x1C   0x.... 0x....      BL       sl_interrupt_manager_set_irq_priority
    264            }
   \       0x20   0x1C64             ADDS     R4,R4,#+1
   \       0x22   0xB260             SXTB     R0,R4
