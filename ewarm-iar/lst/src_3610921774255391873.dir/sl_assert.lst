     33          
     34          /* When Crash Manager is present, include its config. If SL_CRASH_MANAGER_ASSERT_HANDLER_ENABLED
     35          * is set, the config defines DEBUG_EFM_USER so that sl_assert.c skips its default assertEFM.
     36          * Crash Manager then provides assertEFM() in sl_crash_manager_hooks.c, which records the
     37          * assert as SL_CRASH_TYPE_ASSERT and invokes the crash handler before halt.
     38          */
     39          #if defined(SL_CATALOG_CRASH_MANAGER_COMPONENT_PRESENT)
     40          #include "sl_crash_manager_config.h"
     41          #endif
     42          
     43          #include "sl_assert.h"
     44          #include <stdbool.h>
     45          
     46          /***************************************************************************//**
     47           * @addtogroup assert
     48           * @details
     49           *  This module contains functions to control the ASSERT peripheral of Silicon
     50           *  Labs 32-bit MCUs and SoCs.
     51           * @{
     52           ******************************************************************************/
     53          
     54          #if defined(DEBUG_EFM) && !defined(DEBUG_EFM_USER)
     55          /***************************************************************************//**
     56           * @brief
     57           *   EFM internal assert handling.
     58           *
     59           *   This function is invoked through EFM_ASSERT() macro usage only and should
     60           *   not be used explicitly.
     61           *
     62           *   This implementation enters an indefinite loop, allowing
     63           *   the use of a debugger to determine a cause of failure. By defining
     64           *   DEBUG_EFM_USER to the preprocessor for all files, a user-defined version
     65           *   of this function must be defined and will be invoked instead, possibly
     66           *   providing output of assertion location.
     67           *
     68           * @note
     69           *   This function is not used unless DEBUG_EFM is defined
     70           *   during preprocessing of EFM_ASSERT() usage.
     71           *
     72           * @param[in] file
     73           *   Name of the source file where assertion failed.
     74           *
     75           * @param[in] line
     76           *   A line number in the source file where assertion failed.
     77           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
     78          void assertEFM(const char *file, int line)
     79          {
     80            (void)file;  /* Unused parameter */
     81            (void)line;  /* Unused parameter */
     82          
     83            while (true) {
   \                     assertEFM: (+1)
   \                     ??assertEFM_0: (+1)
   \        0x0   0xE7FE             B.N      ??assertEFM_0
     84            }
     85          }
     86          #endif /* DEBUG_EFM && !DEBUG_EFM_USER */
     87          
     88          /** @} (end addtogroup assert) */

