    197          /***************************************************************************//**
    198           * Returns true if em4 entry is blocked by a watchdog peripheral.
    199           ******************************************************************************/
    200          static bool is_em4_blocked(void)
    201          {
    202          #if defined(WDOG_PRESENT)
    203          #if WDOG_COUNT > 0
    204            if ( WDOG0_CLOCK_ENABLED_BIT && (WDOG0->CFG & WDOG_CFG_EM4BLOCK) && (WDOG0->EN & WDOG_EN_EN) ) {
    205              return true;
    206            }
    207          #endif
    208          #if WDOG_COUNT > 1
    209            if ( WDOG1_CLOCK_ENABLED_BIT && (WDOG1->CFG & WDOG_CFG_EM4BLOCK) && (WDOG1->EN & WDOG_EN_EN) ) {
    210              return true;
    211            }
    212          #endif
    213          #endif
    214            return false;
    215          }
