    236          /***************************************************************************//**
    237           * The voltage of Dvdd is ramped up to VMCU by sending pulses to a DCDC test
    238           * register. These pulses are delayed, and ipkval and ipktimeout are tuned
    239           * such that the voltage at Dvdd increases gradually to the voltage level of
    240           * VMCU. Using the IADC, once Dvdd has gotten sufficiently close to VMCU,
    241           * the DCDC peripheral is then switched into bypass mode. The IADC is used to
    242           * detect this by sampling the voltage of Dvdd periodically, and calculating the
    243           * difference between samples, when the difference is within some margin of zero
    244           * then we know that the ramp sequence has reached a plateau.
    245           ******************************************************************************/
    246          static void ramp_dvdd_and_switch_to_dcdc_bypass_mode(void)
    247          {
    248            // Initialize the IADC for the purposes of detecting when the Dvdd ramp
    249            // reaches a plateau.
    250            IADC_Init_t init = IADC_INIT_DEFAULT;
    251            IADC_AllConfigs_t initAllConfigs = IADC_ALLCONFIGS_DEFAULT;
    252            IADC_InitSingle_t initSingle = IADC_INITSINGLE_DEFAULT;
    253            IADC_SingleInput_t initSingleInput = IADC_SINGLEINPUT_DEFAULT;
    254            CMU_ClockEnable(cmuClock_IADC0, true);
    255          
    256            init.srcClkPrescale = IADC_calcSrcClkPrescale(IADC0, CLK_SRC_ADC_FREQ, 0);
    257            initAllConfigs.configs[0].reference = iadcCfgReferenceInt1V2;
    258            initAllConfigs.configs[0].vRef = 1210;
    259            initAllConfigs.configs[0].analogGain = iadcCfgAnalogGain1x;
    260            initAllConfigs.configs[0].digAvg = iadcDigitalAverage1;
    261            initAllConfigs.configs[0].adcClkPrescale =
    262              IADC_calcAdcClkPrescale(IADC0,
    263                                      CLK_ADC_FREQ,
    264                                      0,
    265                                      iadcCfgModeNormal,
    266                                      init.srcClkPrescale);
    267            init.warmup = iadcWarmupKeepWarm;
    268          
    269            IADC_reset(IADC0);
    270            CMU_ClockSelectSet(cmuClock_IADCCLK, cmuSelect_EM01GRPACLK);
    271            initSingle.triggerAction = iadcTriggerActionContinuous;
    272            initSingle.alignment = iadcAlignRight12;
    273            initSingleInput.compare = false;                   // Disable Window CMP
    274            initSingleInput.posInput = iadcPosInputDvdd;
    275            IADC_init(IADC0, &init, &initAllConfigs);
    276            IADC_initSingle(IADC0, &initSingle, &initSingleInput);
    277          
    278            // Start capturing
    279            IADC_command(IADC0, iadcCmdStartSingle);
    280          
    281            // Initialize DCDC peak current value and timeout to reach peak current value
    282            DCDC->EM01CTRL0 = (DCDC->EM01CTRL0 & ~_DCDC_EM01CTRL0_IPKVAL_MASK) | (ipkval << 0);
    283            DCDC->CTRL = (DCDC->CTRL & ~_DCDC_CTRL_IPKTMAXCTRL_MASK) | (ipktimeout << 4);
    284          
    285            /* Generate pulses */
    286            uint32_t iter = 1U;
    287            IADC_Result_t prev_result;
    288            volatile IADC_Result_t current_result = IADC_readSingleResult(IADC0);
    289            while (true) {
    290              // If the algorithm doesn't converge after 500 pulses, switch to dcdc
    291              // bypass anyways.
    292              if (iter >= 500) {
    293                DCDC->CTRL_CLR = DCDC_CTRL_MODE;
    294                EFM_ASSERT(false);
    295                return;
    296              }
    297          
    298              /* Pulse generation sequence TOCTRIG (bit 3) TOCMODE (bit 2)*/
    299              *dcdc_test_addr = cmd[0];
    300              *dcdc_test_addr = cmd[1];
    301          
    302              // In DCDC mode, MCU input voltage VREGVDD cannot be directly measured, so
    303              // we can't know what the target DVDD voltage is. Instead, since DVDD
    304              // ramp-up should follow a RC charge curve, measure DVDD and keep charging
    305              // until the delta between measures is smaller than the set tolerance.
    306              if (iter % 20U == 0U) {
    307                prev_result = current_result;
    308                current_result = IADC_readSingleResult(IADC0);
    309                if ( abs((int32_t)(current_result.data - prev_result.data)) < SL_POWER_MANAGER_RAMP_DVDD_TOLERANCE ) {
    310                  DCDC->CTRL_CLR = DCDC_CTRL_MODE;
    311                  return;
    312                }
    313              }
    314          
    315              if (DCDC->IF & DCDC_IF_TMAX) {
    316                if (ipkval) {
    317                  ipkval--; // DCDC peak current value
    318                }
    319          
    320                if (ipktimeout < 7) {
    321                  ipktimeout++; // Timeout to reach peak current value
    322                }
    323          
    324                DCDC->EM01CTRL0 = (DCDC->EM01CTRL0 & ~_DCDC_EM01CTRL0_IPKVAL_MASK) | (ipkval << 0);
    325                DCDC->CTRL = (DCDC->CTRL & ~_DCDC_CTRL_IPKTMAXCTRL_MASK) | (ipktimeout << 4);
    326          
    327                DCDC->IF_CLR = DCDC_IF_TMAX;
    328              }
    329          
    330              /* delay for 8 clock cycles */
    331              sli_delay_loop(8);
    332              iter++;
    333            }
    334          }
    335          
    336          #endif // defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2) && (SL_POWER_MANAGER_RAMP_DVDD_EN == 1)

