   2134          /***************************************************************************//**
   2135           * @brief Manually clear eusart Tx fifo.
   2136           ******************************************************************************/
   2137          static void clearEusartFifos(EUSART_TypeDef *eusart)
   2138          {
   2139            // EUSART_CMD_CLEARTX reportedly only affects UART, not SPI mode,
   2140            // and there is no EUSART_CMD_CLEARRX. Only way to clear the
   2141            // FIFOs is via the big hammer of disabling then reenabling it.
   2142          #if defined(_SILICON_LABS_32B_SERIES_2)
   2143            EUSART_Enable(eusart, eusartDisable);
   2144            EUSART_Enable(eusart, eusartEnable);
   2145          #else
   2146            sl_hal_eusart_disable_rx(eusart);
   2147            sl_hal_eusart_disable_tx(eusart);
   2148            sl_hal_eusart_disable(eusart);
   2149            while (eusart->EN & _EUSART_EN_DISABLING_MASK) ;
   2150          
   2151            sl_hal_eusart_enable(eusart);
   2152            sl_hal_eusart_enable_rx(eusart);
   2153            sl_hal_eusart_enable_tx(eusart);
   2154            sl_hal_eusart_wait_sync(eusart, _EUSART_SYNCBUSY_MASK);
   2155          #endif
   2156          }
   2157          #endif
