   2444          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT) && defined(EUSART_PRESENT)
   2445          /***************************************************************************//**
   2446           * @brief Enable EUSART and SPI IOs after deepsleep
   2447           ******************************************************************************/
   2448          static Ecode_t sli_spidrv_exit_em23(SPIDRV_Handle_t handle)
   2449          {
   2450            EUSART_TypeDef *eusart = handle->peripheral.eusartPort;
   2451          
   2452            uint32_t eusart_num = EUSART_NUM(eusart);
   2453            bool is_eusart_not_em2_capable = EUSART_NOT_EM2_CAPABLE(eusart_num);
   2454          
   2455            if (is_eusart_not_em2_capable || (handle->initData.type == spidrvMaster)) {
   2456          #if defined(_SILICON_LABS_32B_SERIES_2)
   2457              EUSART_Enable(eusart, eusartEnable);
   2458          
   2459              BUS_RegMaskedWrite(&GPIO->EUSARTROUTE[EUSART_NUM(eusart)].ROUTEEN,
   2460                                 _GPIO_EUSART_ROUTEEN_TXPEN_MASK | _GPIO_EUSART_ROUTEEN_SCLKPEN_MASK,
   2461                                 GPIO_EUSART_ROUTEEN_TXPEN | GPIO_EUSART_ROUTEEN_SCLKPEN);
   2462          #else
   2463              sl_hal_eusart_enable(eusart);
   2464              sl_hal_eusart_enable_rx(eusart);
   2465              sl_hal_eusart_enable_tx(eusart);
   2466              sl_hal_eusart_wait_sync(eusart, _EUSART_SYNCBUSY_MASK);
   2467              sl_hal_bus_reg_write_mask(&GPIO->EUSARTROUTE[EUSART_NUM(eusart)].ROUTEEN,
   2468                                        _GPIO_EUSART_ROUTEEN_TXPEN_MASK | _GPIO_EUSART_ROUTEEN_SCLKPEN_MASK,
   2469                                        GPIO_EUSART_ROUTEEN_TXPEN | GPIO_EUSART_ROUTEEN_SCLKPEN);
   2470          #endif
   2471            }
   2472            return ECODE_EMDRV_SPIDRV_OK;
   2473          }
   2474          
   2475          /***************************************************************************//**
   2476           * @brief Disable SPIO IOs before deepsleep
   2477           ******************************************************************************/
   2478          static Ecode_t sli_spidrv_enter_em23(SPIDRV_Handle_t handle)
   2479          {
   2480            EUSART_TypeDef *eusart = handle->peripheral.eusartPort;
   2481          
   2482            uint32_t eusart_num = EUSART_NUM(eusart);
   2483            bool is_eusart_not_em2_capable = EUSART_NOT_EM2_CAPABLE(eusart_num);
   2484          
   2485            if (is_eusart_not_em2_capable || (handle->initData.type == spidrvMaster)) {
   2486          #if defined(_SILICON_LABS_32B_SERIES_2)
   2487              EUSART_Enable(eusart, eusartDisable);
   2488          
   2489              BUS_RegMaskedWrite(&GPIO->EUSARTROUTE[EUSART_NUM(eusart)].ROUTEEN,
   2490                                 _GPIO_EUSART_ROUTEEN_TXPEN_MASK | _GPIO_EUSART_ROUTEEN_SCLKPEN_MASK,
   2491                                 0);
   2492          #else
   2493              sl_hal_bus_reg_write_mask(&GPIO->EUSARTROUTE[EUSART_NUM(eusart)].ROUTEEN,
   2494                                        _GPIO_EUSART_ROUTEEN_TXPEN_MASK | _GPIO_EUSART_ROUTEEN_SCLKPEN_MASK,
   2495                                        0);
   2496          #endif
   2497            }
   2498          
   2499            return ECODE_EMDRV_SPIDRV_OK;
   2500          }
   2501          
   2502          /***************************************************************************//**
   2503           * Power Manager callback notification for EUSART.
   2504           * It is used to prepare EUSART module before/after deepsleeping.
   2505           ******************************************************************************/
   2506          static void on_power_manager_event(sl_power_manager_em_t from,
   2507                                             sl_power_manager_em_t to)
   2508          {
   2509            (void)from;
   2510            SPIDRV_Handle_t handle;
   2511          
   2512            if (to == SL_POWER_MANAGER_EM1
   2513                || to == SL_POWER_MANAGER_EM0) {
   2514              SL_SLIST_FOR_EACH_ENTRY(eusart_handle_list, handle, SPIDRV_HandleData_t, node) {
   2515                sli_spidrv_exit_em23(handle);
   2516              }
   2517            }
   2518          
   2519            if (to == SL_POWER_MANAGER_EM2
   2520                || to == SL_POWER_MANAGER_EM3) {
   2521              SL_SLIST_FOR_EACH_ENTRY(eusart_handle_list, handle, SPIDRV_HandleData_t, node) {
   2522                sli_spidrv_enter_em23(handle);
   2523              }
   2524            }
   2525          }
   2526          #endif
   2527          
   2528          /***************************************************************************//**
   2529           * @brief Verify if an EUSART handle is already initialized.
   2530           ******************************************************************************/
   2531          #if defined(EUSART_PRESENT)
   2532          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT)
   2533          static Ecode_t spidrvCheckDuplicateHandle(SPIDRV_Handle_t handle)
   2534          {
   2535            CORE_DECLARE_IRQ_STATE;
   2536            CORE_ENTER_ATOMIC();
   2537            SPIDRV_Handle_t existing_handle;
   2538            SL_SLIST_FOR_EACH_ENTRY(eusart_handle_list, existing_handle, SPIDRV_HandleData_t, node) {
   2539              if (existing_handle == handle) {
   2540                CORE_EXIT_ATOMIC();
   2541                return ECODE_EMDRV_SPIDRV_ALREADY_INITIALIZED;
   2542              }
   2543            }
   2544            CORE_EXIT_ATOMIC();
   2545          
   2546            return ECODE_EMDRV_SPIDRV_OK;
   2547          }
   2548          #else
   2549          static Ecode_t spidrvCheckDuplicateHandle(SPIDRV_Handle_t handle)
   2550          {
   2551            (void)handle;
   2552            return ECODE_EMDRV_SPIDRV_OK;
   2553          }
   2554          #endif
   2555          #endif
   2556          
   2557          /// @endcond
   2558          
   2559          /* *INDENT-OFF* */
   2560          /******** THE REST OF THE FILE IS DOCUMENTATION ONLY !**********************//**
   2561           * @addtogroup spidrv SPIDRV - SPI Driver
   2562           * @brief Serial Peripheral Interface Driver
   2563           * @{
   2564          
   2565             @details
   2566             The spidrv.c and spidrv.h source files for the SPI driver library are in the
   2567             emdrv/spidrv folder.
   2568          
   2569             @n @section spidrv_intro Introduction
   2570             The SPI driver supports the SPI capabilities of EFM32/EZR32/EFR32 USARTs.
   2571             The driver is fully reentrant, supports several driver instances, and
   2572             does not buffer or queue data. Both synchronous and asynchronous transfer
   2573             functions are included for both master and slave SPI mode. Synchronous
   2574             transfer functions are blocking and do
   2575             not return before the transfer is complete. Asynchronous transfer
   2576             functions report transfer completion with callback functions. Transfers are
   2577             handled using DMA.
   2578          
   2579             @note Transfer completion callback functions are called from within the DMA
   2580             interrupt handler with interrupts disabled.
   2581          
   2582             @note When doing USART synchronous transfers, fractional clock
   2583             division of the reference clock is suppressed at @ref SPIDRV_SetBitrate.
   2584             This restriction prevents timing violations causing framing errors and data corruption at high frequencies.
   2585          
   2586             @n @section spidrv_conf Configuration Options
   2587          
   2588             Some properties of the SPIDRV driver are compile-time configurable. These
   2589             properties are stored in a file named spidrv_config.h. A template for
   2590             this file, containing default values, is in the emdrv/config folder.
   2591             Currently the configuration options are as follows:
   2592             @li Inclusion of slave API transfer functions.
   2593          
   2594             To configure SPIDRV, provide a custom configuration file. This is a
   2595             sample spidrv_config.h file:
   2596             @verbatim
   2597          #ifndef __SILICON_LABS_SPIDRV_CONFIG_H__
   2598          #define __SILICON_LABS_SPIDRV_CONFIG_H__
   2599          
   2600          // SPIDRV configuration option. Use this define to include the
   2601          // slave part of the SPIDRV API.
   2602          #define EMDRV_SPIDRV_INCLUDE_SLAVE
   2603          
   2604          #endif
   2605             @endverbatim
   2606          
   2607             The properties of each SPI driver instance are set at run-time using the
   2608             @ref SPIDRV_Init data structure input parameter to the @ref SPIDRV_Init()
   2609             function.
   2610          
   2611             @n @section spidrv_api The API
   2612          
   2613             This section contains brief descriptions of the API functions. For
   2614             detailed information on input and output parameters and return values,
   2615             click on the hyperlinked function names. Most functions return an error
   2616             code, @ref ECODE_EMDRV_SPIDRV_OK is returned on success,
   2617             see ecode.h and spidrv.h for other error codes.
   2618          
   2619             The application code must include @em spidrv.h.
   2620          
   2621             @ref SPIDRV_Init(), @ref SPIDRV_DeInit() @n
   2622              These functions initialize or deinitializes the SPIDRV driver. Typically,
   2623              SPIDRV_Init() is called once in the startup code.
   2624          
   2625             @ref SPIDRV_GetTransferStatus() @n
   2626              Query the status of a transfer. Reports number of items (frames) transmitted
   2627              and remaining.
   2628          
   2629             @ref SPIDRV_AbortTransfer() @n
   2630              Stop an ongoing transfer.
   2631          
   2632             @ref SPIDRV_SetBitrate(), @ref SPIDRV_GetBitrate() @n
   2633              Set or query the SPI bus bitrate.
   2634          
   2635             @ref SPIDRV_SetFramelength(), @ref SPIDRV_GetFramelength() @n
   2636              Set or query SPI the bus frame length.
   2637          
   2638             SPIDRV_MReceive(), SPIDRV_MReceiveB() @n
   2639             SPIDRV_MTransfer(), SPIDRV_MTransferB(), SPIDRV_MTransferSingleItemB() @n
   2640             SPIDRV_MTransmit(), SPIDRV_MTransmitB() @n
   2641             SPIDRV_SReceive(), SPIDRV_SReceiveB() @n
   2642             SPIDRV_STransfer(), SPIDRV_STransferB() @n
   2643             SPIDRV_STransmit(), SPIDRV_STransmitB() @n
   2644              SPI transfer functions for SPI masters have an uppercase M in their name,
   2645              the slave counterparts have an S.
   2646          
   2647              As previously mentioned, transfer functions are synchronous and asynchronous.
   2648              The synchronous versions have an uppercase B (for Blocking) at the end of
   2649              their function name.
   2650          
   2651              @em Transmit functions discard received data, @em receive functions transmit
   2652              a fixed data pattern set when the driver is initialized
   2653              (@ref SPIDRV_Init.dummyTxValue). @em Transfer functions both receive and
   2654              transmit data.
   2655          
   2656              All slave transfer functions have a millisecond timeout parameter. Use 0
   2657              for no (infinite) timeout.
   2658          
   2659             @n @section spidrv_example Example
   2660             @verbatim
   2661          #include "spidrv.h"
   2662          
   2663          SPIDRV_HandleData_t handleData;
   2664          SPIDRV_Handle_t handle = &handleData;
   2665          
   2666          void TransferComplete(SPIDRV_Handle_t handle,
   2667                                Ecode_t transferStatus,
   2668                                int itemsTransferred)
   2669          {
   2670            if (transferStatus == ECODE_EMDRV_SPIDRV_OK) {
   2671             // Success !
   2672            }
   2673          }
   2674          
   2675          int main(void)
   2676          {
   2677            uint8_t buffer[10];
   2678            SPIDRV_Init_t initData = SPIDRV_MASTER_USART2;
   2679          
   2680            // Initialize an SPI driver instance.
   2681            SPIDRV_Init(handle, &initData);
   2682          
   2683            // Transmit data using a blocking transmit function.
   2684            SPIDRV_MTransmitB(handle, buffer, 10);
   2685          
   2686            // Transmit data using a callback to catch transfer completion.
   2687            SPIDRV_MTransmit(handle, buffer, 10, TransferComplete);
   2688          }
   2689             @endverbatim
   2690          
   2691           * @} end group spidrv ****************************************************/

