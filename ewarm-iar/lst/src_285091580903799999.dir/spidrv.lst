    209            CORE_DECLARE_IRQ_STATE;
    210            CORE_ENTER_ATOMIC();
    211            if (handle->em1RequestCount == 0) {
    212              sl_power_manager_add_em_requirement(SL_POWER_MANAGER_EM1);
    213            }
    214            handle->em1RequestCount++;
    215            CORE_EXIT_ATOMIC();
    216          #else
    217            handle->em1RequestCount++;
    218          #endif
    219          }
