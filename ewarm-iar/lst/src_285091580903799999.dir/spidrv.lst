    297          /***************************************************************************//**
    298           * @brief
    299           *    Initialize an SPI driver DMA channel instances.
    300           *
    301           * @return
    302           *    @ref ECODE_EMDRV_SPIDRV_OK on success. On failure, an appropriate
    303           *    SPIDRV @ref Ecode_t is returned.
    304           ******************************************************************************/
    305          static Ecode_t SPIDRV_initializeDma(SPIDRV_Handle_t handle)
    306          {
    307            uint8_t txChNum;
    308            uint8_t rxChNum;
    309          
    310            sl_dma_manager_init(NULL, NULL);
    311          
    312            if (sl_dma_manager_allocate_channel(NULL, &txChNum) != SL_STATUS_OK) {
    313              return ECODE_EMDRV_SPIDRV_DMA_ALLOC_ERROR;
    314            }
    315          
    316            if (sl_dma_manager_allocate_channel(NULL, &rxChNum) != SL_STATUS_OK) {
    317              sl_dma_manager_free_channel(NULL, txChNum);
    318              return ECODE_EMDRV_SPIDRV_DMA_ALLOC_ERROR;
    319            }
    320          
    321            // Initialize TX DMA channel handle (no callback - SPI uses RX complete only)
    322            sl_dma_channel_init(&handle->txDMACh, SL_PERIPHERAL_LDMA0, txChNum, NULL, NULL);
    323            sl_dma_channel_set_peripheral_signal(&handle->txDMACh, handle->txDMASignal);
    324          
    325            // Initialize RX DMA channel handle with completion callback
    326            sl_dma_channel_init(&handle->rxDMACh, SL_PERIPHERAL_LDMA0, rxChNum, RxDMAComplete, handle);
    327            sl_dma_channel_set_peripheral_signal(&handle->rxDMACh, handle->rxDMASignal);
    328          
    329            return ECODE_EMDRV_SPIDRV_OK;
    330          }
    331          
    332          #if defined (USART_PRESENT)
    333          /***************************************************************************//**
    334           * @brief
    335           *    Initialize an SPI driver usart instance.
    336           *
    337           * @param[out] handle  Pointer to an SPI driver handle; refer to @ref
    338           *                     SPIDRV_Handle_t.
    339           *
    340           * @param[in] initData Pointer to an initialization data structure;
    341           *                     refer to @ref SPIDRV_Init.
    342           *
    343           * @return
    344           *    @ref ECODE_EMDRV_SPIDRV_OK on success. On failure, an appropriate
    345           *    SPIDRV @ref Ecode_t is returned.
    346           ******************************************************************************/
    347          static Ecode_t SPIDRV_InitUsart(SPIDRV_Handle_t handle, SPIDRV_Init_t *initData)
    348          {
    349            Ecode_t retVal;
    350            USART_InitSync_TypeDef usartInit = USART_INITSYNC_DEFAULT;
    351            int8_t spiPortNum = -1;
    352            sl_bus_clock_t bus_clock;
    353          
    354            if (handle == NULL) {
    355              return ECODE_EMDRV_SPIDRV_ILLEGAL_HANDLE;
    356            }
    357          
    358            if (initData == NULL) {
    359              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    360            }
    361          
    362            memset(handle, 0, sizeof(SPIDRV_HandleData_t));
    363            emRequestInit(handle);
    364          
    365            if (0) {
    366          #if defined(USART0)
    367            } else if ((USART_TypeDef*)initData->port == USART0) {
    368              handle->usartPeripheral  = SL_PERIPHERAL_USART0;
    369              handle->txDMASignal = SL_DMA_SIGNAL_USART0_TXBL;
    370              handle->rxDMASignal = SL_DMA_SIGNAL_USART0_RXDATAV;
    371              spiPortNum = 0;
    372          #endif
    373          #if defined(USART1)
    374            } else if ((USART_TypeDef*)initData->port == USART1) {
    375              handle->usartPeripheral  = SL_PERIPHERAL_USART1;
    376              handle->txDMASignal = SL_DMA_SIGNAL_USART1_TXBL;
    377              handle->rxDMASignal = SL_DMA_SIGNAL_USART1_RXDATAV;
    378              spiPortNum = 1;
    379          #endif
    380          #if defined(USART2)
    381            } else if ((USART_TypeDef*)initData->port == USART2) {
    382              handle->usartPeripheral  = SL_PERIPHERAL_USART2;
    383              handle->txDMASignal = SL_DMA_SIGNAL_USART2_TXBL;
    384              handle->rxDMASignal = SL_DMA_SIGNAL_USART2_RXDATAV;
    385              spiPortNum = 2;
    386          #endif
    387            } else {
    388              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    389            }
    390          
    391            handle->peripheral.usartPort  = initData->port;
    392            handle->peripheralType        = spidrvPeripheralTypeUsart;
    393            handle->initData              = *initData;
    394          
    395            if (initData->bitOrder == spidrvBitOrderMsbFirst) {
    396              usartInit.msbf = true;
    397            }
    398          
    399            if (initData->clockMode == spidrvClockMode0) {
    400              usartInit.clockMode = usartClockMode0;
    401            } else if (initData->clockMode == spidrvClockMode1) {
    402              usartInit.clockMode = usartClockMode1;
    403            } else if (initData->clockMode == spidrvClockMode2) {
    404              usartInit.clockMode = usartClockMode2;
    405            } else if (initData->clockMode == spidrvClockMode3) {
    406              usartInit.clockMode = usartClockMode3;
    407            } else {
    408              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    409            }
    410          
    411            if (initData->type == spidrvSlave) {
    412              usartInit.master = false;
    413              usartInit.baudrate = 115200;      // Dummy value needed by USART_InitSync()
    414            } else {
    415              usartInit.baudrate = initData->bitRate;
    416            }
    417          
    418            sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_GPIO);
    419            bus_clock = sl_device_peripheral_get_bus_clock(handle->usartPeripheral);
    420            sl_clock_manager_enable_bus_clock(bus_clock);
    421          
    422            if ((initData->frameLength < 4U) || (initData->frameLength > 16U)) {
    423              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    424            }
    425            uint32_t databits = initData->frameLength - 4U + _USART_FRAME_DATABITS_FOUR;
    426            usartInit.databits = (USART_Databits_TypeDef)databits;
    427          
    428            USART_InitSync(initData->port, &usartInit);
    429          
    430            if ((initData->type == spidrvMaster)
    431                && (initData->csControl == spidrvCsControlAuto)) {
    432              #if defined(USART_HAS_SET_CLEAR)
    433              handle->peripheral.usartPort->CTRL_SET = USART_CTRL_AUTOCS;
    434              #else
    435              handle->peripheral.usartPort->CTRL |= USART_CTRL_AUTOCS;
    436              #endif
    437            }
    438          
    439            if (initData->csControl == spidrvCsControlAuto) {
    440              // SPI 4 wire mode
    441          #if defined(USART_ROUTEPEN_TXPEN)
    442              handle->peripheral.usartPort->ROUTELOC0 = (handle->peripheral.usartPort->ROUTELOC0
    443                                                         & ~(_USART_ROUTELOC0_TXLOC_MASK
    444                                                             | _USART_ROUTELOC0_RXLOC_MASK
    445                                                             | _USART_ROUTELOC0_CLKLOC_MASK
    446                                                             | _USART_ROUTELOC0_CSLOC_MASK))
    447                                                        | (initData->portLocationTx  << _USART_ROUTELOC0_TXLOC_SHIFT)
    448                                                        | (initData->portLocationRx  << _USART_ROUTELOC0_RXLOC_SHIFT)
    449                                                        | (initData->portLocationClk << _USART_ROUTELOC0_CLKLOC_SHIFT)
    450                                                        | (initData->portLocationCs  << _USART_ROUTELOC0_CSLOC_SHIFT);
    451          
    452              handle->peripheral.usartPort->ROUTEPEN = USART_ROUTEPEN_TXPEN
    453                                                       | USART_ROUTEPEN_RXPEN
    454                                                       | USART_ROUTEPEN_CLKPEN
    455                                                       | USART_ROUTEPEN_CSPEN;
    456          #elif defined (_GPIO_USART_ROUTEEN_MASK)
    457              GPIO->USARTROUTE[spiPortNum].TXROUTE = ((uint32_t)initData->portTx
    458                                                      << _GPIO_USART_TXROUTE_PORT_SHIFT)
    459                                                     | ((uint32_t)initData->pinTx
    460                                                        << _GPIO_USART_TXROUTE_PIN_SHIFT);
    461          
    462              GPIO->USARTROUTE[spiPortNum].RXROUTE = ((uint32_t)initData->portRx
    463                                                      << _GPIO_USART_RXROUTE_PORT_SHIFT)
    464                                                     | ((uint32_t)initData->pinRx
    465                                                        << _GPIO_USART_RXROUTE_PIN_SHIFT);
    466          
    467              GPIO->USARTROUTE[spiPortNum].CLKROUTE = ((uint32_t)initData->portClk
    468                                                       << _GPIO_USART_CLKROUTE_PORT_SHIFT)
    469                                                      | ((uint32_t)initData->pinClk
    470                                                         << _GPIO_USART_CLKROUTE_PIN_SHIFT);
    471          
    472              GPIO->USARTROUTE[spiPortNum].CSROUTE = ((uint32_t)initData->portCs
    473                                                      << _GPIO_USART_CSROUTE_PORT_SHIFT)
    474                                                     | ((uint32_t)initData->pinCs
    475                                                        << _GPIO_USART_CSROUTE_PIN_SHIFT);
    476          
    477              GPIO->USARTROUTE[spiPortNum].ROUTEEN = GPIO_USART_ROUTEEN_TXPEN
    478                                                     | GPIO_USART_ROUTEEN_RXPEN
    479                                                     | GPIO_USART_ROUTEEN_CLKPEN
    480                                                     | GPIO_USART_ROUTEEN_CSPEN;
    481          #else
    482              handle->peripheral.usartPort->ROUTE = USART_ROUTE_TXPEN
    483                                                    | USART_ROUTE_RXPEN
    484                                                    | USART_ROUTE_CLKPEN
    485                                                    | USART_ROUTE_CSPEN
    486                                                    | (initData->portLocation
    487                                                       << _USART_ROUTE_LOCATION_SHIFT);
    488          #endif
    489            } else {
    490              // SPI 3 wire mode
    491          #if defined(USART_ROUTEPEN_TXPEN)
    492              handle->peripheral.usartPort->ROUTELOC0 = (handle->peripheral.usartPort->ROUTELOC0
    493                                                         & ~(_USART_ROUTELOC0_TXLOC_MASK
    494                                                             | _USART_ROUTELOC0_RXLOC_MASK
    495                                                             | _USART_ROUTELOC0_CLKLOC_MASK))
    496                                                        | (initData->portLocationTx  << _USART_ROUTELOC0_TXLOC_SHIFT)
    497                                                        | (initData->portLocationRx  << _USART_ROUTELOC0_RXLOC_SHIFT)
    498                                                        | (initData->portLocationClk << _USART_ROUTELOC0_CLKLOC_SHIFT);
    499          
    500              handle->peripheral.usartPort->ROUTEPEN = USART_ROUTEPEN_TXPEN
    501                                                       | USART_ROUTEPEN_RXPEN
    502                                                       | USART_ROUTEPEN_CLKPEN;
    503          #elif defined (GPIO_USART_ROUTEEN_TXPEN)
    504              GPIO->USARTROUTE[spiPortNum].TXROUTE = ((uint32_t)initData->portTx
    505                                                      << _GPIO_USART_TXROUTE_PORT_SHIFT)
    506                                                     | ((uint32_t)initData->pinTx
    507                                                        << _GPIO_USART_TXROUTE_PIN_SHIFT);
    508          
    509              GPIO->USARTROUTE[spiPortNum].RXROUTE = ((uint32_t)initData->portRx
    510                                                      << _GPIO_USART_RXROUTE_PORT_SHIFT)
    511                                                     | ((uint32_t)initData->pinRx
    512                                                        << _GPIO_USART_RXROUTE_PIN_SHIFT);
    513          
    514              GPIO->USARTROUTE[spiPortNum].CLKROUTE = ((uint32_t)initData->portClk
    515                                                       << _GPIO_USART_CLKROUTE_PORT_SHIFT)
    516                                                      | ((uint32_t)initData->pinClk
    517                                                         << _GPIO_USART_CLKROUTE_PIN_SHIFT);
    518          
    519              GPIO->USARTROUTE[spiPortNum].ROUTEEN = GPIO_USART_ROUTEEN_TXPEN
    520                                                     | GPIO_USART_ROUTEEN_RXPEN
    521                                                     | GPIO_USART_ROUTEEN_CLKPEN;
    522          #else
    523              handle->peripheral.usartPort->ROUTE = USART_ROUTE_TXPEN
    524                                                    | USART_ROUTE_RXPEN
    525                                                    | USART_ROUTE_CLKPEN
    526                                                    | (initData->portLocation
    527                                                       << _USART_ROUTE_LOCATION_SHIFT);
    528          #endif
    529            }
    530          
    531            if ((retVal = ConfigGPIO(handle, true)) != ECODE_EMDRV_SPIDRV_OK) {
    532              return retVal;
    533            }
    534          
    535            CORE_DECLARE_IRQ_STATE;
    536            CORE_ENTER_ATOMIC();
    537            if (!spidrvIsInitialized) {
    538              spidrvIsInitialized = true;
    539              CORE_EXIT_ATOMIC();
    540          
    541          #if defined(EMDRV_SPIDRV_INCLUDE_SLAVE)
    542              sl_sleeptimer_init();
    543          #endif
    544            } else {
    545              CORE_EXIT_ATOMIC();
    546            }
    547          
    548            return SPIDRV_initializeDma(handle);
    549          }
    550          #endif // defined USART_PRESENT
    551          
    552          #if defined(EUSART_PRESENT)
    553          /***************************************************************************//**
    554           * @brief
    555           *    Initialize an SPI driver eusart instance.
    556           *
    557           * @param[out] handle  Pointer to an SPI driver handle; refer to @ref
    558           *                     SPIDRV_Handle_t.
    559           *
    560           * @param[in] initData Pointer to an initialization data structure;
    561           *                     refer to @ref SPIDRV_Init.
    562           *
    563           * @return
    564           *    @ref ECODE_EMDRV_SPIDRV_OK on success. On failure, an appropriate
    565           *    SPIDRV @ref Ecode_t is returned.
    566           ******************************************************************************/
    567          static Ecode_t SPIDRV_InitEusart(SPIDRV_Handle_t handle, SPIDRV_Init_t *initData)
    568          {
    569            Ecode_t retVal;
    570            int8_t spiPortNum = -1;
    571            sl_bus_clock_t bus_clock;
    572          #if defined(_SILICON_LABS_32B_SERIES_2)
    573            EUSART_SpiAdvancedInit_TypeDef eusartAdvancedSpiInit = EUSART_SPI_ADVANCED_INIT_DEFAULT;
    574            EUSART_SpiInit_TypeDef eusartSpiInit = EUSART_SPI_MASTER_INIT_DEFAULT_HF;
    575            eusartSpiInit.advancedSettings = &eusartAdvancedSpiInit;
    576          #else
    577            sl_clock_branch_t clock_branch;
    578            sl_hal_eusart_spi_advanced_config_t eusartAdvancedSpiInit = SL_HAL_EUSART_SPI_ADVANCED_INIT_DEFAULT;
    579            sl_hal_eusart_spi_config_t eusartSpiInit = SL_HAL_EUSART_SPI_MASTER_INIT_DEFAULT_HF;
    580            eusartSpiInit.advanced_config = &eusartAdvancedSpiInit;
    581          #endif
    582          
    583            if (handle == NULL) {
    584              return ECODE_EMDRV_SPIDRV_ILLEGAL_HANDLE;
    585            }
    586          
    587            if (initData == NULL) {
    588              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    589            }
    590          
    591            memset(handle, 0, sizeof(SPIDRV_HandleData_t));
    592            emRequestInit(handle);
    593          
    594            if (0) {
    595          #if defined(EUSART0)
    596            } else if (initData->port == EUSART0) {
    597              handle->usartPeripheral  = SL_PERIPHERAL_EUSART0;
    598              handle->txDMASignal = SL_DMA_SIGNAL_EUSART0_TXFL;
    599              handle->rxDMASignal = SL_DMA_SIGNAL_EUSART0_RXFL;
    600              spiPortNum = 0;
    601          #endif
    602          #if defined(EUSART1)
    603            } else if (initData->port == EUSART1) {
    604              handle->usartPeripheral  = SL_PERIPHERAL_EUSART1;
    605              handle->txDMASignal = SL_DMA_SIGNAL_EUSART1_TXFL;
    606              handle->rxDMASignal = SL_DMA_SIGNAL_EUSART1_RXFL;
    607              spiPortNum = 1;
    608          #endif
    609          #if defined(EUSART2)
    610            } else if (initData->port == EUSART2) {
    611              handle->usartPeripheral  = SL_PERIPHERAL_EUSART2;
    612              handle->txDMASignal = SL_DMA_SIGNAL_EUSART2_TXFL;
    613              handle->rxDMASignal = SL_DMA_SIGNAL_EUSART2_RXFL;
    614              spiPortNum = 2;
    615          #endif
    616          #if defined(EUSART3)
    617            } else if (initData->port == EUSART3) {
    618              handle->usartPeripheral  = SL_PERIPHERAL_EUSART3;
    619              handle->txDMASignal = SL_DMA_SIGNAL_EUSART3_TXFL;
    620              handle->rxDMASignal = SL_DMA_SIGNAL_EUSART3_RXFL;
    621              spiPortNum = 3;
    622          #endif
    623          #if defined(EUSART4)
    624            } else if (initData->port == EUSART4) {
    625              handle->usartPeripheral  = SL_PERIPHERAL_EUSART4;
    626              handle->txDMASignal = SL_DMA_SIGNAL_EUSART4_TXFL;
    627              handle->rxDMASignal = SL_DMA_SIGNAL_EUSART4_RXFL;
    628              spiPortNum = 4;
    629          #endif
    630            } else {
    631              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    632            }
    633          
    634            handle->peripheral.eusartPort = initData->port;
    635            handle->peripheralType        = spidrvPeripheralTypeEusart;
    636            handle->initData              = *initData;
    637          #if defined(_SILICON_LABS_32B_SERIES_2)
    638            if (initData->bitOrder == spidrvBitOrderMsbFirst) {
    639              eusartAdvancedSpiInit.msbFirst = true;
    640            }
    641          
    642            if (initData->clockMode == spidrvClockMode0) {
    643              eusartSpiInit.clockMode = eusartClockMode0;
    644            } else if (initData->clockMode == spidrvClockMode1) {
    645              eusartSpiInit.clockMode = eusartClockMode1;
    646            } else if (initData->clockMode == spidrvClockMode2) {
    647              eusartSpiInit.clockMode = eusartClockMode2;
    648            } else if (initData->clockMode == spidrvClockMode3) {
    649              eusartSpiInit.clockMode = eusartClockMode3;
    650            } else {
    651              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    652            }
    653          
    654            if (initData->type == spidrvSlave) {
    655              if (initData->bitRate >= 5000000) {
    656                // If baud-rate is more than 5MHz, a value of 4 is required
    657                eusartSpiInit.advancedSettings->setupWindow = 4;
    658              } else {
    659                // If baud-rate is less than 5MHz, a value of 5 is required
    660                eusartSpiInit.advancedSettings->setupWindow = 5;
    661              }
    662              eusartSpiInit.master  = false;
    663              eusartSpiInit.bitRate = 1000000;
    664            } else {
    665              eusartAdvancedSpiInit.forceLoad = false;
    666              eusartSpiInit.bitRate = initData->bitRate;
    667            }
    668          #else /* Series 3 and above */
    669            if (initData->bitOrder == spidrvBitOrderMsbFirst) {
    670              eusartAdvancedSpiInit.msb_first = true;
    671            }
    672          
    673            if (initData->clockMode == spidrvClockMode0) {
    674              eusartSpiInit.clock_mode = SL_HAL_EUSART_CLOCK_MODE_0;
    675            } else if (initData->clockMode == spidrvClockMode1) {
    676              eusartSpiInit.clock_mode = SL_HAL_EUSART_CLOCK_MODE_1;
    677            } else if (initData->clockMode == spidrvClockMode2) {
    678              eusartSpiInit.clock_mode = SL_HAL_EUSART_CLOCK_MODE_2;
    679            } else if (initData->clockMode == spidrvClockMode3) {
    680              eusartSpiInit.clock_mode = SL_HAL_EUSART_CLOCK_MODE_3;
    681            } else {
    682              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    683            }
    684          
    685            uint32_t ref_freq;
    686            if (initData->type == spidrvSlave) {
    687              if (initData->bitRate >= 5000000) {
    688                // If baud-rate is more than 5MHz, a value of 4 is required
    689                eusartSpiInit.advanced_config->setup_window = 4;
    690              } else {
    691                // If baud-rate is less than 5MHz, a value of 5 is required
    692                eusartSpiInit.advanced_config->setup_window = 5;
    693              }
    694              eusartSpiInit.master  = false;
    695              clock_branch = sl_device_peripheral_get_clock_branch(handle->usartPeripheral);
    696              sl_clock_manager_get_clock_branch_frequency(clock_branch, &ref_freq);
    697              eusartSpiInit.clock_div = sl_hal_eusart_spi_calculate_clock_div(ref_freq, 1000000);
    698            } else {
    699              eusartAdvancedSpiInit.force_load = false;
    700              clock_branch = sl_device_peripheral_get_clock_branch(handle->usartPeripheral);
    701              sl_clock_manager_get_clock_branch_frequency(clock_branch, &ref_freq);
    702              eusartSpiInit.clock_div = sl_hal_eusart_spi_calculate_clock_div(ref_freq, initData->bitRate);
    703            }
    704          #endif
    705            // Leave eusartAdvancedSpiInit.defaultTxData = 0, not initData->dummyTxValue
    706            // for EUSART compatibility with USART behavior.
    707          
    708            sl_clock_manager_enable_bus_clock(SL_BUS_CLOCK_GPIO);
    709            bus_clock = sl_device_peripheral_get_bus_clock(handle->usartPeripheral);
    710            sl_clock_manager_enable_bus_clock(bus_clock);
    711          
    712            if ((initData->frameLength < 7U) || (initData->frameLength > 16U)) {
    713              return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    714            }
    715          
    716            uint32_t databits = initData->frameLength - 7U + EUSART_FRAMECFG_DATABITS_SEVEN;
    717          #if defined(_SILICON_LABS_32B_SERIES_2)
    718            eusartSpiInit.databits = (EUSART_Databits_TypeDef)databits;
    719            if (initData->type == spidrvMaster) {
    720              // Don't assume EUSART_SPI_ADVANCED_INIT_DEFAULT has desired autoCsEnable
    721              eusartAdvancedSpiInit.autoCsEnable = (initData->csControl == spidrvCsControlAuto);
    722            }
    723            if ((retVal = ConfigGPIO(handle, true)) != ECODE_EMDRV_SPIDRV_OK) {
    724              return retVal;
    725            }
    726            EUSART_SpiInit(initData->port, &eusartSpiInit);
    727          #else /* Series 3 and above */
    728            eusartSpiInit.data_bits = (sl_hal_eusart_data_bits_t)databits;
    729            if (initData->type == spidrvMaster) {
    730              // Don't assume EUSART_SPI_ADVANCED_INIT_DEFAULT has desired autoCsEnable
    731              eusartAdvancedSpiInit.auto_cs_enable = (initData->csControl == spidrvCsControlAuto);
    732            }
    733            if ((retVal = ConfigGPIO(handle, true)) != ECODE_EMDRV_SPIDRV_OK) {
    734              return retVal;
    735            }
    736            sl_hal_eusart_init_spi(initData->port, &eusartSpiInit);
    737            sl_hal_eusart_enable(initData->port);
    738            sl_hal_eusart_enable_rx(initData->port);
    739            sl_hal_eusart_enable_tx(initData->port);
    740            sl_hal_eusart_wait_sync(initData->port, _EUSART_SYNCBUSY_MASK);
    741          #endif
    742          
    743            // Common GPIO EUSARTROUTE configuration for both series
    744            GPIO->EUSARTROUTE[spiPortNum].TXROUTE = ((uint32_t)initData->portTx
    745                                                     << _GPIO_EUSART_TXROUTE_PORT_SHIFT)
    746                                                    | ((uint32_t)initData->pinTx
    747                                                       << _GPIO_EUSART_TXROUTE_PIN_SHIFT);
    748            GPIO->EUSARTROUTE[spiPortNum].RXROUTE = ((uint32_t)initData->portRx
    749                                                     << _GPIO_EUSART_RXROUTE_PORT_SHIFT)
    750                                                    | ((uint32_t)initData->pinRx
    751                                                       << _GPIO_EUSART_RXROUTE_PIN_SHIFT);
    752            GPIO->EUSARTROUTE[spiPortNum].SCLKROUTE = ((uint32_t)initData->portClk
    753                                                       << _GPIO_EUSART_SCLKROUTE_PORT_SHIFT)
    754                                                      | ((uint32_t)initData->pinClk
    755                                                         << _GPIO_EUSART_SCLKROUTE_PIN_SHIFT);
    756            GPIO->EUSARTROUTE[spiPortNum].ROUTEEN = GPIO_EUSART_ROUTEEN_TXPEN
    757                                                    | GPIO_EUSART_ROUTEEN_RXPEN
    758                                                    | GPIO_EUSART_ROUTEEN_SCLKPEN;
    759            if (initData->csControl == spidrvCsControlAuto) {
    760              // SPI 4 wire mode, Chip Select controlled by the peripheral
    761              GPIO->EUSARTROUTE[spiPortNum].CSROUTE = ((uint32_t)initData->portCs << _GPIO_EUSART_CSROUTE_PORT_SHIFT)
    762                                                      | ((uint32_t)initData->pinCs << _GPIO_EUSART_CSROUTE_PIN_SHIFT);
    763              GPIO->EUSARTROUTE_SET[spiPortNum].ROUTEEN = GPIO_EUSART_ROUTEEN_CSPEN;
    764            }
    765          
    766            CORE_DECLARE_IRQ_STATE;
    767            CORE_ENTER_ATOMIC();
    768            if (!spidrvIsInitialized) {
    769              spidrvIsInitialized = true;
    770              CORE_EXIT_ATOMIC();
    771          
    772          #if defined(EMDRV_SPIDRV_INCLUDE_SLAVE)
    773              sl_sleeptimer_init();
    774          #endif
    775            } else {
    776              CORE_EXIT_ATOMIC();
    777            }
    778          
    779            return SPIDRV_initializeDma(handle);
    780          }
    781          #endif  // defined(EUSART_PRESENT)
    782          
    783          /***************************************************************************//**
    784           * @brief
    785           *    Deinitialize an SPI driver instance.
    786           *
    787           * @warning
    788           *  This function should only be called with an initialized spidrv instance handle.
    789           *
    790           * @param[in] handle Pointer to an SPI driver handle.
    791           *
    792           * @return
    793           *    @ref ECODE_EMDRV_SPIDRV_OK on success. On failure, an appropriate
    794           *    SPIDRV @ref Ecode_t is returned.
    795           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    796          Ecode_t SPIDRV_DeInit(SPIDRV_Handle_t handle)
    797          {
   \                     SPIDRV_DeInit: (+1)
   \        0x0   0xB5F8             PUSH     {R3-R7,LR}
   \        0x2   0x4604             MOV      R4,R0
    798            sl_bus_clock_t bus_clock;
    799          #if defined(USART_PRESENT)
    800            int8_t USART_spiPortNum = -1;
    801          #endif
    802          
    803          #if defined(EUSART_PRESENT)
    804            int8_t EUSART_spiPortNum = -1;
    805          #endif
    806          
    807            if (0) {
    808            }
    809          #if defined(USART_PRESENT)
    810            else if (handle->peripheralType == spidrvPeripheralTypeUsart) {
   \        0x4   0xF894 0x0084      LDRB     R0,[R4, #+132]
   \        0x8   0x.... 0x....      LDR.W    R5,??DataTable29_16
   \        0xC   0xB948             CBNZ.N   R0,??SPIDRV_DeInit_0
    811          #if (USART_COUNT == 1) && !defined(USART_NUM)
    812              USART_spiPortNum = 0;
    813          #else
    814              USART_spiPortNum = USART_NUM((USART_TypeDef*)handle->peripheral.usartPort);
   \        0xE   0x6820             LDR      R0,[R4, #+0]
   \       0x10   0x.... 0x....      LDR.W    R1,??DataTable29_2
   \       0x14   0x4288             CMP      R0,R1
   \       0x16   0xD108             BNE.N    ??SPIDRV_DeInit_1
   \       0x18   0x2000             MOVS     R0,#+0
   \                     ??SPIDRV_DeInit_2: (+1)
   \       0x1A   0x.... 0x....      LDR.W    R1,??DataTable29_3
   \       0x1E   0xEB01 0x1540      ADD      R5,R1,R0, LSL #+5
    815          #endif
    816              if (USART_spiPortNum == -1) {
    817                return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    818              }
    819            }
    820          #endif
    821          #if defined (EUSART_PRESENT)
    822            else if (handle->peripheralType == spidrvPeripheralTypeEusart) {
    823          #if (EUSART_COUNT == 1) && !defined(EUSART_NUM)
    824              EUSART_spiPortNum = 0;
    825          #else
    826              EUSART_spiPortNum = EUSART_NUM((EUSART_TypeDef*)handle->peripheral.eusartPort);
    827          #endif
    828              if (EUSART_spiPortNum == -1) {
    829                return ECODE_EMDRV_SPIDRV_PARAM_ERROR;
    830              }
    831            }
    832          #endif
