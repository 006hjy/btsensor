    187          #endif
    188          
    189          static void emRequestDeinit(UARTDRV_Handle_t handle)
    190          {
    191          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT)
    192            CORE_DECLARE_IRQ_STATE;
    193            sl_status_t status;
    194            bool running;
    195          
    196            CORE_ENTER_ATOMIC();
    197            status = sl_sleeptimer_is_timer_running(&handle->delayedTxTimer, &running);
    198            if ((status == SL_STATUS_OK) && running) {
    199              sl_sleeptimer_stop_timer(&handle->delayedTxTimer);
    200            }
    201            CORE_EXIT_ATOMIC();
    202          #endif
    203            if (handle->em1RequestCount > 0) {
    204              handle->em1RequestCount = 1;
    205              em1RequestRemove(handle);
    206            }
    207          }
