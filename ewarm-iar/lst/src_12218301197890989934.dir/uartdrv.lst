   2009          /***************************************************************************//**
   2010           * @brief Stop tx DMA transfers
   2011           ******************************************************************************/
   2012          __STATIC_INLINE void AbortTxDmaTransfers(UARTDRV_Handle_t handle)
   2013          {
   2014            UARTDRV_Buffer_t *txBuffer;
   2015          
   2016            // Get bytes completed from the DMA channel before aborting
   2017            sl_dma_channel_status_t dmaStatus;
   2018            sl_dma_channel_get_status(&handle->txDmaCh, &dmaStatus);
   2019          
   2020            // Mark DMA as inactive before aborting so that if sl_dma_channel_abort
   2021            // invokes TransmitDmaComplete for a transfer that completed between the
   2022            // critical section entry and the channel disable, the callback detects
   2023            // the abort-in-progress state and returns early.
   2024            handle->txDmaActive = false;
   2025          
   2026            // Abort the DMA channel and clean up its descriptor queue
   2027            sl_dma_channel_abort(&handle->txDmaCh);
   2028          
   2029            if (handle->txQueue->used > 0) {
   2030              // Update the transfer status of the active transfer
   2031              GetTailBuffer(handle->txQueue, &txBuffer);
   2032              txBuffer->itemsRemaining = txBuffer->transferCount - dmaStatus.bytes_completed;
   2033              txBuffer->transferStatus = ECODE_EMDRV_UARTDRV_ABORTED;
   2034          
   2035              // Dequeue all transfers and call callback
   2036              while (handle->txQueue->used > 0) {
   2037                DequeueBuffer(handle->txQueue, &txBuffer);
   2038          
   2039                // Call the callback with ABORTED error code
   2040                if (txBuffer->callback != NULL) {
   2041                  txBuffer->callback(handle,
   2042                                     ECODE_EMDRV_UARTDRV_ABORTED,
   2043                                     txBuffer->data,
   2044                                     txBuffer->transferCount - txBuffer->itemsRemaining
   2045                                     #if defined(UARTDRV_USER_SPECIFIED_CALLBACK_ENABLE) \
   2046                                     && (UARTDRV_USER_SPECIFIED_CALLBACK_ENABLE == 1)
   2047                                     , txBuffer->userParam
   2048                                     #endif
   2049                                     );
   2050                }
   2051              }
   2052            }
   2053          
   2054            while (!(UARTDRV_GetPeripheralStatus(handle) & UARTDRV_STATUS_TXIDLE)) {
   2055              // Wait for peripheral to finish cleaning up, to prevent framing errors
   2056              // on subsequent transfers
   2057            }
   2058          
   2059            if (handle->em1RequestCount > 0) {
   2060              em1RequestRemove(handle);
   2061            }
   2062          }
   2063          
