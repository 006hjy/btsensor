     99          #define uartdrv_eusart_enable(eusart, enable) do { if (enable == UARTDRV_EUSART_DISABLE)                                                                \
    100                                                             { sl_hal_eusart_disable(eusart); }                                                                   \
    101                                                             else if (enable == UARTDRV_EUSART_ENABLE_RX)                                                         \
    102                                                             { sl_hal_eusart_enable(eusart); sl_hal_eusart_enable_rx(eusart); sl_hal_eusart_disable_tx(eusart); } \
