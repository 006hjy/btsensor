    459          #endif
    460              // Disable Tx
    461              handle->peripheral.uart->CMD = USART_CMD_TXDIS;
    462            }
    463          #endif  // UART || USART
    464          #if defined(LEUART_COUNT) && (LEUART_COUNT > 0) && !defined(_SILICON_LABS_32B_SERIES_2)
    465            else if (handle->type == uartdrvUartTypeLeuart) {
