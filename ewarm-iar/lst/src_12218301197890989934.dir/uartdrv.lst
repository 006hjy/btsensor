    488          #elif defined(EUSART_PRESENT)
    489              GPIO->EUSARTROUTE_CLR[handle->uartNum].ROUTEEN = GPIO_EUSART_ROUTEEN_TXPEN;
    490          #endif
    491            }
    492          #endif
    493          }
