    478            }
    479          #elif (defined(EUART_COUNT) && (EUART_COUNT > 0)) || (defined(EUSART_COUNT) && (EUSART_COUNT > 0))
    480            else if (handle->type == uartdrvUartTypeEuart) {
    481              if (uartdrv_eusart_get_status(handle->peripheral.euart) &  EUSART_STATUS_RXENS) {
