    259          /*******************************************************************************
    260           * Computes difference between two times taking into account timer wrap-around.
    261           *
    262           * @param a Time.
    263           * @param b Time to substract from a.
    264           *
    265           * @return Time difference.
    266           ******************************************************************************/
    267          __STATIC_INLINE uint32_t get_time_diff(uint32_t a,
    268                                                 uint32_t b)
    269          {
    270            return (a - b);
    271          }
