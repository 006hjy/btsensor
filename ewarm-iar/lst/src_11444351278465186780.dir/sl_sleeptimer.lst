   1781          
   1782          /*******************************************************************************
   1783           * Compute the day of the year. This function assumes that the inputs are properly
   1784           * sanitized.
   1785           *
   1786           * @param month Number of months since January.
   1787           * @param day Day of the month
   1788           * @param is_leap_year Specifies if the year computed against is a leap year.
   1789           *
   1790           * @return the number of days since the beginning of the year
   1791           ******************************************************************************/
   1792          static uint16_t compute_day_of_year(sl_sleeptimer_month_t month, uint8_t day, bool is_leap_year)
   1793          {
   1794            uint8_t i;
   1795            uint16_t dayOfYear = 0;
   1796          
   1797            for (i = 0; i < month; ++i) {
   1798              dayOfYear += days_in_month[is_leap_year][i];
   1799            }
   1800            dayOfYear += day;
   1801          
   1802            return dayOfYear;
   1803          }
   1804          
   1805          /*******************************************************************************
   1806           * Checks if the year is a leap year.
   1807           *
   1808           * @param year Year to check.
   1809           *
   1810           * @return true if the year is a leap year. False otherwise.
   1811           ******************************************************************************/
   1812          static bool is_leap_year(uint16_t year)
   1813          {
   1814            // 1900 is not a leap year but 0 % anything is 0.
   1815            if (year == 0) {
   1816              return false;
   1817            }
   1818          
   1819            bool leap_year;
   1820          
   1821            leap_year = (((year %   4u) == 0u)
   1822                         && (((year % 100u) != 0u) || ((year % 400u) == 0u))) ? true : false;
   1823          
   1824            return (leap_year);
   1825          }
   1826          
   1827          /*******************************************************************************
   1828           * Checks if the time stamp, format and time zone are
   1829           *  within the supported range.
   1830           *
   1831           * @param base_year Year to start from to compute leap days.
   1832           * @param current_year Year end at for computing leap days.
   1833           *
   1834           * @return leap_days Days number of leap days between base_year and current_year.
   1835           ******************************************************************************/
   1836          static uint16_t number_of_leap_days(uint32_t base_year, uint32_t current_year)
   1837          {
   1838            // Regular leap years
   1839            uint16_t lo_reg = (base_year - 0) / 4;
   1840            uint16_t hi_reg = (current_year - 1) / 4;
   1841            uint16_t leap_days = hi_reg - lo_reg;
   1842          
   1843            // Account for non leap years
   1844            uint16_t lo_century = (base_year - 0) / 100;
   1845            uint16_t hi_century = (current_year - 1) / 100;
   1846            leap_days -= hi_century - lo_century;
   1847          
   1848            // Account for quad century leap years
   1849            uint16_t lo_quad = (base_year - 0) / 400;
   1850            uint16_t hi_quad = (current_year - 1) / 400;
   1851            leap_days += hi_quad - lo_quad;
   1852          
   1853            return (leap_days);
   1854          }
   1855          
   1856          /*******************************************************************************
   1857           * Checks if the time stamp, format and time zone are
   1858           *  within the supported range.
   1859           *
   1860           * @param time Time stamp to check.
   1861           * @param format Format of the time.
   1862           * @param time_zone Time zone offset in second.
   1863           *
   1864           * @return true if the time is valid. False otherwise.
   1865           ******************************************************************************/
   1866          static bool is_valid_time(sl_sleeptimer_timestamp_t time,
   1867                                    sl_sleeptimer_time_format_t format,
   1868                                    sl_sleeptimer_time_zone_offset_t time_zone)
   1869          {
   1870            bool valid_time = false;
   1871          
   1872            // Check for overflow.
   1873            if ((time_zone < 0 && time > (uint32_t)abs(time_zone)) \
   1874                || (time_zone >= 0 && (time <= UINT32_MAX - time_zone))) {
   1875              valid_time = true;
   1876            }
   1877            if (format == TIME_FORMAT_UNIX) {
   1878              if (time > TIME_UNIX_TIMESTAMP_MAX) { // Check if Unix time stamp is an unsigned 31 bits.
   1879                valid_time = false;
   1880              }
   1881            } else {
   1882              if ((format == TIME_FORMAT_NTP) && (time >= TIME_NTP_EPOCH_OFFSET_SEC)) {
   1883                valid_time &= true;
   1884              } else if ((format == TIME_FORMAT_ZIGBEE_CLUSTER) && (time <= TIME_UNIX_TIMESTAMP_MAX - TIME_ZIGBEE_EPOCH_OFFSET_SEC)) {
   1885                valid_time &= true;
   1886              } else {
   1887                valid_time = false;
   1888              }
   1889            }
   1890            return valid_time;
   1891          }
   1892          
   1893          /*******************************************************************************
   1894           * Checks if the time stamp, format and time zone are
   1895           *  within the supported range.
   1896           *
   1897           * @param time Time stamp to check.
   1898           * @param format Format of the time.
   1899           * @param time_zone Time zone offset in second.
   1900           *
   1901           * @return true if the time is valid. False otherwise.
   1902           ******************************************************************************/
   1903          static bool is_valid_time_64(sl_sleeptimer_timestamp_64_t time,
   1904                                       sl_sleeptimer_time_format_t format,
   1905                                       sl_sleeptimer_time_zone_offset_t time_zone)
   1906          {
   1907            bool valid_time = false;
   1908          
   1909            // Check for overflow.
   1910            if ((time_zone < 0 && time > (uint64_t)abs(time_zone))
   1911                || (time_zone >= 0 && (time <= UINT64_MAX - time_zone))) {
   1912              valid_time = true;
   1913            }
   1914            if (format == TIME_FORMAT_UNIX_64_BIT) {
   1915              if (time > TIME_64_BIT_UNIX_TIMESTAMP_MAX) { // Check if time stamp is an unsigned 64 bits.
   1916                valid_time = false;
   1917              }
   1918            }
   1919            return valid_time;
   1920          }
   1921          
   1922          /*******************************************************************************
   1923           * Checks if the date is valid.
   1924           *
   1925           * @param date Date to check.
   1926           *
   1927           * @return true if the date is valid. False otherwise.
   1928           ******************************************************************************/
   1929          static bool is_valid_date(sl_sleeptimer_date_t *date)
   1930          {
   1931            if ((date == NULL)
   1932                || (date->year > TIME_UNIX_YEAR_MAX)
   1933                || (date->month > MONTH_DECEMBER)
   1934                || (date->month_day == 0 || date->month_day > days_in_month[is_leap_year(date->year)][date->month])
   1935                || (date->hour > 23)
   1936                || (date->min > 59)
   1937                || (date->sec > 59)) {
   1938              return false;
   1939            }
   1940          
   1941            // Unix is valid until the 19th of January 2038 at 03:14:07
   1942            if (date->year == TIME_UNIX_YEAR_MAX) {
   1943              if ((uint8_t)date->month > (uint8_t)MONTH_JANUARY) {
   1944                return false;
   1945              } else if (date->month_day > 19) {
   1946                return false;
   1947              } else if (date->hour > 3) {
   1948                return false;
   1949              } else if (date->min > 14) {
   1950                return false;
   1951              } else if (date->sec > 7) {
   1952                return false;
   1953              }
   1954            }
   1955          
   1956            return true;
   1957          }
   1958          
   1959          /*******************************************************************************
