    723          #if SL_SLEEPTIMER_WALLCLOCK_CONFIG
    724          /***************************************************************************//**
    725           * Retrieves current 32 bit time.
    726           ******************************************************************************/
    727          sl_sleeptimer_timestamp_t sl_sleeptimer_get_time(void)
    728          {
    729            uint64_t temp_time = sl_sleeptimer_get_time_64();
    730            // Add offset for 64 to 32 bit time
    731            if (temp_time >= TIME_64_TO_32_EPOCH_OFFSET_SEC) {
    732              temp_time -= TIME_64_TO_32_EPOCH_OFFSET_SEC;
    733            }
    734            // Return lower 32 bits of 64 bit time
    735            uint32_t time = (temp_time & 0xFFFFFFFF);
    736          
    737            return time;
    738          }
    739          
    740          /***************************************************************************//**
    741           * Retrieves current 64 bit time.
    742           ******************************************************************************/
    743          sl_sleeptimer_timestamp_64_t sl_sleeptimer_get_time_64(void)
    744          {
    745            uint32_t cnt = 0u;
    746            uint32_t freq = 0u;
    747            sl_sleeptimer_timestamp_64_t time;
    748            CORE_DECLARE_IRQ_STATE;
    749          
    750            cnt = sleeptimer_hal_get_counter();
    751            freq = sl_sleeptimer_get_timer_frequency();
    752          
    753            CORE_ENTER_ATOMIC();
    754            time = second_count + cnt / freq;
    755          
    756            if (cnt % freq + overflow_tick_rest >= freq) {
    757              time++;
    758            }
    759            CORE_EXIT_ATOMIC();
    760          
    761            return time;
    762          }
    763          
    764          /***************************************************************************//**
    765           * Sets current time from 32 bit variable.
    766           ******************************************************************************/
    767          sl_status_t sl_sleeptimer_set_time(sl_sleeptimer_timestamp_t time)
    768          {
    769            // convert 32 bit time to 64 bit time
    770            uint64_t temp_time = time + (uint64_t)TIME_64_TO_32_EPOCH_OFFSET_SEC;
    771            sl_status_t err_code = sl_sleeptimer_set_time_64(temp_time);
    772            return err_code;
    773          }
    774          
    775          /***************************************************************************//**
    776           * Sets current time from 64 bit variable.
    777           ******************************************************************************/
    778          sl_status_t sl_sleeptimer_set_time_64(sl_sleeptimer_timestamp_64_t time)
    779          {
    780            uint32_t freq = 0u;
    781            uint32_t counter_sec = 0u;
    782            uint32_t cnt = 0;
    783            CORE_DECLARE_IRQ_STATE;
    784          
    785            // convert 64 bit time to 32 bit time
    786            if (!is_valid_time_64(time, TIME_FORMAT_UNIX_64_BIT, 0u)) {
    787              return SL_STATUS_INVALID_PARAMETER;
    788            }
    789          
    790            freq = sl_sleeptimer_get_timer_frequency();
    791            cnt = sleeptimer_hal_get_counter();
    792          
    793            CORE_ENTER_ATOMIC();
    794            // store 64 bit time as 64 bits's
    795            second_count = time;
    796          
    797            // Convert 64 bit time to 32 bit time in order to check for overflow
    798            // i.e. if 32 bit time is >=counter_sec
    799            uint64_t temp_time = second_count - TIME_64_TO_32_EPOCH_OFFSET_SEC;
    800            uint32_t second_time_32 = (temp_time & 0xFFFFFFFF);
    801          
    802            overflow_tick_rest = 0;
    803            counter_sec = cnt / freq;
    804          
    805            if (second_time_32 >= counter_sec) {
    806              second_count -= counter_sec;
    807            } else {
    808              CORE_EXIT_ATOMIC();
    809          
    810              return SL_STATUS_INVALID_PARAMETER;
    811            }
    812          
    813            CORE_EXIT_ATOMIC();
    814          
    815            return SL_STATUS_OK;
    816          }
    817          
    818          /***************************************************************************//**
    819           * Gets current date.
    820           ******************************************************************************/
    821          sl_status_t sl_sleeptimer_get_datetime(sl_sleeptimer_date_t *date)
    822          {
    823            sl_sleeptimer_timestamp_64_t time = 0u;
    824            sl_sleeptimer_time_zone_offset_t tz;
    825            sl_status_t err_code = SL_STATUS_OK;
    826          
    827            // Fetch 64 bit timestamp
    828            time = sl_sleeptimer_get_time_64();
    829            tz = sl_sleeptimer_get_tz();
    830            err_code = sl_sleeptimer_convert_time_to_date_64(time, tz, date);
    831          
    832            return err_code;
    833          }
    834          
    835          /***************************************************************************//**
    836           * Sets current time, in date format.
    837           ******************************************************************************/
    838          sl_status_t sl_sleeptimer_set_datetime(sl_sleeptimer_date_t *date)
    839          {
    840            sl_sleeptimer_timestamp_64_t time = 0u;
    841            sl_status_t err_code = SL_STATUS_OK;
    842            CORE_DECLARE_IRQ_STATE;
    843          
    844            if (!is_valid_date_64(date)) {
    845              return SL_STATUS_INVALID_PARAMETER;
    846            }
    847          
    848            err_code = sl_sleeptimer_convert_date_to_time_64(date, &time);
    849            if (err_code != SL_STATUS_OK) {
    850              return err_code;
    851            }
    852          
    853            CORE_ENTER_ATOMIC();
    854            // sets the 64 bit second_time value
    855            err_code = sl_sleeptimer_set_time_64(time);
    856            if (err_code == SL_STATUS_OK) {
    857              sl_sleeptimer_set_tz(date->time_zone);
    858            }
    859            CORE_EXIT_ATOMIC();
    860          
    861            return err_code;
    862          }
    863          
    864          /***************************************************************************//**
    865           * Builds a date time structure based on the provided parameters.
    866           ******************************************************************************/
    867          sl_status_t sl_sleeptimer_build_datetime(sl_sleeptimer_date_t *date,
    868                                                   uint16_t year,
    869                                                   sl_sleeptimer_month_t month,
    870                                                   uint8_t month_day,
    871                                                   uint8_t hour,
    872                                                   uint8_t min,
    873                                                   uint8_t sec,
    874                                                   sl_sleeptimer_time_zone_offset_t tz_offset)
    875          {
    876            if (date == NULL) {
    877              return SL_STATUS_NULL_POINTER;
    878            }
    879          
    880            // If year is smaller than 1900, assume NTP Epoch is used.
    881            date->year = ((year < TIME_NTP_EPOCH) ? year : (year - TIME_NTP_EPOCH));
    882            date->month = month;
    883            date->month_day = month_day;
    884            date->hour = hour;
    885            date->min = min;
    886            date->sec = sec;
    887            date->time_zone = tz_offset;
    888          
    889            // Validate that input parameters are correct before filing the missing fields
    890            if (!is_valid_date(date)) {
    891              return SL_STATUS_INVALID_PARAMETER;
    892            }
    893          
    894            date->day_of_year = compute_day_of_year(date->month, date->month_day, is_leap_year(date->year));
    895            date->day_of_week = compute_day_of_week(((date->year - TIME_NTP_UNIX_EPOCH_DIFF)  * TIME_DAY_PER_YEAR)
    896                                                    + number_of_leap_days(TIME_UNIX_EPOCH, (date->year + TIME_NTP_EPOCH))
    897                                                    + date->day_of_year - 1);
    898          
    899            return SL_STATUS_OK;
    900          }
    901          
    902          /***************************************************************************//**
    903           * Builds a date time structure based on the provided parameters.
    904           ******************************************************************************/
    905          sl_status_t sl_sleeptimer_build_datetime_64(sl_sleeptimer_date_t *date,
    906                                                      uint16_t year,
    907                                                      sl_sleeptimer_month_t month,
    908                                                      uint8_t month_day,
    909                                                      uint8_t hour,
    910                                                      uint8_t min,
    911                                                      uint8_t sec,
    912                                                      sl_sleeptimer_time_zone_offset_t tz_offset)
    913          {
    914            if (date == NULL) {
    915              return SL_STATUS_NULL_POINTER;
    916            }
    917          
    918            // Ensure that year is greater than 1900 and based on 0 epoch
    919            if (year < TIME_NTP_EPOCH) {
    920              return SL_STATUS_INVALID_PARAMETER;
    921            }
    922          
    923            // Convert year based on 0 epoch to a valid date->year based on 1900 epoch
    924            date->year = (year - TIME_NTP_EPOCH);
    925            date->month = month;
    926            date->month_day = month_day;
    927            date->hour = hour;
    928            date->min = min;
    929            date->sec = sec;
    930            date->time_zone = tz_offset;
    931          
    932            // Validate that input parameters are correct before filing the missing fields
    933            if (!is_valid_date_64(date)) {
    934              return SL_STATUS_INVALID_PARAMETER;
    935            }
    936          
    937            date->day_of_year = compute_day_of_year(date->month, date->month_day, is_leap_year(date->year));
    938            date->day_of_week = compute_day_of_week_64((date->year * TIME_DAY_PER_YEAR)
    939                                                       + number_of_leap_days(TIME_NTP_EPOCH, (date->year + TIME_NTP_EPOCH))
    940                                                       + date->day_of_year - 1);
    941          
    942            return SL_STATUS_OK;
    943          }
    944          
    945          /*******************************************************************************
    946           * Convert a 32 bit time stamp into a date structure.
    947           ******************************************************************************/
    948          sl_status_t sl_sleeptimer_convert_time_to_date(sl_sleeptimer_timestamp_t time,
    949                                                         sl_sleeptimer_time_zone_offset_t time_zone,
    950                                                         sl_sleeptimer_date_t *date)
    951          {
    952            // convert 32 bit timestamp to 64 bit
    953            sl_sleeptimer_timestamp_64_t temp_time = (uint64_t)time + TIME_64_TO_32_EPOCH_OFFSET_SEC;
    954            sl_status_t err_code = sl_sleeptimer_convert_time_to_date_64(temp_time, time_zone, date);
    955            return err_code;
    956          }
    957          
    958          /*******************************************************************************
    959           * Convert a 64 bit time stamp into a date structure.
    960           ******************************************************************************/
    961          sl_status_t sl_sleeptimer_convert_time_to_date_64(sl_sleeptimer_timestamp_64_t time,
    962                                                            sl_sleeptimer_time_zone_offset_t time_zone,
    963                                                            sl_sleeptimer_date_t *date)
    964          {
    965            uint16_t full_year = 0;
    966            uint16_t leap_day = 0;
    967            uint8_t leap_year_flag = 0;
    968            uint8_t current_month = 0;
    969          
    970            if (!is_valid_time_64(time, TIME_FORMAT_UNIX_64_BIT, time_zone)) {
    971              return SL_STATUS_INVALID_PARAMETER;
    972            }
    973          
    974            time += time_zone;  // add UTC offset to convert to Standard Time
    975            date->sec = time % 60;
    976            time /= 60;
    977            date->min = time % 60;
    978            time /= 60;
    979            date->hour = time % 24;
    980            time /= 24; // time is now the number of days since 1900
    981          
    982            date->day_of_week = (sl_sleeptimer_weekDay_t)compute_day_of_week_64(time);
    983          
    984            full_year = time / TIME_DAY_PER_YEAR; // Approximates the number of full years
    985            uint32_t base_year = 1900u;
    986            uint32_t current_year = full_year + base_year;
    987          
    988            if (full_year > 4) { // 1904 is the first leap year since 1900
    989              leap_day = number_of_leap_days(base_year, current_year);  // Approximates the number of leap days.
    990              full_year = (time - leap_day) / TIME_DAY_PER_YEAR; // Computes the number of year integrating the leap days.
    991              current_year = full_year + base_year;
    992              leap_day = number_of_leap_days(base_year, current_year); // Computes the actual number of leap days of the previous years.
    993            }
    994            date->year = full_year; // Year in date struct must be based on a 1900 epoch.
    995            if (is_leap_year(date->year)) {
    996              leap_year_flag = 1;
    997            }
    998          
    999            time = (time - leap_day) - (TIME_DAY_PER_YEAR * full_year);  // Subtracts days of previous year.
   1000            date->day_of_year = time + 1;
   1001          
   1002            while (time >= days_in_month[leap_year_flag][current_month]) {
   1003              time -= days_in_month[leap_year_flag][current_month]; // Subtracts the number of days of the passed month.
   1004              current_month++;
   1005            }
   1006            date->month = (sl_sleeptimer_month_t)current_month;
   1007            date->month_day = time + 1;
   1008            date->time_zone = time_zone;
   1009          
   1010            return SL_STATUS_OK;
   1011          }
   1012          
   1013          /*******************************************************************************
   1014           * Convert a date structure into a 32 bit time stamp.
   1015           ******************************************************************************/
   1016          sl_status_t sl_sleeptimer_convert_date_to_time(sl_sleeptimer_date_t *date,
   1017                                                         sl_sleeptimer_timestamp_t *time)
   1018          {
   1019            // Create a 64 bit time stamp
   1020            sl_sleeptimer_timestamp_64_t temp_time =  0;
   1021            sl_status_t err_code = sl_sleeptimer_convert_date_to_time_64(date, &temp_time);
   1022          
   1023            if (err_code != SL_STATUS_OK) {
   1024              return err_code;
   1025            }
   1026            // Convert 64 bit time to 32 bit time
   1027          
   1028            sl_sleeptimer_timestamp_64_t time_32 = temp_time;
   1029            time_32 -= TIME_64_TO_32_EPOCH_OFFSET_SEC;
   1030            *time = (time_32 & 0xFFFFFFFF);
   1031          
   1032            return err_code;
   1033          }
   1034          
   1035          /*******************************************************************************
   1036           * Convert a date structure into a 64 bit time stamp.
   1037           ******************************************************************************/
   1038          sl_status_t sl_sleeptimer_convert_date_to_time_64(sl_sleeptimer_date_t *date,
   1039                                                            sl_sleeptimer_timestamp_64_t *time)
   1040          {
   1041            uint16_t month_days = 0;
   1042            uint8_t  month;
   1043            uint16_t  full_year = 0;
   1044            uint8_t  leap_year_flag = 0;
   1045            uint16_t  leap_days = 0;
   1046          
   1047            if (!is_valid_date_64(date)) {
   1048              return SL_STATUS_INVALID_PARAMETER;
   1049            }
   1050          
   1051            full_year = (date->year);                                  // base year for 64 bits its 1900 not 1970
   1052            month = date->month;                              // offset to get months value from 1 to 12.
   1053          
   1054            uint32_t base_year = 1900u;
   1055            uint32_t current_year = full_year + base_year;
   1056          
   1057            *time = (full_year * (uint64_t)TIME_SEC_PER_YEAR);
   1058          
   1059            if (full_year > 4) {                                       // 1904 is the first leap year since 1900
   1060              leap_days = number_of_leap_days(base_year, current_year);
   1061              month_days = leap_days;
   1062            }
   1063          
   1064            if (is_leap_year(date->year)) {
   1065              leap_year_flag = 1;
   1066            }
   1067          
   1068            for (int i = 0; i < month; i++) {
   1069              month_days += days_in_month[leap_year_flag][i];         // Add the number of days of the month of the year.
   1070            }
   1071          
   1072            month_days += (date->month_day - 1);                       // Add full days of the current month.
   1073            *time += month_days * TIME_SEC_PER_DAY;
   1074            *time += (3600 * date->hour) + (60 * date->min) + date->sec;
   1075            *time -= date->time_zone;
   1076          
   1077            return SL_STATUS_OK;
   1078          }
   1079          
   1080          /*******************************************************************************
   1081           * Convert a date structure to string.
   1082           ******************************************************************************/
   1083          uint32_t sl_sleeptimer_convert_date_to_str(char *str,
   1084                                                     size_t size,
   1085                                                     const uint8_t *format,
   1086                                                     sl_sleeptimer_date_t *date)
   1087          {
   1088            uint32_t  return_size = 0u;
   1089            if (is_valid_date(date)) {
   1090              struct tm date_struct;
   1091          
   1092              date_struct.tm_hour = date->hour;
   1093              date_struct.tm_mday = date->month_day;
   1094              date_struct.tm_min = date->min;
   1095              date_struct.tm_mon = date->month;
   1096              date_struct.tm_sec = date->sec;
   1097              date_struct.tm_wday = date->day_of_week;
   1098              date_struct.tm_yday = date->day_of_year;
   1099              date_struct.tm_year = date->year;
   1100          
   1101              return_size = strftime(str,
   1102                                     size,
   1103                                     (const char *)format,
   1104                                     &date_struct);
   1105            }
   1106          
   1107            return return_size;
   1108          }
