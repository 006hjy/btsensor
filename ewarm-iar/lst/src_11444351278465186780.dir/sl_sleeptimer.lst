   1141          /***************************************************************************//**
   1142           * Converts Unix 32 timestamp into NTP timestamp.
   1143           ******************************************************************************/
   1144          sl_status_t sl_sleeptimer_convert_unix_time_to_ntp(sl_sleeptimer_timestamp_t time,
   1145                                                             uint32_t *ntp_time)
   1146          {
   1147            if (time > TIME_UNIX_TO_NTP_MAX) {
   1148              // Maximum Unix timestamp that can be converted to NTP is 2085978495
   1149              return SL_STATUS_INVALID_PARAMETER;
   1150            }
   1151          
   1152            uint32_t temp_ntp_time;
   1153            temp_ntp_time = time + TIME_NTP_EPOCH_OFFSET_SEC;
   1154            if (!is_valid_time(temp_ntp_time, TIME_FORMAT_NTP, 0u)) {
   1155              return SL_STATUS_INVALID_PARAMETER;
   1156            } else {
   1157              *ntp_time = temp_ntp_time;
   1158              return SL_STATUS_OK;
   1159            }
   1160          }
   1161          
   1162          /***************************************************************************//**
   1163           * Converts NTP timestamp into Unix timestamp.
   1164           ******************************************************************************/
   1165          sl_status_t sl_sleeptimer_convert_ntp_time_to_unix(uint32_t ntp_time,
   1166                                                             sl_sleeptimer_timestamp_t *time)
   1167          {
   1168            uint32_t temp_time;
   1169            temp_time = ntp_time - TIME_NTP_EPOCH_OFFSET_SEC;
   1170            if (!is_valid_time(temp_time, TIME_FORMAT_UNIX, 0u)) {
   1171              return SL_STATUS_INVALID_PARAMETER;
   1172            } else {
   1173              *time = temp_time;
   1174              return SL_STATUS_OK;
   1175            }
   1176          }
