    107          static void adc_set_channel(uint8_t chanel)
    108          {
    109            IADC_SingleInput_t initSingleInput = IADC_SINGLEINPUT_DEFAULT;
    110            if (chanel == 0)
    111            {
    112              initSingleInput.posInput = IADC_INPUT_0_PORT_PIN;
    113              initSingleInput.negInput = iadcNegInputGnd;
    114              IADC_updateSingleInput(IADC0, &initSingleInput);
    115            }
    116            else
    117            {
    118              initSingleInput.posInput = IADC_INPUT_1_PORT_PIN;
    119              initSingleInput.negInput = iadcNegInputGnd;
    120              IADC_updateSingleInput(IADC0, &initSingleInput);
    121            }
    122          }
