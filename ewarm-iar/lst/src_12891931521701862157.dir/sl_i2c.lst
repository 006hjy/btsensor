   1563                      return SL_STATUS_NOT_FOUND;
   1564                    } else if (i2c_handle->event == SL_I2C_EVENT_DATA_NACK) {
   1565                      return SL_STATUS_ABORT;
   1566                    } else {
   1567                      i2c_handle->event = SL_I2C_EVENT_COMPLETED;
   1568                      return SL_STATUS_OK;
   1569                    }
   1570                  }
   1571                  break;
