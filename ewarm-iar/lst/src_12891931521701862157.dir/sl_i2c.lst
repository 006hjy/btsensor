   1525                case SL_I2C_STATE_SEND_DATA:
   1526                  if (i2c_handle->tx_offset < current_tx_len) {
   1527                    sl_hal_i2c_tx(i2c_base_addr, current_tx_buffer[i2c_handle->tx_offset++]);
   1528                    i2c_handle->state = SL_I2C_STATE_DATA_WAIT_FOR_ACK_OR_NACK;
   1529                  } else {
   1530                    // Current buffer complete
   1531                    if (!is_second_buffer) {
   1532                      // First buffer complete - switch to second buffer without STOP
   1533                      current_tx_buffer = tx_buffer2;
   1534                      current_tx_len = tx_len2;
   1535                      i2c_handle->tx_offset = 0;
   1536                      is_second_buffer = true;
