     41          /*******************************************************************************
     42          *******************************   DEFINES   ***********************************
     43          *******************************************************************************/
     44          /**
     45           * @brief Number of clock cycles for bus recovery.
     46           *
     47           * @note
     48           *   Set to 10 clock cycles to ensure the bus can be cleared effectively,
     49           *   allowing for proper recovery.
     50           *   This helps resume communication quickly without leaving the bus in a stalled state.
     51           */
     52          #define I2C_RECOVER_NUM_CLOCKS  10
     53          
     54          /**
     55           * @brief SCL hold time in microseconds.
     56           *
     57           * @note
     58           *   Set to 100 microseconds to ensure proper synchronization
     59           *   between leader and follower devices.
     60           *   This provides enough time for data processing on the SDA line
     61           *   and ensures reliable communication, even with slower devices.
     62           */
     63          #ifndef I2C_SCL_HOLD_TIME_US
     64          #define I2C_SCL_HOLD_TIME_US 100
     65          #endif
