   1432          
   1433          /***************************************************************************//**
   1434           * State machine for write-write operation in blocking I2C transfer.
   1435           *
   1436           * @details
   1437           *   Implements a blocking state machine for I2C write-write operations that
   1438           *   transmits two separate buffers consecutively in a single atomic I2C transaction.
   1439           *   The transaction format is: S+ADDR(W)+DATA1+DATA2+P.
   1440           *   This ensures atomicity and is primarily designed for I2CSPM compatibility.
   1441           *
   1442           * @param[in] i2c_handle  Pointer to the I2C handle structure.
   1443           * @param[in] tx_buffer1  Pointer to the first transmit buffer.
   1444           * @param[in] tx_len1     Number of bytes in the first buffer.
   1445           * @param[in] tx_buffer2  Pointer to the second transmit buffer.
   1446           * @param[in] tx_len2     Number of bytes in the second buffer.
   1447           * @param[in] timeout     Timeout duration in milliseconds (0 = no timeout).
   1448           *
   1449           * @return
   1450           *   SL_STATUS_OK on success, or appropriate error code on failure.
   1451           *
   1452           * @note
   1453           *   This function supports I2CSPM write_write compatibility, enabling seamless
   1454           *   migration from I2CSPM to I2C driver for applications requiring atomic
   1455           *   two-buffer write operations.
   1456           *   @deprecated This function will be removed when I2CSPM is deprecated.
   1457           ******************************************************************************/
   1458          static sl_status_t i2c_leader_mode_write_no_stop_blocking_state_machine(sl_i2c_handle_t *i2c_handle,
   1459                                                                                  const uint8_t *tx_buffer1,
   1460                                                                                  uint32_t tx_len1,
   1461                                                                                  const uint8_t *tx_buffer2,
   1462                                                                                  uint32_t tx_len2,
   1463                                                                                  uint32_t timeout)
   1464          {
   1465            uint32_t pending_irq;
   1466            I2C_TypeDef *i2c_base_addr = sl_device_peripheral_i2c_get_base_addr(i2c_handle->i2c_peripheral);
   1467          
   1468            i2c_handle->state = SL_I2C_STATE_SEND_START_AND_ADDR;
   1469          
   1470            uint16_t actual_follower_addr = (i2c_handle->follower_address << 1);
   1471            uint8_t first_addr_byte;
   1472            first_addr_byte = (actual_follower_addr & SL_I2C_7BIT_FOLLOWER_ADDRESS_MASK);
   1473          
   1474            uint32_t start_time = get_current_time_ms();
   1475          
   1476            // Local variables to track current buffer and state
   1477            const uint8_t *current_tx_buffer = tx_buffer1;
   1478            uint32_t current_tx_len = tx_len1;
   1479            bool is_second_buffer = false;
   1480          
   1481            while (true) {
   1482              if (timeout > 0 && (get_current_time_ms() - start_time >= timeout)) {
   1483                i2c_base_addr->CMD = I2C_CMD_ABORT;
   1484                i2c_handle->event = SL_I2C_EVENT_TIMEOUT;
   1485                return SL_STATUS_TIMEOUT;
   1486              }
   1487          
   1488              pending_irq = sl_hal_i2c_get_enabled_pending_interrupts(i2c_base_addr);
   1489          
   1490              // Handle errors first - fastest path for error conditions
   1491              if (pending_irq & SL_HAL_I2C_IF_ERRORS) {
   1492                sl_hal_i2c_clear_interrupts(i2c_base_addr, _I2C_IF_MASK);
   1493                i2c_base_addr->CMD = I2C_CMD_ABORT;
   1494                i2c_handle->state = SL_I2C_STATE_ERROR;
   1495          
   1496                if (pending_irq & I2C_IF_ARBLOST) {
   1497                  i2c_handle->event = SL_I2C_EVENT_ARBITRATION_LOST;
   1498                  return SL_STATUS_TRANSMIT;
   1499                } else {
   1500                  i2c_handle->event = SL_I2C_EVENT_BUS_ERROR;
   1501                  return SL_STATUS_IO;
   1502                }
   1503              }
   1504          
   1505              switch (i2c_handle->state) {
   1506                case SL_I2C_STATE_SEND_START_AND_ADDR:
   1507                  sl_hal_i2c_start_cmd(i2c_base_addr);
   1508                  sl_hal_i2c_tx(i2c_base_addr, first_addr_byte);
   1509                  i2c_handle->state = SL_I2C_STATE_ADDR_WAIT_FOR_ACK_OR_NACK;
   1510                  i2c_handle->event = SL_I2C_EVENT_IN_PROGRESS;
   1511                  break;
   1512          
   1513                case SL_I2C_STATE_ADDR_WAIT_FOR_ACK_OR_NACK:
   1514                  if (pending_irq & I2C_IF_ACK) {
   1515                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_ACK);
   1516                    i2c_handle->state = SL_I2C_STATE_SEND_DATA;
   1517                  } else if (pending_irq & I2C_IF_NACK) {
   1518                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_NACK);
