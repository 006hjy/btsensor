   1542                    }
   1543                  }
   1544                  break;
   1545          
   1546                case SL_I2C_STATE_DATA_WAIT_FOR_ACK_OR_NACK:
   1547                  if (pending_irq & I2C_IF_ACK) {
   1548                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_ACK);
   1549                    i2c_handle->state = SL_I2C_STATE_SEND_DATA;
   1550                  } else if (pending_irq & I2C_IF_NACK) {
   1551                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_NACK);
   1552          
   1553                    sl_hal_i2c_stop_cmd(i2c_base_addr);
   1554                    i2c_handle->state = SL_I2C_STATE_SEND_STOP;
   1555                    i2c_handle->event = SL_I2C_EVENT_DATA_NACK;
   1556                  }
   1557                  break;
   1558          
   1559                case SL_I2C_STATE_SEND_STOP:
   1560                  if (pending_irq & I2C_IF_MSTOP) {
   1561                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_MSTOP);
