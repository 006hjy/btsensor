   \        0x4   0x....             LDR.N    R2,??DataTable2_3
   \        0x6   0x6001             STR      R1,[R0, #+0]
   \        0x8   0x6042             STR      R2,[R0, #+4]
    198          #endif
    199          
    200          #if defined(SL_CATALOG_MEMORY_MANAGER_ITCM_PRESENT) && !defined(SL_SE_MAILBOX_DISABLE)
    201            // ITCM is configured in 64 KB blocks (minimum 2 blocks = 128 KB).
    202            // Only DMEM beyond that hardware-rounded reservation is reclaimable.
    203          #if defined(__GNUC__)
    204            uintptr_t itcm_used     = (uintptr_t)&__itcm_used__;
    205          #elif defined(__ICCARM__)
    206            uintptr_t itcm_used     = (uintptr_t)__section_size(IAR_ITCM_BLOCK_NAME);
    207          #endif
    208            uintptr_t itcm_align    = SLI_ITCM_BLOCK_SIZE - 1u;
    209            uintptr_t itcm_reserved = (itcm_used + itcm_align) & ~itcm_align;
    210          
    211            // Ensure minimum fixed size of 128KB for ITCM.
    212            if (itcm_reserved < SLI_ITCM_MIN_RESERVED_SIZE) {
    213              itcm_reserved = SLI_ITCM_MIN_RESERVED_SIZE;
    214            }
    215          
    216            // Adjust size of DMEM general purpose heap given the ITCM real used size.
    217            sli_memory_heap_region.size -= (size_t)(itcm_reserved - SLI_ITCM_MIN_RESERVED_SIZE);
