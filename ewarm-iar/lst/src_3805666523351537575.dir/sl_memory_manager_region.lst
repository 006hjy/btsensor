    222          /***************************************************************************//**
    223           * Extends the process data space.
    224           *
    225           * @param[in]  incr   Number of bytes to increment/decrement
    226           *
    227           * @return Start of the new space allocated if successful. -1 if error.
    228           *
    229           * @note (1) This is a helper function called by the standard C library
    230           *           function malloc(). _sbrk() is used to dynamically change the
    231           *           amount of space allocated for the calling process data segment.
    232           *           The change is made by allocating the appropriate amount of space
    233           *           from the end of heap.
    234           *           _sbrk() adds 'incr' bytes to the end of heap and changes
    235           *           the allocated space accordingly. 'incr' can be negative, in which
    236           *           case the amount of allocated space is decreased.
    237           *
    238           * @note (2) When the Memory Manager (MM) is used, there is no need for
    239           *           _sbrk() as there is no possible extension with the MM controlling
    240           *           the entire heap size.
    241           *           If _sbrk() is called by the standard C library, then the project
    242           *           may have used the standard C malloc() function implementation.
    243           *           In that case, the MM retarget, wrapping the GCC malloc() to the
    244           *           MM sl_malloc(), may have not worked. You may want to double-check
    245           *           your project settings.
    246           ******************************************************************************/
    247          __USED __WEAK void * _sbrk(int incr)
    248          {
    249          #if defined(SL_CATALOG_MEMORY_MANAGER_PRESENT)
    250            (void)incr;
    251          
    252            // This means there is an issue with the setup of C standard library. See Note #2.
    253            while (1) {
