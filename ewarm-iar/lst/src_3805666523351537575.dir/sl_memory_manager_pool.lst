    412          
    413          #if (defined(SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE) && (SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE == 1))
    414          /***************************************************************************//**
    415           * Checks if a value looks like a valid free list pointer.
    416           * Used as a quick O(1) pre-check for double-free detection.
    417           *
    418           * A value looks like a free list pointer if it's either:
    419           * - The end-of-list marker (SLI_MEM_POOL_OUT_OF_MEMORY), OR
    420           * - A block-aligned address within the pool's memory range
    421           *
    422           * @param[in] pool_handle  Pointer to the memory pool handle.
    423           * @param[in] value        The value to check.
    424           *
    425           * @return true if value looks like it could be a free list pointer.
    426           ******************************************************************************/
    427          static inline bool value_looks_like_free_list_ptr(const sl_memory_pool_t *pool_handle,
    428                                                            size_t value)
    429          {
    430            // Check for end-of-list marker.
    431            if (value == SLI_MEM_POOL_OUT_OF_MEMORY) {
    432              return true;
    433            }
    434          
    435            // Check if it points within the pool's block range.
    436            size_t pool_start = (size_t)pool_handle->block_address;
    437            size_t pool_end = pool_start + (pool_handle->block_size * pool_handle->block_count);
    438          
    439            if ((value >= pool_start) && (value < pool_end)) {
    440              // Must be aligned to a block boundary.
    441              size_t offset = value - pool_start;
    442              return (offset % pool_handle->block_size) == 0;
    443            }
    444          
    445            return false;
    446          }
    447          
    448          /***************************************************************************//**
    449           * Checks if a block is in the free list by walking the list.
    450           * Used as O(n) verification when the quick check is suspicious.
    451           *
    452           * @param[in] pool_handle  Pointer to the memory pool handle.
    453           * @param[in] block        The block address to search for.
    454           *
    455           * @return true if block is found in the free list (already freed).
    456           *
    457           * @note Must be called within an atomic section.
    458           ******************************************************************************/
    459          static bool block_is_in_free_list(const sl_memory_pool_t *pool_handle,
    460                                            const void *block)
    461          {
    462            void *current = pool_handle->block_free;
    463          
    464            while ((size_t)current != SLI_MEM_POOL_OUT_OF_MEMORY) {
    465              if (current == block) {
    466                return true;
    467              }
    468          
    469              // Follow the free list to the next block.
    470              current = (void *)*(size_t *)current;
    471            }
    472          
    473            return false;
    474          }
    475          #endif // (defined(SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE) && (SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE == 1))

