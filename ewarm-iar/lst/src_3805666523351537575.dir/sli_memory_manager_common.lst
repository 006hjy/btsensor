    588          /***************************************************************************//**
    589           * Bookkeeps a reservation for profiling purposes.
    590           ******************************************************************************/
    591          sl_status_t sli_memory_save_reservation_handle(sl_memory_reservation_t *reservation_handle_ptr)
    592          {
    593            uint32_t reservation_ix = sli_get_available_reservation_handle_ix();
    594          
    595            if (reservation_ix != (uint32_t)-1) {
    596              sli_reservation_handle_ptr_table[reservation_ix] = reservation_handle_ptr;
    597              return SL_STATUS_OK;
    598            } else {
    599              return SL_STATUS_FULL;
    600            }
    601          }
    602          
    603          /***************************************************************************//**
    604           * Removes a reservation from records.
    605           ******************************************************************************/
    606          sl_status_t sli_memory_remove_reservation_handle(sl_memory_reservation_t *reservation_handle_ptr)
    607          {
    608            uint32_t reservation_ix = get_reservation_ix_by_handle(reservation_handle_ptr);
    609          
    610            if (reservation_ix != (uint32_t)-1) {
    611              sli_reservation_handle_ptr_table[reservation_ix] = NULL;
    612              return SL_STATUS_OK;
    613            } else {
    614              return SL_STATUS_NOT_FOUND;
    615            }
    616          }
