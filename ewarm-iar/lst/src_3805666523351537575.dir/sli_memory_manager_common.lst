    650          /***************************************************************************//**
    651           * Does a heap integrity check forwards from the general-purpose heap free_lt_list_head
    652           * and return the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    653           * This could go past reservations so there are checks.
    654           *
    655           * @return    Pointer to the corrupted sli_block_metadata_t{}.
    656           ******************************************************************************/
    657          sli_block_metadata_t *sli_memory_check_general_purpose_heap_integrity_forwards(void)
    658          {
    659            return sli_memory_check_heap_integrity_forwards(&sli_general_purpose_heap);
    660          }
    661          
    662          /***************************************************************************//**
    663           * Does a heap integrity check forwards from the general-purpose heap and return
    664           * the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    665           * This could go past reservations so there are checks.
    666           *
    667           * @note: Here are a few typical heap layout patterns that can be checked:
    668           *
    669           * Meta(LT1)|Payload(LT1)|Meta(LT2)|Payload(LT2)|Meta(free1)|Payload(free1)||
    670           * Meta(LT1)|Payload(LT1)|Meta(free1)|Payload(free1)|Meta(ST1)|Payload(ST1)||
    671           * Meta(RH1)|Payload(RH1)|Meta(free1)|Payload(free1)|Payload(R1)||
    672           * Meta(RH1)|Payload(RH1)|Meta(free1)|Payload(free1)|Payload(R1)|Payload(RNR1)||
    673           * Meta(RH1)|Payload(RH1)|Meta(LT1)|Payload(LT1)|Meta(free1)|Payload(free1)|Payload(R1)|Payload(RNR1)||
    674           * Meta(RH1)|Payload(RH1)|Meta(LT1)|Payload(LT1)|Meta(free1)|Payload(free1)|Meta(ST1)|Payload(ST1)|Payload(R1)|Payload(RNR1)||
    675           *
    676           * Legend of heap layouts:
    677           *    LT1 = allocated long-term block, ST1 = allocated short-term block
    678           *    RH1 = reservation handle, R1 = reserved block
    679           *    RNR1 = reserved block with no retention
    680           *    free1 = free block
    681           *    || = real end of heap
    682           ******************************************************************************/
    683          sli_block_metadata_t *sli_memory_check_heap_integrity_forwards(sl_memory_heap_t *heap)
    684          {
    685            uint64_t *heap_end_by_metadata = NULL;
    686            uint32_t is_corrupted = 0;
    687            sli_block_metadata_t *current = (sli_block_metadata_t *)heap->free_lt_list_head;
    688            sl_memory_region_t heap_region = sli_memory_heap_get_heap_region(heap);
    689            uint32_t reservation_size = 0;
    690          
    691            while (current != NULL) {
    692              // Reached last block in heap.
    693              if (sli_block_offset_next_dword_decode(current) == 0) {
    694                heap_end_by_metadata = (uint64_t *)current + sli_block_len_dword_decode(current) + SLI_BLOCK_METADATA_SIZE_DWORD;
    695          
    696                // Check if reservation (one or more).
    697                while ((reservation_size = sli_memory_get_reservation_size_by_addr((void *)heap_end_by_metadata)) != 0) {
    698                  heap_end_by_metadata = (uint64_t *)((uint8_t *)heap_end_by_metadata + reservation_size);
    699                }
    700          
    701                // Check if reservation no retention (one or more) if heap end is at the end of the DMEM.
    702                if ((uint64_t *)heap->base_addr + heap->size == (uint64_t *)heap_region.addr + heap_region.size) {
    703                  while ((reservation_size = sli_memory_get_reservation_no_retention_size((void *)heap_end_by_metadata)) != 0) {
    704                    heap_end_by_metadata = (uint64_t *)((uint8_t *)heap_end_by_metadata + reservation_size);
    705                  }
    706                }
    707          
    708                // Check the computed heap_end_by_metadata against real heap end, after accounting for any reserved blocks
    709                // and reserved blocks no retention.
    710                if (heap_end_by_metadata != (void *)((uintptr_t)heap->base_addr + heap->size)) {
    711                  is_corrupted = 1;
    712                }
    713                break;
    714              }
    715          
    716              // Calculate the address of the next block using offset and length.
    717              sli_block_metadata_t *next_blk_by_offset = (sli_block_metadata_t *)((uint64_t *)current + sli_block_offset_next_dword_decode(current));
    718              sli_block_metadata_t *next_blk_by_len = (sli_block_metadata_t *)((uint64_t *)current + sli_block_len_dword_decode(current) + SLI_BLOCK_METADATA_SIZE_DWORD);
    719          
    720              // Check if reservation (one or more).
    721              while ((reservation_size = sli_memory_get_reservation_size_by_addr((void *)next_blk_by_len)) != 0) {
    722                next_blk_by_len = (sli_block_metadata_t *)((uint8_t *)next_blk_by_len + reservation_size);
    723              }
    724          
    725              // Check the computed next_blk_by_len against the next block, after accounting for any reserved blocks.
    726              if (next_blk_by_offset != next_blk_by_len) {
    727                is_corrupted = 1;
    728                break;
    729              } else {
    730                current = next_blk_by_offset;
    731              }
    732            }
    733          
    734            return is_corrupted ? current : NULL;
    735          }
    736          
    737          /***************************************************************************//**
    738           * Does a heap integrity check backwards from the general-purpose heap free_st_list_head
    739           * and return the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    740           * This should not go past any reservations, hence there are no checks.
    741           ******************************************************************************/
    742          sli_block_metadata_t *sli_memory_check_general_purpose_heap_integrity_backwards(void)
    743          {
    744            return sli_memory_check_heap_integrity_backwards(&sli_general_purpose_heap);
    745          }
    746          
    747          /***************************************************************************//**
    748           * Does a heap integrity check backwards from free_st_list_head and return
    749           * the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    750           * This should not go past any reservations, hence there are no checks.
    751           ******************************************************************************/
    752          sli_block_metadata_t *sli_memory_check_heap_integrity_backwards(sl_memory_heap_t *heap)
    753          {
    754            uint64_t *heap_base_by_metadata = 0;
    755            uint32_t is_corrupted = 0;
    756            uint32_t reservation_size;
    757            sli_block_metadata_t *current = (sli_block_metadata_t *)heap->free_st_list_head;
    758          
    759            while (current != NULL) {
    760              // Reached first block in heap.
    761              if (sli_block_offset_prev_dword_decode(current) == 0) {
    762                heap_base_by_metadata = ((uint64_t *)current);
    763                if (heap_base_by_metadata != (void *)heap->base_addr) {
    764                  is_corrupted = 1;
    765                }
    766                break;
    767              }
    768          
    769              // Calculate the address of the current block using offset and length of the previous block.
    770              sli_block_metadata_t *prev_blk_by_offset = (sli_block_metadata_t *)((uint64_t *)current - sli_block_offset_prev_dword_decode(current));
    771              sli_block_metadata_t *current_by_prev_offset = (sli_block_metadata_t *)((uint64_t *)prev_blk_by_offset + sli_block_offset_next_dword_decode(prev_blk_by_offset));
    772              sli_block_metadata_t *current_by_prev_len = (sli_block_metadata_t *)((uint64_t *)prev_blk_by_offset + (sli_block_len_dword_decode(prev_blk_by_offset) + SLI_BLOCK_METADATA_SIZE_DWORD));
    773          
    774              // Check if reservation (one or more).
    775              // This is required when sli_general_purpose_heap.free_st_list_head has reservations before it.
    776              reservation_size = sli_memory_get_reservation_size_by_addr((void *)current_by_prev_len);
    777          
    778              while (reservation_size != 0) {
    779                current_by_prev_len = (sli_block_metadata_t *)((uint8_t *)current_by_prev_len + reservation_size);
    780                reservation_size = sli_memory_get_reservation_size_by_addr((void *)current_by_prev_len);
    781              }
    782          
    783              // Check the computed current_by_prev_len against the previous block, after accounting for any reserved blocks.
    784              // This doesn't apply if this is the first block at the heap start that has undergone a data payload adjustment.
    785              if ((current_by_prev_len != current_by_prev_offset) && !(current->heap_start_align)) {
    786                is_corrupted = 1;
    787                break;
    788              } else {
    789                current = prev_blk_by_offset;
    790              }
    791            }
    792          
    793            if (is_corrupted) {
    794              return (sli_block_metadata_t *)current;
    795            }
    796          
    797            return NULL;
    798          }
    799          #endif /* SLI_MEMORY_MANAGER_ENABLE_TEST_UTILITIES */

