    560          /***************************************************************************//**
    561           * Gets the pointer to sl_memory_reservation_t{} by block address.
    562           ******************************************************************************/
    563          sl_memory_reservation_t *sli_memory_get_reservation_handle_by_addr(void *addr)
    564          {
    565            uint32_t reservation_ix = get_reservation_ix_by_addr(addr);
    566          
    567            if (reservation_ix != (uint32_t)-1) {
    568              return sli_reservation_handle_ptr_table[reservation_ix];
    569            }
    570          
    571            return NULL;
    572          }
    573          
    574          /***************************************************************************//**
    575           * Gets the size of a reservation by block address.
    576           ******************************************************************************/
    577          uint32_t sli_memory_get_reservation_size_by_addr(void *addr)
    578          {
    579            sl_memory_reservation_t *reservation_handle_ptr = sli_memory_get_reservation_handle_by_addr(addr);
    580          
    581            if (reservation_handle_ptr != NULL) {
    582              return reservation_handle_ptr->block_size;
    583            }
    584            // Not a reservation, return 0 size.
    585            return 0;
    586          }
