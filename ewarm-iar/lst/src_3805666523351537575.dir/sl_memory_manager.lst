   1959          /***************************************************************************//**
   1960           * Retrieves the amount of heap that would not be retained in the specified
   1961           * heap if entering EM2.
   1962           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
   1963          size_t sl_memory_heap_get_unretained_size(const sl_memory_heap_t *heap)
   1964          {
   1965          #if (SLI_MEMORY_MANAGER_RETENTION_STATISTICS_AVAILABLE == 1)
   1966            if (heap == NULL || heap->retention_control == NULL) {
   1967              return (size_t)-1;
   1968            }
   1969          
   1970            // Unretained = free + (heap_used - retained_size); requires heap statistics.
   1971            CORE_DECLARE_IRQ_STATE;
   1972            CORE_ENTER_ATOMIC();
   1973            size_t retained_size = ((sli_retention_control_t *)heap->retention_control)->retained_size;
   1974            size_t heap_used = heap->used_size;
   1975            CORE_EXIT_ATOMIC();
   1976          
   1977            if (retained_size > heap_used) {
   1978              return (size_t)-1;
   1979            }
   1980          
   1981            size_t free_sz = sl_memory_heap_get_free_size(heap);
   1982            return free_sz + (heap_used - retained_size);
   1983          #else
   1984            (void) heap;
   1985            return (size_t)-1;
   \                     sl_memory_heap_get_unretained_size: (+1)
   \        0x0   0x....             B.N      ?Subroutine2
   1986          #endif
   1987          }
