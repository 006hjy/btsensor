   2225          #if defined(SLI_MEMORY_MANAGER_SUPPORT_ALLOCATION_FALLBACK)
   2226          /***************************************************************************//**
   2227           * Manages allocation fallback into different heap types.
   2228           *
   2229           * @param[in]  size                     Size of the block to allocate in bytes.
   2230           * @param[in]  align                    Alignment required, in bytes.
   2231           * @param[in]  type                     Block type and attribute mask.
   2232           * @param[out] block                    Pointer to variable that will receive
   2233           *                                      the start address of the allocated memory.
   2234           *
   2235           * @return     SL_STATUS_OK if success.
   2236           *             SL_STATUS_NO_MORE_RESOURCE if no fallbacks are available.
   2237           *             Allocation error code otherwise.
   2238           *
   2239           * @note (1) This function is used to handle allocation fallbacks when the
   2240           *           requested allocation cannot be satisfied by the current heap.
   2241           *           It tries to allocate from different heaps based on the specified
   2242           *           block attributes.
   2243           *
   2244           * @note (2) The fallback order follows the heaps initialization order which is:
   2245           *             1. General Purpose Heap
   2246           *             2. PSRAM
   2247           *             3. DTCM
   2248           *
   2249           *           This  makes it so that:
   2250           *             Failed allocations from the general purpose heap always goes first to the
   2251           *             PSRAM and then to the DTCM.
   2252           ******************************************************************************/
   2253          static sl_status_t memory_manage_allocation_fallback(size_t size,
   2254                                                               size_t align,
   2255                                                               uint8_t type,
   2256                                                               void **block)
   2257          {
   2258            sl_memory_heap_t *fallback_heap = sli_general_purpose_heap.next_handle;
   2259            uint8_t blocks_heap_attribute = (uint8_t) (type & SLI_MEMORY_BLOCK_ATTRIBUTE_MASK);
   2260            size_t allocation_size = SLI_ALIGN_ROUND_UP(size, SLI_BLOCK_ALLOC_MIN_ALIGN);
   2261          
   2262            while (fallback_heap != NULL) {
   2263              // If the fallback heap attribute matches one of the blocks heap attributes
   2264              // and there is enough space in heap, try the allocation.
   2265              if (((fallback_heap->attrib & blocks_heap_attribute) == fallback_heap->attrib)
   2266                  && (allocation_size <= (fallback_heap->size - fallback_heap->used_size))) {
   2267                sl_status_t status = sl_memory_heap_alloc_advanced(fallback_heap,
   2268                                                                   size,
   2269                                                                   align,
   2270                                                                   type & ~SLI_MEMORY_BLOCK_ATTRIBUTE_MASK,  // No fallback on this allocation
   2271                                                                   block);
   2272                if (status == SL_STATUS_OK) {
   2273                  return SL_STATUS_OK;
   2274                }
   2275              }
   2276          
   2277              fallback_heap = fallback_heap->next_handle;
   2278            }
   2279          
   2280            return SL_STATUS_NO_MORE_RESOURCE;
   2281          }
   2282          #endif  // SLI_MEMORY_MANAGER_SUPPORT_ALLOCATION_FALLBACK

