   2052            if (heap == NULL || heap->retention_control == NULL) {
   2053              return 0ULL;
   2054            }
   2055          
   2056            CORE_DECLARE_IRQ_STATE;
   2057            CORE_ENTER_ATOMIC();
   2058          
   2059            const sli_retention_control_t *retention_control =
   2060              (const sli_retention_control_t *)heap->retention_control;
   2061            uint64_t mask = 0ULL;
   2062            uint32_t num_banks_to_scan = retention_control->num_banks;
   2063            if (num_banks_to_scan > SLI_MEMORY_MANAGER_ABSOLUTE_RETAINED_BANKS_MASK_MAX_BITS) {
   2064              num_banks_to_scan = SLI_MEMORY_MANAGER_ABSOLUTE_RETAINED_BANKS_MASK_MAX_BITS;
   2065            }
   2066          
   2067            for (uint32_t bank_index = 0u; bank_index < num_banks_to_scan; bank_index++) {
