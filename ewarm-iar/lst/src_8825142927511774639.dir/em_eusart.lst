    220          #if defined(EUSART_PRESENT)
    221          /***************************************************************************//**
    222           * Initializes the EUSART when used in SPI mode.
    223           ******************************************************************************/
    224          void EUSART_SpiInit(EUSART_TypeDef *eusart, EUSART_SpiInit_TypeDef const *init)
    225          {
    226            // Make sure the module exists on the selected chip.
    227            EFM_ASSERT(EUSART_REF_VALID(eusart));
    228            // Init structure must be provided.
    229            EFM_ASSERT(init);
    230            if (init->master) {
    231              EFM_ASSERT(init->bitRate <= 20000000);
    232          
    233              if (init->advancedSettings) {
    234                EFM_ASSERT(!(init->advancedSettings->prsClockEnable));
    235              }
    236            } else {
    237              EFM_ASSERT(init->bitRate <= 10000000);
    238              if (init->advancedSettings && init->advancedSettings->forceLoad) {
    239                // If baud-rate is more than 5MHz, a value of 4 is recommended, any values
    240                // smaller than that can be tried out but avoid using 0. If baud-rate is less than 5MHz,
    241                // value of 5 is recommended, values higher than 5 can be used but it may make the load
    242                // error easy to occur. The recommended values for frequency bands should be sufficient
    243                // to work all the time.
    244                EFM_ASSERT((init->bitRate >= 5000000 && init->advancedSettings->setupWindow <= 4)
    245                           || (init->bitRate < 5000000 && init->advancedSettings->setupWindow >= 5));
    246              }
    247            }
    248          
    249            EUSART_SyncInitCommon(eusart, init);
    250          }
    251          
    252          #if defined(EUSART_DALICFG_DALIEN)
    253          /***************************************************************************//**
    254           * Initializes the EUSART when used in DALI mode with the high or low
    255           * frequency clock.
    256           *
    257           * @note (1) When EUSART oversampling is set to eusartOVS0 (Disable), the peripheral
    258           *           clock frequency must be at least three times higher than the
    259           *           chosen baud rate. In LF, max input clock is 32768 (LFXO or LFRCO),
    260           *           thus 32768 / 3 ~ 9600 baudrate.
    261           ******************************************************************************/
    262          void EUSART_DaliInit(EUSART_TypeDef *eusart,
    263                               const EUSART_DaliInit_TypeDef *daliInit)
    264          {
    265            // Make sure the module exists on the selected chip.
    266            EFM_ASSERT(EUSART_REF_VALID(eusart));
    267            // Init structure must be provided.
    268            EFM_ASSERT(daliInit);
    269          
    270            if (daliInit->init.loopbackEnable) {
    271              // If LOOPBK in CFG0 is set to 1 in order to do loopback testing for DALI,
    272              // then in this case DALIRXENDT should be set to 1 and DALIRXDATABITS should
    273              // be set the same as DALITXDATABITS.
    274              EFM_ASSERT( (daliInit->TXdatabits >> _EUSART_DALICFG_DALITXDATABITS_SHIFT)
    275                          == (daliInit->RXdatabits >> _EUSART_DALICFG_DALIRXDATABITS_SHIFT));
    276            }
    277          
    278            if (daliInit->daliLowFrequencyEnable) {
    279              // Validate the low frequency capability of the EUSART instance.
    280              EFM_ASSERT(EUSART_EM2_CAPABLE(EUSART_NUM(eusart)));
    281              // The oversampling must be disabled when using a low frequency clock.
    282              EFM_ASSERT(daliInit->init.oversampling == eusartOVS0);
    283              // In LF, max baudrate is 9600. See Note #1.
    284              // but manchester is running at 2x clock 9600 => 4800
    285              EFM_ASSERT(daliInit->init.baudrate <= 4800);
    286            } else {
    287              EFM_ASSERT(daliInit->init.oversampling != eusartOVS0);
    288              // In HF, 2.4 kbps <= baudrate <= 1.152 Mbps.
    289              // but manchester is running at 2x clock so 2.4 kbps => 1.2 kbps
    290              EFM_ASSERT(daliInit->init.baudrate >= 1200 && daliInit->init.baudrate <= 57600);
    291            }
    292          
    293            // Initialize EUSART with common features to HF and LF.
    294            EUSART_AsyncInitCommon(eusart, &daliInit->init, NULL, daliInit);
    295          }
    296          #endif /* EUSART_DALICFG_DALIEN */
    297          #endif /* EUSART_PRESENT */
