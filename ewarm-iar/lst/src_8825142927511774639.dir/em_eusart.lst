   1098          /***************************************************************************//**
   1099           * Initializes the EUSART with synchronous common settings to high
   1100           * and low frequency clock.
   1101           *
   1102           * @param eusart Pointer to the EUSART peripheral register block.
   1103           * @param init A pointer to the initialization structure.
   1104           ******************************************************************************/
   1105          static void EUSART_SyncInitCommon(EUSART_TypeDef *eusart,
   1106                                            EUSART_SpiInit_TypeDef const *init)
   1107          {
   1108            const void *advancedSetting_ptr = init->advancedSettings; // Used to avoid GCC over optimization.
   1109          
   1110            // LF register about to be modified requires sync busy check.
   1111            if (eusart->EN) {
   1112              eusart_sync(eusart, _EUSART_SYNCBUSY_MASK);
   1113            }
   1114          
   1115            // Initialize EUSART registers to hardware reset state.
   1116            EUSART_Reset(eusart);
   1117          
   1118            // Configure global configuration register 2.
   1119            eusart->CFG2 = (eusart->CFG2 & ~(_EUSART_CFG2_MASTER_MASK
   1120                                             | _EUSART_CFG2_CLKPOL_MASK
   1121                                             | _EUSART_CFG2_CLKPHA_MASK
   1122                                             | _EUSART_CFG2_FORCELOAD_MASK))
   1123                           | (uint32_t)(init->master)
   1124                           | (uint32_t)(init->clockMode)
   1125                           | (uint32_t)(EUSART_CFG2_FORCELOAD); // Force load feature enabled by default.
   1126          
   1127            if (advancedSetting_ptr) {
   1128              // Configure global configuration register 2.
   1129              eusart->CFG2 = (eusart->CFG2 & ~(_EUSART_CFG2_FORCELOAD_MASK
   1130                                               | _EUSART_CFG2_AUTOCS_MASK
   1131                                               | _EUSART_CFG2_AUTOTX_MASK
