    491          /***************************************************************************//**
    492           * Transmits one frame.
    493           ******************************************************************************/
    494          void EUSART_Dali_Tx(EUSART_TypeDef *eusart, uint32_t data)
    495          {
    496            uint32_t packet;
    497          
    498            // Make sure the module exists on the selected chip.
    499            EFM_ASSERT(EUSART_REF_VALID(eusart));
    500          
    501            // Check that transmit FIFO is not full.
    502            while (!(eusart->STATUS & EUSART_STATUS_TXFL)) {
    503              // Wait for TX FIFO.
    504            }
    505          
    506            for (uint8_t index = 0; index < dali_tx_nb_packets[EUSART_NUM(eusart)]; index++) {
    507              // when DALICFG.DALIEN is set to 1, then all 16 bits [15:0] represent data
    508              // First write to TXDATA register should contain 16 LSBs of the TX frame.
    509              // Transmission will not start after this first write.
    510              // Second write to TXDATA register should contain the remaining TX frame bits.
    511              // This second write will result in start of transmission.
    512              packet = (data >> (index * 16));
    513              // To ensure compatibility with future devices, always write bits [31:16] to 0.
    514              packet &= 0x0000FFFF;
    515              eusart->TXDATA = packet;
    516            }
    517          }
    518          
    519          /***************************************************************************//**
    520           * Receive one frame.
    521           ******************************************************************************/
    522          uint32_t EUSART_Dali_Rx(EUSART_TypeDef *eusart)
    523          {
    524            uint32_t data = 0;
    525          
    526            // Make sure the module exists on the selected chip.
    527            EFM_ASSERT(EUSART_REF_VALID(eusart));
    528          
    529            while (!(eusart->STATUS & EUSART_STATUS_RXFL)) {
    530              // Wait for incoming data.
    531            }
    532          
    533            for (uint8_t index = 0; index < dali_rx_nb_packets[EUSART_NUM(eusart)]; index++) {
    534              // when DALICFG.DALIEN is set to 1, then all 16 bits [15:0] represent data
    535              // When receiving a frame that has more than 16 databits,
    536              // RXDATA register needs to be read twice:
    537              //    First read will provide 16 LSBs of the received frame.
    538              //    Second read will provide the remaining RX frame bits.
    539              data |= ((eusart->RXDATA & _EUSART_RXDATA_RXDATA_MASK) << (index * 16));
    540            }
    541            return data;
    542          }
    543          
    544          #endif /* EUSART_DALICFG_DALIEN */
