   1247          /***************************************************************************//**
   1248           * Calculate baudrate for a given reference frequency, clock division,
   1249           * and oversampling rate when the module is in UART mode.
   1250           *
   1251           * @param refFreq The EUSART reference clock frequency in Hz that will be used.
   1252           * @param clkdiv Clock division factor to be used.
   1253           * @param ovs Oversampling to be used.
   1254           *
   1255           * @return Computed baudrate from given settings.
   1256           ******************************************************************************/
   1257          __STATIC_INLINE uint32_t EUSART_AsyncBaudrateCalc(uint32_t refFreq,
   1258                                                            uint32_t clkdiv,
   1259                                                            EUSART_OVS_TypeDef ovs)
   1260          {
   1261            uint32_t oversample;
   1262            uint64_t divisor;
   1263            uint64_t factor;
   1264            uint64_t remainder;
   1265            uint64_t quotient;
   1266            uint32_t br;
   1267          
   1268            // Out of bound clkdiv.
   1269            EFM_ASSERT(clkdiv <= _EUSART_CLKDIV_MASK);
   1270          
   1271            // Mask out unused bits
   1272            clkdiv &= _EUSART_CLKDIV_MASK;
   1273          
   1274            /* Use integer division to avoid forcing in float division
   1275             * utils and yet keep rounding effect errors to a minimum.
   1276             *
   1277             * Baudrate in is given by:
   1278             *
   1279             * br = fUARTn/(oversample * (1 + (CLKDIV / 256)))
   1280             * or
   1281             * br = (256 * fUARTn)/(oversample * (256 + CLKDIV))
   1282             *
   1283             * 256 factor of the dividend is reduced with a
   1284             * (part of) oversample part of the divisor.
   1285             */
   1286          
   1287            switch (ovs) {
   1288              case eusartOVS16:
   1289                oversample = 1;
   1290                factor = 256 / 16;
   1291                break;
   1292          
   1293              case eusartOVS8:
   1294                oversample = 1;
   1295                factor = 256 / 8;
   1296                break;
   1297          
   1298              case eusartOVS6:
   1299                oversample = 3;
   1300                factor = 256 / 2;
   1301                break;
   1302          
   1303              case eusartOVS4:
   1304                oversample = 1;
   1305                factor = 256 / 4;
   1306                break;
   1307          
   1308              case eusartOVS0:
   1309                oversample = 1;
   1310                factor = 256;
   1311                break;
   1312          
   1313              default:
   1314                return 0u;
   1315                break;
   1316            }
   1317          
   1318            /*
   1319             * The basic problem with integer division in the above formula is that
   1320             * the dividend (factor * fUARTn) may become larger than a 32 bit
   1321             * integer. Yet we want to evaluate the dividend first before dividing
   1322             * to get as small rounding effects as possible. Too harsh restrictions
   1323             * should not be made on the maximum fUARTn value either.
   1324             *
   1325             * For division a/b,
   1326             *
   1327             * a = qb + r
   1328             *
   1329             * where q is the quotient and r is the remainder, both integers.
   1330             *
   1331             * The original baudrate formula can be rewritten as
   1332             *
   1333             * br = xa / b = x(qb + r)/b = xq + xr/b
   1334             *
   1335             * where x is 'factor', a is 'refFreq' and b is 'divisor', referring to
   1336             * variable names.
   1337             */
   1338          
   1339            /*
   1340             * The divisor will never exceed max 32 bit value since
   1341             * clkdiv <= _EUSART_CLKDIV_MASK (currently 0x7FFFF8)
   1342             * and 'oversample' has been reduced to <= 3.
   1343             */
   1344            divisor = (uint64_t)(oversample * (256 + clkdiv));
   1345          
   1346            quotient = refFreq / divisor;
   1347            remainder = refFreq % divisor;
   1348          
   1349            // The factor <= 128 and since divisor >= 256, the below cannot exceed the maximum
   1350            // 32 bit value. However, factor * remainder can become larger than 32-bit
   1351            // because of the size of _EUSART_CLKDIV_DIV_MASK on some families.
   1352            br = (uint32_t) (factor * quotient);
   1353          
   1354            /*
   1355             * The factor <= 128 and remainder < (oversample*(256 + clkdiv)), which
   1356             * means dividend (factor * remainder) worst case is
   1357             * 128 * (3 * (256 + _EUSART_CLKDIV_MASK)) = 0xC001_7400.
   1358             */
   1359            br += (uint32_t) ((factor * remainder) / divisor);
   1360          
   1361            return br;
   1362          }
