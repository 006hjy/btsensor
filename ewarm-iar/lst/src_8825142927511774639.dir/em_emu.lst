   2305          /***************************************************************************//**
   2306           * @brief
   2307           *   Load DCDC calibration constants from the DI page. A constant means that calibration
   2308           *   data that does not change depending on other configuration parameters.
   2309           *
   2310           * @return
   2311           *   False if calibration registers are locked.
   2312           ******************************************************************************/
   2313          static bool dcdcConstCalibrationLoad(void)
   2314          {
   2315          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2316            uint32_t val;
   2317            volatile uint32_t *reg;
   2318          
   2319            /* DI calibration data in Flash. */
   2320            volatile uint32_t* const diCal_EMU_DCDCLNFREQCTRL =  (volatile uint32_t *)(0x0FE08038);
   2321            volatile uint32_t* const diCal_EMU_DCDCLNVCTRL =     (volatile uint32_t *)(0x0FE08040);
   2322            volatile uint32_t* const diCal_EMU_DCDCLPCTRL =      (volatile uint32_t *)(0x0FE08048);
   2323            volatile uint32_t* const diCal_EMU_DCDCLPVCTRL =     (volatile uint32_t *)(0x0FE08050);
   2324            volatile uint32_t* const diCal_EMU_DCDCTRIM0 =       (volatile uint32_t *)(0x0FE08058);
   2325            volatile uint32_t* const diCal_EMU_DCDCTRIM1 =       (volatile uint32_t *)(0x0FE08060);
   2326          
   2327            if (DEVINFO->DCDCLPVCTRL0 != UINT_MAX) {
   2328              val = *(diCal_EMU_DCDCLNFREQCTRL + 1);
   2329              reg = (volatile uint32_t *)*diCal_EMU_DCDCLNFREQCTRL;
   2330              *reg = val;
   2331          
   2332              val = *(diCal_EMU_DCDCLNVCTRL + 1);
   2333              reg = (volatile uint32_t *)*diCal_EMU_DCDCLNVCTRL;
   2334              *reg = val;
   2335          
   2336              val = *(diCal_EMU_DCDCLPCTRL + 1);
   2337              reg = (volatile uint32_t *)*diCal_EMU_DCDCLPCTRL;
   2338              *reg = val;
   2339          
   2340              val = *(diCal_EMU_DCDCLPVCTRL + 1);
   2341              reg = (volatile uint32_t *)*diCal_EMU_DCDCLPVCTRL;
   2342              *reg = val;
   2343          
   2344              val = *(diCal_EMU_DCDCTRIM0 + 1);
   2345              reg = (volatile uint32_t *)*diCal_EMU_DCDCTRIM0;
   2346              *reg = val;
   2347          
   2348              val = *(diCal_EMU_DCDCTRIM1 + 1);
   2349              reg = (volatile uint32_t *)*diCal_EMU_DCDCTRIM1;
   2350              *reg = val;
   2351          
   2352              return true;
   2353            }
   2354            EFM_ASSERT(false);
   2355            /* Return when assertions are disabled. */
   2356            return false;
   2357          
   2358          #else
   2359            return true;
   2360          #endif
   2361          }
   2362          
   2363          /***************************************************************************//**
   2364           * @brief
   2365           *   Set recommended and validated current optimization and timing settings.
   2366           *
   2367           ******************************************************************************/
   2368          static void dcdcValidatedConfigSet(void)
   2369          {
   2370            uint32_t lnForceCcm;
   2371          
   2372          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2373            uint32_t dcdcTiming;
   2374            SYSTEM_ChipRevision_TypeDef rev;
   2375          #endif
   2376          
   2377            /* Enable duty cycling of the bias. */
   2378            EMU->DCDCLPCTRL |= EMU_DCDCLPCTRL_LPVREFDUTYEN;
   2379          
   2380            /* Set low-noise RCO for LNFORCECCM configuration.
   2381             * LNFORCECCM is default 1 for EFR32
   2382             * LNFORCECCM is default 0 for EFM32
   2383             */
   2384            lnForceCcm = BUS_RegBitRead(&EMU->DCDCMISCCTRL, _EMU_DCDCMISCCTRL_LNFORCECCM_SHIFT);
   2385            if (lnForceCcm != 0U) {
   2386              /* 7 MHz is recommended for LNFORCECCM = 1. */
   2387              EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_7MHz);
   2388            } else {
   2389              /* 3 MHz is recommended for LNFORCECCM = 0. */
   2390              EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_3MHz);
   2391            }
   2392          
   2393          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2394            EMU->DCDCTIMING &= ~_EMU_DCDCTIMING_DUTYSCALE_MASK;
   2395            EMU->DCDCMISCCTRL |= EMU_DCDCMISCCTRL_LPCMPHYSDIS
   2396                                 | EMU_DCDCMISCCTRL_LPCMPHYSHI;
   2397          
   2398            SYSTEM_ChipRevisionGet(&rev);
   2399            if ((rev.major == 1)
   2400                && (rev.minor < 3)
   2401                && (errataFixDcdcHsState == errataFixDcdcHsInit)) {
   2402              /* LPCMPWAITDIS = 1 */
   2403              EMU_DCDCSMCTRL |= 1;
   2404          
   2405              dcdcTiming = EMU->DCDCTIMING;
   2406              dcdcTiming &= ~(_EMU_DCDCTIMING_LPINITWAIT_MASK
   2407                              | _EMU_DCDCTIMING_LNWAIT_MASK
   2408                              | _EMU_DCDCTIMING_BYPWAIT_MASK);
   2409          
   2410              dcdcTiming |= ((180 << _EMU_DCDCTIMING_LPINITWAIT_SHIFT)
   2411                             | (12 << _EMU_DCDCTIMING_LNWAIT_SHIFT)
   2412                             | (180 << _EMU_DCDCTIMING_BYPWAIT_SHIFT));
   2413              EMU->DCDCTIMING = dcdcTiming;
   2414          
   2415              errataFixDcdcHsState = errataFixDcdcHsTrimSet;
   2416            }
   2417          #endif
   2418          }
   2419          
   2420          /***************************************************************************//**
   2421           * @brief
   2422           *   Compute current limiters:
   2423           *     LNCLIMILIMSEL: LN current limiter threshold
   2424           *     LPCLIMILIMSEL: LP current limiter threshold
   2425           *     DCDCZDETCTRL:  zero detector limiter threshold
   2426           ******************************************************************************/
   2427          static void currentLimitersUpdate(void)
   2428          {
   2429            uint32_t lncLimSel;
   2430            uint32_t zdetLimSel;
   2431            uint32_t pFetCnt;
   2432            uint16_t maxReverseCurrent_mA;
   2433          
   2434            /* 80 mA as recommended peak in Application Note AN0948.
   2435               The peak current is the average current plus 50% of the current ripple.
   2436               Hence, a 14 mA average current is recommended in LP mode. Since LP PFETCNT is also
   2437               a constant, lpcLimImSel = 1. The following calculation is provided
   2438               for documentation only. */
   2439            const uint32_t lpcLim = (((14 + 40) + ((14 + 40) / 2))
   2440                                     / (5 * (DCDC_LP_PFET_CNT + 1)))
   2441                                    - 1;
   2442            const uint32_t lpcLimSel = lpcLim << _EMU_DCDCMISCCTRL_LPCLIMILIMSEL_SHIFT;
   2443          
   2444            /* Get enabled PFETs. */
   2445            pFetCnt = (EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_PFETCNT_MASK)
   2446                      >> _EMU_DCDCMISCCTRL_PFETCNT_SHIFT;
   2447          
   2448            /* Compute the LN current limiter threshold from the nominal user input current and
   2449               LN PFETCNT as described in the register description for
   2450               EMU_DCDCMISCCTRL_LNCLIMILIMSEL. */
   2451            lncLimSel = ((((uint32_t)dcdcMaxCurrent_mA + 40U)
   2452                          + (((uint32_t)dcdcMaxCurrent_mA + 40U) / 2U))
   2453                         / (5U * (pFetCnt + 1U)))
   2454                        - 1U;
   2455          
   2456            /* Saturate the register field value. */
   2457            lncLimSel = SL_MIN(lncLimSel,
   2458                               _EMU_DCDCMISCCTRL_LNCLIMILIMSEL_MASK
   2459                               >> _EMU_DCDCMISCCTRL_LNCLIMILIMSEL_SHIFT);
   2460          
   2461            lncLimSel <<= _EMU_DCDCMISCCTRL_LNCLIMILIMSEL_SHIFT;
   2462          
   2463            /* Check for overflow. */
   2464            EFM_ASSERT((lncLimSel & ~_EMU_DCDCMISCCTRL_LNCLIMILIMSEL_MASK) == 0x0U);
   2465            EFM_ASSERT((lpcLimSel & ~_EMU_DCDCMISCCTRL_LPCLIMILIMSEL_MASK) == 0x0U);
   2466          
   2467            EMU->DCDCMISCCTRL = (EMU->DCDCMISCCTRL & ~(_EMU_DCDCMISCCTRL_LNCLIMILIMSEL_MASK
   2468                                                       | _EMU_DCDCMISCCTRL_LPCLIMILIMSEL_MASK))
   2469                                | (lncLimSel | lpcLimSel);
   2470          
   2471            /* Compute the reverse current limit threshold for the zero detector from the user input
   2472               maximum reverse current and LN PFETCNT as described in the register description
   2473               for EMU_DCDCZDETCTRL_ZDETILIMSEL. */
   2474            if (dcdcReverseCurrentControl >= 0) {
   2475              /* If dcdcReverseCurrentControl < 0, EMU_DCDCZDETCTRL_ZDETILIMSEL is "don't care". */
   2476              maxReverseCurrent_mA = (uint16_t)dcdcReverseCurrentControl;
   2477          
   2478              zdetLimSel = ((((uint32_t)maxReverseCurrent_mA + 40U)
   2479                             + (((uint32_t)maxReverseCurrent_mA + 40U) / 2U))
   2480                            / ((2U * (pFetCnt + 1U)) + ((pFetCnt + 1U) / 2U)));
   2481              /* Saturate the register field value. */
   2482              zdetLimSel = SL_MIN(zdetLimSel,
   2483                                  _EMU_DCDCZDETCTRL_ZDETILIMSEL_MASK
   2484                                  >> _EMU_DCDCZDETCTRL_ZDETILIMSEL_SHIFT);
   2485          
   2486              zdetLimSel <<= _EMU_DCDCZDETCTRL_ZDETILIMSEL_SHIFT;
   2487          
   2488              /* Check for overflow. */
   2489              EFM_ASSERT((zdetLimSel & ~_EMU_DCDCZDETCTRL_ZDETILIMSEL_MASK) == 0x0U);
   2490          
   2491              EMU->DCDCZDETCTRL = (EMU->DCDCZDETCTRL & ~_EMU_DCDCZDETCTRL_ZDETILIMSEL_MASK)
   2492                                  | zdetLimSel;
   2493            }
   2494          }
   2495          
   2496          /***************************************************************************//**
   2497           * @brief
   2498           *   Set static variables that hold the user set maximum peak current
   2499           *   and reverse current. Update limiters.
   2500           *
   2501           * @param[in] maxCurrent_mA
   2502           *   Set the maximum peak current that the DCDC can draw from the power source.
   2503           * @param[in] reverseCurrentControl
   2504           *   Reverse the current control as defined by
   2505           *   @ref EMU_DcdcLnReverseCurrentControl_TypeDef. Positive values have unit mA.
   2506           ******************************************************************************/
   2507          static void userCurrentLimitsSet(uint32_t maxCurrent_mA,
   2508                                           EMU_DcdcLnReverseCurrentControl_TypeDef reverseCurrentControl)
   2509          {
   2510            dcdcMaxCurrent_mA = (uint16_t)maxCurrent_mA;
   2511            dcdcReverseCurrentControl = reverseCurrentControl;
   2512          }
   2513          
   2514          /***************************************************************************//**
   2515           * @brief
   2516           *   Set DCDC low noise compensator control register.
   2517           *
   2518           * @param[in] comp
   2519           *   Low-noise mode compensator trim setpoint.
   2520           ******************************************************************************/
   2521          static void compCtrlSet(EMU_DcdcLnCompCtrl_TypeDef comp)
   2522          {
   2523            switch (comp) {
   2524              case emuDcdcLnCompCtrl_1u0F:
   2525                EMU->DCDCLNCOMPCTRL = 0x57204077UL;
   2526                break;
   2527          
   2528              case emuDcdcLnCompCtrl_4u7F:
   2529                EMU->DCDCLNCOMPCTRL = 0xB7102137UL;
   2530                break;
   2531          
   2532              default:
   2533                EFM_ASSERT(false);
   2534                break;
   2535            }
   2536          }
   2537          
   2538          /***************************************************************************//**
   2539           * @brief
   2540           *   Load EMU_DCDCLPCTRL_LPCMPHYSSEL depending on LP bias, LP feedback
   2541           *   attenuation, and DEVINFOREV.
   2542           *
   2543           * @param[in] lpAttenuation
   2544           *   LP feedback attenuation.
   2545           * @param[in] lpCmpBias
   2546           *   lpCmpBias selection.
   2547           * @param[in] trimMode
   2548           *   DCDC trim mode.
   2549           ******************************************************************************/
   2550          static bool lpCmpHystCalibrationLoad(bool lpAttenuation,
   2551                                               uint8_t lpCmpBias,
   2552                                               dcdcTrimMode_TypeDef trimMode)
   2553          {
   2554            uint32_t lpcmpHystSel;
   2555          #if !defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2556            (void)lpAttenuation;
   2557          #endif
   2558          
   2559            /* Get calibration data revision. */
   2560          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2561            uint8_t devinfoRev = SYSTEM_GetDevinfoRev();
   2562          
   2563            /* Load LPATT indexed calibration data. */
   2564            if (devinfoRev < 4) {
   2565              lpcmpHystSel = DEVINFO->DCDCLPCMPHYSSEL0;
   2566          
   2567              if (lpAttenuation) {
   2568                lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT1_MASK)
   2569                               >> _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT1_SHIFT;
   2570              } else {
   2571                lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT0_MASK)
   2572                               >> _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT0_SHIFT;
   2573              }
   2574            } else
   2575          #endif
   2576            {
   2577              /* devinfoRev >= 4: load LPCMPBIAS indexed calibration data. */
   2578              lpcmpHystSel = DEVINFO->DCDCLPCMPHYSSEL1;
   2579              switch (lpCmpBias) {
   2580                case 0:
   2581                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS0_MASK)
   2582                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS0_SHIFT;
   2583                  break;
   2584          
   2585                case 1:
   2586                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS1_MASK)
   2587                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS1_SHIFT;
   2588                  break;
   2589          
   2590                case 2:
   2591                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS2_MASK)
   2592                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS2_SHIFT;
   2593                  break;
   2594          
   2595                case 3:
   2596                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS3_MASK)
   2597                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS3_SHIFT;
   2598                  break;
   2599          
   2600                default:
   2601                  EFM_ASSERT(false);
   2602                  /* Return when assertions are disabled. */
   2603                  return false;
   2604              }
   2605            }
   2606          
   2607            /* Set trims. */
   2608            if (trimMode == dcdcTrimMode_EM234H_LP) {
   2609              /* Make sure the sel value is within the field range. */
   2610              lpcmpHystSel <<= _GENERIC_DCDCLPCTRL_LPCMPHYSSELEM234H_SHIFT;
   2611              if ((lpcmpHystSel & ~_GENERIC_DCDCLPCTRL_LPCMPHYSSELEM234H_MASK) != 0U) {
   2612                EFM_ASSERT(false);
   2613                /* Return when assertions are disabled. */
   2614                return false;
   2615              }
   2616              EMU->DCDCLPCTRL = (EMU->DCDCLPCTRL & ~_GENERIC_DCDCLPCTRL_LPCMPHYSSELEM234H_MASK) | lpcmpHystSel;
   2617            }
   2618          
   2619          #if defined(_EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_MASK)
   2620            if (trimMode == dcdcTrimMode_EM01_LP) {
   2621              /* Make sure the sel value is within the field range. */
   2622              lpcmpHystSel <<= _EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_SHIFT;
   2623              if ((lpcmpHystSel & ~_EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_MASK) != 0U) {
   2624                EFM_ASSERT(false);
   2625                /* Return when assertions are disabled. */
   2626                return false;
   2627              }
   2628              EMU->DCDCLPEM01CFG = (EMU->DCDCLPEM01CFG & ~_EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_MASK) | lpcmpHystSel;
   2629            }
   2630          #endif
   2631          
   2632            return true;
   2633          }
   2634          
   2635          /***************************************************************************//**
   2636           * @brief
   2637           *   Load LPVREF low and high from DEVINFO.
   2638           *
   2639           * @param[out] vrefL
   2640           *   LPVREF low from DEVINFO.
   2641           * @param[out] vrefH
   2642           *   LPVREF high from DEVINFO.
   2643           * @param[in] lpAttenuation
   2644           *   LP feedback attenuation.
   2645           * @param[in] lpcmpBias
   2646           *   lpcmpBias to look up in DEVINFO.
   2647           ******************************************************************************/
   2648          static void lpGetDevinfoVrefLowHigh(uint32_t *vrefL,
   2649                                              uint32_t *vrefH,
   2650                                              bool lpAttenuation,
   2651                                              uint8_t lpcmpBias)
   2652          {
   2653            uint32_t vrefLow = 0;
   2654            uint32_t vrefHigh = 0;
   2655          
   2656            /* Find VREF high and low in DEVINFO indexed by LPCMPBIAS (lpcmpBias)
   2657               and LPATT (lpAttenuation) */
   2658            uint32_t switchVal = ((uint32_t)lpcmpBias << 8) | (lpAttenuation ? 1U : 0U);
   2659            switch (switchVal) {
   2660              case ((0 << 8) | 1):
   2661                vrefLow  = DEVINFO->DCDCLPVCTRL2;
   2662                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS0_MASK)
   2663                           >> _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS0_SHIFT;
   2664                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS0_MASK)
   2665                           >> _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS0_SHIFT;
   2666                break;
   2667          
   2668              case ((1 << 8) | 1):
   2669                vrefLow  = DEVINFO->DCDCLPVCTRL2;
   2670                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS1_MASK)
   2671                           >> _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS1_SHIFT;
   2672                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS1_MASK)
   2673                           >> _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS1_SHIFT;
   2674                break;
   2675          
   2676              case ((2 << 8) | 1):
   2677                vrefLow  = DEVINFO->DCDCLPVCTRL3;
   2678                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS2_MASK)
   2679                           >> _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS2_SHIFT;
   2680                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS2_MASK)
   2681                           >> _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS2_SHIFT;
   2682                break;
   2683          
   2684              case ((3 << 8) | 1):
   2685                vrefLow  = DEVINFO->DCDCLPVCTRL3;
   2686                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS3_MASK)
   2687                           >> _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS3_SHIFT;
   2688                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS3_MASK)
   2689                           >> _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS3_SHIFT;
   2690                break;
   2691          
   2692              case ((0 << 8) | 0):
   2693                vrefLow  = DEVINFO->DCDCLPVCTRL0;
   2694                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS0_MASK)
   2695                           >> _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS0_SHIFT;
   2696                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS0_MASK)
   2697                           >> _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS0_SHIFT;
   2698                break;
   2699          
   2700              case ((1 << 8) | 0):
   2701                vrefLow  = DEVINFO->DCDCLPVCTRL0;
   2702                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS1_MASK)
   2703                           >> _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS1_SHIFT;
   2704                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS1_MASK)
   2705                           >> _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS1_SHIFT;
   2706                break;
   2707          
   2708              case ((2 << 8) | 0):
   2709                vrefLow  = DEVINFO->DCDCLPVCTRL1;
   2710                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS2_MASK)
   2711                           >> _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS2_SHIFT;
   2712                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS2_MASK)
   2713                           >> _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS2_SHIFT;
   2714                break;
   2715          
   2716              case ((3 << 8) | 0):
   2717                vrefLow  = DEVINFO->DCDCLPVCTRL1;
   2718                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS3_MASK)
   2719                           >> _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS3_SHIFT;
   2720                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS3_MASK)
   2721                           >> _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS3_SHIFT;
   2722                break;
   2723          
   2724              default:
   2725                EFM_ASSERT(false);
   2726                break;
   2727            }
   2728            *vrefL = vrefLow;
   2729            *vrefH = vrefHigh;
   2730          }
   2731          
   2732          /***************************************************************************//**
   2733           * @brief
   2734           *   Configure the DCDC regulator.
   2735           *
   2736           * @note
   2737           * Do not call this function if the power circuit is configured for NODCDC as
   2738           * described in the Power Configurations section of the Reference Manual.
   2739           * Instead, call @ref EMU_DCDCPowerOff().
   2740           *
   2741           * @param[in] dcdcInit
   2742           *  The DCDC initialization structure.
   2743           *
   2744           * @return
   2745           *   True if initialization parameters are valid.
   2746           ******************************************************************************/
   2747          bool EMU_DCDCInit(const EMU_DCDCInit_TypeDef *dcdcInit)
   2748          {
   2749            uint32_t lpCmpBiasSelEM234H;
   2750          
   2751          #if defined(_EMU_PWRCFG_MASK)
   2752            /* Set the external power configuration. This enables writing to the other
   2753               DCDC registers. */
   2754            EMU->PWRCFG = EMU_PWRCFG_PWRCFG_DCDCTODVDD;
   2755          
   2756            /* EMU->PWRCFG is write-once and POR reset only. Check that
   2757               the desired power configuration was set. */
   2758            if ((EMU->PWRCFG & _EMU_PWRCFG_PWRCFG_MASK) != EMU_PWRCFG_PWRCFG_DCDCTODVDD) {
   2759              /* If this assert triggers unexpectedly, power cycle the
   2760                 kit to reset the power configuration. */
   2761              EFM_ASSERT(false);
   2762              /* Return when assertions are disabled. */
   2763              return false;
   2764            }
   2765          #endif
   2766          
   2767            /* Load DCDC calibration data from the DI page. */
   2768            (void)dcdcConstCalibrationLoad();
   2769          
   2770            /* Check current parameters */
   2771            EFM_ASSERT(dcdcInit->maxCurrent_mA <= 200U);
   2772            EFM_ASSERT(dcdcInit->em01LoadCurrent_mA <= dcdcInit->maxCurrent_mA);
   2773            EFM_ASSERT(dcdcInit->reverseCurrentControl <= 200);
   2774          
   2775            if (dcdcInit->dcdcMode == emuDcdcMode_LowNoise) {
   2776              /* DCDC low-noise supports max 200 mA. */
   2777              EFM_ASSERT(dcdcInit->em01LoadCurrent_mA <= 200U);
   2778            }
   2779          #if (_SILICON_LABS_GECKO_INTERNAL_SDID != 80)
   2780            else if (dcdcInit->dcdcMode == emuDcdcMode_LowPower) {
   2781              /* Up to 10 mA is supported for EM01-LP mode. */
   2782              EFM_ASSERT(dcdcInit->em01LoadCurrent_mA <= 10U);
   2783            }
   2784          #endif
   2785            else {
   2786              /* No need to check the EM01 load limit. */
   2787            }
   2788          
   2789            /* EM2/3/4 current above 10 mA is not supported. */
   2790            EFM_ASSERT(dcdcInit->em234LoadCurrent_uA <= 10000U);
   2791          
   2792            if (dcdcInit->em234LoadCurrent_uA < 75U) {
   2793              lpCmpBiasSelEM234H  = 0;
   2794            } else if (dcdcInit->em234LoadCurrent_uA < 500U) {
   2795              lpCmpBiasSelEM234H  = 1U << _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT;
   2796            } else if (dcdcInit->em234LoadCurrent_uA < 2500U) {
   2797              lpCmpBiasSelEM234H  = 2U << _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT;
   2798            } else {
   2799              lpCmpBiasSelEM234H  = 3U << _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT;
   2800            }
   2801          
   2802            /* ==== THESE NEXT STEPS ARE STRONGLY ORDER DEPENDENT ==== */
   2803          
   2804            /* Set DCDC low-power mode comparator bias selection. */
   2805          
   2806            /* 1. Set DCDC low-power mode comparator bias selection and forced CCM.
   2807                  => Updates DCDCMISCCTRL_LNFORCECCM */
   2808            EMU->DCDCMISCCTRL = (EMU->DCDCMISCCTRL & ~(_GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_MASK
   2809                                                       | _EMU_DCDCMISCCTRL_LNFORCECCM_MASK))
   2810                                | ((uint32_t)lpCmpBiasSelEM234H
   2811                                   | (dcdcInit->reverseCurrentControl >= 0
   2812                                      ? EMU_DCDCMISCCTRL_LNFORCECCM : 0U));
   2813          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   2814            /* Only 10 mA EM01-LP current is supported. */
   2815            EMU->DCDCLPEM01CFG = (EMU->DCDCLPEM01CFG & ~_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   2816                                 | EMU_DCDCLPEM01CFG_LPCMPBIASEM01_BIAS3;
   2817          #endif
   2818          
   2819            /* 2. Set recommended and validated current optimization settings.
   2820                  <= Depends on LNFORCECCM
   2821                  => Updates DCDCLNFREQCTRL_RCOBAND */
   2822            dcdcEm01LoadCurrent_mA = dcdcInit->em01LoadCurrent_mA;
   2823            dcdcValidatedConfigSet();
   2824          
   2825            /* 3. Updated static currents and limits user data.
   2826                  Limiters are updated in @ref EMU_DCDCOptimizeSlice(). */
   2827            userCurrentLimitsSet(dcdcInit->maxCurrent_mA,
   2828                                 dcdcInit->reverseCurrentControl);
   2829          
   2830            /* 4. Optimize LN slice based on the given user input load current.
   2831                  <= Depends on DCDCMISCCTRL_LNFORCECCM and DCDCLNFREQCTRL_RCOBAND
   2832                  <= Depends on dcdcInit->maxCurrent_mA and dcdcInit->reverseCurrentControl
   2833                  => Updates DCDCMISCCTRL_P/NFETCNT
   2834                  => Updates DCDCMISCCTRL_LNCLIMILIMSEL and DCDCMISCCTRL_LPCLIMILIMSEL
   2835                  => Updates DCDCZDETCTRL_ZDETILIMSEL */
   2836            EMU_DCDCOptimizeSlice(dcdcInit->em01LoadCurrent_mA);
   2837          
   2838            /* ======================================================= */
   2839          
   2840            /* Set DCDC low noise mode compensator control register. */
   2841            compCtrlSet(dcdcInit->dcdcLnCompCtrl);
   2842          
   2843            /* Set DCDC output voltage. */
   2844            if (!EMU_DCDCOutputVoltageSet(dcdcInit->mVout, true, true)) {
   2845              EFM_ASSERT(false);
   2846              /* Return when assertions are disabled. */
   2847              return false;
   2848            }
   2849          
   2850          #if (_SILICON_LABS_GECKO_INTERNAL_SDID == 80)
   2851            /* Select analog peripheral power supply. This must be done before
   2852               DCDC mode is set for all EFM32xG1 and EFR32xG1 devices. */
   2853            BUS_RegBitWrite(&EMU->PWRCTRL,
   2854                            _EMU_PWRCTRL_ANASW_SHIFT,
   2855                            dcdcInit->anaPeripheralPower ? 1 : 0);
   2856          #endif
   2857          
   2858          #if defined(_EMU_PWRCTRL_REGPWRSEL_MASK)
   2859            /* Select DVDD as input to the digital regulator. The switch to DVDD will take
   2860               effect once the DCDC output is stable. */
   2861            #if defined (EMU_HAS_SET_CLEAR)
   2862            EMU->PWRCTRL_SET = EMU_PWRCTRL_REGPWRSEL_DVDD;
   2863            #else
   2864            EMU->PWRCTRL |= EMU_PWRCTRL_REGPWRSEL_DVDD;
   2865            #endif
   2866          #endif
   2867          
   2868            /* Set EM0 DCDC operating mode. Output voltage set in
   2869               @ref EMU_DCDCOutputVoltageSet() above takes effect if mode
   2870               is changed from bypass/off mode. */
   2871            EMU_DCDCModeSet(dcdcInit->dcdcMode);
   2872          
   2873          #if (_SILICON_LABS_GECKO_INTERNAL_SDID != 80)
   2874            /* Select the analog peripheral power supply. This must be done after
   2875               DCDC mode is set for all devices other than EFM32xG1 and EFR32xG1. */
   2876            BUS_RegBitWrite(&EMU->PWRCTRL,
   2877                            _EMU_PWRCTRL_ANASW_SHIFT,
   2878                            dcdcInit->anaPeripheralPower
   2879                            == emuDcdcAnaPeripheralPower_DCDC ? 1U : 0U);
   2880          #endif
   2881          
   2882            return true;
   2883          }
   2884          
   2885          /***************************************************************************//**
   2886           * @brief
   2887           *   Set DCDC regulator operating mode.
   2888           *
   2889           * @param[in] dcdcMode
   2890           *   DCDC mode.
   2891           ******************************************************************************/
   2892          void EMU_DCDCModeSet(EMU_DcdcMode_TypeDef dcdcMode)
   2893          {
   2894            bool dcdcLocked;
   2895            uint32_t currentDcdcMode;
   2896          
   2897            dcdcLocked = (EMU->PWRLOCK == EMU_PWRLOCK_LOCKKEY_LOCKED);
   2898            EMU_PowerUnlock();
   2899          
   2900            /* Wait for any previous write sync to complete and read DCDC mode. */
   2901            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   2902            }
   2903            currentDcdcMode = (EMU->DCDCCTRL & _EMU_DCDCCTRL_DCDCMODE_MASK);
   2904          
   2905            /* Enable bypass current limiter when not in bypass mode to prevent
   2906               excessive current between VREGVDD and DVDD supplies when reentering bypass mode.  */
   2907            if (currentDcdcMode != EMU_DCDCCTRL_DCDCMODE_BYPASS) {
   2908              BUS_RegBitWrite(&EMU->DCDCCLIMCTRL, _EMU_DCDCCLIMCTRL_BYPLIMEN_SHIFT, 1);
   2909            }
   2910          
   2911            if ((EMU_DcdcMode_TypeDef)currentDcdcMode == dcdcMode) {
   2912              /* Mode already set. If already in bypass, make sure the bypass current limiter
   2913                 is disabled. */
   2914              if (dcdcMode == emuDcdcMode_Bypass) {
   2915                BUS_RegBitWrite(&EMU->DCDCCLIMCTRL, _EMU_DCDCCLIMCTRL_BYPLIMEN_SHIFT, 0);
   2916              }
   2917              return;
   2918            }
   2919          
   2920          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2921          
   2922            /* Fix for errata DCDC_E203. */
   2923            if ((currentDcdcMode == EMU_DCDCCTRL_DCDCMODE_BYPASS)
   2924                && (dcdcMode == emuDcdcMode_LowNoise)) {
   2925              errataFixDcdcHsState = errataFixDcdcHsBypassLn;
   2926            }
   2927          #endif // (_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2928          
   2929          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_84)
   2930          
   2931            /* Fix for errata DCDC_E204. */
   2932            if (((currentDcdcMode == EMU_DCDCCTRL_DCDCMODE_OFF) || (currentDcdcMode == EMU_DCDCCTRL_DCDCMODE_BYPASS))
   2933                && ((dcdcMode == emuDcdcMode_LowPower) || (dcdcMode == emuDcdcMode_LowNoise))) {
   2934              /* Always start in LOWNOISE. Switch to LOWPOWER mode once LOWNOISE startup is complete. */
   2935              EMU_IntClear(EMU_IFC_DCDCLNRUNNING);
   2936              while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   2937              }
   2938              EMU->DCDCCTRL = (EMU->DCDCCTRL & ~_EMU_DCDCCTRL_DCDCMODE_MASK) | EMU_DCDCCTRL_DCDCMODE_LOWNOISE;
   2939              while ((EMU_IntGet() & EMU_IF_DCDCLNRUNNING) == 0U) {
   2940              }
   2941            }
   2942          #endif // (_SILICON_LABS_GECKO_INTERNAL_SDID_84)
   2943          
   2944            /* Set user-requested mode. */
   2945            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0UL) {
   2946            }
   2947            EMU->DCDCCTRL = (EMU->DCDCCTRL & ~_EMU_DCDCCTRL_DCDCMODE_MASK)
   2948                            | (uint32_t)dcdcMode;
   2949          
   2950            /* Disable bypass current limiter after bypass mode is entered.
   2951               Enable the limiter if any other mode is entered. */
   2952            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   2953            }
   2954            BUS_RegBitWrite(&EMU->DCDCCLIMCTRL,
   2955                            _EMU_DCDCCLIMCTRL_BYPLIMEN_SHIFT,
   2956                            dcdcMode == emuDcdcMode_Bypass ? 0U : 1U);
   2957          
   2958            if (dcdcLocked) {
   2959              EMU_PowerLock();
   2960            }
   2961          }
   2962          
   2963          #if defined(EMU_DCDCCTRL_DCDCMODEEM23)
   2964          /***************************************************************************//**
   2965           * @brief
   2966           *   Set DCDC Mode EM23 operating mode.
   2967           *
   2968           * @param[in] dcdcModeEM23
   2969           *   DCDC mode EM23.
   2970           ******************************************************************************/
   2971          void EMU_DCDCModeEM23Set(EMU_DcdcModeEM23_TypeDef dcdcModeEM23)
   2972          {
   2973            bool dcdcLocked;
   2974          
   2975            dcdcLocked = (EMU->PWRLOCK == EMU_PWRLOCK_LOCKKEY_LOCKED);
   2976            EMU_PowerUnlock();
   2977          
   2978            /* Set user-requested mode. */
   2979            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0UL) {
   2980            }
   2981            EMU->DCDCCTRL = (EMU->DCDCCTRL & ~_EMU_DCDCCTRL_DCDCMODEEM23_MASK)
   2982                            | (uint32_t)dcdcModeEM23;
   2983          
   2984            if (dcdcLocked) {
   2985              EMU_PowerLock();
   2986            }
   2987          }
   2988          #endif
   2989          
   2990          /***************************************************************************//**
   2991           * @brief
   2992           *   Power off the DCDC regulator.
   2993           *
   2994           * @details
   2995           *   This function powers off the DCDC controller. This function should only be
   2996           *   used if the external power circuit is wired for no DCDC. If the external power
   2997           *   circuit is wired for DCDC usage, use @ref EMU_DCDCInit() and set the
   2998           *   DCDC in bypass mode to disable DCDC.
   2999           *
   3000           * @return
   3001           *   Return false if the DCDC could not be disabled.
   3002           ******************************************************************************/
   3003          bool EMU_DCDCPowerOff(void)
   3004          {
   3005            bool dcdcModeSet;
   3006          
   3007          #if defined(_EMU_PWRCFG_MASK)
   3008            /* Set DCDCTODVDD only to enable write access to EMU->DCDCCTRL. */
   3009            EMU->PWRCFG = EMU_PWRCFG_PWRCFG_DCDCTODVDD;
   3010          #endif
   3011          
   3012            /* Select DVDD as input to the digital regulator. */
   3013          #if defined(EMU_PWRCTRL_IMMEDIATEPWRSWITCH)
   3014           #if defined (EMU_HAS_SET_CLEAR)
   3015            EMU->PWRCTRL_SET = EMU_PWRCTRL_REGPWRSEL_DVDD | EMU_PWRCTRL_IMMEDIATEPWRSWITCH;
   3016            #else
   3017            EMU->PWRCTRL |= EMU_PWRCTRL_REGPWRSEL_DVDD | EMU_PWRCTRL_IMMEDIATEPWRSWITCH;
   3018            #endif
   3019          #elif defined(EMU_PWRCTRL_REGPWRSEL_DVDD)
   3020            #if defined (EMU_HAS_SET_CLEAR)
   3021            EMU->PWRCTRL_SET = EMU_PWRCTRL_REGPWRSEL_DVDD;
   3022            #else
   3023            EMU->PWRCTRL |= EMU_PWRCTRL_REGPWRSEL_DVDD;
   3024            #endif
   3025          #endif
   3026          
   3027            /* Set DCDC to OFF and disable LP in EM2/3/4. Verify that the required
   3028               mode could be set. */
   3029            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   3030            }
   3031            EMU->DCDCCTRL = EMU_DCDCCTRL_DCDCMODE_OFF;
   3032          
   3033            dcdcModeSet = (EMU->DCDCCTRL == EMU_DCDCCTRL_DCDCMODE_OFF);
   3034            EFM_ASSERT(dcdcModeSet);
   3035          
   3036            return dcdcModeSet;
   3037          }
   3038          
   3039          /***************************************************************************//**
   3040           * @brief
   3041           *   Set DCDC LN regulator conduction mode.
   3042           *
   3043           * @param[in] conductionMode
   3044           *   DCDC LN conduction mode.
   3045           * @param[in] rcoDefaultSet
   3046           *   The default DCDC RCO band for the conductionMode will be used if true.
   3047           *   Otherwise, the current RCO configuration is used.
   3048           ******************************************************************************/
   3049          void EMU_DCDCConductionModeSet(EMU_DcdcConductionMode_TypeDef conductionMode,
   3050                                         bool rcoDefaultSet)
   3051          {
   3052            EMU_DcdcMode_TypeDef currentDcdcMode
   3053              = (EMU_DcdcMode_TypeDef)((uint32_t)
   3054                                       (EMU->DCDCCTRL & _EMU_DCDCCTRL_DCDCMODE_MASK));
   3055            EMU_DcdcLnRcoBand_TypeDef rcoBand
   3056              = (EMU_DcdcLnRcoBand_TypeDef)((uint32_t)
   3057                                            ((EMU->DCDCLNFREQCTRL
   3058                                              & _EMU_DCDCLNFREQCTRL_RCOBAND_MASK)
   3059                                             >> _EMU_DCDCLNFREQCTRL_RCOBAND_SHIFT));
   3060          
   3061            /* Set bypass mode and wait for bypass mode to settle before
   3062               EMU_DCDCMISCCTRL_LNFORCECCM is set. Restore current DCDC mode. */
   3063            EMU_IntClear(EMU_IFC_DCDCINBYPASS);
   3064            EMU_DCDCModeSet(emuDcdcMode_Bypass);
   3065            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   3066            }
   3067            while ((EMU_IntGet() & EMU_IF_DCDCINBYPASS) == 0U) {
   3068            }
   3069            if (conductionMode == emuDcdcConductionMode_DiscontinuousLN) {
   3070              EMU->DCDCMISCCTRL &= ~EMU_DCDCMISCCTRL_LNFORCECCM;
   3071              if (rcoDefaultSet) {
   3072                EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_3MHz);
   3073              } else {
   3074                /* emuDcdcConductionMode_DiscontinuousLN supports up to 4MHz LN RCO. */
   3075                EFM_ASSERT(rcoBand <= emuDcdcLnRcoBand_4MHz);
   3076              }
   3077            } else {
   3078              EMU->DCDCMISCCTRL |= EMU_DCDCMISCCTRL_LNFORCECCM;
   3079              if (rcoDefaultSet) {
   3080                EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_7MHz);
   3081              }
   3082            }
   3083            EMU_DCDCModeSet(currentDcdcMode);
   3084            /* Update slice configuration as it depends on conduction mode and RCO band.*/
   3085            EMU_DCDCOptimizeSlice(dcdcEm01LoadCurrent_mA);
   3086          }
   3087          
   3088          /***************************************************************************//**
   3089           * @brief
   3090           *   Set the DCDC output voltage.
   3091           *
   3092           * @note
   3093           *   The DCDC is not characterized for the entire valid output voltage range.
   3094           *   For that reason an upper limit of 3.0V output voltage is enforced.
   3095           *
   3096           * @param[in] mV
   3097           *   Target DCDC output voltage in mV.
   3098           *
   3099           * @param[in] setLpVoltage
   3100           *   Update LP voltage
   3101           *
   3102           * @param[in] setLnVoltage
   3103           *   Update LN voltage
   3104           *
   3105           * @return
   3106           *   True if the mV parameter is valid.
   3107           ******************************************************************************/
   3108          bool EMU_DCDCOutputVoltageSet(uint32_t mV,
   3109                                        bool setLpVoltage,
   3110                                        bool setLnVoltage)
   3111          {
   3112          #if defined(_DEVINFO_DCDCLNVCTRL0_3V0LNATT1_MASK)
   3113          
   3114            bool validOutVoltage;
   3115            bool attenuationSet;
   3116            uint32_t mVlow = 0;
   3117            uint32_t mVhigh = 0;
   3118            uint32_t mVdiff;
   3119            uint32_t vrefVal[DCDC_TRIM_MODES] = { 0 };
   3120            uint32_t vrefLow[DCDC_TRIM_MODES] = { 0 };
   3121            uint32_t vrefHigh[DCDC_TRIM_MODES] = { 0 };
   3122            uint8_t lpcmpBias[DCDC_TRIM_MODES] = { 0 };
   3123          
   3124            /* Check that the set voltage is within valid range.
   3125               Voltages are obtained from the data sheet. */
   3126            validOutVoltage = (mV >= PWRCFG_DCDCTODVDD_VMIN)
   3127                              && (mV <= PWRCFG_DCDCTODVDD_VMAX);
   3128          
   3129            if (!validOutVoltage) {
   3130              EFM_ASSERT(false);
   3131              /* Return when assertions are disabled. */
   3132              return false;
   3133            }
   3134          
   3135            /* Set attenuation to use and low/high range. */
   3136            attenuationSet = mV > 1800U;
   3137            if (attenuationSet) {
   3138              mVlow = 1800;
   3139              mVhigh = 3000;
   3140              mVdiff = mVhigh - mVlow;
   3141            } else {
   3142              mVlow = 1200;
   3143              mVhigh = 1800;
   3144              mVdiff = mVhigh - mVlow;
   3145            }
   3146          
   3147            /* Get 2-point calibration data from DEVINFO. */
   3148          
   3149            /* LN mode */
   3150            if (attenuationSet) {
   3151              vrefLow[dcdcTrimMode_LN]  = DEVINFO->DCDCLNVCTRL0;
   3152              vrefHigh[dcdcTrimMode_LN] = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_3V0LNATT1_MASK)
   3153                                          >> _DEVINFO_DCDCLNVCTRL0_3V0LNATT1_SHIFT;
   3154              vrefLow[dcdcTrimMode_LN]  = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_1V8LNATT1_MASK)
   3155                                          >> _DEVINFO_DCDCLNVCTRL0_1V8LNATT1_SHIFT;
   3156            } else {
   3157              vrefLow[dcdcTrimMode_LN]  = DEVINFO->DCDCLNVCTRL0;
   3158              vrefHigh[dcdcTrimMode_LN] = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_1V8LNATT0_MASK)
   3159                                          >> _DEVINFO_DCDCLNVCTRL0_1V8LNATT0_SHIFT;
   3160              vrefLow[dcdcTrimMode_LN]  = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_1V2LNATT0_MASK)
   3161                                          >> _DEVINFO_DCDCLNVCTRL0_1V2LNATT0_SHIFT;
   3162            }
   3163          
   3164            /* LP EM234H mode */
   3165            lpcmpBias[dcdcTrimMode_EM234H_LP] = (uint8_t)
   3166                                                ((EMU->DCDCMISCCTRL & _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_MASK)
   3167                                                 >> _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT);
   3168            lpGetDevinfoVrefLowHigh(&vrefLow[dcdcTrimMode_EM234H_LP],
   3169                                    &vrefHigh[dcdcTrimMode_EM234H_LP],
   3170                                    attenuationSet,
   3171                                    lpcmpBias[dcdcTrimMode_EM234H_LP]);
   3172          
   3173          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3174            /* LP EM01 mode */
   3175            lpcmpBias[dcdcTrimMode_EM01_LP] = (uint8_t)
   3176                                              ((EMU->DCDCLPEM01CFG & _EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3177                                               >> _EMU_DCDCLPEM01CFG_LPCMPBIASEM01_SHIFT);
   3178            lpGetDevinfoVrefLowHigh(&vrefLow[dcdcTrimMode_EM01_LP],
   3179                                    &vrefHigh[dcdcTrimMode_EM01_LP],
   3180                                    attenuationSet,
   3181                                    lpcmpBias[dcdcTrimMode_EM01_LP]);
   3182          #endif
   3183          
   3184            /* Calculate output voltage trims. */
   3185            vrefVal[dcdcTrimMode_LN]         = ((mV - mVlow) * (vrefHigh[dcdcTrimMode_LN] - vrefLow[dcdcTrimMode_LN]))
   3186                                               / mVdiff;
   3187            vrefVal[dcdcTrimMode_LN]        += vrefLow[dcdcTrimMode_LN];
   3188          
   3189            vrefVal[dcdcTrimMode_EM234H_LP]  = ((mV - mVlow) * (vrefHigh[dcdcTrimMode_EM234H_LP] - vrefLow[dcdcTrimMode_EM234H_LP]))
   3190                                               / mVdiff;
   3191            vrefVal[dcdcTrimMode_EM234H_LP] += vrefLow[dcdcTrimMode_EM234H_LP];
   3192          
   3193          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3194            vrefVal[dcdcTrimMode_EM01_LP]    = ((mV - mVlow) * (vrefHigh[dcdcTrimMode_EM01_LP] - vrefLow[dcdcTrimMode_EM01_LP]))
   3195                                               / mVdiff;
   3196            vrefVal[dcdcTrimMode_EM01_LP]   += vrefLow[dcdcTrimMode_EM01_LP];
   3197          #endif
   3198          
   3199            /* Range checks */
   3200            if ((vrefVal[dcdcTrimMode_LN] > vrefHigh[dcdcTrimMode_LN])
   3201                || (vrefVal[dcdcTrimMode_LN] < vrefLow[dcdcTrimMode_LN])
   3202          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3203                || (vrefVal[dcdcTrimMode_EM01_LP] > vrefHigh[dcdcTrimMode_EM01_LP])
   3204                || (vrefVal[dcdcTrimMode_EM01_LP] < vrefLow[dcdcTrimMode_EM01_LP])
   3205          #endif
   3206                || (vrefVal[dcdcTrimMode_EM234H_LP] > vrefHigh[dcdcTrimMode_EM234H_LP])
   3207                || (vrefVal[dcdcTrimMode_EM234H_LP] < vrefLow[dcdcTrimMode_EM234H_LP])) {
   3208              EFM_ASSERT(false);
   3209              /* Return when assertions are disabled. */
   3210              return false;
   3211            }
   3212          
   3213            /* Update output voltage tuning for LN and LP modes. */
   3214            if (setLnVoltage) {
   3215              EMU->DCDCLNVCTRL = (EMU->DCDCLNVCTRL & ~(_EMU_DCDCLNVCTRL_LNVREF_MASK | _EMU_DCDCLNVCTRL_LNATT_MASK))
   3216                                 | (vrefVal[dcdcTrimMode_LN] << _EMU_DCDCLNVCTRL_LNVREF_SHIFT)
   3217                                 | (attenuationSet ? EMU_DCDCLNVCTRL_LNATT : 0U);
   3218            }
   3219          
   3220            if (setLpVoltage) {
   3221              /* Load LP EM234H comparator hysteresis calibration. */
   3222              if (!(lpCmpHystCalibrationLoad(attenuationSet, lpcmpBias[dcdcTrimMode_EM234H_LP], dcdcTrimMode_EM234H_LP))) {
   3223                EFM_ASSERT(false);
   3224                /* Return when assertions are disabled. */
   3225                return false;
   3226              }
   3227          
   3228          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3229              /* Load LP EM234H comparator hysteresis calibration. */
   3230              if (!(lpCmpHystCalibrationLoad(attenuationSet, lpcmpBias[dcdcTrimMode_EM01_LP], dcdcTrimMode_EM01_LP))) {
   3231                EFM_ASSERT(false);
   3232                /* Return when assertions are disabled. */
   3233                return false;
   3234              }
   3235          
   3236              /* LP VREF is that maximum of trims for EM01 and EM234H. */
   3237              vrefVal[dcdcTrimMode_EM234H_LP] = SL_MAX(vrefVal[dcdcTrimMode_EM234H_LP], vrefVal[dcdcTrimMode_EM01_LP]);
   3238          #endif
   3239          
   3240              /* Don't exceed the maximum available code as specified in the reference manual for EMU_DCDCLPVCTRL. */
   3241              vrefVal[dcdcTrimMode_EM234H_LP] = SL_MIN(vrefVal[dcdcTrimMode_EM234H_LP], 0xE7U);
   3242              EMU->DCDCLPVCTRL = (EMU->DCDCLPVCTRL & ~(_EMU_DCDCLPVCTRL_LPVREF_MASK | _EMU_DCDCLPVCTRL_LPATT_MASK))
   3243                                 | (vrefVal[dcdcTrimMode_EM234H_LP] << _EMU_DCDCLPVCTRL_LPVREF_SHIFT)
   3244                                 | (attenuationSet ? EMU_DCDCLPVCTRL_LPATT : 0U);
   3245            }
   3246          #endif
   3247            return true;
   3248          }
   3249          
   3250          /***************************************************************************//**
   3251           * @brief
   3252           *   Optimize the DCDC slice count based on the estimated average load current
   3253           *   in EM0.
   3254           *
   3255           * @param[in] em0LoadCurrentmA
   3256           *   Estimated average EM0 load current in mA.
   3257           ******************************************************************************/
   3258          void EMU_DCDCOptimizeSlice(uint32_t em0LoadCurrentmA)
   3259          {
   3260            uint32_t sliceCount = 0;
   3261            uint32_t rcoBand = (EMU->DCDCLNFREQCTRL & _EMU_DCDCLNFREQCTRL_RCOBAND_MASK)
   3262                               >> _EMU_DCDCLNFREQCTRL_RCOBAND_SHIFT;
   3263          
   3264            /* Set the recommended slice count. */
   3265            if (((EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_LNFORCECCM_MASK) != 0U)
   3266                && (rcoBand >= (uint32_t)emuDcdcLnRcoBand_5MHz)) {
   3267              if (em0LoadCurrentmA < 20U) {
   3268                sliceCount = 4;
   3269              } else if ((em0LoadCurrentmA >= 20U) && (em0LoadCurrentmA < 40U)) {
   3270                sliceCount = 8;
   3271              } else {
   3272                sliceCount = 16;
   3273              }
   3274            } else if (((EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_LNFORCECCM_MASK) == 0U)
   3275                       && (rcoBand <= (uint32_t)emuDcdcLnRcoBand_4MHz)) {
   3276              if (em0LoadCurrentmA < 10U) {
   3277                sliceCount = 4;
   3278              } else if ((em0LoadCurrentmA >= 10U) && (em0LoadCurrentmA < 20U)) {
   3279                sliceCount = 8;
   3280              } else {
   3281                sliceCount = 16;
   3282              }
   3283            } else if (((EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_LNFORCECCM_MASK) != 0U)
   3284                       && (rcoBand <= (uint32_t)emuDcdcLnRcoBand_4MHz)) {
   3285              if (em0LoadCurrentmA < 40U) {
   3286                sliceCount = 8;
   3287              } else {
   3288                sliceCount = 16;
   3289              }
   3290            } else {
   3291              /* This configuration is not recommended. @ref EMU_DCDCInit() applies a recommended
   3292                 configuration. */
   3293              EFM_ASSERT(false);
   3294            }
   3295          
   3296            /* The selected slices are PSLICESEL + 1. */
   3297            sliceCount--;
   3298          
   3299            /* Apply slice count to both N and P slice. */
   3300            sliceCount = (sliceCount << _EMU_DCDCMISCCTRL_PFETCNT_SHIFT
   3301                          | sliceCount << _EMU_DCDCMISCCTRL_NFETCNT_SHIFT);
   3302            EMU->DCDCMISCCTRL = (EMU->DCDCMISCCTRL & ~(_EMU_DCDCMISCCTRL_PFETCNT_MASK
   3303                                                       | _EMU_DCDCMISCCTRL_NFETCNT_MASK))
   3304                                | sliceCount;
   3305          
   3306            /* Update the current limiters. */
   3307            currentLimitersUpdate();
   3308          }
   3309          
   3310          /***************************************************************************//**
   3311           * @brief
   3312           *   Set DCDC Low-noise RCO band.
   3313           *
   3314           * @param[in] band
   3315           *   RCO band to set.
   3316           ******************************************************************************/
   3317          void EMU_DCDCLnRcoBandSet(EMU_DcdcLnRcoBand_TypeDef band)
   3318          {
   3319            uint32_t forcedCcm;
   3320            forcedCcm = BUS_RegBitRead(&EMU->DCDCMISCCTRL, _EMU_DCDCMISCCTRL_LNFORCECCM_SHIFT);
   3321          
   3322            /* DCM mode supports up to 4 MHz LN RCO. */
   3323            EFM_ASSERT(((forcedCcm == 0U) && band <= emuDcdcLnRcoBand_4MHz)
   3324                       || (forcedCcm != 0U));
   3325          
   3326            EMU->DCDCLNFREQCTRL = (EMU->DCDCLNFREQCTRL & ~_EMU_DCDCLNFREQCTRL_RCOBAND_MASK)
   3327                                  | ((uint32_t)band << _EMU_DCDCLNFREQCTRL_RCOBAND_SHIFT);
   3328          
   3329            /* Update slice configuration as this depends on the RCO band. */
   3330            EMU_DCDCOptimizeSlice(dcdcEm01LoadCurrent_mA);
   3331          }
   3332          #endif /* EMU_SERIES1_DCDC_BUCK_PRESENT */
   3333          
   3334          #if defined(EMU_SERIES2_DCDC_BOOST_PRESENT)
   3335          /***************************************************************************//**
   3336           * @brief
   3337           *   Configure the DCDC Boost regulator.
   3338           *
   3339           * @param[in] dcdcBoostInit
   3340           *  The DCDC initialization structure.
   3341           *
   3342           * @return
   3343           *   True if initialization parameters are valid.
   3344           ******************************************************************************/
   3345          bool EMU_DCDCBoostInit(const EMU_DCDCBoostInit_TypeDef *dcdcBoostInit)
   3346          {
   3347            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3348          #if defined(_DCDC_DVDDBBCFG_MASK)
   3349          #if defined(_EMU_VREGVDDCMPCTRL_THRESSEL_MASK)
   3350            EMU->VREGVDDCMPCTRL = ((uint32_t)dcdcBoostInit->cmpThreshold
   3351                                   << _EMU_VREGVDDCMPCTRL_THRESSEL_SHIFT)
   3352                                  | EMU_VREGVDDCMPCTRL_VREGINCMPEN;
   3353          #endif
   3354            DCDC->DVDDBBCFG   = (DCDC->DVDDBBCFG & ~(_DCDC_DVDDBBCFG_DVDDBBEN_MASK | _DCDC_DVDDBBCFG_DVDDBSTEN_MASK))
   3355                                | (uint32_t)DCDC_DVDDBBCFG_DVDDBBEN
   3356                                | (uint32_t)DCDC_DVDDBBCFG_DVDDBSTEN;
   3357          
   3358            DCDC->CTRL = (DCDC->CTRL & ~(_DCDC_CTRL_IPKTMAXCTRL_MASK))
   3359                         | ((uint32_t)dcdcBoostInit->tonMax << _DCDC_CTRL_IPKTMAXCTRL_SHIFT);
   3360            DCDC->EM01CTRL0 = ((uint32_t)dcdcBoostInit->driveSpeedEM01 << _DCDC_EM01CTRL0_DRVSPEED_SHIFT)
   3361                              | ((uint32_t)dcdcBoostInit->peakCurrentEM01 << _DCDC_EM01CTRL0_IPKVAL_SHIFT)
   3362                              | ((uint32_t)dcdcBoostInit->ledPeakCurrentEM01 << _DCDC_EM01CTRL0_IPKLEDVAL_SHIFT);
   3363            DCDC->EM23CTRL0 = ((uint32_t)dcdcBoostInit->driveSpeedEM23 << _DCDC_EM23CTRL0_DRVSPEED_SHIFT)
   3364                              | ((uint32_t)dcdcBoostInit->peakCurrentEM23 << _DCDC_EM23CTRL0_IPKVAL_SHIFT)
   3365                              | ((uint32_t)dcdcBoostInit->ledPeakCurrentEM23 << _DCDC_EM23CTRL0_IPKLEDVAL_SHIFT);
   3366          
   3367          #if defined(_DCDC_LEDVDDRAMPCFG_MASK)
   3368            BUS_RegMaskedWrite(&DCDC->LEDVDDRAMPCFG,
   3369                               _DCDC_LEDVDDRAMPCFG_LEDVDDVREGSTEPSIZE_MASK,
   3370                               (uint32_t)dcdcBoostInit->ledvddRampStepSize << _DCDC_LEDVDDRAMPCFG_LEDVDDVREGSTEPSIZE_SHIFT);
   3371            BUS_RegMaskedWrite(&DCDC->LEDVDDRAMPCFG,
   3372                               _DCDC_LEDVDDRAMPCFG_LEDVDDTOCNTLD_MASK,
   3373                               (uint32_t)dcdcBoostInit->ledvddRampTimeoutCntld << _DCDC_LEDVDDRAMPCFG_LEDVDDTOCNTLD_SHIFT);
   3374            BUS_RegMaskedWrite(&DCDC->LEDVDDRAMPCFG,
   3375                               _DCDC_LEDVDDRAMPCFG_LEDVDDSTEPUPWAIT_MASK,
   3376                               (uint32_t)dcdcBoostInit->ledvddRampStepUpWait << _DCDC_LEDVDDRAMPCFG_LEDVDDSTEPUPWAIT_SHIFT);
   3377          #endif
   3378          #if defined(_DCDC_LEDVDDBCTRL_LEDVDDEN_MASK)
   3379            BUS_RegMaskedWrite(&DCDC->LEDVDDBCTRL,
   3380                               _DCDC_LEDVDDBCTRL_LEDVDDEN_MASK,
   3381                               (uint32_t)_DCDC_LEDVDDBCTRL_LEDVDDEN_Enable << _DCDC_LEDVDDBCTRL_LEDVDDEN_SHIFT);
   3382          #endif
   3383          #if defined(_DCDC_OUTEN_LEDVDDOUTEN_MASK)
   3384            BUS_RegMaskedWrite(&DCDC->OUTEN,
   3385                               _DCDC_OUTEN_LEDVDDOUTEN_MASK,
   3386                               (uint32_t)_DCDC_OUTEN_LEDVDDOUTEN_enable << _DCDC_OUTEN_LEDVDDOUTEN_SHIFT);
   3387          #endif
   3388          
   3389          #if defined(_DCDC_OUTEN_DVDDOUTEN_MASK) && defined(_DCDC_OUTEN_DECOUTEN_MASK)
   3390            DCDC->OUTEN |= DCDC_OUTEN_DVDDOUTEN_enable | DCDC_OUTEN_DECOUTEN_enable;
   3391          #endif
   3392          
   3393            EMU_DCDCModeSet(emuDcdcMode_Regulation);
   3394          #if defined(_DCDC_SYNCBUSY_MASK)
   3395            EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3396          #endif
   3397          
   3398            EMU_DCDCUpdatedHook();
   3399          #else
   3400            bool dcdcLocked;
   3401          
   3402          #if defined(_DCDC_EN_EN_MASK)
   3403            DCDC->EN_SET    = DCDC_EN_EN;
   3404          #endif
   3405            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3406            EMU_DCDCUnlock();
   3407          
   3408          #if defined(_DCDC_SYNCBUSY_MASK)
   3409            EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3410          #endif
   3411          
   3412          #if defined(_DCDC_CTRL_DVDDBSTPRG_MASK)
   3413            BUS_RegMaskedWrite(&DCDC->CTRL,
   3414                               _DCDC_CTRL_DVDDBSTPRG_MASK,
   3415                               ((uint32_t)dcdcBoostInit->outputVoltage << _DCDC_CTRL_DVDDBSTPRG_SHIFT));
   3416          #endif
   3417          
   3418            DCDC->BSTCTRL = (DCDC->BSTCTRL & ~(_DCDC_BSTCTRL_IPKTMAXCTRL_MASK))
   3419                            | ((uint32_t)dcdcBoostInit->tonMax << _DCDC_BSTCTRL_IPKTMAXCTRL_SHIFT);
   3420            DCDC->BSTEM01CTRL = ((uint32_t)dcdcBoostInit->driveSpeedEM01 << _DCDC_BSTEM01CTRL_DRVSPEED_SHIFT)
   3421                                | ((uint32_t)dcdcBoostInit->peakCurrentEM01 << _DCDC_BSTEM01CTRL_IPKVAL_SHIFT);
   3422            DCDC->BSTEM23CTRL = ((uint32_t)dcdcBoostInit->driveSpeedEM23 << _DCDC_BSTEM23CTRL_DRVSPEED_SHIFT)
   3423                                | ((uint32_t)dcdcBoostInit->peakCurrentEM23 << _DCDC_BSTEM23CTRL_IPKVAL_SHIFT);
   3424          
   3425            EMU_BoostExternalShutdownEnable(dcdcBoostInit->externalShutdownEn);
   3426          
   3427            EMU_DCDCModeSet(emuDcdcMode_Regulation);
   3428          
   3429            if (dcdcLocked) {
   3430              EMU_DCDCLock();
   3431            }
   3432          
   3433            EMU_DCDCUpdatedHook();
   3434          #endif
   3435            return true;
   3436          }
   3437          
   3438          /***************************************************************************//**
   3439           * @brief
   3440           *   Set EM01 mode Boost Peak Current setting.
   3441           *
   3442           * @param[in] boostPeakCurrentEM01
   3443           *  Boost Peak load current coefficient in EM01 mode.
   3444           ******************************************************************************/
   3445          void EMU_EM01BoostPeakCurrentSet(const EMU_DcdcBoostEM01PeakCurrent_TypeDef boostPeakCurrentEM01)
   3446          {
   3447            bool dcdcLocked = false;
   3448            bool dcdcClkWasEnabled = false;
   3449          
   3450            dcdcClkWasEnabled = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) != 0);
   3451            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3452          
   3453            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3454            EMU_DCDCUnlock();
   3455          
   3456            /* Wait for synchronization before writing new value */
   3457          #if defined(_DCDC_SYNCBUSY_MASK)
   3458            EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3459          #endif
   3460          
   3461          #if defined(_DCDC_DVDDBBCFG_MASK)
   3462            BUS_RegMaskedWrite(&DCDC->EM01CTRL0,
   3463                               _DCDC_EM01CTRL0_IPKVAL_MASK,
   3464                               ((uint32_t)boostPeakCurrentEM01 << _DCDC_EM01CTRL0_IPKVAL_SHIFT));
   3465          #else
   3466            BUS_RegMaskedWrite(&DCDC->BSTEM01CTRL,
   3467                               _DCDC_BSTEM01CTRL_IPKVAL_MASK,
   3468                               ((uint32_t)boostPeakCurrentEM01 << _DCDC_BSTEM01CTRL_IPKVAL_SHIFT));
   3469          #endif
   3470          
   3471            if (dcdcLocked) {
   3472              EMU_DCDCLock();
   3473            }
   3474          
   3475            if (!dcdcClkWasEnabled) {
   3476              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3477            }
   3478          
   3479            EMU_DCDCUpdatedHook();
   3480          }
   3481          
   3482          /***************************************************************************//**
   3483           * @brief
   3484           *   Enable/disable Boost External Shutdown Mode.
