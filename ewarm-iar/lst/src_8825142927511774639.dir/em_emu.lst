   4110           *
   4111           * @param[in] enable
   4112           *   True to enable separate IPK DAC values for DVDD and DEC outputs.
   4113           ******************************************************************************/
   4114          void EMU_DCDCSetDualIpkEnable(bool enable)
   4115          {
