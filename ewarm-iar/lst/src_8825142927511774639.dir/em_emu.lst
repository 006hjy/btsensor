   4676          /***************************************************************************//**
   4677           * @brief
   4678           *   Set to enable HDREG EM2 Exit current limit.
   4679           *
   4680           * @details
   4681           *   Limit HDREG max current drawn on EM2 exit by temporarily adjusting its
   4682           *   output trim so current is pulled from DECOUPLE cap.
   4683           *
   4684           * @param[in] enable
   4685           *   True to enable HDREG EM2 Exit current limit.
   4686           ******************************************************************************/
   4687          void EMU_HDRegEM2ExitCurrentLimitEnable(bool enable)
   4688          {
   4689            if (enable) {
   4690              EMU->CTRL_SET = EMU_CTRL_HDREGEM2EXITCLIM;
   4691            } else {
   4692              EMU->CTRL_CLR = EMU_CTRL_HDREGEM2EXITCLIM;
   4693            }
   4694          }
   4695          #endif
