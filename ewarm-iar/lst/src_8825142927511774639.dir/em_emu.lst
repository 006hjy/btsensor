   2015          /***************************************************************************//**
   2016           * @brief
   2017           *   Configure Backup Power Domain settings.
   2018           *
   2019           * @param[in] bupdInit
   2020           *   Backup power domain initialization structure.
   2021           ******************************************************************************/
   2022          void EMU_BUPDInit(const EMU_BUPDInit_TypeDef *bupdInit)
   2023          {
   2024            uint32_t reg;
   2025          
   2026            /* Set the power connection configuration. */
   2027            reg = EMU->PWRCONF & ~(_EMU_PWRCONF_PWRRES_MASK
   2028                                   | _EMU_PWRCONF_VOUTSTRONG_MASK
   2029                                   | _EMU_PWRCONF_VOUTMED_MASK
   2030                                   | _EMU_PWRCONF_VOUTWEAK_MASK);
   2031          
   2032            reg |= bupdInit->resistor
   2033                   | (bupdInit->voutStrong << _EMU_PWRCONF_VOUTSTRONG_SHIFT)
   2034                   | (bupdInit->voutMed    << _EMU_PWRCONF_VOUTMED_SHIFT)
   2035                   | (bupdInit->voutWeak   << _EMU_PWRCONF_VOUTWEAK_SHIFT);
   2036          
   2037            EMU->PWRCONF = reg;
   2038          
   2039            /* Set the backup domain inactive mode configuration. */
   2040            reg = EMU->BUINACT & ~(_EMU_BUINACT_PWRCON_MASK);
   2041            reg |= (bupdInit->inactivePower);
   2042            EMU->BUINACT = reg;
   2043          
   2044            /* Set the backup domain active mode configuration. */
   2045            reg = EMU->BUACT & ~(_EMU_BUACT_PWRCON_MASK);
   2046            reg |= (bupdInit->activePower);
   2047            EMU->BUACT = reg;
   2048          
   2049            /* Set the power control configuration */
   2050            reg = EMU->BUCTRL & ~(_EMU_BUCTRL_PROBE_MASK
   2051                                  | _EMU_BUCTRL_BODCAL_MASK
   2052                                  | _EMU_BUCTRL_STATEN_MASK
   2053                                  | _EMU_BUCTRL_EN_MASK);
   2054          
   2055            /* Note the use of ->enable to enable BUPD. Use BU_VIN pin input and
   2056               release reset. */
   2057            reg |= bupdInit->probe
   2058                   | (bupdInit->bodCal          << _EMU_BUCTRL_BODCAL_SHIFT)
   2059                   | (bupdInit->statusPinEnable << _EMU_BUCTRL_STATEN_SHIFT)
   2060                   | (bupdInit->enable          << _EMU_BUCTRL_EN_SHIFT);
   2061          
   2062            /* Enable configuration. */
   2063            EMU->BUCTRL = reg;
   2064          
   2065            /* If enable is true, enable BU_VIN input power pin. If not, disable it.  */
   2066            EMU_BUPinEnable(bupdInit->enable);
   2067          
   2068            /* If enable is true, release BU reset. If not, keep reset asserted. */
   2069            BUS_RegBitWrite(&(RMU->CTRL), _RMU_CTRL_BURSTEN_SHIFT, !bupdInit->enable);
   2070          }
   2071          
   2072          /***************************************************************************//**
   2073           * @brief
   2074           *   Configure the Backup Power Domain BOD Threshold value.
   2075           * @note
   2076           *   These values are precalibrated.
   2077           * @param[in] mode Active or Inactive mode
   2078           * @param[in] value
   2079           ******************************************************************************/
   2080          void EMU_BUThresholdSet(EMU_BODMode_TypeDef mode, uint32_t value)
   2081          {
   2082            EFM_ASSERT(value < 8);
   2083            EFM_ASSERT(value <= (_EMU_BUACT_BUEXTHRES_MASK >> _EMU_BUACT_BUEXTHRES_SHIFT));
   2084          
   2085            switch (mode) {
   2086              case emuBODMode_Active:
   2087                EMU->BUACT = (EMU->BUACT & ~_EMU_BUACT_BUEXTHRES_MASK)
   2088                             | (value << _EMU_BUACT_BUEXTHRES_SHIFT);
   2089                break;
   2090              case emuBODMode_Inactive:
   2091                EMU->BUINACT = (EMU->BUINACT & ~_EMU_BUINACT_BUENTHRES_MASK)
   2092                               | (value << _EMU_BUINACT_BUENTHRES_SHIFT);
   2093                break;
   2094            }
   2095          }
   2096          
   2097          /***************************************************************************//**
   2098           * @brief
   2099           *  Configure the Backup Power Domain BOD Threshold Range.
   2100           * @note
   2101           *  These values are precalibrated.
   2102           * @param[in] mode Active or Inactive mode
   2103           * @param[in] value
   2104           ******************************************************************************/
   2105          void EMU_BUThresRangeSet(EMU_BODMode_TypeDef mode, uint32_t value)
   2106          {
   2107            EFM_ASSERT(value < 4);
   2108            EFM_ASSERT(value <= (_EMU_BUACT_BUEXRANGE_MASK >> _EMU_BUACT_BUEXRANGE_SHIFT));
   2109          
   2110            switch (mode) {
   2111              case emuBODMode_Active:
   2112                EMU->BUACT = (EMU->BUACT & ~_EMU_BUACT_BUEXRANGE_MASK)
   2113                             | (value << _EMU_BUACT_BUEXRANGE_SHIFT);
   2114                break;
   2115              case emuBODMode_Inactive:
   2116                EMU->BUINACT = (EMU->BUINACT & ~_EMU_BUINACT_BUENRANGE_MASK)
   2117                               | (value << _EMU_BUINACT_BUENRANGE_SHIFT);
   2118                break;
   2119            }
   2120          }
   2121          #endif
