   2129           *   Backup power domain initialization structure.
   2130           ******************************************************************************/
   2131          void EMU_BUInit(const EMU_BUInit_TypeDef *buInit)
   2132          {
   2133            uint32_t reg = 0;
   2134          
   2135            /* Set the backup power configuration. */
   2136            reg |= (buInit->disMaxComp << _EMU_BUCTRL_DISMAXCOMP_SHIFT);
   2137            reg |= (uint32_t)(buInit->inactivePwrCon);
   2138            reg |= (uint32_t)(buInit->activePwrCon);
   2139            reg |= (uint32_t)(buInit->pwrRes);
   2140            reg |= (uint32_t)(buInit->voutRes);
   2141            reg |= (buInit->buVinProbeEn << _EMU_BUCTRL_BUVINPROBEEN_SHIFT);
   2142            reg |= (buInit->staEn << _EMU_BUCTRL_STATEN_SHIFT);
   2143            reg |= (buInit->enable << _EMU_BUCTRL_EN_SHIFT);
   2144            EMU->BUCTRL = reg;
   2145          }
   2146          #endif
