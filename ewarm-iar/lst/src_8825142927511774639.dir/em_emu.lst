   4171          #if defined(EMU_STATUS_VMONRDY)
   4172          
   4173          /***************************************************************************//**
   4174           * @brief
   4175           *   Get the calibrated threshold value.
   4176           *
   4177           * @details
   4178           *   All VMON channels have two calibration fields in the DI page that
   4179           *   describes the threshold at 1.86 V and 2.98 V. This function will convert
   4180           *   the uncalibrated input voltage threshold in millivolts into a calibrated
   4181           *   threshold.
   4182           *
   4183           * @param[in] channel
   4184           *   A VMON channel.
   4185           *
   4186           * @param[in] threshold
   4187           *   A desired threshold in millivolts.
   4188           *
   4189           * @return
   4190           *   A calibrated threshold value to use. The first digit of the return value is placed
   4191           *   in the "fine" register fields while the next digits are placed in the
   4192           *   "coarse" register fields.
   4193           ******************************************************************************/
   4194          static uint32_t vmonCalibratedThreshold(EMU_VmonChannel_TypeDef channel,
   4195                                                  int threshold)
   4196          {
   4197            uint32_t tDiff = 0;
   4198            uint32_t tLow = 0;
   4199            uint32_t tHigh = 0;
   4200            uint32_t calReg;
   4201          
   4202            /* Get calibration values for 1.86 V and 2.98 V */
   4203            switch (channel) {
   4204              case emuVmonChannel_AVDD:
   4205                calReg = DEVINFO->VMONCAL0;
   4206                tLow = (10U * ((calReg & _DEVINFO_VMONCAL0_AVDD1V86THRESCOARSE_MASK)
   4207                               >> _DEVINFO_VMONCAL0_AVDD1V86THRESCOARSE_SHIFT))
   4208                       + ((calReg & _DEVINFO_VMONCAL0_AVDD1V86THRESFINE_MASK)
   4209                          >> _DEVINFO_VMONCAL0_AVDD1V86THRESFINE_SHIFT);
   4210                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL0_AVDD2V98THRESCOARSE_MASK)
   4211                                >> _DEVINFO_VMONCAL0_AVDD2V98THRESCOARSE_SHIFT))
   4212                        + ((calReg & _DEVINFO_VMONCAL0_AVDD2V98THRESFINE_MASK)
   4213                           >> _DEVINFO_VMONCAL0_AVDD2V98THRESFINE_SHIFT);
   4214                break;
   4215              case emuVmonChannel_ALTAVDD:
   4216                calReg = DEVINFO->VMONCAL0;
   4217                tLow = (10U * ((calReg & _DEVINFO_VMONCAL0_ALTAVDD1V86THRESCOARSE_MASK)
   4218                               >> _DEVINFO_VMONCAL0_ALTAVDD1V86THRESCOARSE_SHIFT))
   4219                       + ((calReg & _DEVINFO_VMONCAL0_ALTAVDD1V86THRESFINE_MASK)
   4220                          >> _DEVINFO_VMONCAL0_ALTAVDD1V86THRESFINE_SHIFT);
   4221                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL0_ALTAVDD2V98THRESCOARSE_MASK)
   4222                                >> _DEVINFO_VMONCAL0_ALTAVDD2V98THRESCOARSE_SHIFT))
   4223                        + ((calReg & _DEVINFO_VMONCAL0_ALTAVDD2V98THRESFINE_MASK)
   4224                           >> _DEVINFO_VMONCAL0_ALTAVDD2V98THRESFINE_SHIFT);
   4225                break;
   4226              case emuVmonChannel_DVDD:
   4227                calReg = DEVINFO->VMONCAL1;
   4228                tLow = (10U * ((calReg & _DEVINFO_VMONCAL1_DVDD1V86THRESCOARSE_MASK)
   4229                               >> _DEVINFO_VMONCAL1_DVDD1V86THRESCOARSE_SHIFT))
   4230                       + ((calReg & _DEVINFO_VMONCAL1_DVDD1V86THRESFINE_MASK)
   4231                          >> _DEVINFO_VMONCAL1_DVDD1V86THRESFINE_SHIFT);
   4232                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL1_DVDD2V98THRESCOARSE_MASK)
   4233                                >> _DEVINFO_VMONCAL1_DVDD2V98THRESCOARSE_SHIFT))
   4234                        + ((calReg & _DEVINFO_VMONCAL1_DVDD2V98THRESFINE_MASK)
   4235                           >> _DEVINFO_VMONCAL1_DVDD2V98THRESFINE_SHIFT);
   4236                break;
   4237              case emuVmonChannel_IOVDD0:
   4238                calReg = DEVINFO->VMONCAL1;
   4239                tLow = (10U * ((calReg & _DEVINFO_VMONCAL1_IO01V86THRESCOARSE_MASK)
   4240                               >> _DEVINFO_VMONCAL1_IO01V86THRESCOARSE_SHIFT))
   4241                       + ((calReg & _DEVINFO_VMONCAL1_IO01V86THRESFINE_MASK)
   4242                          >> _DEVINFO_VMONCAL1_IO01V86THRESFINE_SHIFT);
   4243                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL1_IO02V98THRESCOARSE_MASK)
   4244                                >> _DEVINFO_VMONCAL1_IO02V98THRESCOARSE_SHIFT))
   4245                        + ((calReg & _DEVINFO_VMONCAL1_IO02V98THRESFINE_MASK)
   4246                           >> _DEVINFO_VMONCAL1_IO02V98THRESFINE_SHIFT);
   4247                break;
   4248          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4249              case emuVmonChannel_IOVDD1:
   4250                calReg = DEVINFO->VMONCAL2;
   4251                tLow = (10U * ((calReg & _DEVINFO_VMONCAL2_IO11V86THRESCOARSE_MASK)
   4252                               >> _DEVINFO_VMONCAL2_IO11V86THRESCOARSE_SHIFT))
   4253                       + ((calReg & _DEVINFO_VMONCAL2_IO11V86THRESFINE_MASK)
   4254                          >> _DEVINFO_VMONCAL2_IO11V86THRESFINE_SHIFT);
   4255                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL2_IO12V98THRESCOARSE_MASK)
   4256                                >> _DEVINFO_VMONCAL2_IO12V98THRESCOARSE_SHIFT))
   4257                        + ((calReg & _DEVINFO_VMONCAL2_IO12V98THRESFINE_MASK)
   4258                           >> _DEVINFO_VMONCAL2_IO12V98THRESFINE_SHIFT);
   4259                break;
   4260          #endif
   4261          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4262              case emuVmonChannel_BUVDD:
   4263                calReg = DEVINFO->VMONCAL2;
   4264                tLow = (10U * ((calReg & _DEVINFO_VMONCAL2_BUVDD1V86THRESCOARSE_MASK)
   4265                               >> _DEVINFO_VMONCAL2_BUVDD1V86THRESCOARSE_SHIFT))
   4266                       + ((calReg & _DEVINFO_VMONCAL2_BUVDD1V86THRESFINE_MASK)
   4267                          >> _DEVINFO_VMONCAL2_BUVDD1V86THRESFINE_SHIFT);
   4268                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL2_BUVDD2V98THRESCOARSE_MASK)
   4269                                >> _DEVINFO_VMONCAL2_BUVDD2V98THRESCOARSE_SHIFT))
   4270                        + ((calReg & _DEVINFO_VMONCAL2_BUVDD2V98THRESFINE_MASK)
   4271                           >> _DEVINFO_VMONCAL2_BUVDD2V98THRESFINE_SHIFT);
   4272                break;
   4273          #endif
   4274              default:
   4275                EFM_ASSERT(false);
   4276                break;
   4277            }
   4278          
   4279            tDiff = tHigh - tLow;
   4280            if (tDiff > 0) {
   4281              /* Calculate threshold.
   4282               *
   4283               * Note that volt is used in the reference manual. However, the results
   4284               * should be in millivolts. The precision of Va and Vb are increased in the
   4285               * calculation instead of using floating points.
   4286               */
   4287              uint32_t va = (1120U * 100U) / (tDiff);
   4288              uint32_t vb = (1860U * 100U) - (va * tLow);
   4289              // If (tHigh - tLow) is large, Va could be zero. Caught by CSTAT.
   4290              if (va != 0) {
   4291                /* Round the threshold to the nearest integer value. */
   4292                return (((uint32_t)threshold * 100U) - vb + (va / 2U)) / va;
   4293              }
   4294            }
   4295          
   4296            /* Uncalibrated device guard. */
   4297            return (uint32_t)threshold;
   4298          }
   4299          
   4300          /***************************************************************************//**
   4301           * @brief
   4302           *   Initialize a VMON channel.
   4303           *
   4304           * @details
   4305           *   Initialize a VMON channel without hysteresis. If the channel supports
   4306           *   separate rise and fall triggers, both thresholds will be set to the same
   4307           *   value. The threshold will be converted to a register field value based
   4308           *   on calibration values from the DI page.
   4309           *
   4310           * @param[in] vmonInit
   4311           *   The VMON initialization structure.
   4312           ******************************************************************************/
   4313          void EMU_VmonInit(const EMU_VmonInit_TypeDef *vmonInit)
   4314          {
   4315            uint32_t thresholdCoarse, thresholdFine;
   4316            uint32_t threshold;
   4317          
   4318            EFM_ASSERT((vmonInit->threshold >= 1620) && (vmonInit->threshold <= 3400));
   4319          
   4320            threshold = vmonCalibratedThreshold(vmonInit->channel, vmonInit->threshold);
   4321            thresholdFine = threshold % 10U;
   4322            thresholdCoarse = threshold / 10U;
   4323          
   4324            /* Saturate the threshold to maximum values. */
   4325            if (thresholdCoarse > 0xFU) {
   4326              thresholdCoarse = 0xF;
   4327              thresholdFine = 9;
   4328            }
   4329          
   4330            switch (vmonInit->channel) {
   4331              case emuVmonChannel_AVDD:
   4332                EMU->VMONAVDDCTRL = (thresholdCoarse << _EMU_VMONAVDDCTRL_RISETHRESCOARSE_SHIFT)
   4333                                    | (thresholdFine << _EMU_VMONAVDDCTRL_RISETHRESFINE_SHIFT)
   4334                                    | (thresholdCoarse << _EMU_VMONAVDDCTRL_FALLTHRESCOARSE_SHIFT)
   4335                                    | (thresholdFine << _EMU_VMONAVDDCTRL_FALLTHRESFINE_SHIFT)
   4336                                    | (vmonInit->riseWakeup ? EMU_VMONAVDDCTRL_RISEWU : 0U)
   4337                                    | (vmonInit->fallWakeup ? EMU_VMONAVDDCTRL_FALLWU : 0U)
   4338                                    | (vmonInit->enable     ? EMU_VMONAVDDCTRL_EN     : 0U);
   4339                break;
   4340              case emuVmonChannel_ALTAVDD:
   4341                EMU->VMONALTAVDDCTRL = (thresholdCoarse << _EMU_VMONALTAVDDCTRL_THRESCOARSE_SHIFT)
   4342                                       | (thresholdFine << _EMU_VMONALTAVDDCTRL_THRESFINE_SHIFT)
   4343                                       | (vmonInit->riseWakeup ? EMU_VMONALTAVDDCTRL_RISEWU : 0U)
   4344                                       | (vmonInit->fallWakeup ? EMU_VMONALTAVDDCTRL_FALLWU : 0U)
   4345                                       | (vmonInit->enable     ? EMU_VMONALTAVDDCTRL_EN     : 0U);
   4346                break;
   4347              case emuVmonChannel_DVDD:
   4348                EMU->VMONDVDDCTRL = (thresholdCoarse << _EMU_VMONDVDDCTRL_THRESCOARSE_SHIFT)
   4349                                    | (thresholdFine << _EMU_VMONDVDDCTRL_THRESFINE_SHIFT)
   4350                                    | (vmonInit->riseWakeup ? EMU_VMONDVDDCTRL_RISEWU : 0U)
   4351                                    | (vmonInit->fallWakeup ? EMU_VMONDVDDCTRL_FALLWU : 0U)
   4352                                    | (vmonInit->enable     ? EMU_VMONDVDDCTRL_EN     : 0U);
   4353                break;
   4354              case emuVmonChannel_IOVDD0:
   4355                EMU->VMONIO0CTRL = (thresholdCoarse << _EMU_VMONIO0CTRL_THRESCOARSE_SHIFT)
   4356                                   | (thresholdFine << _EMU_VMONIO0CTRL_THRESFINE_SHIFT)
   4357                                   | (vmonInit->retDisable ? EMU_VMONIO0CTRL_RETDIS : 0U)
   4358                                   | (vmonInit->riseWakeup ? EMU_VMONIO0CTRL_RISEWU : 0U)
   4359                                   | (vmonInit->fallWakeup ? EMU_VMONIO0CTRL_FALLWU : 0U)
   4360                                   | (vmonInit->enable     ? EMU_VMONIO0CTRL_EN     : 0U);
   4361                break;
   4362          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4363              case emuVmonChannel_IOVDD1:
   4364                EMU->VMONIO1CTRL = (thresholdCoarse << _EMU_VMONIO1CTRL_THRESCOARSE_SHIFT)
   4365                                   | (thresholdFine << _EMU_VMONIO1CTRL_THRESFINE_SHIFT)
   4366                                   | (vmonInit->retDisable ? EMU_VMONIO1CTRL_RETDIS : 0U)
   4367                                   | (vmonInit->riseWakeup ? EMU_VMONIO1CTRL_RISEWU : 0U)
   4368                                   | (vmonInit->fallWakeup ? EMU_VMONIO1CTRL_FALLWU : 0U)
   4369                                   | (vmonInit->enable     ? EMU_VMONIO1CTRL_EN     : 0U);
   4370                break;
   4371          #endif
   4372          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4373              case emuVmonChannel_BUVDD:
   4374                EMU->VMONBUVDDCTRL = (thresholdCoarse << _EMU_VMONBUVDDCTRL_THRESCOARSE_SHIFT)
   4375                                     | (thresholdFine << _EMU_VMONBUVDDCTRL_THRESFINE_SHIFT)
   4376                                     | (vmonInit->riseWakeup ? EMU_VMONBUVDDCTRL_RISEWU : 0U)
   4377                                     | (vmonInit->fallWakeup ? EMU_VMONBUVDDCTRL_FALLWU : 0U)
   4378                                     | (vmonInit->enable     ? EMU_VMONBUVDDCTRL_EN     : 0U);
   4379                break;
   4380          #endif
   4381              default:
   4382                EFM_ASSERT(false);
   4383                return;
   4384            }
   4385          }
   4386          
   4387          /***************************************************************************//**
   4388           * @brief
   4389           *   Initialize a VMON channel with hysteresis (separate rise and fall triggers).
   4390           *
   4391           * @details
   4392           *   Initialize a VMON channel which supports hysteresis. The AVDD channel is
   4393           *   the only channel to support separate rise and fall triggers. The rise and
   4394           *   fall thresholds will be converted to a register field value based on the
   4395           *   calibration values from the DI page.
   4396           *
   4397           * @param[in] vmonInit
   4398           *   The VMON hysteresis initialization structure.
   4399           ******************************************************************************/
   4400          void EMU_VmonHystInit(const EMU_VmonHystInit_TypeDef *vmonInit)
   4401          {
   4402            uint32_t riseThreshold;
   4403            uint32_t fallThreshold;
   4404          
   4405            /* VMON supports voltages between 1620 mV and 3400 mV (inclusive). */
   4406            EFM_ASSERT((vmonInit->riseThreshold >= 1620) && (vmonInit->riseThreshold <= 3400));
   4407            EFM_ASSERT((vmonInit->fallThreshold >= 1620) && (vmonInit->fallThreshold <= 3400));
   4408            /* The fall threshold has to be lower than rise threshold. */
   4409            EFM_ASSERT(vmonInit->fallThreshold <= vmonInit->riseThreshold);
   4410          
   4411            riseThreshold = vmonCalibratedThreshold(vmonInit->channel, vmonInit->riseThreshold);
   4412            fallThreshold = vmonCalibratedThreshold(vmonInit->channel, vmonInit->fallThreshold);
   4413          
   4414            switch (vmonInit->channel) {
   4415              case emuVmonChannel_AVDD:
   4416                EMU->VMONAVDDCTRL = ((riseThreshold / 10U) << _EMU_VMONAVDDCTRL_RISETHRESCOARSE_SHIFT)
   4417                                    | ((riseThreshold % 10U) << _EMU_VMONAVDDCTRL_RISETHRESFINE_SHIFT)
   4418                                    | ((fallThreshold / 10U) << _EMU_VMONAVDDCTRL_FALLTHRESCOARSE_SHIFT)
   4419                                    | ((fallThreshold % 10U) << _EMU_VMONAVDDCTRL_FALLTHRESFINE_SHIFT)
   4420                                    | (vmonInit->riseWakeup ? EMU_VMONAVDDCTRL_RISEWU : 0U)
   4421                                    | (vmonInit->fallWakeup ? EMU_VMONAVDDCTRL_FALLWU : 0U)
   4422                                    | (vmonInit->enable     ? EMU_VMONAVDDCTRL_EN     : 0U);
   4423                break;
   4424              default:
   4425                EFM_ASSERT(false);
   4426                return;
   4427            }
   4428          }
   4429          
   4430          /***************************************************************************//**
   4431           * @brief
   4432           *   Enable or disable a VMON channel.
   4433           *
   4434           * @param[in] channel
   4435           *   A VMON channel to enable/disable.
   4436           *
   4437           * @param[in] enable
   4438           *   Indicates whether to enable or disable.
   4439           ******************************************************************************/
   4440          void EMU_VmonEnable(EMU_VmonChannel_TypeDef channel, bool enable)
   4441          {
   4442            uint32_t volatile * reg;
   4443            uint32_t bit;
   4444          
   4445            switch (channel) {
   4446              case emuVmonChannel_AVDD:
   4447                reg = &(EMU->VMONAVDDCTRL);
   4448                bit = _EMU_VMONAVDDCTRL_EN_SHIFT;
   4449                break;
   4450              case emuVmonChannel_ALTAVDD:
   4451                reg = &(EMU->VMONALTAVDDCTRL);
   4452                bit = _EMU_VMONALTAVDDCTRL_EN_SHIFT;
   4453                break;
   4454              case emuVmonChannel_DVDD:
   4455                reg = &(EMU->VMONDVDDCTRL);
   4456                bit = _EMU_VMONDVDDCTRL_EN_SHIFT;
   4457                break;
   4458              case emuVmonChannel_IOVDD0:
   4459                reg = &(EMU->VMONIO0CTRL);
   4460                bit = _EMU_VMONIO0CTRL_EN_SHIFT;
   4461                break;
   4462          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4463              case emuVmonChannel_IOVDD1:
   4464                reg = &(EMU->VMONIO1CTRL);
   4465                bit = _EMU_VMONIO1CTRL_EN_SHIFT;
   4466                break;
   4467          #endif
   4468          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4469              case emuVmonChannel_BUVDD:
   4470                reg = &(EMU->VMONBUVDDCTRL);
   4471                bit = _EMU_VMONBUVDDCTRL_EN_SHIFT;
   4472                break;
   4473          #endif
   4474              default:
   4475                EFM_ASSERT(false);
   4476                return;
   4477            }
   4478          
   4479            BUS_RegBitWrite(reg, bit, (uint32_t)enable);
   4480          }
   4481          
   4482          /***************************************************************************//**
   4483           * @brief
   4484           *   Get the status of a voltage monitor channel.
   4485           *
   4486           * @param[in] channel
   4487           *   A VMON channel to get the status for.
   4488           *
   4489           * @return
   4490           *   A status of the selected VMON channel. True if the channel is triggered.
   4491           ******************************************************************************/
   4492          bool EMU_VmonChannelStatusGet(EMU_VmonChannel_TypeDef channel)
   4493          {
   4494            uint32_t bit;
   4495            switch (channel) {
   4496              case emuVmonChannel_AVDD:
   4497                bit = _EMU_STATUS_VMONAVDD_SHIFT;
   4498                break;
   4499              case emuVmonChannel_ALTAVDD:
   4500                bit = _EMU_STATUS_VMONALTAVDD_SHIFT;
   4501                break;
   4502              case emuVmonChannel_DVDD:
   4503                bit = _EMU_STATUS_VMONDVDD_SHIFT;
   4504                break;
   4505              case emuVmonChannel_IOVDD0:
   4506                bit = _EMU_STATUS_VMONIO0_SHIFT;
   4507                break;
   4508          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4509              case emuVmonChannel_IOVDD1:
   4510                bit = _EMU_STATUS_VMONIO1_SHIFT;
   4511                break;
   4512          #endif
   4513          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4514              case emuVmonChannel_BUVDD:
   4515                bit = _EMU_STATUS_VMONBUVDD_SHIFT;
   4516                break;
   4517          #endif
   4518              default:
   4519                bit = 0;
   4520                EFM_ASSERT(false);
   4521                break;
   4522            }
   4523          
   4524            return BUS_RegBitRead(&EMU->STATUS, bit) != 0U;
   4525          }
   4526          #endif /* EMU_STATUS_VMONRDY */
   4527          
   4528          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   4529          /***************************************************************************//**
   4530           * @brief
   4531           *   Adjust the bias refresh rate.
   4532           *
   4533           * @details
   4534           *   This function is only meant to be used under high-temperature operation on
   4535           *   EFR32xG1 and EFM32xG1 devices. Adjusting the bias mode will
   4536           *   increase the typical current consumption. See application note 1027
   4537           *   and errata documents for more details.
   4538           *
   4539           * @param [in] mode
   4540           *   The new bias refresh rate.
   4541           ******************************************************************************/
   4542          void EMU_SetBiasMode(EMU_BiasMode_TypeDef mode)
   4543          {
   4544            uint32_t freq = 0x2u;
   4545            bool emuTestLocked = false;
   4546          
   4547            if (mode == emuBiasMode_1KHz) {
   4548              freq = 0x0u;
   4549            }
   4550          
   4551            if (EMU_TESTLOCK == 0x1u) {
   4552              emuTestLocked = true;
   4553              EMU_TESTLOCK = 0xADE8u;
   4554            }
   4555          
   4556            if (mode == emuBiasMode_Continuous) {
   4557              EMU_BIASCONF &= ~0x74u;
   4558            } else {
   4559              EMU_BIASCONF |= 0x74u;
   4560            }
   4561          
   4562            EMU_BIASTESTCTRL |= 0x8u;
   4563            CMU_ULFRCOCTRL    = (CMU_ULFRCOCTRL & ~0xC00u)
   4564                                | ((freq & 0x3u) << 10u);
   4565            EMU_BIASTESTCTRL &= ~0x8u;
   4566          
   4567            if (emuTestLocked) {
   4568              EMU_TESTLOCK = 0u;
   4569            }
   4570          }
   4571          #endif
   4572          
   4573          #if defined(_EMU_TEMP_TEMP_MASK)
   4574          /***************************************************************************//**
   4575           * @brief
   4576           *   Get temperature in degrees Celsius
   4577           *
   4578           * @return
   4579           *   Temperature in degrees Celsius
   4580           ******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
   4581          float EMU_TemperatureGet(void)
   4582          {
   4583          #if defined(_EMU_TEMP_TEMPLSB_MASK)
   4584            return ((float) ((EMU->TEMP & (_EMU_TEMP_TEMP_MASK | _EMU_TEMP_TEMPLSB_MASK) )
   4585                             >> _EMU_TEMP_TEMPLSB_SHIFT)
   4586                    ) / 4.0f - EMU_TEMP_ZERO_C_IN_KELVIN;
   \                     EMU_TemperatureGet: (+1)
   \        0x0   0x....             LDR.N    R0,??DataTable18_31
   \        0x2   0x6801             LDR      R1,[R0, #+0]
   \        0x4   0xEDDF 0x....      VLDR.W   S1,??DataTable18
   \        0x8   0xF3C1 0x010A      UBFX     R1,R1,#+0,#+11
   \        0xC   0xEE00 0x1A10      VMOV     S0,R1
   \       0x10   0xEEBB 0x0ACF      VCVT.F32.U32 S0,S0,#+2
   \       0x14   0xEE30 0x0A20      VADD.F32 S0,S0,S1
   \       0x18   0x4770             BX       LR
   4587          #else
   4588            uint32_t val1;
   4589            uint32_t val2;
   4590            float tempCo;
   4591            uint32_t diTemp, diEmu;
   4592          
   4593            // Calculate calibration temp based on DI page values
   4594            diTemp = ((DEVINFO->CAL & _DEVINFO_CAL_TEMP_MASK) >> _DEVINFO_CAL_TEMP_SHIFT);
   4595            diEmu = ((DEVINFO->EMUTEMP & _DEVINFO_EMUTEMP_EMUTEMPROOM_MASK) >> _DEVINFO_EMUTEMP_EMUTEMPROOM_SHIFT);
   4596            tempCo = EMU_TEMPCO_CONST + (diEmu / 100.0f);
   4597          
   4598            // Read temperature twice to ensure a stable value
   4599            do {
   4600              val1 = (EMU->TEMP & _EMU_TEMP_TEMP_MASK)
   4601                     >> _EMU_TEMP_TEMP_SHIFT;
   4602              val2 = (EMU->TEMP & _EMU_TEMP_TEMP_MASK)
   4603                     >> _EMU_TEMP_TEMP_SHIFT;
   4604            } while (val1 != val2);
   4605          
   4606            return diTemp + tempCo * ((int) diEmu - (int) val1);
   4607          #endif
   4608          }
   4609          #endif // defined(_EMU_TEMP_TEMP_MASK)
   4610          
   4611          #if defined(EMU_CTRL_EFPDIRECTMODEEN)
