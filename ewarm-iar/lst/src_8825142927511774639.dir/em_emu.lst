   4093          
   4094              case emuDcdcRegulationType_RegDVDDDEC:
   4095                return (((DCDC->OUTEN & DCDC_OUTEN_DVDDOUTEN) != 0U)
   4096                        && ((DCDC->OUTEN & DCDC_OUTEN_DECOUTEN) != 0U));
   4097          
   4098              default:
   4099                break;
   4100            }
   4101            return false;
   4102          }
