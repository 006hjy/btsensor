    641          #if defined(ERRATA_FIX_DCDC_LNHS_BLOCK_ENABLE)
    642          static void dcdcHsFixLnBlock(void)
    643          {
    644            if ((errataFixDcdcHsState == errataFixDcdcHsTrimSet)
    645                || (errataFixDcdcHsState == errataFixDcdcHsBypassLn)) {
    646              /* Wait for LNRUNNING */
    647              if ((EMU->DCDCCTRL & _EMU_DCDCCTRL_DCDCMODE_MASK) == EMU_DCDCCTRL_DCDCMODE_LOWNOISE) {
    648                while (!(EMU_DCDCSTATUS & (0x1 << 16))) {
    649                }
    650              }
    651              errataFixDcdcHsState = errataFixDcdcHsLnWaitDone;
    652            }
    653          }
    654          #endif
    655          
    656          #if defined(_EMU_CTRL_EM23VSCALE_MASK) && defined(EMU_CTRL_EM23VSCALEAUTOWSEN)
    657          /* Configure EMU and CMU for EM2 and 3 voltage downscale. */
    658          static void vScaleDownEM23Setup(void)
    659          {
    660          #if defined(_SILICON_LABS_32B_SERIES_1)
    661            if (EMU_LDOStatusGet() == false) {
    662              /* Skip voltage scaling if the LDO regulator is turned off. */
    663              return;
    664            }
    665          #endif
    666          
    667            /* Wait until previous scaling is done. */
    668            EMU_VScaleWait();
    669          
    670            uint32_t em23vs = (EMU->CTRL & _EMU_CTRL_EM23VSCALE_MASK) >> _EMU_CTRL_EM23VSCALE_SHIFT;
    671            uint32_t em01vs = (EMU->STATUS & _EMU_STATUS_VSCALE_MASK) >> _EMU_STATUS_VSCALE_SHIFT;
    672          
    673            /* Inverse coding. */
    674            if (em23vs > em01vs) {
    675              EMU->CTRL |= EMU_CTRL_EM23VSCALEAUTOWSEN;
    676          #if defined(_MSC_RAMCTRL_RAMWSEN_MASK)
    677              /* Set RAM wait states for safe EM2 wakeup. */
    678              BUS_RegMaskedSet(&MSC->RAMCTRL, (MSC_RAMCTRL_RAMWSEN
    679                                               | MSC_RAMCTRL_RAM1WSEN
    680                                               | MSC_RAMCTRL_RAM2WSEN));
    681          #endif
    682            } else {
    683              EMU->CTRL &= ~EMU_CTRL_EM23VSCALEAUTOWSEN;
    684            }
    685          }
    686          
    687          /* Handle automatic HFRCO adjustment that may have occurred during EM2/EM3. */
    688          static void vScaleAfterWakeup(void)
    689          {
    690            if ((EMU->CTRL & EMU_CTRL_EM23VSCALEAUTOWSEN) != 0U) {
    691              /* The hardware may have updated the HFRCOCTRL register during EM2/EM3
    692               * entry if voltage scaling in EM2/EM3 is enabled. The hardware would
    693               * then update the HFRCO frequency to 19 MHz automatically. */
    694              uint32_t freqRange = (CMU->HFRCOCTRL & _CMU_HFRCOCTRL_FREQRANGE_MASK)
    695                                   >> _CMU_HFRCOCTRL_FREQRANGE_SHIFT;
    696              if (freqRange == 0x08U) {
    697                SystemHfrcoFreq = 19000000;
    698              }
    699            }
    700          }
    701          #endif
