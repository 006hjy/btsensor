    348            || defined(ERRATA_FIX_EMU_E110_ENABLE)
    349          SL_RAMFUNC_DECLARATOR static void __attribute__ ((noinline)) ramWFI(void);
    350          SL_RAMFUNC_DEFINITION_BEGIN

   \                                 In section text_application_ram, align 4, keep-with-next
    351          static void __attribute__ ((noinline)) ramWFI(void)
    352          {
   \                     ramWFI: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    353          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_205)
    354            EMU_CallWFI();                      // Enter EM2 or EM3
   \        0x2   0x.... 0x....      BL       EMU_CallWFI
    355            if (CoreDebug->DHCSR & CoreDebug_DHCSR_C_DEBUGEN_Msk) {
   \        0x6   0x4806             LDR.N    R0,??ramWFI_0
   \        0x8   0x6801             LDR      R1,[R0, #+0]
   \        0xA   0x07CA             LSLS     R2,R1,#+31
   \        0xC   0xD507             BPL.N    ??ramWFI_1
    356              for (volatile int i = 0; i < 6; i++) {
   \        0xE   0x2000             MOVS     R0,#+0
   \       0x10   0xE001             B.N      ??ramWFI_2
   \                     ??ramWFI_3: (+1)
   \       0x12   0x9800             LDR      R0,[SP, #+0]
   \       0x14   0x1C40             ADDS     R0,R0,#+1
   \                     ??ramWFI_2: (+1)
   \       0x16   0x9000             STR      R0,[SP, #+0]
   \       0x18   0x9800             LDR      R0,[SP, #+0]
   \       0x1A   0x2806             CMP      R0,#+6
   \       0x1C   0xDBF9             BLT.N    ??ramWFI_3
    357              }                           // Dummy wait loop ...
    358            }
    359          
    360          #else
    361            EMU_CallWFI();                      // Enter EM2 or EM3
    362          #if defined(__GNUC__)
    363          #pragma GCC diagnostic push
    364          #pragma GCC diagnostic ignored "-Warray-bounds"
    365          #endif
    366            *(volatile uint32_t*)4;       // Clear faulty read data after wakeup
    367          #if defined(__GNUC__)
    368          #pragma GCC diagnostic pop
    369          #endif
    370          #endif
    371          }
   \                     ??ramWFI_1: (+1)
   \       0x1E   0xBD01             POP      {R0,PC}
   \                     ??ramWFI_0:
   \       0x20   0xE000'EDF0        DC32     0xe000edf0
    372          SL_RAMFUNC_DEFINITION_END
    373          #endif
    374          
    375          #if defined(ERRATA_FIX_EMU_E220_DECBOD_ENABLE)
    376          SL_RAMFUNC_DECLARATOR static void __attribute__ ((noinline)) ramWFI(void);
    377          SL_RAMFUNC_DEFINITION_BEGIN
    378          static void __attribute__ ((noinline)) ramWFI(void)
    379          {
    380            /* Second part of EMU_E220 DECBOD Errata fix. Calibration needs to be disabled
    381             * quickly when coming out of EM2/EM3. Ram execution is needed to meet timing.
    382             * Calibration is re-enabled after voltage scaling completes. */
    383            uint32_t temp = EMU_PORBOD | EMU_PORBOD_GMC_CALIB_DISABLE;
    384            EMU_CallWFI();
    385            EMU_PORBOD = temp;
    386          }
    387          SL_RAMFUNC_DEFINITION_END
    388          #endif
    389          
    390          #if (_SILICON_LABS_32B_SERIES < 2)
    391          /***************************************************************************//**
    392           * @brief
    393           *   Save/restore/update oscillator, core clock and voltage scaling configuration on
    394           *   EM2 or EM3 entry/exit.
    395           *
    396           * @details
    397           *   Hardware may automatically change the oscillator and the voltage scaling configuration
    398           *   when going into or out of an energy mode. Static data in this function keeps track of
    399           *   such configuration bits and is used to restore state if needed.
    400           *
    401           ******************************************************************************/
    402          typedef enum {
    403            emState_Save,         /* Save EMU and CMU state. */
    404            emState_Restore,      /* Restore and unlock.     */
    405          } emState_TypeDef;
    406          
    407          static void emState(emState_TypeDef action)
    408          {
    409            uint32_t oscEnCmd;
    410            uint32_t cmuLocked;
    411            static uint32_t cmuStatus;
    412            static CMU_Select_TypeDef hfClock;
    413          #if defined(EMU_VSCALE_PRESENT)
    414            static uint8_t vScaleStatus;
    415            static uint32_t hfrcoCtrl;
    416          #endif
    417          
    418            /* Save or update state. */
    419            if (action == emState_Save) {
    420              /* Save configuration. */
    421              cmuStatus = CMU->STATUS;
    422              hfClock = CMU_ClockSelectGet(cmuClock_HF);
    423          #if defined(EMU_VSCALE_PRESENT)
    424              /* Save vscale. */
    425              EMU_VScaleWait();
    426              vScaleStatus = (uint8_t)((EMU->STATUS & _EMU_STATUS_VSCALE_MASK)
    427                                       >> _EMU_STATUS_VSCALE_SHIFT);
    428              hfrcoCtrl = CMU->HFRCOCTRL;
    429          #endif
    430            } else { /* Restore state. */
    431              /* Apply saved configuration. */
    432          #if defined(EMU_VSCALE_PRESENT)
    433          #if defined(_SILICON_LABS_32B_SERIES_1)
    434              if (EMU_LDOStatusGet() == true)
    435              /* Restore voltage scaling level if LDO regulator is on. */
    436          #endif
    437              {
    438                /* Restore EM0 and 1 voltage scaling level.
    439                   @ref EMU_VScaleWait() is called later,
    440                   just before HF clock select is set. */
    441                EMU->CMD = vScaleEM01Cmd((EMU_VScaleEM01_TypeDef)vScaleStatus);
    442              }
    443          #endif
    444              /* CMU registers may be locked. */
    445              cmuLocked = CMU->LOCK & CMU_LOCK_LOCKKEY_LOCKED;
    446              CMU_Unlock();
    447          
    448          #if defined(_CMU_OSCENCMD_MASK)
    449              /* AUXHFRCO are automatically disabled (except if using debugger). */
    450              /* HFRCO, USHFRCO and HFXO are automatically disabled. */
    451              /* LFRCO/LFXO may be disabled by SW in EM3. */
    452              /* Restore according to status prior to entering energy mode. */
    453              oscEnCmd = 0;
    454              oscEnCmd |= (cmuStatus & CMU_STATUS_HFRCOENS) != 0U
    455                          ? CMU_OSCENCMD_HFRCOEN : 0U;
    456              oscEnCmd |= (cmuStatus & CMU_STATUS_AUXHFRCOENS) != 0U
    457                          ? CMU_OSCENCMD_AUXHFRCOEN : 0U;
    458              oscEnCmd |= (cmuStatus & CMU_STATUS_LFRCOENS) != 0U
    459                          ? CMU_OSCENCMD_LFRCOEN : 0U;
    460              oscEnCmd |= (cmuStatus & CMU_STATUS_HFXOENS) != 0U
    461                          ? CMU_OSCENCMD_HFXOEN : 0U;
    462              oscEnCmd |= (cmuStatus & CMU_STATUS_LFXOENS) != 0U
    463                          ? CMU_OSCENCMD_LFXOEN : 0U;
    464          #if defined(_CMU_STATUS_USHFRCOENS_MASK)
    465              oscEnCmd |= (cmuStatus & CMU_STATUS_USHFRCOENS) != 0U
    466                          ? CMU_OSCENCMD_USHFRCOEN : 0U;
    467          #endif
    468              CMU->OSCENCMD = oscEnCmd;
    469          #endif
    470          
    471          #if defined(_EMU_STATUS_VSCALE_MASK)
    472              /* Wait for upscale to complete and then restore selected clock. */
    473              EMU_VScaleWait();
    474              if ((EMU->CTRL & _EMU_CTRL_EM23VSCALEAUTOWSEN_MASK) != 0U) {
    475                /* Restore HFRCO frequency which was automatically adjusted by hardware. */
    476                while ((CMU->SYNCBUSY & CMU_SYNCBUSY_HFRCOBSY) != 0U) {
    477                }
    478                CMU->HFRCOCTRL = hfrcoCtrl;
    479                if (hfClock == cmuSelect_HFRCO) {
    480                  /* Optimize wait state after EM2/EM3 wakeup because hardware has
    481                   * modified them. */
    482                  CMU_UpdateWaitStates(SystemHfrcoFreq, (int)EMU_VScaleGet());
    483                }
    484              }
    485          #endif
    486          
    487              switch (hfClock) {
    488                case cmuSelect_LFXO:
    489                  CMU_CLOCK_SELECT_SET(HF, LFXO);
    490                  break;
    491                case cmuSelect_LFRCO:
    492                  CMU_CLOCK_SELECT_SET(HF, LFRCO);
    493                  break;
    494                case cmuSelect_HFXO:
    495                  CMU_CLOCK_SELECT_SET(HF, HFXO);
    496                  break;
    497          #if defined(CMU_CMD_HFCLKSEL_USHFRCODIV2)
    498                case cmuSelect_USHFRCODIV2:
    499                  CMU_CLOCK_SELECT_SET(HF, USHFRCODIV2);
    500                  break;
    501          #endif
    502          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
    503                case cmuSelect_HFRCODIV2:
    504                  CMU_CLOCK_SELECT_SET(HF, HFRCODIV2);
    505                  break;
    506          #endif
    507          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
    508                case cmuSelect_CLKIN0:
    509                  CMU_CLOCK_SELECT_SET(HF, CLKIN0);
    510                  break;
    511          #endif
    512          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
    513                case cmuSelect_USHFRCO:
    514                  CMU_CLOCK_SELECT_SET(HF, USHFRCO);
    515                  break;
    516          #endif
    517              }
    518          
    519          #if defined(_CMU_OSCENCMD_MASK)
    520              /* If HFRCO was disabled before entering Energy Mode, turn it off again */
    521              /* as it is automatically enabled by wake up */
    522              if ((cmuStatus & CMU_STATUS_HFRCOENS) == 0U) {
    523                CMU->OSCENCMD = CMU_OSCENCMD_HFRCODIS;
    524              }
    525          #endif
    526          
    527              /* Restore CMU register locking */
    528              if (cmuLocked != 0U) {
    529                CMU_Lock();
    530              }
    531            }
    532          }
    533          #endif
    534          
    535          #if defined(ERRATA_FIX_EMU_E107_ENABLE)
    536          /* Get enable conditions for errata EMU_E107 fix. */
    537          __STATIC_INLINE bool getErrataFixEmuE107En(void)
    538          {
    539          #if defined(_EFM32_HAPPY_FAMILY)   \
    540            || defined(_EFM32_TINY_FAMILY)   \
    541            || defined(_EFM32_WONDER_FAMILY) \
    542            || defined(_EFM32_ZERO_FAMILY)
    543            // all revisions have the errata
    544            return true;
    545          #else
    546            /* SYSTEM_ChipRevisionGet() could have been used here, but a faster implementation
    547             * would be needed in this case.
    548             */
    549            uint16_t majorMinorRev;
    550          
    551            /* CHIP MAJOR bit [3:0]. */
    552            majorMinorRev = ((ROMTABLE->PID0 & _ROMTABLE_PID0_REVMAJOR_MASK)
    553                             >> _ROMTABLE_PID0_REVMAJOR_SHIFT)
    554                            << 8;
    555            /* CHIP MINOR bit [7:4]. */
    556            majorMinorRev |= ((ROMTABLE->PID2 & _ROMTABLE_PID2_REVMINORMSB_MASK)
    557                              >> _ROMTABLE_PID2_REVMINORMSB_SHIFT)
    558                             << 4;
    559            /* CHIP MINOR bit [3:0]. */
    560            majorMinorRev |= (ROMTABLE->PID3 & _ROMTABLE_PID3_REVMINORLSB_MASK)
    561                             >> _ROMTABLE_PID3_REVMINORLSB_SHIFT;
    562          
    563          #if defined(_EFM32_GECKO_FAMILY)
    564            // all GECKO revisions except Revision E have the errata
    565            return (majorMinorRev <= 0x0103);
    566          #elif defined(_EFM32_GIANT_FAMILY)
    567            // all LEOPARD GECKO (Major = 0x01 Or 0x02) revisions have the errata
    568            // all GIANT GECKO (Major = 0x01) revisions except Revision E have the errata
    569            return (majorMinorRev <= 0x0103) || (majorMinorRev == 0x0204) || (majorMinorRev == 0x0205);
    570          #else
    571            /* Invalid configuration. */
    572            EFM_ASSERT(false);
    573            /* Return when assertions are disabled. */
    574            return false;
    575          #endif
    576          #endif /* #if defined(_EFM32_ZERO_FAMILY) || defined(_EFM32_HAPPY_FAMILY) #else */
    577          }
    578          #endif /* #if defined(ERRATA_FIX_EMU_E107_ENABLE) */
    579          
    580          #if defined(ERRATA_FIX_EMU_E110_ENABLE)
    581          /* Get enable conditions for errata EMU_E110 fix. */
    582          __STATIC_INLINE bool getErrataFixEmuE110En(void)
    583          {
    584            /* SYSTEM_ChipRevisionGet() could have been used here, but a faster implementation
    585             * would be needed in this case.
    586             */
    587            uint16_t majorMinorRev;
    588          
    589            /* CHIP MAJOR bit [3:0]. */
    590            majorMinorRev = ((ROMTABLE->PID0 & _ROMTABLE_PID0_REVMAJOR_MASK)
    591                             >> _ROMTABLE_PID0_REVMAJOR_SHIFT)
    592                            << 8;
    593            /* CHIP MINOR bit [7:4]. */
    594            majorMinorRev |= ((ROMTABLE->PID2 & _ROMTABLE_PID2_REVMINORMSB_MASK)
    595                              >> _ROMTABLE_PID2_REVMINORMSB_SHIFT)
    596                             << 4;
    597            /* CHIP MINOR bit [3:0]. */
    598            majorMinorRev |= (ROMTABLE->PID3 & _ROMTABLE_PID3_REVMINORLSB_MASK)
    599                             >> _ROMTABLE_PID3_REVMINORLSB_SHIFT;
    600          
    601          #if defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_ZERO_FAMILY)
    602            return (majorMinorRev == 0x0100);
    603          #elif defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_HAPPY_FAMILY)
    604            return ((majorMinorRev == 0x0100 || majorMinorRev == 0x0101));
    605          #elif defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_WONDER_FAMILY)
    606            return (majorMinorRev == 0x0100);
    607          #elif defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_GIANT_FAMILY)
    608            return (majorMinorRev == 0x0204);
    609          #else
    610            /* Invalid configuration. */
    611            EFM_ASSERT(false);
    612            /* Return when assertions are disabled. */
    613            return false;
    614          #endif
    615          }
    616          #endif /* #if defined(ERRATA_FIX_EMU_E110_ENABLE) */
    617          
    618          /* LP prepare / LN restore P/NFET count. */
    619          #if defined(ERRATA_FIX_DCDC_FETCNT_SET_ENABLE)
    620          static void currentLimitersUpdate(void);
    621          static void dcdcFetCntSet(bool lpModeSet)
    622          {
    623            uint32_t tmp;
    624            static uint32_t emuDcdcMiscCtrlReg;
    625          
    626            if (lpModeSet) {
    627              emuDcdcMiscCtrlReg = EMU->DCDCMISCCTRL;
    628              tmp  = EMU->DCDCMISCCTRL
    629                     & ~(_EMU_DCDCMISCCTRL_PFETCNT_MASK | _EMU_DCDCMISCCTRL_NFETCNT_MASK);
    630              tmp |= (DCDC_LP_PFET_CNT << _EMU_DCDCMISCCTRL_PFETCNT_SHIFT)
    631                     | (DCDC_LP_NFET_CNT << _EMU_DCDCMISCCTRL_NFETCNT_SHIFT);
    632              EMU->DCDCMISCCTRL = tmp;
    633              currentLimitersUpdate();
    634            } else {
    635              EMU->DCDCMISCCTRL = emuDcdcMiscCtrlReg;
    636              currentLimitersUpdate();
    637            }
    638          }
    639          #endif
