    100          /**
    101           * TIMER PRS registers are moved into the PRS register space on series 2 devices.
    102           * The PRS Consumer registers for a timer consist of 6 registers.
    103           *
    104           * [0] - CC0 PRS Consumer
    105           * [1] - CC1 PRS Consumer
    106           * [2] - CC2 PRS Consumer
    107           * [3] - DTI PRS Consumer
    108           * [4] - DTIFS1 PRS Consumer
    109           * [5] - DTIFS2 PRS Consumer
    110           */
    111          typedef struct {
    112            /* Hardware register array; volatile required for device access, not inter-thread. */
    113            __IOM uint32_t CONSUMER_CH[6];         /**< TIMER PRS consumers. */
    114          } PRS_TIMERn_Consumer_TypeDef;
    115          
    116          typedef struct {
    117            PRS_TIMERn_Consumer_TypeDef TIMER_CONSUMER[TIMER_COUNT];
    118          } PRS_TIMERn_TypeDef;
    119          
    120          /**
    121           * @brief Configure a timer capture/compare channel to use a PRS channel as input.
    122           *
    123           * @param[in] timer
    124           *
    125           * @param[in] cc
    126           *   Timer input channel. Valid input is 0-5.
    127           *   0 - CC0
    128           *   1 - CC1
    129           *   2 - CC2
    130           *   3 - DTI
    131           *   4 - DTIFS1
    132           *   5 - DTIFS2
    133           *
