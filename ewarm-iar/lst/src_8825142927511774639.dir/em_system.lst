    150          /***************************************************************************//**
    151           * @brief
    152           *   Get family security capability.
    153           *
    154           * @note
    155           *   This function retrieves the family security capability based on the
    156           *   device number. The device number is one letter and 3 digits:
    157           *   DEVICENUMBER = (alpha-'A')*1000 + numeric. i.e. 0d = "A000"; 1123d = "B123".
    158           *   The security capabilities are represented by ::SYSTEM_SecurityCapability_TypeDef.
    159           *
    160           * @return
    161           *   Security capability of MCU.
    162           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    163          SYSTEM_SecurityCapability_TypeDef SYSTEM_GetSecurityCapability(void)
    164          {
    165            SYSTEM_SecurityCapability_TypeDef sc;
    166          
    167          #if (_SILICON_LABS_32B_SERIES == 0)
    168            sc = securityCapabilityNA;
    169          #elif (_SILICON_LABS_32B_SERIES == 1)
    170            sc = securityCapabilityBasic;
    171          #elif (_SILICON_LABS_32B_SERIES == 2)
    172            uint16_t mcuFeatureSetMajor;
    173            uint16_t deviceNumber;
    174            deviceNumber = SYSTEM_GetPartNumber();
   \                     SYSTEM_GetSecurityCapability: (+1)
   \        0x0   0x....             LDR.N    R0,??DataTable10_4
   \        0x2   0x6801             LDR      R1,[R0, #+0]
    175            mcuFeatureSetMajor = 'A' + (deviceNumber / 1000);
    176          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)
    177            // override feature set since BRD4182A Rev A00 -> rev B02 are marked "A"
    178            mcuFeatureSetMajor = 'C';
    179          #endif
    180          
    181            switch (mcuFeatureSetMajor) {
    182              case 'A':
    183                sc = securityCapabilitySE;
    184                break;
    185          
    186              case 'B':
    187                sc = securityCapabilityVault;
    188                break;
    189          
    190              case 'C':
    191                sc = securityCapabilityRoT;
    192                break;
    193          
    194              default:
    195                sc = securityCapabilityUnknown;
    196                break;
    197            }
    198          #else
    199            sc = securityCapabilityUnknown;
    200          #endif
    201          
    202            return sc;
   \        0x4   0x2003             MOVS     R0,#+3
   \        0x6   0x4770             BX       LR
    203          }
