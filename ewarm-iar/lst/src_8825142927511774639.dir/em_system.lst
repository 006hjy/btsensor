   \                                 In section .text, align 2, keep-with-next
    212          uint64_t SYSTEM_GetUnique(void)
    213          {
    214          #if defined (_DEVINFO_EUI64H_MASK)
    215            uint32_t tmp = DEVINFO->EUI64L;
   \                     SYSTEM_GetUnique: (+1)
   \        0x0   0x....             LDR.N    R1,??DataTable10_5
   \        0x2   0x6808             LDR      R0,[R1, #+0]
    216            return ((uint64_t)DEVINFO->EUI64H << 32) | tmp;
   \        0x4   0x6849             LDR      R1,[R1, #+4]
   \        0x6   0x4770             BX       LR
    217          #elif defined(_DEVINFO_UNIQUEH_MASK)
    218            uint32_t tmp = DEVINFO->UNIQUEL;
    219            return ((uint64_t)DEVINFO->UNIQUEH << 32) | tmp;
    220          #else
    221          #error (em_system.c): Location of device unique number is not defined.
    222          #endif
    223          }
