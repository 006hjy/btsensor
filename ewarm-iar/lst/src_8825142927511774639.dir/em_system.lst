    120          bool SYSTEM_GetCalibrationValue(volatile uint32_t *regAddress)
    121          {
    122            const SYSTEM_CalAddrVal_TypeDef * p;
    123            const SYSTEM_CalAddrVal_TypeDef * end;
    124          
