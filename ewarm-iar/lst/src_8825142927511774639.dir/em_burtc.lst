    106          /***************************************************************************//**
    107           * @brief Initialize BURTC.
    108           *
    109           * @details
    110           *    Configures the BURTC peripheral.
    111           *
    112           * @note
    113           *   Before initialization, BURTC module must first be enabled by clearing the
    114           *   reset bit in the RMU, i.e.,
    115           * @verbatim
    116           *   RMU_ResetControl(rmuResetBU, rmuResetModeClear);
    117           * @endverbatim
    118           *   Compare channel 0 must be configured outside this function, before
    119           *   initialization if enable is set to true. The counter will always be reset.
    120           *
    121           * @param[in] burtcInit
    122           *   A pointer to the BURTC initialization structure.
    123           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    124          void BURTC_Init(const BURTC_Init_TypeDef *burtcInit)
    125          {
   \                     BURTC_Init: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
   \        0x2   0x4605             MOV      R5,R0
    126          #if defined(_SILICON_LABS_32B_SERIES_0)
    127            uint32_t ctrl;
    128            uint32_t presc;
    129          
    130            /* Check initializer structure integrity. */
    131            EFM_ASSERT(burtcInit != (BURTC_Init_TypeDef *) 0);
    132            /* Clock divider must be between 1 and 128, really on the form 2^n. */
    133            EFM_ASSERT((burtcInit->clkDiv >= 1) && (burtcInit->clkDiv <= 128));
    134          
    135            /* Ignored compare bits during low power operation must be less than 7. */
    136            /* Note! Giant Gecko revision C errata, do NOT use LPCOMP=7. */
    137            EFM_ASSERT(burtcInit->lowPowerComp <= 6);
    138            /* You cannot enable the BURTC if mode is set to disabled. */
    139            EFM_ASSERT((burtcInit->enable == false)
    140                       || ((burtcInit->enable == true)
    141                           && (burtcInit->mode != burtcModeDisable)));
    142            /* Low power mode is only available with LFRCO or LFXO as clock source. */
    143            EFM_ASSERT((burtcInit->clkSel != burtcClkSelULFRCO)
    144                       || ((burtcInit->clkSel == burtcClkSelULFRCO)
    145                           && (burtcInit->lowPowerMode == burtcLPDisable)));
    146          
    147            /* Calculate a prescaler value from the clock divider input. */
    148            /* Note! If clock select (clkSel) is ULFRCO, a clock divisor (clkDiv) of
    149               value 1 will select a 2 kHz ULFRCO clock, while any other value will
    150               select a 1 kHz ULFRCO clock source. */
    151            presc = divToLog2(burtcInit->clkDiv);
    152          
    153            /* Make sure all registers are updated simultaneously. */
    154            if (burtcInit->enable) {
    155              BURTC_FreezeEnable(true);
    156            }
    157          
    158            /* Modification of LPMODE register requires sync with potential ongoing
    159             * register updates in LF domain. */
    160            regSync(BURTC_SYNCBUSY_LPMODE);
    161          
    162            /* Configure low power mode. */
    163            BURTC->LPMODE = (uint32_t) (burtcInit->lowPowerMode);
    164          
    165            /* New configuration. */
    166            ctrl = (BURTC_CTRL_RSTEN
    167                    | (burtcInit->mode)
    168                    | (burtcInit->debugRun << _BURTC_CTRL_DEBUGRUN_SHIFT)
    169                    | (burtcInit->compare0Top << _BURTC_CTRL_COMP0TOP_SHIFT)
    170                    | (burtcInit->lowPowerComp << _BURTC_CTRL_LPCOMP_SHIFT)
    171                    | (presc << _BURTC_CTRL_PRESC_SHIFT)
    172                    | (burtcInit->clkSel)
    173                    | (burtcInit->timeStamp << _BURTC_CTRL_BUMODETSEN_SHIFT));
    174          
    175            /* Clear interrupts. */
    176            BURTC_IntClear(0xFFFFFFFF);
    177          
    178            /* Set the new configuration. */
    179            BURTC->CTRL = ctrl;
    180          
    181            /* Enable BURTC and counter. */
    182            if (burtcInit->enable) {
    183              /* To enable BURTC counter, disable reset. */
    184              BURTC_Enable(true);
    185          
    186              /* Clear freeze. */
    187              BURTC_FreezeEnable(false);
    188            }
    189          #elif defined(_SILICON_LABS_32B_SERIES_2)
    190            uint32_t presc;
    191          
    192            presc = divToLog2(burtcInit->clkDiv);
