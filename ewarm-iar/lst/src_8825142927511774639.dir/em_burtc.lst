   \              0x2E 0x63    
   \              0x00
   \       0x7F                      DS8 1
    385          
    386          #if defined(_BURTC_CTRL_MASK)
    387          /***************************************************************************//**
    388           * @brief
    389           *   Get the clock frequency of the BURTC.
    390           *
    391           * @return
    392           *   The current frequency in Hz.
    393           ******************************************************************************/
    394          uint32_t BURTC_ClockFreqGet(void)
    395          {
    396            uint32_t clkSel;
    397            uint32_t clkDiv;
    398            uint32_t frequency;
    399          
    400            clkSel = BURTC->CTRL & _BURTC_CTRL_CLKSEL_MASK;
    401            clkDiv = (BURTC->CTRL & _BURTC_CTRL_PRESC_MASK) >> _BURTC_CTRL_PRESC_SHIFT;
    402          
    403            switch (clkSel) {
    404              /** Ultra-low frequency (1 kHz) clock. */
    405              case BURTC_CTRL_CLKSEL_ULFRCO:
    406                if (_BURTC_CTRL_PRESC_DIV1 == clkDiv) {
    407                  frequency = 2000;     /* 2 kHz when clock divisor is 1. */
    408                } else {
    409                  frequency = SystemULFRCOClockGet();  /* 1 kHz when divisor is different
    410                                                          from 1. */
    411                }
    412                break;
    413          
    414              /** Low-frequency RC oscillator. */
    415              case BURTC_CTRL_CLKSEL_LFRCO:
    416                frequency = SystemLFRCOClockGet() / (1 << clkDiv); /* freq=32768/2^clkDiv */
    417                break;
    418          
    419              /** Low-frequency crystal oscillator. */
    420              case BURTC_CTRL_CLKSEL_LFXO:
    421                frequency = SystemLFXOClockGet() / (1 << clkDiv); /* freq=32768/2^clkDiv */
    422                break;
    423          
    424              default:
    425                /* No clock selected for BURTC. */
    426                frequency = 0;
    427            }
    428            return frequency;
    429          }
    430          #endif
    431          
    432          /** @} (end addtogroup burtc) */
    433          
    434          #endif /* BURTC_PRESENT */

