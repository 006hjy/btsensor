   1630          #ifndef __GNUC__
   1631          #define __asm__        asm
   1632          #endif
   1633          
   1634            /*
   1635             * Performs a read and write of all RAM address to initialize
   1636             * ECC syndromes. ECC is initialized by reading a RAM address
   1637             * while ECC is disabled and write it back while ECC is enabled.
   1638             *
   1639             * HardFault could occur if we try to read values from RAM while ECC
   1640             * is enabled and not initialized. In this case, ECC tries to correct the
   1641             * value and ended giving the wrong value which could be sometimes an
   1642             * non-existing address.
   1643             *
   1644             * So for ECC initialization to work properly, this must ensures that while
   1645             * ECC is enabled, RAM will be accessed only through writes, no reads shall
   1646             * occur. It's hard to have such guarantee with C code, because the C
   1647             * compiler with optimization settings, can get in the way
   1648             * and do some unwanted reads while ECC is enabled. Assembly allows such
   1649             * guarantee and let ECC be initialized without triggering errors.
   1650             */
