   1685          /***************************************************************************//**
   1686           * @brief
   1687           *    DMA read and write existing values (for ECC initialization).
   1688           *
   1689           * @details
   1690           *    This function uses DMA to read and write the existing data values in
   1691           *    the RAM region specified by start and size. The function will use the
   1692           *    2 DMA channels specified by the channels[2] array.
   1693           *
   1694           * @param[in] start
   1695           *    Start address of address range in RAM to read/write.
   1696           *
   1697           * @param[in] size
   1698           *    Size of address range in RAM to read/write.
   1699           *
   1700           * @param[in] channels[2]
   1701           *    Array of 2 DMA channels to use.
   1702           ******************************************************************************/
   1703          static void mscEccReadWriteExistingDma(uint32_t start,
   1704                                                 uint32_t size,
   1705                                                 uint32_t channels[2])
   1706          {
   1707            uint32_t descCnt = 0;
   1708            volatile uint32_t dmaDesc[ECC_DMA_DESCS][4];
   1709            uint32_t chMask = (1 << channels[0]) | (1 << channels[1]);
   1710            /* Assert that the 2 DMA channel numbers are different. */
   1711            EFM_ASSERT(channels[0] != channels[1]);
   1712          
   1713            /* Make sure ECC_RAM_SIZE_MAX is a multiple of ECC_DMA_DESC_SIZE in order
   1714               to match the total xfer size of the descriptor chain with the largest
   1715               ECC RAM bank. */
   1716            EFM_ASSERT((ECC_RAM_SIZE_MAX % ECC_DMA_DESC_SIZE) == 0);
   1717          
   1718            /* Initialize LDMA descriptor chain. */
   1719            do {
   1720              dmaDesc[descCnt][0] =                 /* DMA desc CTRL word */
   1721                                    LDMA_CH_CTRL_STRUCTTYPE_TRANSFER
   1722                                    | LDMA_CH_CTRL_STRUCTREQ
   1723                                    | _LDMA_CH_CTRL_XFERCNT_MASK
   1724                                    | LDMA_CH_CTRL_BLOCKSIZE_ALL
   1725                                    | LDMA_CH_CTRL_REQMODE_ALL
   1726                                    | LDMA_CH_CTRL_SRCINC_ONE
   1727                                    | LDMA_CH_CTRL_SIZE_WORD
   1728                                    | LDMA_CH_CTRL_DSTINC_ONE;
   1729          
   1730              /* source and destination address */
   1731              dmaDesc[descCnt][1] = start;
   1732              dmaDesc[descCnt][2] = start;
   1733              /* link to next descriptor */
   1734              dmaDesc[descCnt][3] = LDMA_CH_LINK_LINK
   1735                                    | (((uint32_t) &dmaDesc[descCnt + 1][0])
   1736                                       & _LDMA_CH_LINK_LINKADDR_MASK);
   1737          
   1738              start += ECC_DMA_DESC_SIZE;
   1739              size  -= ECC_DMA_DESC_SIZE;
   1740              descCnt++;
   1741            } while (size);
   1742          
   1743            /* Make sure descCnt is valid to avoid out-of-bounds access when writing to
   1744               dmaDesc array. */
   1745            if ((descCnt < 2) || (descCnt > ECC_DMA_DESCS)) {
   1746              while (true) {
   1747                EFM_ASSERT(false);
   1748              }
   1749            }
   1750          
   1751            /* Now, divide the descriptor list in two parts, one for each channel,
   1752               by setting the link bit and address 0 of the descriptor in the middle
   1753               to 0. */
   1754            dmaDesc[(descCnt / 2) - 1][3] = 0;
   1755          
   1756            /* Set last descriptor link bit and address to 0. */
   1757            dmaDesc[descCnt - 1][3] = 0;
   1758          
   1759          #if !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_1)
   1760            /* Start the LDMA clock now */
   1761            CMU_ClockEnable(cmuClock_LDMA, true);
   1762          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)
   1763            CMU_ClockEnable(cmuClock_LDMAXBAR, true);
   1764          #endif
   1765          #endif
   1766            /* Round robin scheduling for all channels (0 = no fixed priority channels).
   1767             */
   1768            LDMA->CTRL    = 0 << _LDMA_CTRL_NUMFIXED_SHIFT;
   1769          #if defined(LDMA_EN_EN)
   1770            LDMA->EN      = LDMA_EN_EN;
   1771          #endif
   1772            LDMA->CHEN    = 0;
   1773            LDMA->DBGHALT = 0;
   1774            LDMA->REQDIS  = 0;
   1775          
   1776            /* Disable LDMA interrupts, and clear interrupt status. */
   1777            LDMA->IEN = 0;
   1778          #if defined (LDMA_HAS_SET_CLEAR)
   1779            LDMA->IF_CLR = chMask;
   1780          #else
   1781            LDMA->IFC = chMask;
   1782          #endif
   1783          
   1784            /* Disable looping */
   1785            LDMA->CH[channels[0]].LOOP = 0;
   1786            LDMA->CH[channels[1]].LOOP = 0;
   1787          
   1788            /* Set descriptor address for first channel. */
   1789            LDMA->CH[channels[0]].LINK = ((uint32_t)&dmaDesc[0][0])
   1790                                         & _LDMA_CH_LINK_LINKADDR_MASK;
   1791            /* Set descriptor address for second channel. */
   1792            LDMA->CH[channels[1]].LINK = ((uint32_t)&dmaDesc[descCnt / 2][0])
   1793                                         & _LDMA_CH_LINK_LINKADDR_MASK;
   1794            /* Clear the channel done flags.  */
   1795            BUS_RegMaskedClear(&LDMA->CHDONE, chMask);
   1796          
   1797            /* Start transfer by loading descriptors.  */
   1798            LDMA->LINKLOAD = chMask;
   1799          
   1800            /* Wait until finished. */
   1801            while (!(
   1802          #if defined(_LDMA_CHSTATUS_MASK)
   1803                     ((LDMA->CHSTATUS & chMask) == 0)
   1804          #else
   1805                     ((LDMA->CHEN & chMask) == 0)
   1806          #endif
   1807                     && ((LDMA->CHDONE & chMask) == chMask))) {
   1808            }
   1809          
   1810          #if !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_1)
   1811            /* Stop the LDMA clock now */
   1812            CMU_ClockEnable(cmuClock_LDMA, false);
   1813          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)
   1814            CMU_ClockEnable(cmuClock_LDMAXBAR, false);
   1815          #endif
   1816          #endif
   1817          }
   1818          #endif // #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2) || defined(_MPAHBRAM_CTRL_MASK)
   1819          
   1820          /***************************************************************************//**
   1821           * @brief
   1822           *    Initialize ECC for a given memory bank.
   1823           *
   1824           * @brief
   1825           *    This function initializes ECC for a given memory bank which is specified
   1826           *    with the MSC_EccBank_Typedef structure input parameter.
   1827           *
   1828           * @param[in] eccBank
   1829           *    ECC memory bank device structure.
   1830           *
   1831           * @param[in] dmaChannels
   1832           *    Array of 2 DMA channels that may be used during ECC initialization.
   1833           *
   1834           ******************************************************************************/
   1835          static void mscEccBankInit(const MSC_EccBank_Typedef *eccBank,
   1836                                     uint32_t dmaChannels[2])
   1837          {
   1838            CORE_DECLARE_IRQ_STATE;
   1839          
   1840            CORE_ENTER_CRITICAL();
   1841          
   1842          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)  \
   1843            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7) \
   1844            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) \
   1845            || defined(_MPAHBRAM_CTRL_MASK)
   1846            (void) dmaChannels;
   1847          #if !defined(_MPAHBRAM_CTRL_MASK)
   1848            /* Disable ECC write */
   1849            ECC_CTRL_REG &= ~eccBank->initSyndromeEnable;
   1850          #endif
   1851            /* Initialize ECC syndromes by using core cpu to load and store the existing
   1852               data values in RAM. */
   1853            mscEccReadWriteExistingPio(eccBank);
   1854          #else
   1855            /* Enable ECC write */
   1856            ECC_CTRL_REG |= eccBank->initSyndromeEnable;
   1857            /* Initialize ECC syndromes by using DMA to read and write the existing
   1858               data values in RAM. */
   1859            mscEccReadWriteExistingDma(eccBank->base, eccBank->size, dmaChannels);
   1860          #endif
   1861          
   1862            /* Clear any ECC errors that may have been reported before or during
   1863               initialization. */
   1864          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
   1865            if (eccBank->base == ECC_RAM0_MEM_BASE) {
   1866              ECC_IFC0_REG = ECC_IFC_MASK;
   1867            } else if (eccBank->base == ECC_RAM1_MEM_BASE) {
   1868              ECC_IFC1_REG = ECC_IFC_MASK;
   1869            }
   1870          #else
   1871            ECC_IFC_REG = ECC_IFC_MASK;
   1872          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
   1873          
   1874          #if !defined(_MPAHBRAM_CTRL_MASK)
   1875            /* Enable ECC decoder to detect and report ECC errors. */
   1876            ECC_CTRL_REG |= eccBank->correctionEnable;
   1877          #endif
   1878          
   1879            CORE_EXIT_CRITICAL();
   1880          }
   1881          
   1882          /***************************************************************************//**
   1883           * @brief
   1884           *    Disable ECC for a given memory bank.
   1885           *
   1886           * @brief
   1887           *    This function disables ECC for a given memory bank which is specified
   1888           *    with the MSC_EccBank_Typedef structure input parameter.
   1889           *
   1890           * @param[in] eccBank
   1891           *    ECC memory bank device structure.
   1892           *
   1893           ******************************************************************************/
   1894          static void mscEccBankDisable(const MSC_EccBank_Typedef *eccBank)
   1895          {
   1896            /* Disable ECC write (encoder) and checking (decoder). */
   1897          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
   1898            if (eccBank->base == ECC_RAM0_MEM_BASE) {
   1899              ECC_CTRL0_REG &= ~(eccBank->initSyndromeEnable | eccBank->correctionEnable);
   1900            } else if (eccBank->base == ECC_RAM1_MEM_BASE) {
   1901              ECC_CTRL1_REG &= ~(eccBank->initSyndromeEnable | eccBank->correctionEnable);
   1902            }
   1903          #else
   1904            ECC_CTRL_REG &= ~(eccBank->initSyndromeEnable | eccBank->correctionEnable);
   1905          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
   1906          }
   1907          
