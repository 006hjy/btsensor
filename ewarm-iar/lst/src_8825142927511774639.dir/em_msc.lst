    807            /* VSCALE must be done. Flash erase and write requires VSCALE2. */
    808            EFM_ASSERT(!(EMU->STATUS & _EMU_STATUS_VSCALEBUSY_MASK));
    809            EFM_ASSERT((EMU->STATUS & _EMU_STATUS_VSCALE_MASK) == EMU_STATUS_VSCALE_VSCALE2);
    810          #endif
    811          
    812            /* Unlock the MSC module. */
    813            MSC->LOCK = MSC_UNLOCK_CODE;
    814            /* Disable writing to the Flash. */
    815            MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
    816          
    817          #if defined(_MSC_TIMEBASE_MASK)
    818            /* Configure MSC->TIMEBASE according to a selected frequency. */
    819            freq = CMU_ClockFreqGet(cmuClock_AUX);
    820          
    821            /* Timebase 5us is used for the 1/1.2 MHz band only. Note that the 1 MHz band
    822               is tuned to 1.2 MHz on newer revisions.  */
    823            if (freq > 1200000) {
    824              /* Calculate a number of clock cycles for 1 us as a base period. */
    825              freq   = (freq * 11) / 10;
    826              cycles = (freq / 1000000) + 1;
    827          
    828              /* Configure clock cycles for flash timing. */
    829              MSC->TIMEBASE = (MSC->TIMEBASE & ~(_MSC_TIMEBASE_BASE_MASK
    830                                                 | _MSC_TIMEBASE_PERIOD_MASK))
    831                              | MSC_TIMEBASE_PERIOD_1US
    832                              | (cycles << _MSC_TIMEBASE_BASE_SHIFT);
    833            } else {
    834              /* Calculate a number of clock cycles for 5 us as a base period. */
    835              freq   = (freq * 5 * 11) / 10;
    836              cycles = (freq / 1000000) + 1;
    837          
    838              /* Configure clock cycles for flash timing */
    839              MSC->TIMEBASE = (MSC->TIMEBASE & ~(_MSC_TIMEBASE_BASE_MASK
    840                                                 | _MSC_TIMEBASE_PERIOD_MASK))
    841                              | MSC_TIMEBASE_PERIOD_5US
    842                              | (cycles << _MSC_TIMEBASE_BASE_SHIFT);
    843            }
    844          #endif
    845          }
    846          
    847          /***************************************************************************//**
    848           * @brief
    849           *   Disables the flash controller for writing.
    850           ******************************************************************************/
    851          void MSC_Deinit(void)
    852          {
    853            /* Disable writing to the Flash. */
    854            MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
    855            /* Lock the MSC module.*/
    856            MSC->LOCK = 0;
    857          }
    858          
    859          /***************************************************************************//**
    860           * @brief
    861           *   Set the MSC code execution configuration.
    862           *
    863           * @param[in] execConfig
    864           *   The code execution configuration.
    865           ******************************************************************************/
    866          void MSC_ExecConfigSet(MSC_ExecConfig_TypeDef *execConfig)
    867          {
    868            uint32_t mscReadCtrl;
    869          
    870          #if defined(MSC_READCTRL_MODE_WS0SCBTP)
    871            mscReadCtrl = MSC->READCTRL & _MSC_READCTRL_MODE_MASK;
    872            if ((mscReadCtrl == MSC_READCTRL_MODE_WS0) && (execConfig->scbtEn)) {
    873              mscReadCtrl |= MSC_READCTRL_MODE_WS0SCBTP;
    874            } else if ((mscReadCtrl == MSC_READCTRL_MODE_WS1) && (execConfig->scbtEn)) {
    875              mscReadCtrl |= MSC_READCTRL_MODE_WS1SCBTP;
    876            } else if ((mscReadCtrl == MSC_READCTRL_MODE_WS0SCBTP) && (!execConfig->scbtEn)) {
    877              mscReadCtrl |= MSC_READCTRL_MODE_WS0;
    878            } else if ((mscReadCtrl == MSC_READCTRL_MODE_WS1SCBTP) && (!execConfig->scbtEn)) {
    879              mscReadCtrl |= MSC_READCTRL_MODE_WS1;
    880            } else {
    881              /* No change needed. */
    882            }
    883          #endif
    884          
    885            mscReadCtrl = MSC->READCTRL & ~(0
    886          #if defined(MSC_READCTRL_SCBTP)
    887                                            | MSC_READCTRL_SCBTP
    888          #endif
    889          #if defined(MSC_READCTRL_USEHPROT)
    890                                            | MSC_READCTRL_USEHPROT
    891          #endif
    892          #if defined(MSC_READCTRL_PREFETCH)
    893                                            | MSC_READCTRL_PREFETCH
    894          #endif
    895          #if defined(MSC_READCTRL_ICCDIS)
    896                                            | MSC_READCTRL_ICCDIS
    897          #endif
    898          #if defined(MSC_READCTRL_AIDIS)
    899                                            | MSC_READCTRL_AIDIS
    900          #endif
    901          #if defined(MSC_READCTRL_IFCDIS)
    902                                            | MSC_READCTRL_IFCDIS
    903          #endif
    904                                            );
    905            mscReadCtrl |= (0
    906          #if defined(MSC_READCTRL_SCBTP)
    907                            | (execConfig->scbtEn ? MSC_READCTRL_SCBTP : 0)
    908          #endif
    909          #if defined(MSC_READCTRL_USEHPROT)
    910                            | (execConfig->useHprot ? MSC_READCTRL_USEHPROT : 0)
    911          #endif
    912          #if defined(MSC_READCTRL_PREFETCH)
    913                            | (execConfig->prefetchEn ? MSC_READCTRL_PREFETCH : 0)
    914          #endif
    915          #if defined(MSC_READCTRL_ICCDIS)
    916                            | (execConfig->iccDis ? MSC_READCTRL_ICCDIS : 0)
    917          #endif
    918          #if defined(MSC_READCTRL_AIDIS)
    919                            | (execConfig->aiDis ? MSC_READCTRL_AIDIS : 0)
    920          #endif
    921          #if defined(MSC_READCTRL_IFCDIS)
    922                            | (execConfig->ifcDis ? MSC_READCTRL_IFCDIS : 0)
    923          #endif
    924                            );
    925          
    926            MSC->READCTRL = mscReadCtrl;
    927          }
    928          
    929          /** @cond DO_NOT_INCLUDE_WITH_DOXYGEN */
    930          
    931          /***************************************************************************//**
    932           * @brief
    933           *   Perform the address phase of the flash write cycle.
    934           * @details
    935           *   This function performs the address phase of a flash write operation by
    936           *   writing the given flash address to the ADDRB register and issuing the
    937           *   LADDRIM command to load the address.
    938           * @param[in] address
    939           *   An address in flash memory. Must be aligned at a 4 byte boundary.
    940           * @return
    941           *   Returns the status of the address load operation, @ref MSC_Status_TypeDef
    942           * @verbatim
    943           *   mscReturnOk - The operation completed successfully.
    944           *   mscReturnInvalidAddr - The operation tried to erase a non-flash area.
    945           *   mscReturnLocked - The operation tried to erase a locked area of the Flash.
    946           * @endverbatim
    947           ******************************************************************************/
    948          MSC_RAMFUNC_DEFINITION_BEGIN
    949          MSC_Status_TypeDef MSC_LoadVerifyAddress(uint32_t* address)
    950          {
    951            uint32_t timeOut;
    952          
    953            /* Wait for the MSC to become ready. */
    954            timeOut = MSC_PROGRAM_TIMEOUT;
    955            while ((MSC->STATUS & MSC_STATUS_BUSY) && (timeOut != 0)) {
    956              timeOut--;
    957            }
    958          
    959            /* Check for timeout. */
    960            if (timeOut == 0) {
    961              return mscReturnTimeOut;
    962            }
    963            /* Load the address. */
    964            MSC->ADDRB    = (uint32_t)address;
    965            MSC->WRITECMD = MSC_WRITECMD_LADDRIM;
    966          
    967            /* Check for an invalid address. */
    968            if (MSC->STATUS & MSC_STATUS_INVADDR) {
    969              return mscReturnInvalidAddr;
    970            }
    971            return mscReturnOk;
    972          }
    973          MSC_RAMFUNC_DEFINITION_END
    974          
    975          /***************************************************************************//**
    976           * @brief
    977           *   Perform a flash data write phase.
    978           * @details
    979           *   This function performs the data phase of a flash write operation by loading
    980           *   the given number of 32-bit words to the WDATA register.
    981           * @param[in] data
    982           *   A pointer to the first data word to load.
    983           * @param[in] numWords
    984           *   A number of data words (32-bit) to load.
    985           * @return
    986           *   Returns the status of the data load operation.
    987           * @verbatim
    988           *   mscReturnOk - An operation completed successfully.
    989           *   mscReturnTimeOut - An operation timed out waiting for the flash operation
    990           *                      to complete.
    991           * @endverbatim
    992           ******************************************************************************/
    993          MSC_RAMFUNC_DEFINITION_BEGIN
    994          MSC_Status_TypeDef MSC_LoadWriteData(uint32_t* data,
    995                                               uint32_t numWords)
    996          {
    997            uint32_t timeOut;
    998            uint32_t wordIndex;
    999            bool useWDouble = false;
   1000            MSC_Status_TypeDef retval = mscReturnOk;
   1001          
   1002          #if defined(_SILICON_LABS_32B_SERIES_0) && defined(_MSC_WRITECTRL_WDOUBLE_MASK)
   1003            /* If the LPWRITE (Low Power Write) is NOT enabled, set WDOUBLE (Write Double word). */
   1004            if (!(MSC->WRITECTRL & MSC_WRITECTRL_LPWRITE)) {
   1005              /* If the number of words to be written is odd, align by writing
   1006                 a single word first, before setting the WDOUBLE bit. */
   1007              if (numWords & 0x1) {
   1008                /* Wait for the MSC to become ready for the next word. */
   1009                timeOut = MSC_PROGRAM_TIMEOUT;
   1010                while ((!(MSC->STATUS & MSC_STATUS_WDATAREADY)) && (timeOut != 0)) {
   1011                  timeOut--;
   1012                }
   1013                /* Check for timeout. */
   1014                if (timeOut == 0) {
   1015                  return mscReturnTimeOut;
   1016                }
   1017          
   1018                /* Clear the double word option to write the initial single word. */
   1019                MSC->WRITECTRL &= ~MSC_WRITECTRL_WDOUBLE;
   1020                /* Write first data word. */
   1021                MSC->WDATA = *data++;
   1022                MSC->WRITECMD = MSC_WRITECMD_WRITEONCE;
   1023          
   1024                /* Wait for the operation to finish. It may be required to change the WDOUBLE
   1025                   configuration after the initial write. It should not be changed while BUSY. */
   1026                timeOut = MSC_PROGRAM_TIMEOUT;
   1027                while ((MSC->STATUS & MSC_STATUS_BUSY) && (timeOut != 0)) {
   1028                  timeOut--;
   1029                }
   1030                /* Check for timeout. */
   1031                if (timeOut == 0) {
   1032                  return mscReturnTimeOut;
   1033                }
   1034                /* Check for a write protected flash area. */
   1035                if (MSC->STATUS & MSC_STATUS_LOCKED) {
   1036                  return mscReturnLocked;
   1037                }
   1038                /* Subtract this initial odd word for the write loop below. */
   1039                numWords -= 1;
   1040                retval = mscReturnOk;
   1041              }
   1042              /* Set the double word option to write two words per
   1043                 data phase. */
   1044              MSC->WRITECTRL |= MSC_WRITECTRL_WDOUBLE;
   1045              useWDouble = true;
   1046            }
   1047          #endif /* defined( _MSC_WRITECTRL_LPWRITE_MASK ) && defined( _MSC_WRITECTRL_WDOUBLE_MASK ) */
   1048          
   1049            /* Write the rest as a double word write if wordsPerDataPhase == 2 */
   1050            if (numWords > 0) {
   1051              /* Requires a system core clock at 1MHz or higher */
   1052              EFM_ASSERT(SystemCoreClock >= 1000000);
   1053              wordIndex = 0;
   1054              while (wordIndex < numWords) {
   1055                if (!useWDouble) {
   1056                  MSC->WDATA = *data++;
   1057                  wordIndex++;
   1058                  MSC->WRITECMD = MSC_WRITECMD_WRITEONCE;
   1059                } else {
   1060                  /* Trigger a double write according to flash properties. */
   1061          #if defined(_SILICON_LABS_32B_SERIES_0) && defined(_MSC_WRITECTRL_WDOUBLE_MASK)
   1062                  MSC->WDATA = *data++;
   1063                  while (!(MSC->STATUS & MSC_STATUS_WDATAREADY)) ;
   1064                  MSC->WDATA = *data++;
   1065                  wordIndex += 2;
   1066                  MSC->WRITECMD = MSC_WRITECMD_WRITEONCE;
   1067          #endif
   1068                }
   1069          
   1070                /* Wait for the transaction to finish. */
   1071                timeOut = MSC_PROGRAM_TIMEOUT;
   1072                while ((MSC->STATUS & MSC_STATUS_BUSY) && (timeOut != 0)) {
   1073                  timeOut--;
   1074                }
   1075                /* Check for a timeout. */
   1076                if (timeOut == 0) {
   1077                  retval = mscReturnTimeOut;
   1078                  break;
   1079                }
   1080                /* Check for a write protected flash area. */
   1081                if (MSC->STATUS & MSC_STATUS_LOCKED) {
   1082                  retval = mscReturnLocked;
   1083                  break;
   1084                }
   1085          #if defined(_EFM32_GECKO_FAMILY)
   1086                MSC->ADDRB += 4;
   1087                MSC->WRITECMD = MSC_WRITECMD_LADDRIM;
   1088          #endif
   1089              }
   1090            }
   1091          
   1092          #if defined(_MSC_WRITECTRL_WDOUBLE_MASK)
   1093            /* Clear a double word option, which should not be left on when returning. */
   1094            MSC->WRITECTRL &= ~MSC_WRITECTRL_WDOUBLE;
   1095          #endif
   1096          
   1097            return retval;
   1098          }
   1099          MSC_RAMFUNC_DEFINITION_END
   1100          
   1101          /***************************************************************************//**
   1102           * @brief
   1103           *   An internal flash write function.
   1104           * @param[in] address
   1105           *   A write address.
   1106           * @param[in] data
   1107           *   A pointer to the first data word to load.
   1108           * @param[in] numBytes
   1109           *   A nsumber of data bytes to load, which must be a multiple of 4 bytes.
   1110           * @return
   1111           *   Returns the status of the data load operation.
   1112           ******************************************************************************/
   1113          MSC_RAMFUNC_DEFINITION_BEGIN
   1114          MSC_Status_TypeDef MSC_WriteWordI(uint32_t *address,
   1115                                            void const *data,
   1116                                            uint32_t numBytes)
   1117          {
   1118            uint32_t wordCount;
   1119            uint32_t numWords;
   1120            uint32_t pageWords;
   1121            uint32_t* pData;
   1122            bool wasLocked;
   1123            MSC_Status_TypeDef retval = mscReturnOk;
   1124          
   1125            wasLocked = MSC_IS_LOCKED();
   1126            MSC->LOCK = MSC_LOCK_LOCKKEY_UNLOCK;
   1127          
   1128            /* Check alignment (must be aligned to words). */
   1129            EFM_ASSERT(((uint32_t) address & 0x3) == 0);
   1130          
   1131            /* Check a number of bytes. Must be divisible by four. */
   1132            EFM_ASSERT((numBytes & 0x3) == 0);
   1133          
   1134          #if defined(_EMU_STATUS_VSCALE_MASK) && defined(_SILICON_LABS_32B_SERIES_1)
   1135            /* VSCALE must be done and flash write requires VSCALE2. */
   1136            EFM_ASSERT(!(EMU->STATUS & _EMU_STATUS_VSCALEBUSY_MASK));
   1137            EFM_ASSERT((EMU->STATUS & _EMU_STATUS_VSCALE_MASK) == EMU_STATUS_VSCALE_VSCALE2);
   1138          #endif
   1139          
   1140            /* Enable writing to the MSC module. */
   1141            MSC->WRITECTRL |= MSC_WRITECTRL_WREN;
   1142          
   1143            /* Convert bytes to words. */
   1144            numWords = numBytes >> 2;
   1145            EFM_ASSERT(numWords > 0);
   1146          
   1147            /* The following loop splits the data into chunks corresponding to flash pages.
   1148               The address is loaded only once per page because the hardware automatically
   1149               increments the address internally for each data load inside a page. */
   1150            for (wordCount = 0, pData = (uint32_t *)data; wordCount < numWords; ) {
   1151              /* First, the address is loaded. The address is auto-incremented within a page.
   1152                 Therefore, the address phase is only needed once for each page. */
   1153              retval = MSC_LoadVerifyAddress(address + wordCount);
   1154              if (mscReturnOk != retval) {
   1155                /* Disable writing to the MSC module. */
   1156                MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1157                if (wasLocked) {
   1158                  MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1159                }
   1160                return retval;
   1161              }
   1162              /* Compute the number of words to write to the current page. */
   1163              pageWords =
   1164                (FLASH_PAGE_SIZE
   1165                 - (((uint32_t) (address + wordCount)) & (FLASH_PAGE_SIZE - 1)))
   1166                / sizeof(uint32_t);
   1167              if (pageWords > numWords - wordCount) {
   1168                pageWords = numWords - wordCount;
   1169              }
   1170              /* Write the data in the current page. */
   1171              retval = MSC_LoadWriteData(pData, pageWords);
   1172              if (mscReturnOk != retval) {
   1173                break;
   1174              }
   1175              wordCount += pageWords;
   1176              pData += pageWords;
   1177            }
   1178          
   1179          #if defined(ERRATA_FIX_FLASH_E201_EN)
   1180            /* Fix for errata FLASH_E201 - Potential program failure after Power On.
   1181             *
   1182             * Check if the first word was programmed correctly. If a failure is detected,
   1183             * retry programming of the first word.
   1184             *
   1185             * A full description of the errata is in the errata document. */
   1186            pData = (uint32_t *) data;
   1187            if (*address != *pData) {
   1188              retval = MSC_LoadVerifyAddress(address);
   1189              if (mscReturnOk == retval) {
   1190                retval = MSC_LoadWriteData(pData, 1);
   1191              }
   1192            }
   1193          #endif
   1194          
   1195            /* Disable writing to the MSC module. */
   1196            MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1197          
   1198          #if defined(_MSC_WRITECTRL_WDOUBLE_MASK)
   1199          #if (WORDS_PER_DATA_PHASE == 2)
   1200            /* Turn off the double word write cycle support. */
   1201            MSC->WRITECTRL &= ~MSC_WRITECTRL_WDOUBLE;
   1202          #endif
   1203          #endif
   1204            if (wasLocked) {
   1205              MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1206            }
   1207            return retval;
   1208          }
   1209          MSC_RAMFUNC_DEFINITION_END
   1210          
   1211          /** @endcond */
   1212          
   1213          /***************************************************************************//**
   1214           * @brief
   1215           *   Erases a page in flash memory.
   1216           * @note
   1217           *   For the Gecko family, it is required to run this function from RAM.
   1218           *
   1219           *   For IAR Embedded Workbench, Simplicity Studio and GCC, this is
   1220           *   achieved automatically by using attributes in the function proctype. For Keil
   1221           *   uVision IDE, define a section called "ram_code" and place this manually in
   1222           *   the project's scatter file.
   1223           *
   1224           * @param[in] startAddress
   1225           *   A pointer to the flash page to erase. Must be aligned to the beginning of the page
   1226           *   boundary.
   1227           * @return
   1228           *   Returns the status of erase operation, @ref MSC_Status_TypeDef
   1229           * @verbatim
   1230           *   mscReturnOk - The operation completed successfully.
   1231           *   mscReturnInvalidAddr - The operation tried to erase a non-flash area.
   1232           *   mscReturnLocked - The operation tried to erase a locked area of the flash.
   1233           *   mscReturnTimeOut - The operation timed out waiting for the flash operation
   1234           *       to complete.
   1235           * @endverbatim
   1236           ******************************************************************************/
   1237          MSC_RAMFUNC_DEFINITION_BEGIN
   1238          MSC_Status_TypeDef MSC_ErasePage(uint32_t *startAddress)
   1239          {
   1240            uint32_t timeOut = MSC_PROGRAM_TIMEOUT;
   1241            bool wasLocked;
   1242          
   1243            wasLocked = MSC_IS_LOCKED();
   1244            MSC->LOCK = MSC_LOCK_LOCKKEY_UNLOCK;
   1245          
   1246            /* An address must be aligned to pages. */
   1247            EFM_ASSERT((((uint32_t) startAddress) & (FLASH_PAGE_SIZE - 1)) == 0);
   1248          #if defined(_EMU_STATUS_VSCALE_MASK) && defined(_SILICON_LABS_32B_SERIES_1)
   1249            /* VSCALE must be done and flash erase requires VSCALE2. */
   1250            EFM_ASSERT(!(EMU->STATUS & _EMU_STATUS_VSCALEBUSY_MASK));
   1251            EFM_ASSERT((EMU->STATUS & _EMU_STATUS_VSCALE_MASK) == EMU_STATUS_VSCALE_VSCALE2);
   1252          #endif
   1253          
   1254            /* Enable writing to the MSC module. */
   1255            MSC->WRITECTRL |= MSC_WRITECTRL_WREN;
   1256          
   1257            /* Load an address. */
   1258            MSC->ADDRB    = (uint32_t)startAddress;
   1259            MSC->WRITECMD = MSC_WRITECMD_LADDRIM;
   1260          
   1261            /* Check for an invalid address. */
   1262            if (MSC->STATUS & MSC_STATUS_INVADDR) {
   1263              /* Disable writing to the MSC module. */
   1264              MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1265              if (wasLocked) {
   1266                MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1267              }
   1268              return mscReturnInvalidAddr;
   1269            }
   1270          
   1271            /* Send erase page command. */
   1272            MSC->WRITECMD = MSC_WRITECMD_ERASEPAGE;
   1273          
   1274            /* Wait for the erase to complete. */
   1275            while ((MSC->STATUS & MSC_STATUS_BUSY) && (timeOut != 0)) {
   1276              timeOut--;
   1277            }
   1278            /* Check for write protected page. */
   1279            if (MSC->STATUS & MSC_STATUS_LOCKED) {
   1280              /* Disable writing to the MSC module. */
   1281              MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1282              if (wasLocked) {
   1283                MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1284              }
   1285              return mscReturnLocked;
   1286            }
   1287            if (timeOut == 0) {
   1288              /* Disable writing to the MSC module. */
   1289              MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1290              if (wasLocked) {
   1291                MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1292              }
   1293              return mscReturnTimeOut;
   1294            }
   1295            /* Disable writing to the MSC module. */
   1296            MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1297            if (wasLocked) {
   1298              MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1299            }
   1300            return mscReturnOk;
   1301          }
   1302          MSC_RAMFUNC_DEFINITION_END
   1303          
   1304          /***************************************************************************//**
   1305           * @brief
   1306           *   Writes data to flash memory. This function is interrupt-safe, but slower than
   1307           *   MSC_WriteWordFast(), which writes to flash with interrupts disabled.
   1308           *   Write data must be aligned to words and contain a number of bytes that is
   1309           *   divisible by four.
   1310           * @note
   1311           *   It is recommended to erase the flash page before performing a write.
   1312           *
   1313           *   For the Gecko family, it is required to run this function from RAM.
   1314           *
   1315           *   For IAR Embedded Workbench, Simplicity Studio and GCC,
   1316           *   this is done automatically by using attributes in the function proctype.
   1317           *   For Keil uVision IDE, define a section called "ram_code" and place it
   1318           *   manually in the project's scatter file.
   1319           *
   1320           *   This function requires a system core clock at 1 MHz or higher.
   1321           *
   1322           * @param[in] address
   1323           *   A pointer to the flash word to write to. Must be aligned to words.
   1324           * @param[in] data
   1325           *   Data to write to flash.
   1326           * @param[in] numBytes
   1327           *   A number of bytes to write from flash. NB: Must be divisible by four.
   1328           * @return
   1329           *   Returns the status of the write operation.
   1330           * @verbatim
   1331           *   flashReturnOk - The operation completed successfully.
   1332           *   flashReturnInvalidAddr - The operation tried to erase a non-flash area.
   1333           *   flashReturnLocked - The operation tried to erase a locked area of the Flash.
   1334           *   flashReturnTimeOut - The operation timed out waiting for the flash operation
   1335           *       to complete, or the MSC module timed out waiting for the software to write
   1336           *       the next word into the DWORD register.
   1337           * @endverbatim
   1338           ******************************************************************************/
   1339          MSC_RAMFUNC_DEFINITION_BEGIN
   1340          MSC_Status_TypeDef MSC_WriteWord(uint32_t *address,
   1341                                           void const *data,
   1342                                           uint32_t numBytes)
   1343          {
   1344            return MSC_WriteWordI(address, data, numBytes);
   1345          }
   1346          MSC_RAMFUNC_DEFINITION_END
   1347          
   1348          /***************************************************************************//**
   1349           * @brief
   1350           *   Writes data to flash memory. This function is faster than MSC_WriteWord(),
   1351           *   but it disables interrupts. Write data must be aligned to words and contain
   1352           *   a number of bytes that is divisible by four.
   1353           * @warning
   1354           *   This function is only available for certain devices.
   1355           * @note
   1356           *   It is recommended to erase the flash page before performing a write.
   1357           *   It is required to run this function from RAM on parts that include a
   1358           *   flash write buffer.
   1359           *
   1360           *   For IAR Embedded Workbench, Simplicity Studio and GCC,
   1361           *   this is done automatically by using attributes in the function proctype.
   1362           *   For Keil uVision IDE, define a section called "ram_code" and place this manually
   1363           *   in the project's scatter file.
   1364           *
   1365           * @deprecated
   1366           *   This function is deprecated, the functionality is the same as calling
   1367           *   @ref MSC_WriteWord().
   1368           *
   1369           * @param[in] address
   1370           *   A pointer to the flash word to write to. Must be aligned to words.
   1371           * @param[in] data
   1372           *   Data to write to flash.
   1373           * @param[in] numBytes
   1374           *   A number of bytes to write from the Flash. NB: Must be divisible by four.
   1375           * @return
   1376           *   Returns the status of the write operation.
   1377           * @verbatim
   1378           *   flashReturnOk - The operation completed successfully.
   1379           *   flashReturnInvalidAddr - The operation tried to erase a non-flash area.
   1380           *   flashReturnLocked - The operation tried to erase a locked area of the flash.
   1381           *   flashReturnTimeOut - The operation timed out waiting for flash operation
   1382           *       to complete. Or the MSC timed out waiting for the software to write
   1383           *       the next word into the DWORD register.
   1384           * @endverbatim
   1385           ******************************************************************************/
   1386          MSC_RAMFUNC_DEFINITION_BEGIN
   1387          MSC_Status_TypeDef MSC_WriteWordFast(uint32_t *address,
   1388                                               void const *data,
   1389                                               uint32_t numBytes)
   1390          {
   1391            return MSC_WriteWord(address, data, numBytes);
   1392          }
   1393          MSC_RAMFUNC_DEFINITION_END
   1394          
   1395          #if (_SILICON_LABS_32B_SERIES > 0)
   1396          /***************************************************************************//**
   1397           * @brief
   1398           *   Writes data from RAM to flash memory using the DMA.
   1399           *
   1400           * @details
   1401           *   This function uses the LDMA to write data to the internal flash memory.
   1402           *   This is the fastest way to write data to the flash and should be used when
   1403           *   the application wants to achieve write speeds like they are reported in the
   1404           *   datasheet. Note that this function only supports writing data from RAM to
   1405           *   flash, it does not support writing data from flash to flash.
   1406           *
   1407           * @note
   1408           *   This function requires that the LDMA clock is enabled.
   1409           *
   1410           * @param[in] ch
   1411           *   DMA channel to use
   1412           *
   1413           * @param[in] address
   1414           *   A pointer to the flash word to write to. Must be aligned to words.
   1415           *
   1416           * @param[in] data
   1417           *   Data to write to flash. Note that this argument must be an address in RAM.
   1418           *   This function does not support copying data from flash to flash on series-1
   1419           *   devices. Must be aligned to words.
   1420           *
   1421           * @param[in] numBytes
   1422           *   A number of bytes to write from flash. NB: Must be divisible by four.
   1423           *
   1424           * @return
   1425           *   Returns the status of the write operation.
   1426           * @verbatim
   1427           *   flashReturnOk - The operation completed successfully.
   1428           *   flashReturnInvalidAddr - The operation tried to erase a non-flash area.
   1429           * @endverbatim
   1430           ******************************************************************************/
   1431          MSC_Status_TypeDef MSC_WriteWordDma(int ch,
   1432                                              uint32_t *address,
   1433                                              const void *data,
   1434                                              uint32_t numBytes)
   1435          {
   1436            uint32_t words = numBytes / 4;
   1437            uint32_t burstLen;
   1438            uint32_t src = (uint32_t) data;
   1439            uint32_t dst = (uint32_t) address;
   1440            bool wasLocked;
   1441          
   1442            EFM_ASSERT((ch >= 0) && (ch < (int)DMA_CHAN_COUNT));
   1443          
   1444            // Verify that the data argument is in RAM
   1445            if (((uint32_t)data < SRAM_BASE) || ((uint32_t)data > (SRAM_BASE + SRAM_SIZE))) {
   1446              EFM_ASSERT(false);
   1447              return mscReturnInvalidAddr;
   1448            }
   1449          
   1450            LDMA->CH[ch].REQSEL = LDMA_CH_REQSEL_SOURCESEL_MSC
   1451                                  | LDMA_CH_REQSEL_SIGSEL_MSCWDATA;
   1452            LDMA->CH[ch].CFG = _LDMA_CH_CFG_RESETVALUE;
   1453            LDMA->CH[ch].LOOP = _LDMA_CH_LOOP_RESETVALUE;
   1454            LDMA->CH[ch].LINK = _LDMA_CH_LINK_RESETVALUE;
   1455          
   1456            wasLocked = MSC_IS_LOCKED();
   1457            MSC->LOCK = MSC_LOCK_LOCKKEY_UNLOCK;
   1458            // Enable writing to the MSC module.
   1459            MSC->WRITECTRL |= MSC_WRITECTRL_WREN;
   1460          
   1461            while (numBytes) {
   1462              // Max burst length is up to next flash page boundary
   1463              burstLen = SL_MIN(numBytes,
   1464                                ((dst + FLASH_PAGE_SIZE) & FLASH_PAGE_MASK) - dst);
   1465              words = burstLen / 4;
   1466          
   1467              // Load the address.
   1468              MSC->ADDRB    = dst;
   1469              MSC->WRITECMD = MSC_WRITECMD_LADDRIM;
   1470          
   1471              // Check for an invalid address.
   1472              if (MSC->STATUS & MSC_STATUS_INVADDR) {
   1473                return mscReturnInvalidAddr;
   1474              }
   1475          
   1476              LDMA->CH[ch].CTRL = LDMA_CH_CTRL_DSTINC_NONE
   1477                                  | LDMA_CH_CTRL_SIZE_WORD
   1478                                  | ((words - 1) << _LDMA_CH_CTRL_XFERCNT_SHIFT);
   1479              LDMA->CH[ch].SRC = src;
   1480              LDMA->CH[ch].DST = (uint32_t)&MSC->WDATA;
   1481          
   1482              // Enable channel
   1483              LDMA->CHEN |= (0x1 << ch);
   1484              MSC->WRITECMD = MSC_WRITECMD_WRITETRIG;
   1485          
   1486              while ((LDMA->CHDONE & (0x1 << ch)) == 0x0) {
   1487                // Wait for LDMA channel.
   1488              }
   1489              BUS_RegMaskedClear(&LDMA->CHDONE, (0x1 << ch));
   1490              BUS_RegMaskedClear(&LDMA->CHEN, (0x1 << ch));
   1491          
   1492              dst      += burstLen;
   1493              src      += burstLen;
   1494              numBytes -= burstLen;
   1495            }
   1496          
   1497            MSC->WRITECMD = MSC_WRITECMD_WRITEEND;
   1498          
   1499            // Disable writing to the MSC module.
   1500            MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1501            if (wasLocked) {
   1502              MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1503            }
   1504          
   1505            return mscReturnOk;
   1506          }
   1507          #endif
   1508          
   1509          #if defined(_MSC_MASSLOCK_MASK)
   1510          SL_RAMFUNC_DEFINITION_BEGIN
   1511          MSC_Status_TypeDef MSC_MassErase(void)
   1512          {
   1513            bool wasLocked;
   1514            wasLocked = MSC_IS_LOCKED();
   1515            MSC->LOCK = MSC_LOCK_LOCKKEY_UNLOCK;
   1516          
   1517            /* Enable writing to the MSC module. */
   1518            MSC->WRITECTRL |= MSC_WRITECTRL_WREN;
   1519          
   1520            /* Unlock the device mass erase. */
   1521            MSC->MASSLOCK = MSC_MASSLOCK_LOCKKEY_UNLOCK;
   1522          
   1523            /* Erase the first 512 K block. */
   1524            MSC->WRITECMD = MSC_WRITECMD_ERASEMAIN0;
   1525          
   1526            /* Waiting for erase to complete. */
   1527            while ((MSC->STATUS & MSC_STATUS_BUSY) != 0U) {
   1528            }
   1529          
   1530          #if ((FLASH_SIZE >= (512 * 1024)) && defined(_MSC_WRITECMD_ERASEMAIN1_MASK))
   1531            /* Erase the second 512 K block. */
   1532            MSC->WRITECMD = MSC_WRITECMD_ERASEMAIN1;
   1533          
   1534            /* Waiting for erase to complete. */
   1535            while ((MSC->STATUS & MSC_STATUS_BUSY) != 0U) {
   1536            }
   1537          #endif
   1538          
   1539            /* Restore the mass erase lock. */
   1540            MSC->MASSLOCK = MSC_MASSLOCK_LOCKKEY_LOCK;
   1541          
   1542            /* Disable writing to the MSC module. */
   1543            MSC->WRITECTRL &= ~MSC_WRITECTRL_WREN;
   1544          
   1545            if (wasLocked) {
   1546              MSC->LOCK = MSC_LOCK_LOCKKEY_LOCK;
   1547            }
   1548          
   1549            /* This will only successfully return if calling function is also in SRAM. */
   1550            return mscReturnOk;
   1551          }
   1552          SL_RAMFUNC_DEFINITION_END
   1553          #endif  // defined(_MSC_MASSLOCK_MASK)
   1554          
   1555          #endif // defined(_SILICON_LABS_32B_SERIES_2)
   1556          
