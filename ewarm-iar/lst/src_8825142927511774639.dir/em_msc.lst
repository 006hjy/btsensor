   1973          #if defined(_SYSCFG_DMEM0PORTMAPSEL_MASK)
   1974          /***************************************************************************//**
   1975           * @brief
   1976           *   Set MPAHBRAM port to use to access DMEM.
   1977           *
   1978           * @details
   1979           *   This function configures which MPAHBRAM slave port is used to access DMEM.
   1980           *   Depending on the use case, it might improve performance by spreading the
   1981           *   load over the N ports (N is usually 2 or 4), instead of starving because a
   1982           *   port is used by another master.
   1983           *
   1984           * @param[in] master
   1985           *   AHBHOST master to be configured.
   1986           * @param[in] port
   1987           *   AHBHOST slave port to use.
   1988           ******************************************************************************/
   1989          void MSC_DmemPortMapSet(MSC_DmemMaster_TypeDef master, uint8_t port)
   1990          {
   1991          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
   1992            uint32_t bitfieldMask = DMEM_NUM_PORTS - 1;
   1993          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
   1994            uint32_t bitfieldMask = DMEM0_NUM_PORTS - 1;
   1995          #endif
   1996          
   1997            /* make sure master is within the mask of port map that can be changed
   1998             * make sure port is a sensible value
   1999             */
   2000            EFM_ASSERT(((1 << master) & _SYSCFG_DMEM0PORTMAPSEL_MASK) != 0x0);
   2001          
   2002          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
   2003            EFM_ASSERT(port < DMEM_NUM_PORTS);
   2004          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
   2005            EFM_ASSERT(port < DMEM0_NUM_PORTS);
   2006          #endif
   2007          
   2008          #if defined(CMU_CLKEN0_SYSCFG)
   2009            bool disableSyscfgClk = false;
   2010          
   2011            if (!(CMU->CLKEN0 & _CMU_CLKEN0_SYSCFG_MASK)) {
   2012              disableSyscfgClk = true;
   2013              CMU->CLKEN0_SET = CMU_CLKEN0_SYSCFG;
   2014            }
   2015          #endif
   2016          
   2017            BUS_RegMaskedWrite(&SYSCFG->DMEM0PORTMAPSEL,
   2018                               bitfieldMask << master,
   2019                               (uint32_t)port << master);
   2020          
   2021          #if defined(CMU_CLKEN0_SYSCFG)
   2022            if (disableSyscfgClk) {
   2023              CMU->CLKEN0_CLR = CMU_CLKEN0_SYSCFG;
   2024            }
   2025          #endif
   2026          }
   2027          #endif
   2028          
   2029          #if defined(_MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK)
   2030          /***************************************************************************//**
   2031           * @brief
   2032           *   Set MPAHBRAM port priority for arbitration when multiple concurrent
   2033           *   transactions to DMEM.
   2034           *
   2035           * @details
   2036           *   This function configures which MPAHBRAM slave port will have priority.
   2037           *   The AHB port arbitration default scheme, round-robin arbitration, is
   2038           *   selected when portPriority == mscPortPriorityNone.
   2039           *
   2040           * @note
   2041           *   Doing this can potentially starve the others AHB port(s).
   2042           *
   2043           * @param[in] portPriority
   2044           *   AHBHOST slave port having elevated priority.
   2045           ******************************************************************************/
   2046          void MSC_PortSetPriority(MSC_PortPriority_TypeDef portPriority)
   2047          {
   2048          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
   2049            EFM_ASSERT(portPriority < ((DMEM_NUM_PORTS + 1) << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT));
   2050          
   2051            BUS_RegMaskedWrite(&DMEM->CTRL,
   2052                               _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
   2053                               (uint32_t)portPriority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
   2054          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
   2055            EFM_ASSERT(portPriority < ((DMEM0_NUM_PORTS + 1) << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT));
   2056          
   2057            BUS_RegMaskedWrite(&DMEM0->CTRL,
   2058                               _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
   2059                               (uint32_t)portPriority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
   2060            BUS_RegMaskedWrite(&DMEM1->CTRL,
   2061                               _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
   2062                               (uint32_t)portPriority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
   2063          #endif
   2064          }
   2065          
   2066          /***************************************************************************//**
   2067           * @brief
   2068           *   Get MPAHBRAM port arbitration priority selection.
   2069           *
   2070           * @details
   2071           *   This function returns the AHBHOST slave with raised priority.
   2072           *
   2073           * @return
   2074           *   Returns the AHBHOST slave port given priority or none.
   2075           ******************************************************************************/
   2076          MSC_PortPriority_TypeDef MSC_PortGetCurrentPriority(void)
   2077          {
   2078            uint32_t port = 0;
