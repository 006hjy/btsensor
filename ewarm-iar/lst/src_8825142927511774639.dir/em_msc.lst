   1652            __asm__ volatile (
   1653              "1:\n\t"                         /* define label 1                       */
   1654              "LDR r1, [%[ramptr]]\n\t"        /* load content of ramptr into R1, ECC
   1655                                                  is disabled to get a correct value   */
   1656              "LDR r0, [%[ctrlreg]]\n\t"       /* load ctrlreg content into R0         */
   1657              "ORR r0, r0, %[enableEcc]\n\t"     /* OR R0 and enableEcc, and store result
   1658                                                    in R0                                */
   1659              "STR r0, [%[ctrlreg]]\n\t"       /* write R0 into ctrlreg, ECC is
   1660                                                  enabled from now on                  */
   1661              "STR r1, [%[ramptr]]\n\t"        /* write back ram content where it was,
   1662                                                  syndrome will be written in ECC      */
   1663              "BIC r0, r0, %[enableEcc]\n\t"     /* bit clear enableEcc from R0, and store
   1664                                                    result in R0                         */
   1665              "STR r0, [%[ctrlreg]]\n\t"       /* write R0 into ctrlreg, ECC is
   1666                                                  disabled                             */
   1667              "ADDS %[ramptr], %[ramptr], #4\n\t" /* increment ramptr by 4 (size of
   1668                                                     a word)                           */
   1669              "CMP %[ramptr], %[endptr]\n\t"   /* compare ramptr and endptr...         */
   1670              "BCC 1b\n\t"                     /* ... and jump back to label 1 if Carry
   1671                                                  Clear (meaning ramptr < endptr)      */
   1672              "ORR r0, r0, %[enableEcc]\n\t"     /* and re-enable ECC ASAP to be sure no */
   1673              "STR r0, [%[ctrlreg]]\n\t"       /* STR occurs with ECC disabled         */
   1674              :[ramptr] "+r" (ramptr)
   1675              :[endptr] "r" (endptr),
   1676              [ctrlreg] "r" (ctrlreg),
   1677              [enableEcc] "r" (enableEcc)
   1678              : "r0", "r1", /* R0  and R1 used as temporary registers */
   1679              "memory"      /* Memory pointed by ramptr is modified   */
   1680              );
