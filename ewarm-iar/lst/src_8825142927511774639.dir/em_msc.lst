   1561          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)  \
   1562            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7) \
   1563            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) \
   1564            || defined(_MPAHBRAM_CTRL_MASK)
