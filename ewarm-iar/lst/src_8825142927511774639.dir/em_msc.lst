   1579           *
   1580           * @param[in] eccBank
   1581           *    Pointer to ECC RAM bank (MSC_EccBank_Typedef)
   1582           ******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
   1583          static void SL_ECC_ASM_NOINLINE mscEccReadWriteExistingPio(const MSC_EccBank_Typedef *eccBank)
