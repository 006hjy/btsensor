   1606            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7) \
   1607            || (defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) && !defined(_MPAHBRAM_CTRL_MASK))
