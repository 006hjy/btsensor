   5811          #if defined(USB_PRESENT)
   5812          /***************************************************************************//**
   5813           * @brief
   5814           *   Get selected oscillator and frequency for @ref cmuClock_USB clock tree.
   5815           *
   5816           * @param[out] freq
   5817           *   The frequency.
   5818           *
   5819           * @param[out] sel
   5820           *   The selected oscillator.
   5821           ******************************************************************************/
   5822          static void usbClkGet(uint32_t *freq, CMU_Select_TypeDef *sel)
   5823          {
   5824            uint32_t f = 0U;
   5825            CMU_Select_TypeDef s;
   5826          
   5827            switch (CMU->USB0CLKCTRL & _CMU_USB0CLKCTRL_CLKSEL_MASK) {
   5828              case CMU_USB0CLKCTRL_CLKSEL_USBPLL0:
   5829                f = PLL0_USB_OUTPUT_FREQ;
   5830                s = cmuSelect_USBPLL0;
   5831                break;
   5832          
   5833              case CMU_USB0CLKCTRL_CLKSEL_LFXO:
   5834                f = SystemLFXOClockGet();
   5835                s = cmuSelect_LFXO;
   5836                break;
   5837          
   5838              case CMU_USB0CLKCTRL_CLKSEL_LFRCO:
   5839                f = SystemLFRCOClockGet();
   5840                s = cmuSelect_LFRCO;
   5841                break;
   5842          
   5843              default:
   5844                s = cmuSelect_Error;
   5845                EFM_ASSERT(false);
   5846                break;
   5847            }
   5848          
   5849            if (freq != NULL) {
   5850              *freq = f;
   5851            }
   5852            if (sel != NULL) {
   5853              *sel = s;
   5854            }
   5855          }
   5856          #endif
