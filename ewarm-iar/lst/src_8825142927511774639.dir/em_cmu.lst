    292          /***************************************************************************//**
    293           * @brief
    294           *   Calibrate an oscillator.
    295           *
    296           * @details
    297           *   Run a calibration of a selectable reference clock againt HCLK. Please
    298           *   refer to the reference manual, CMU chapter, for further details.
    299           *
    300           * @note
    301           *   This function will not return until calibration measurement is completed.
    302           *
    303           * @param[in] cycles
    304           *   The number of HCLK cycles to run calibration. Increasing this number
    305           *   increases precision, but the calibration will take more time.
    306           *
    307           * @param[in] ref
    308           *   The reference clock used to compare against HCLK.
    309           *
    310           * @return
    311           *   The number of ticks the selected reference clock ticked while running
    312           *   cycles ticks of the HCLK clock.
    313           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    314          uint32_t CMU_Calibrate(uint32_t cycles, CMU_Select_TypeDef ref)
    315          {
   \                     CMU_Calibrate: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
   \        0x2   0x4604             MOV      R4,R0
   \        0x4   0x460D             MOV      R5,R1
    316            // Check for cycle count overflow
    317          #if defined(_CMU_CALCTRL_CALTOP_MASK)
    318            EFM_ASSERT(cycles <= (_CMU_CALCTRL_CALTOP_MASK
    319                                  >> _CMU_CALCTRL_CALTOP_SHIFT));
   \        0x6   0xF5B4 0x1F80      CMP      R4,#+1048576
