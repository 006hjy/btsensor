   4720          #if ((defined(CMU_SYSCLKCTRL_RHCLKPRESC)) \
   4721            && (_SILICON_LABS_EFR32_RADIO_TYPE != _SILICON_LABS_EFR32_RADIO_NONE))
   4722          /***************************************************************************//**
   4723           * @brief
   4724           *   Set maximum allowed prescaler for radio clock tree (RHCLK).
   4725           ******************************************************************************/
   4726          static void rhclkPrescMax(void)
   4727          {
   4728            // Set largest prescaler (DIV2).
   4729            CMU->SYSCLKCTRL_SET = CMU_SYSCLKCTRL_RHCLKPRESC;
   4730          }
   4731          
   4732          /***************************************************************************//**
   4733           * @brief
   4734           *   Set radio clock tree prescaler to achieve highest possible frequency
   4735           *   and still be within spec.
   4736           ******************************************************************************/
   4737          static void rhclkPrescOptimize(void)
   4738          {
   4739            if (CMU_ClockFreqGet(cmuClock_SYSCLK) <= CMU_MAX_RHCLK_FREQ) {
   4740              // Set smallest prescaler (DIV1).
   4741              CMU->SYSCLKCTRL_CLR = CMU_SYSCLKCTRL_RHCLKPRESC;
   4742            }
   4743          }
   4744          #endif // ((defined(CMU_SYSCLKCTRL_RHCLKPRESC)) && (_SILICON_LABS_EFR32_RADIO_TYPE != _SILICON_LABS_EFR32_RADIO_NONE))
   4745          #endif // #if (_SILICON_LABS_32B_SERIES_2_CONFIG > 1)
   4746          
   4747          #if defined(HFRCOEM23_PRESENT)
   4748          /***************************************************************************//**
   4749           * @brief
   4750           *   Get calibrated HFRCOEM23 tuning value from Device information (DI) page
   4751           *   for a given frequency. Calibration value is not available for all frequency
   4752           *   bands.
   4753           *
   4754           * @param[in] freq
   4755           *   HFRCOEM23 frequency band
   4756           ******************************************************************************/
   4757          static uint32_t HFRCOEM23DevinfoGet(CMU_HFRCOEM23Freq_TypeDef freq)
   4758          {
   4759            uint32_t ret = 0U;
   4760          
   4761            switch (freq) {
   4762              // 1, 2 and 4MHz share the same calibration word
   4763              case cmuHFRCOEM23Freq_1M0Hz:
   4764              case cmuHFRCOEM23Freq_2M0Hz:
   4765              case cmuHFRCOEM23Freq_4M0Hz:
   4766                ret = DEVINFO->HFRCOEM23CAL[0].HFRCOEM23CAL;
   4767                break;
   4768          
   4769              case cmuHFRCOEM23Freq_13M0Hz:
   4770                ret = DEVINFO->HFRCOEM23CAL[6].HFRCOEM23CAL;
   4771                break;
   4772          
   4773              case cmuHFRCOEM23Freq_16M0Hz:
   4774                ret = DEVINFO->HFRCOEM23CAL[7].HFRCOEM23CAL;
   4775                break;
   4776          
   4777              case cmuHFRCOEM23Freq_19M0Hz:
   4778                ret = DEVINFO->HFRCOEM23CAL[8].HFRCOEM23CAL;
   4779                break;
   4780          
   4781              case cmuHFRCOEM23Freq_26M0Hz:
   4782                ret = DEVINFO->HFRCOEM23CAL[10].HFRCOEM23CAL;
   4783                break;
   4784          
   4785              case cmuHFRCOEM23Freq_32M0Hz:
   4786                ret = DEVINFO->HFRCOEM23CAL[11].HFRCOEM23CAL;
   4787                break;
   4788          
   4789              case cmuHFRCOEM23Freq_40M0Hz:
   4790                ret = DEVINFO->HFRCOEM23CAL[12].HFRCOEM23CAL;
   4791                break;
   4792          
   4793          #if !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_1)
   4794              case cmuHFRCOEM23Freq_5M0Hz:
   4795                ret = DEVINFO->HFRCOEM23CAL[1].HFRCOEM23CAL;
   4796                break;
   4797          
   4798              case cmuHFRCOEM23Freq_10M0Hz:
   4799                ret = DEVINFO->HFRCOEM23CAL[4].HFRCOEM23CAL;
   4800                break;
   4801          
   4802              case cmuHFRCOEM23Freq_20M0Hz:
   4803                ret = DEVINFO->HFRCOEM23CAL[9].HFRCOEM23CAL;
   4804                break;
   4805          #endif
   4806          
   4807              case cmuHFRCOEM23Freq_UserDefined:
   4808                break;
   4809          
   4810              default:
   4811                EFM_ASSERT(false);
   4812                break;
   4813            }
   4814            return ret;
   4815          }
   4816          #endif // defined(HFRCOEM23_PRESENT)
