   6871          
   6872          /***************************************************************************//**
   6873           * @brief
   6874           *   Get the LFnCLK frequency based on the current configuration.
   6875           *
   6876           * @param[in] lfClkBranch
   6877           *   Selected LF branch.
   6878           *
   6879           * @return
   6880           *   The LFnCLK frequency in Hz. If no LFnCLK is selected (disabled), 0 is
   6881           *   returned.
   6882           ******************************************************************************/
   6883          static uint32_t lfClkGet(CMU_Clock_TypeDef lfClkBranch)
   6884          {
   6885            uint32_t sel;
   6886            uint32_t ret = 0;
   6887          
   6888            switch (lfClkBranch) {
   6889              case cmuClock_LFA:
   6890              case cmuClock_LFB:
   6891          #if defined(_CMU_LFCCLKEN0_MASK)
   6892              case cmuClock_LFC:
   6893          #endif
   6894          #if defined(_CMU_LFECLKSEL_MASK)
   6895              case cmuClock_LFE:
   6896          #endif
   6897                break;
   6898          
   6899              default:
   6900                EFM_ASSERT(false);
   6901                break;
   6902            }
   6903          
   6904            sel = (uint32_t)CMU_ClockSelectGet(lfClkBranch);
   6905          
   6906            /* Get clock select field */
   6907            switch (lfClkBranch) {
   6908              case cmuClock_LFA:
   6909          #if defined(_CMU_LFCLKSEL_MASK)
   6910                sel = (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFA_MASK) >> _CMU_LFCLKSEL_LFA_SHIFT;
   6911          #elif defined(_CMU_LFACLKSEL_MASK)
   6912                sel = (CMU->LFACLKSEL & _CMU_LFACLKSEL_LFA_MASK) >> _CMU_LFACLKSEL_LFA_SHIFT;
   6913          #else
   6914                EFM_ASSERT(false);
   6915          #endif
   6916                break;
   6917          
   6918              case cmuClock_LFB:
   6919          #if defined(_CMU_LFCLKSEL_MASK)
   6920                sel = (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFB_MASK) >> _CMU_LFCLKSEL_LFB_SHIFT;
   6921          #elif defined(_CMU_LFBCLKSEL_MASK)
   6922                sel = (CMU->LFBCLKSEL & _CMU_LFBCLKSEL_LFB_MASK) >> _CMU_LFBCLKSEL_LFB_SHIFT;
   6923          #else
   6924                EFM_ASSERT(false);
   6925          #endif
   6926                break;
   6927          
   6928          #if defined(_CMU_LFCCLKEN0_MASK)
   6929              case cmuClock_LFC:
   6930          #if defined(_CMU_LFCLKSEL_LFC_MASK)
   6931                sel = (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFC_MASK) >> _CMU_LFCLKSEL_LFC_SHIFT;
   6932          #elif defined(_CMU_LFCCLKSEL_LFC_MASK)
   6933                sel = (CMU->LFCCLKSEL & _CMU_LFCCLKSEL_LFC_MASK) >> _CMU_LFCCLKSEL_LFC_SHIFT;
   6934          #else
   6935                EFM_ASSERT(false);
   6936          #endif
   6937                break;
   6938          #endif
   6939          
   6940          #if defined(_CMU_LFECLKSEL_MASK)
   6941              case cmuClock_LFE:
   6942                sel = (CMU->LFECLKSEL & _CMU_LFECLKSEL_LFE_MASK) >> _CMU_LFECLKSEL_LFE_SHIFT;
   6943                break;
   6944          #endif
   6945          
   6946              default:
   6947                EFM_ASSERT(false);
   6948                break;
   6949            }
   6950          
   6951            /* Get the clock frequency. */
   6952          #if defined(_CMU_LFCLKSEL_MASK)
   6953            switch (sel) {
   6954              case _CMU_LFCLKSEL_LFA_LFRCO:
   6955                ret = SystemLFRCOClockGet();
   6956                break;
   6957          
   6958              case _CMU_LFCLKSEL_LFA_LFXO:
   6959                ret = SystemLFXOClockGet();
   6960                break;
   6961          
   6962          #if defined(_CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2)
   6963              case _CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2:
   6964          #if defined(CMU_MAX_FREQ_HFLE)
   6965                /* HFLE bit is or'ed by hardware with HFCORECLKLEDIV to reduce the
   6966                 * frequency of CMU_HFCORECLKLEDIV2. */
   6967                ret = SystemCoreClockGet() / (1U << (getHfLeConfig() + 1));
   6968          #else
   6969                ret = SystemCoreClockGet() / 2U;
   6970          #endif
   6971                break;
   6972          #endif
   6973          
   6974              case _CMU_LFCLKSEL_LFA_DISABLED:
   6975                ret = 0;
   6976          #if defined(CMU_LFCLKSEL_LFAE)
   6977                /* Check LF Extended bit setting for LFA or LFB ULFRCO clock. */
   6978                if ((lfClkBranch == cmuClock_LFA) || (lfClkBranch == cmuClock_LFB)) {
   6979                  if (CMU->LFCLKSEL >> (lfClkBranch == cmuClock_LFA
   6980                                        ? _CMU_LFCLKSEL_LFAE_SHIFT
   6981                                        : _CMU_LFCLKSEL_LFBE_SHIFT)) {
   6982                    ret = SystemULFRCOClockGet();
   6983                  }
   6984                }
   6985          #endif
   6986                break;
   6987          
   6988              default:
   6989                ret = 0U;
   6990                EFM_ASSERT(false);
   6991                break;
   6992            }
   6993          #endif /* _CMU_LFCLKSEL_MASK */
   6994          
   6995          #if defined(_CMU_LFACLKSEL_MASK)
   6996            switch (sel) {
   6997              case _CMU_LFACLKSEL_LFA_LFRCO:
   6998                ret = SystemLFRCOClockGet();
   6999                break;
   7000          
   7001              case _CMU_LFACLKSEL_LFA_LFXO:
   7002                ret = SystemLFXOClockGet();
   7003                break;
   7004          
   7005              case _CMU_LFACLKSEL_LFA_ULFRCO:
   7006                ret = SystemULFRCOClockGet();
   7007                break;
   7008          
   7009          #if defined(PLFRCO_PRESENT)
   7010              case _CMU_LFACLKSEL_LFA_PLFRCO:
   7011                ret = SystemLFRCOClockGet();
   7012                break;
   7013          #endif
   7014          
   7015          #if defined(_CMU_LFBCLKSEL_LFB_HFCLKLE)
   7016              case _CMU_LFBCLKSEL_LFB_HFCLKLE:
   7017                ret = SystemHFClockGet()
   7018                      / SL_Log2ToDiv(((CMU->HFPRESC & _CMU_HFPRESC_HFCLKLEPRESC_MASK)
   7019                                      >> _CMU_HFPRESC_HFCLKLEPRESC_SHIFT) + 1UL);
   7020                break;
   7021          #endif
   7022          
   7023              case _CMU_LFACLKSEL_LFA_DISABLED:
   7024                ret = 0;
   7025                break;
   7026          
   7027              default:
   7028                ret = 0U;
   7029                EFM_ASSERT(false);
   7030                break;
   7031            }
   7032          #endif
   7033          
   7034            return ret;
   7035          }
   7036          
   7037          /***************************************************************************//**
   7038           * @brief
   7039           *   Wait for an ongoing sync of register(s) to low-frequency domain to complete.
   7040           *
   7041           * @param[in] mask
   7042           *   A bitmask corresponding to SYNCBUSY register defined bits, indicating
   7043           *   registers that must complete any ongoing synchronization.
   7044           ******************************************************************************/
   7045          __STATIC_INLINE void syncReg(uint32_t mask)
   7046          {
   7047            /* Avoid a deadlock if modifying the same register twice when freeze mode is */
   7048            /* activated. */
   7049            if ((CMU->FREEZE & CMU_FREEZE_REGFREEZE) != 0UL) {
   7050              return;
   7051            }
   7052          
   7053            /* Wait for any pending previous write operation to complete */
   7054            /* in low-frequency domain. */
   7055            while ((CMU->SYNCBUSY & mask) != 0UL) {
   7056              // Wait for CMU sync.
   7057            }
   7058          }
   7059          
   7060          #if defined(USBC_CLOCK_PRESENT)
   7061          /***************************************************************************//**
   7062           * @brief
   7063           *   Get the USBC frequency.
   7064           *
   7065           * @return
   7066           *   USBC frequency in Hz.
   7067           ******************************************************************************/
   7068          static uint32_t usbCClkGet(void)
   7069          {
   7070            uint32_t ret;
   7071            CMU_Select_TypeDef clk;
   7072          
   7073            /* Get the selected clock source. */
   7074            clk = CMU_ClockSelectGet(cmuClock_USBC);
   7075          
   7076            switch (clk) {
   7077              case cmuSelect_LFXO:
   7078                ret = SystemLFXOClockGet();
   7079                break;
   7080              case cmuSelect_LFRCO:
   7081                ret = SystemLFRCOClockGet();
   7082                break;
   7083          #if defined (_CMU_USHFRCOCTRL_MASK)
   7084              case cmuSelect_USHFRCO:
   7085                ret = ushfrcoFreq;
   7086                break;
   7087          #endif
   7088              case cmuSelect_HFCLK:
   7089                ret = SystemHFClockGet();
   7090                break;
   7091              default:
   7092                /* Clock is not enabled */
   7093                ret = 0;
   7094                break;
   7095            }
   7096            return ret;
   7097          }
   7098          #endif
   7099          
   7100          /***************************************************************************//**
   7101           * @brief
   7102           *   Set HFPER clock tree prescalers to safe values.
   7103           *
   7104           * @note
   7105           *   This function applies to EFM32GG11B. There are 3 HFPER clock trees with
   7106           *   these frequency limits:
   7107           *     HFPERCLK  (A-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   7108           *     HFPERBCLK (B-tree): 20MHz in VSCALE0 mode, 72MHz in VSCALE2 mode.
   7109           *     HFPERCCLK (C-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   7110           ******************************************************************************/
   7111          static void hfperClkSafePrescaler(void)
   7112          {
   7113          #if defined(_CMU_HFPERPRESC_MASK) && defined(_CMU_HFPERPRESCB_MASK) \
   7114            && defined(_CMU_HFPERPRESCC_MASK)
   7115            // Assuming a maximum HFCLK of 72MHz, set prescalers to DIV4.
   7116            CMU_ClockPrescSet(cmuClock_HFPER, 3U);
   7117            CMU_ClockPrescSet(cmuClock_HFPERB, 3U);
   7118            CMU_ClockPrescSet(cmuClock_HFPERC, 3U);
   7119          #endif
   7120          }
   7121          
   7122          /***************************************************************************//**
   7123           * @brief
   7124           *   Set HFPER clock tree prescalers to give highest possible clock node
   7125           *   frequency while still beeing within spec.
   7126           *
   7127           * @note
   7128           *   This function applies to EFM32GG11B. There are 3 HFPER clock trees with
   7129           *   these frequency limits:
   7130           *     HFPERCLK  (A-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   7131           *     HFPERBCLK (B-tree): 20MHz in VSCALE0 mode, 72MHz in VSCALE2 mode.
   7132           *     HFPERCCLK (C-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   7133           ******************************************************************************/
   7134          static void hfperClkOptimizedPrescaler(void)
   7135          {
   7136          #if defined(_CMU_HFPERPRESC_MASK) && defined(_CMU_HFPERPRESCB_MASK) \
   7137            && defined(_CMU_HFPERPRESCC_MASK)
   7138            uint32_t hfClkFreq, divisor;
   7139          
   7140            hfClkFreq = SystemHFClockGet();
   7141          
   7142            if ( EMU_VScaleGet() == emuVScaleEM01_LowPower) {
   7143              divisor = (hfClkFreq + 20000000U - 1U) / 20000000U; // ceil(x)
   7144              if (divisor > 0U) {
   7145                divisor--;                                        // Convert to prescaler
   7146              }
   7147              CMU_ClockPrescSet(cmuClock_HFPER, divisor);
   7148              CMU_ClockPrescSet(cmuClock_HFPERB, divisor);
   7149              CMU_ClockPrescSet(cmuClock_HFPERC, divisor);
   7150            } else {
   7151              divisor = (hfClkFreq + 50000000U - 1U) / 50000000U;
   7152              if (divisor > 0U) {
   7153                divisor--;
   7154              }
   7155              CMU_ClockPrescSet(cmuClock_HFPER, divisor);
   7156              CMU_ClockPrescSet(cmuClock_HFPERC, divisor);
   7157          
   7158              divisor = (hfClkFreq + 72000000U - 1U) / 72000000U;
   7159              if (divisor > 0U) {
   7160                divisor--;
   7161              }
   7162              CMU_ClockPrescSet(cmuClock_HFPERB, divisor);
   7163            }
   7164          #endif
   7165          }
   7166          
   7167          /*******************************************************************************
   7168           **************************   GLOBAL FUNCTIONS   *******************************
   7169           ******************************************************************************/
   7170          
   7171          #if defined(_CMU_AUXHFRCOCTRL_BAND_MASK)
   7172          /***************************************************************************//**
   7173           * @brief
   7174           *   Get the AUXHFRCO band in use.
   7175           *
   7176           * @return
   7177           *   AUXHFRCO band in use.
   7178           ******************************************************************************/
   7179          CMU_AUXHFRCOBand_TypeDef CMU_AUXHFRCOBandGet(void)
   7180          {
   7181            return (CMU_AUXHFRCOBand_TypeDef)((CMU->AUXHFRCOCTRL
   7182                                               & _CMU_AUXHFRCOCTRL_BAND_MASK)
   7183                                              >> _CMU_AUXHFRCOCTRL_BAND_SHIFT);
   7184          }
   7185          #endif /* _CMU_AUXHFRCOCTRL_BAND_MASK */
   7186          
   7187          #if defined(_CMU_AUXHFRCOCTRL_BAND_MASK)
   7188          /***************************************************************************//**
   7189           * @brief
   7190           *   Set the AUXHFRCO band and the tuning value based on the value in the
   7191           *   calibration table made during production.
   7192           *
   7193           * @param[in] band
   7194           *   AUXHFRCO band to activate.
   7195           ******************************************************************************/
   7196          void CMU_AUXHFRCOBandSet(CMU_AUXHFRCOBand_TypeDef band)
   7197          {
   7198            uint32_t tuning;
   7199          
   7200            /* Read a tuning value from the calibration table. */
   7201            switch (band) {
   7202              case cmuAUXHFRCOBand_1MHz:
   7203                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND1_MASK)
   7204                         >> _DEVINFO_AUXHFRCOCAL0_BAND1_SHIFT;
   7205                break;
   7206          
   7207              case cmuAUXHFRCOBand_7MHz:
   7208                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND7_MASK)
   7209                         >> _DEVINFO_AUXHFRCOCAL0_BAND7_SHIFT;
   7210                break;
   7211          
   7212              case cmuAUXHFRCOBand_11MHz:
   7213                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND11_MASK)
   7214                         >> _DEVINFO_AUXHFRCOCAL0_BAND11_SHIFT;
   7215                break;
   7216          
   7217              case cmuAUXHFRCOBand_14MHz:
   7218                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND14_MASK)
   7219                         >> _DEVINFO_AUXHFRCOCAL0_BAND14_SHIFT;
   7220                break;
   7221          
   7222              case cmuAUXHFRCOBand_21MHz:
   7223                tuning = (DEVINFO->AUXHFRCOCAL1 & _DEVINFO_AUXHFRCOCAL1_BAND21_MASK)
   7224                         >> _DEVINFO_AUXHFRCOCAL1_BAND21_SHIFT;
   7225                break;
   7226          
   7227          #if defined(_CMU_AUXHFRCOCTRL_BAND_28MHZ)
   7228              case cmuAUXHFRCOBand_28MHz:
   7229                tuning = (DEVINFO->AUXHFRCOCAL1 & _DEVINFO_AUXHFRCOCAL1_BAND28_MASK)
   7230                         >> _DEVINFO_AUXHFRCOCAL1_BAND28_SHIFT;
   7231                break;
   7232          #endif
   7233          
   7234              default:
   7235                EFM_ASSERT(false);
   7236                return;
   7237            }
   7238          
   7239            /* Set band/tuning. */
   7240            CMU->AUXHFRCOCTRL = (CMU->AUXHFRCOCTRL
   7241                                 & ~(_CMU_AUXHFRCOCTRL_BAND_MASK
   7242                                     | _CMU_AUXHFRCOCTRL_TUNING_MASK))
   7243                                | (band << _CMU_AUXHFRCOCTRL_BAND_SHIFT)
   7244                                | (tuning << _CMU_AUXHFRCOCTRL_TUNING_SHIFT);
   7245          }
   7246          #endif /* _CMU_AUXHFRCOCTRL_BAND_MASK */
   7247          
   7248          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   7249          /**************************************************************************//**
   7250           * @brief
   7251           *   Get the AUXHFRCO frequency calibration word in DEVINFO.
   7252           *
   7253           * @param[in] freq
   7254           *   Frequency in Hz.
   7255           *
   7256           * @return
   7257           *   AUXHFRCO calibration word for a given frequency.
   7258           *****************************************************************************/
   7259          static uint32_t CMU_AUXHFRCODevinfoGet(CMU_AUXHFRCOFreq_TypeDef freq)
   7260          {
   7261            switch (freq) {
   7262              /* 1, 2, and 4 MHz share the same calibration word. */
   7263              case cmuAUXHFRCOFreq_1M0Hz:
   7264              case cmuAUXHFRCOFreq_2M0Hz:
   7265              case cmuAUXHFRCOFreq_4M0Hz:
   7266                return DEVINFO->AUXHFRCOCAL0;
   7267          
   7268              case cmuAUXHFRCOFreq_7M0Hz:
   7269                return DEVINFO->AUXHFRCOCAL3;
   7270          
   7271              case cmuAUXHFRCOFreq_13M0Hz:
   7272                return DEVINFO->AUXHFRCOCAL6;
   7273          
   7274              case cmuAUXHFRCOFreq_16M0Hz:
   7275                return DEVINFO->AUXHFRCOCAL7;
   7276          
   7277              case cmuAUXHFRCOFreq_19M0Hz:
   7278                return DEVINFO->AUXHFRCOCAL8;
   7279          
   7280              case cmuAUXHFRCOFreq_26M0Hz:
   7281                return DEVINFO->AUXHFRCOCAL10;
   7282          
   7283              case cmuAUXHFRCOFreq_32M0Hz:
   7284                return DEVINFO->AUXHFRCOCAL11;
   7285          
   7286              case cmuAUXHFRCOFreq_38M0Hz:
   7287                return DEVINFO->AUXHFRCOCAL12;
   7288          
   7289          #if defined(_DEVINFO_AUXHFRCOCAL13_MASK)
   7290              case cmuAUXHFRCOFreq_48M0Hz:
   7291                return DEVINFO->AUXHFRCOCAL13;
   7292          #endif
   7293          #if defined(_DEVINFO_AUXHFRCOCAL14_MASK)
   7294              case cmuAUXHFRCOFreq_50M0Hz:
   7295                return DEVINFO->AUXHFRCOCAL14;
   7296          #endif
   7297          
   7298              default: /* cmuAUXHFRCOFreq_UserDefined */
   7299                return 0;
   7300            }
   7301          }
   7302          #endif /* _CMU_AUXHFRCOCTRL_FREQRANGE_MASK */
   7303          
   7304          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   7305          /***************************************************************************//**
   7306           * @brief
   7307           *   Get the current AUXHFRCO frequency.
   7308           *
   7309           * @return
   7310           *   AUXHFRCO frequency.
   7311           ******************************************************************************/
   7312          CMU_AUXHFRCOFreq_TypeDef CMU_AUXHFRCOBandGet(void)
   7313          {
   7314            return auxHfrcoFreq;
   7315          }
   7316          #endif /* _CMU_AUXHFRCOCTRL_FREQRANGE_MASK */
   7317          
   7318          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   7319          /***************************************************************************//**
   7320           * @brief
   7321           *   Set AUXHFRCO calibration for the selected target frequency.
   7322           *
   7323           * @param[in] setFreq
   7324           *   AUXHFRCO frequency to set
   7325           ******************************************************************************/
   7326          void CMU_AUXHFRCOBandSet(CMU_AUXHFRCOFreq_TypeDef setFreq)
   7327          {
   7328            uint32_t freqCal;
   7329          
   7330            /* Get DEVINFO index and set global auxHfrcoFreq. */
   7331            freqCal = CMU_AUXHFRCODevinfoGet(setFreq);
   7332            EFM_ASSERT((freqCal != 0UL) && (freqCal != UINT_MAX));
   7333            auxHfrcoFreq = setFreq;
   7334          
   7335            /* Wait for any previous sync to complete, then set calibration data
   7336               for the selected frequency.  */
   7337            while (BUS_RegBitRead(&CMU->SYNCBUSY,
   7338                                  _CMU_SYNCBUSY_AUXHFRCOBSY_SHIFT) != 0UL) {
   7339              // Wait for AUXHFRCO sync.
   7340            }
   7341          
   7342            /* Set a divider in AUXHFRCOCTRL for 1, 2, and 4 MHz. */
   7343            switch (setFreq) {
   7344              case cmuAUXHFRCOFreq_1M0Hz:
   7345                freqCal = (freqCal & ~_CMU_AUXHFRCOCTRL_CLKDIV_MASK)
   7346                          | CMU_AUXHFRCOCTRL_CLKDIV_DIV4;
   7347                break;
   7348          
   7349              case cmuAUXHFRCOFreq_2M0Hz:
   7350                freqCal = (freqCal & ~_CMU_AUXHFRCOCTRL_CLKDIV_MASK)
   7351                          | CMU_AUXHFRCOCTRL_CLKDIV_DIV2;
   7352                break;
   7353          
   7354              case cmuAUXHFRCOFreq_4M0Hz:
   7355                freqCal = (freqCal & ~_CMU_AUXHFRCOCTRL_CLKDIV_MASK)
   7356                          | CMU_AUXHFRCOCTRL_CLKDIV_DIV1;
   7357                break;
   7358          
   7359              default:
   7360                break;
   7361            }
   7362            CMU->AUXHFRCOCTRL = freqCal;
   7363          }
   7364          #endif /* _CMU_AUXHFRCOCTRL_FREQRANGE_MASK */
   7365          
   7366          /***************************************************************************//**
   7367           * @brief
   7368           *   Calibrate the clock.
   7369           *
   7370           * @details
   7371           *   Run a calibration for HFCLK against a selectable reference clock.
   7372           *   See the reference manual, CMU chapter, for more details.
   7373           *
   7374           * @note
   7375           *   This function will not return until the calibration measurement is completed.
   7376           *
   7377           * @param[in] HFCycles
   7378           *   The number of HFCLK cycles to run the calibration. Increasing this number
   7379           *   increases precision but the calibration will take more time.
   7380           *
   7381           * @param[in] reference
   7382           *   The reference clock used to compare HFCLK.
   7383           *
   7384           * @return
   7385           *   The number of ticks the reference clock after HFCycles ticks on the HF
   7386           *   clock.
   7387           ******************************************************************************/
   7388          uint32_t CMU_Calibrate(uint32_t HFCycles, CMU_Osc_TypeDef reference)
   7389          {
   7390            EFM_ASSERT(HFCycles <= (_CMU_CALCNT_CALCNT_MASK >> _CMU_CALCNT_CALCNT_SHIFT));
   7391          
   7392            /* Set the reference clock source. */
   7393            switch (reference) {
   7394              case cmuOsc_LFXO:
   7395                CMU->CALCTRL = CMU_CALCTRL_UPSEL_LFXO;
   7396                break;
   7397          
   7398              case cmuOsc_LFRCO:
   7399                CMU->CALCTRL = CMU_CALCTRL_UPSEL_LFRCO;
   7400                break;
   7401          
   7402          #if defined(PLFRCO_PRESENT)
   7403              case cmuOsc_PLFRCO:
   7404                CMU->CALCTRL = CMU_CALCTRL_UPSEL_PLFRCO;
   7405                break;
   7406          #endif
   7407          
   7408              case cmuOsc_HFXO:
   7409                CMU->CALCTRL = CMU_CALCTRL_UPSEL_HFXO;
   7410                break;
   7411          
   7412              case cmuOsc_HFRCO:
   7413                CMU->CALCTRL = CMU_CALCTRL_UPSEL_HFRCO;
   7414                break;
   7415          
   7416              case cmuOsc_AUXHFRCO:
   7417                CMU->CALCTRL = CMU_CALCTRL_UPSEL_AUXHFRCO;
   7418                break;
   7419          
   7420          #if defined (_CMU_USHFRCOCTRL_MASK)
   7421              case cmuOsc_USHFRCO:
   7422                CMU->CALCTRL = CMU_CALCTRL_UPSEL_USHFRCO;
   7423                break;
   7424          #endif
   7425          
   7426              default:
   7427                EFM_ASSERT(false);
   7428                return 0;
   7429            }
   7430          
   7431            /* Set the top value. */
   7432            CMU->CALCNT = HFCycles;
   7433          
   7434            /* Start the calibration. */
   7435            CMU->CMD = CMU_CMD_CALSTART;
   7436          
   7437          #if defined(CMU_STATUS_CALRDY)
   7438            /* Wait until calibration completes. */
   7439            while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALRDY_SHIFT) == 0UL) {
   7440              // Wait for CALRDY.
   7441            }
   7442          #else
   7443            /* Wait until calibration completes. */
   7444            while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALBSY_SHIFT) != 0UL) {
   7445              // Wait for CALBSY clear.
   7446            }
   7447          #endif
   7448          
   7449            return CMU->CALCNT;
   7450          }
   7451          
   7452          #if defined(_CMU_CALCTRL_UPSEL_MASK) && defined(_CMU_CALCTRL_DOWNSEL_MASK)
   7453          /***************************************************************************//**
   7454           * @brief
   7455           *   Configure the clock calibration.
   7456           *
   7457           * @details
   7458           *   Configure a calibration for a selectable clock source against another
   7459           *   selectable reference clock.
   7460           *   See the reference manual, CMU chapter, for more details.
   7461           *
   7462           * @note
   7463           *   After configuration, a call to @ref CMU_CalibrateStart() is required and
   7464           *   the resulting calibration value can be read out with the
   7465           *   @ref CMU_CalibrateCountGet() function call.
   7466           *
   7467           * @param[in] downCycles
   7468           *   The number of downSel clock cycles to run the calibration. Increasing this
   7469           *   number increases precision but the calibration will take more time.
   7470           *
   7471           * @param[in] downSel
   7472           *   The clock, which will be counted down downCycles.
   7473           *
   7474           * @param[in] upSel
   7475           *   The reference clock; the number of cycles generated by this clock will
   7476           *   be counted and added up and the result can be given with the
   7477           *   @ref CMU_CalibrateCountGet() function call.
   7478           ******************************************************************************/
   7479          void CMU_CalibrateConfig(uint32_t downCycles, CMU_Osc_TypeDef downSel,
   7480                                   CMU_Osc_TypeDef upSel)
   7481          {
   7482            /* Keep configuration settings untouched. */
   7483            uint32_t calCtrl = CMU->CALCTRL
   7484                               & ~(_CMU_CALCTRL_UPSEL_MASK | _CMU_CALCTRL_DOWNSEL_MASK);
   7485          
   7486            /* 20 bits of precision to calibration count register. */
   7487            EFM_ASSERT(downCycles <= (_CMU_CALCNT_CALCNT_MASK >> _CMU_CALCNT_CALCNT_SHIFT));
   7488          
   7489            /* Set down counting clock source - down counter. */
   7490            switch (downSel) {
   7491              case cmuOsc_LFXO:
   7492                calCtrl |= CMU_CALCTRL_DOWNSEL_LFXO;
   7493                break;
   7494          
   7495              case cmuOsc_LFRCO:
   7496                calCtrl |= CMU_CALCTRL_DOWNSEL_LFRCO;
   7497                break;
   7498          
   7499          #if defined(PLFRCO_PRESENT)
   7500              case cmuOsc_PLFRCO:
   7501                calCtrl |= CMU_CALCTRL_DOWNSEL_PLFRCO;
   7502                break;
   7503          #endif
   7504          
   7505              case cmuOsc_HFXO:
   7506                calCtrl |= CMU_CALCTRL_DOWNSEL_HFXO;
   7507                break;
   7508          
   7509              case cmuOsc_HFRCO:
   7510                calCtrl |= CMU_CALCTRL_DOWNSEL_HFRCO;
   7511                break;
   7512          
   7513              case cmuOsc_AUXHFRCO:
   7514                calCtrl |= CMU_CALCTRL_DOWNSEL_AUXHFRCO;
   7515                break;
   7516          
   7517          #if defined (_CMU_USHFRCOCTRL_MASK)
   7518              case cmuOsc_USHFRCO:
   7519                calCtrl |= CMU_CALCTRL_DOWNSEL_USHFRCO;
   7520                break;
   7521          #endif
   7522          
   7523              default:
   7524                EFM_ASSERT(false);
   7525                break;
   7526            }
   7527          
   7528            /* Set the top value to be counted down by the downSel clock. */
   7529            CMU->CALCNT = downCycles;
   7530          
   7531            /* Set the reference clock source - up counter. */
   7532            switch (upSel) {
   7533              case cmuOsc_LFXO:
   7534                calCtrl |= CMU_CALCTRL_UPSEL_LFXO;
   7535                break;
   7536          
   7537              case cmuOsc_LFRCO:
   7538                calCtrl |= CMU_CALCTRL_UPSEL_LFRCO;
   7539                break;
   7540          
   7541          #if defined(PLFRCO_PRESENT)
   7542              case cmuOsc_PLFRCO:
   7543                calCtrl |= CMU_CALCTRL_UPSEL_PLFRCO;
   7544                break;
   7545          #endif
   7546          
   7547              case cmuOsc_HFXO:
   7548                calCtrl |= CMU_CALCTRL_UPSEL_HFXO;
   7549                break;
   7550          
   7551              case cmuOsc_HFRCO:
   7552                calCtrl |= CMU_CALCTRL_UPSEL_HFRCO;
   7553                break;
   7554          
   7555              case cmuOsc_AUXHFRCO:
   7556                calCtrl |= CMU_CALCTRL_UPSEL_AUXHFRCO;
   7557                break;
   7558          
   7559          #if defined (_CMU_USHFRCOCTRL_MASK)
   7560              case cmuOsc_USHFRCO:
   7561                calCtrl |= CMU_CALCTRL_UPSEL_USHFRCO;
   7562                break;
   7563          #endif
   7564          
   7565              default:
   7566                EFM_ASSERT(false);
   7567                break;
   7568            }
   7569          
   7570            CMU->CALCTRL = calCtrl;
   7571          }
   7572          #endif
   7573          
   7574          /***************************************************************************//**
   7575           * @brief
   7576           *    Get the calibration count register.
   7577           * @note
   7578           *    If continuous calibration mode is active, calibration busy will almost
   7579           *    always be off and only the value needs to be read. In a normal case,
   7580           *    this function call is triggered by the CALRDY
   7581           *    interrupt flag.
   7582           * @return
   7583           *    The calibration count, the number of UPSEL clocks
   7584           *    in the period of DOWNSEL oscillator clock cycles configured by a previous
   7585           *    write operation to CMU->CALCNT.
   7586           ******************************************************************************/
   7587          uint32_t CMU_CalibrateCountGet(void)
   7588          {
   7589            /* Wait until calibration completes, UNLESS continuous calibration mode is  */
   7590            /* active. */
   7591          #if defined(CMU_CALCTRL_CONT)
   7592            if (BUS_RegBitRead(&CMU->CALCTRL, _CMU_CALCTRL_CONT_SHIFT) == 0UL) {
   7593          #if defined(CMU_STATUS_CALRDY)
   7594              /* Wait until calibration completes */
   7595              while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALRDY_SHIFT) == 0UL) {
   7596                // Wait for CALRDY.
   7597              }
   7598          #else
   7599              /* Wait until calibration completes */
   7600              while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALBSY_SHIFT) != 0UL) {
   7601                // Wait for CALBSY clear.
   7602              }
   7603          #endif
   7604            }
   7605          #else
   7606            while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALBSY_SHIFT) != 0UL) {
   7607              // Wait for CALBSY clear.
   7608            }
   7609          #endif
   7610            return CMU->CALCNT;
   7611          }
   7612          
   7613          /***************************************************************************//**
   7614           * @brief
   7615           *   Get the clock divisor/prescaler.
   7616           *
   7617           * @param[in] clock
   7618           *   A clock point to get the divisor/prescaler for. Notice that not all clock points
   7619           *   have a divisor/prescaler. See the CMU overview in the reference manual.
   7620           *
   7621           * @return
   7622           *   The current clock point divisor/prescaler. 1 is returned
   7623           *   if @p clock specifies a clock point without a divisor/prescaler.
   7624           ******************************************************************************/
   7625          CMU_ClkDiv_TypeDef CMU_ClockDivGet(CMU_Clock_TypeDef clock)
   7626          {
   7627          #if defined(_SILICON_LABS_32B_SERIES_1)
   7628            return 1UL + (uint32_t)CMU_ClockPrescGet(clock);
   7629          
   7630          #elif defined(_SILICON_LABS_32B_SERIES_0)
   7631            uint32_t           divReg;
   7632            CMU_ClkDiv_TypeDef ret;
   7633          
   7634            /* Get divisor reg ID. */
   7635            divReg = (clock >> CMU_DIV_REG_POS) & CMU_DIV_REG_MASK;
   7636          
   7637            switch (divReg) {
   7638          #if defined(_CMU_CTRL_HFCLKDIV_MASK)
   7639              case CMU_HFCLKDIV_REG:
   7640                ret = 1 + ((CMU->CTRL & _CMU_CTRL_HFCLKDIV_MASK)
   7641                           >> _CMU_CTRL_HFCLKDIV_SHIFT);
   7642                break;
   7643          #endif
   7644          
   7645              case CMU_HFPERCLKDIV_REG:
   7646                ret = (CMU_ClkDiv_TypeDef)((CMU->HFPERCLKDIV
   7647                                            & _CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   7648                                           >> _CMU_HFPERCLKDIV_HFPERCLKDIV_SHIFT);
   7649                ret = SL_Log2ToDiv(ret);
   7650                break;
   7651          
   7652              case CMU_HFCORECLKDIV_REG:
   7653                ret = (CMU_ClkDiv_TypeDef)((CMU->HFCORECLKDIV
   7654                                            & _CMU_HFCORECLKDIV_HFCORECLKDIV_MASK)
   7655                                           >> _CMU_HFCORECLKDIV_HFCORECLKDIV_SHIFT);
   7656                ret = SL_Log2ToDiv(ret);
   7657                break;
   7658          
   7659          #if defined(_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7660              case CMU_HFCORECLKLEDIV_REG:
   7661                ret = (CMU_ClkDiv_TypeDef)((CMU->HFCORECLKDIV
   7662                                            & _CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7663                                           >> _CMU_HFCORECLKDIV_HFCORECLKLEDIV_SHIFT);
   7664                ret = SL_Log2ToDiv(ret + 1U);
   7665                break;
   7666          #endif
   7667          
   7668              case CMU_LFAPRESC0_REG:
   7669                switch (clock) {
   7670                  case cmuClock_RTC:
   7671                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFAPRESC0 & _CMU_LFAPRESC0_RTC_MASK)
   7672                                               >> _CMU_LFAPRESC0_RTC_SHIFT);
   7673                    ret = SL_Log2ToDiv(ret);
   7674                    break;
   7675          
   7676          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   7677                  case cmuClock_LETIMER0:
   7678                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   7679                                               >> _CMU_LFAPRESC0_LETIMER0_SHIFT);
   7680                    ret = SL_Log2ToDiv(ret);
   7681                    break;
   7682          #endif
   7683          
   7684          #if defined(_CMU_LFAPRESC0_LCD_MASK)
   7685                  case cmuClock_LCDpre:
   7686                    ret = (CMU_ClkDiv_TypeDef)(((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   7687                                                >> _CMU_LFAPRESC0_LCD_SHIFT)
   7688                                               + CMU_DivToLog2(cmuClkDiv_16));
   7689                    ret = SL_Log2ToDiv(ret);
   7690                    break;
   7691          #endif
   7692          
   7693          #if defined(_CMU_LFAPRESC0_LESENSE_MASK)
   7694                  case cmuClock_LESENSE:
   7695                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LESENSE_MASK)
   7696                                               >> _CMU_LFAPRESC0_LESENSE_SHIFT);
   7697                    ret = SL_Log2ToDiv(ret);
   7698                    break;
   7699          #endif
   7700          
   7701                  default:
   7702                    ret = cmuClkDiv_1;
   7703                    EFM_ASSERT(false);
   7704                    break;
   7705                }
   7706                break;
   7707          
   7708              case CMU_LFBPRESC0_REG:
   7709                switch (clock) {
   7710          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   7711                  case cmuClock_LEUART0:
   7712                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   7713                                               >> _CMU_LFBPRESC0_LEUART0_SHIFT);
   7714                    ret = SL_Log2ToDiv(ret);
   7715                    break;
   7716          #endif
   7717          
   7718          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   7719                  case cmuClock_LEUART1:
   7720                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   7721                                               >> _CMU_LFBPRESC0_LEUART1_SHIFT);
   7722                    ret = SL_Log2ToDiv(ret);
   7723                    break;
   7724          #endif
   7725          
   7726                  default:
   7727                    ret = cmuClkDiv_1;
   7728                    EFM_ASSERT(false);
   7729                    break;
   7730                }
   7731                break;
   7732          
   7733              default:
   7734                ret = cmuClkDiv_1;
   7735                EFM_ASSERT(false);
   7736                break;
   7737            }
   7738          
   7739            return ret;
   7740          #endif
   7741          }
   7742          
   7743          /***************************************************************************//**
   7744           * @brief
   7745           *   Set the clock divisor/prescaler.
   7746           *
   7747           * @note
   7748           *   If setting an LF clock prescaler, synchronization into the low-frequency
   7749           *   domain is required. If the same register is modified before a previous
   7750           *   update has completed, this function will stall until the previous
   7751           *   synchronization has completed. See @ref CMU_FreezeEnable() for
   7752           *   a suggestion on how to reduce the stalling time in some use cases.
   7753           *
   7754           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   7755           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   7756           *
   7757           * @param[in] clock
   7758           *   Clock point to set divisor/prescaler for. Notice that not all clock points
   7759           *   have a divisor/prescaler. See the CMU overview in the reference
   7760           *   manual.
   7761           *
   7762           * @param[in] div
   7763           *   The clock divisor to use (<= cmuClkDiv_512).
   7764           ******************************************************************************/
   7765          void CMU_ClockDivSet(CMU_Clock_TypeDef clock, CMU_ClkDiv_TypeDef div)
   7766          {
   7767          #if defined(_SILICON_LABS_32B_SERIES_1)
   7768            CMU_ClockPrescSet(clock, (CMU_ClkPresc_TypeDef)(div - 1U));
   7769          
   7770          #elif defined(_SILICON_LABS_32B_SERIES_0)
   7771            uint32_t freq;
   7772            uint32_t divReg;
   7773          
   7774            /* Get the divisor reg ID. */
   7775            divReg = (clock >> CMU_DIV_REG_POS) & CMU_DIV_REG_MASK;
   7776          
   7777            switch (divReg) {
   7778          #if defined(_CMU_CTRL_HFCLKDIV_MASK)
   7779              case CMU_HFCLKDIV_REG:
   7780                EFM_ASSERT((div >= cmuClkDiv_1) && (div <= cmuClkDiv_8));
   7781          
   7782                /* Configure worst case wait states for flash access before setting divisor. */
   7783                flashWaitStateMax();
   7784          
   7785                /* Set the divider. */
   7786                CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFCLKDIV_MASK)
   7787                            | ((div - 1) << _CMU_CTRL_HFCLKDIV_SHIFT);
   7788          
   7789                /* Update the CMSIS core clock variable. */
   7790                /* (The function will update the global variable). */
   7791                freq = SystemCoreClockGet();
   7792          
   7793                /* Optimize flash access wait state setting for the current core clk. */
   7794                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   7795                break;
   7796          #endif
   7797          
   7798              case CMU_HFPERCLKDIV_REG:
   7799                EFM_ASSERT((div >= cmuClkDiv_1) && (div <= cmuClkDiv_512));
   7800                /* Convert to the correct scale. */
   7801                div = CMU_DivToLog2(div);
   7802                CMU->HFPERCLKDIV = (CMU->HFPERCLKDIV & ~_CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   7803                                   | (div << _CMU_HFPERCLKDIV_HFPERCLKDIV_SHIFT);
   7804                break;
   7805          
   7806          #if defined(_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7807              case CMU_HFCORECLKLEDIV_REG:
   7808                /*
   7809                   This divisor is usually set when changing HF clock to keep HFLE clock
   7810                   within safe bounds. This code path ignore these constraints.
   7811                 */
   7812                /* Convert to the correct scale. */
   7813                div = CMU_DivToLog2(div) - 1U;
   7814                CMU->HFCORECLKDIV = (CMU->HFCORECLKDIV
   7815                                     & ~_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7816                                    | (div << _CMU_HFCORECLKDIV_HFCORECLKLEDIV_SHIFT);
   7817                break;
   7818          #endif
   7819          
   7820              case CMU_HFCORECLKDIV_REG:
   7821                EFM_ASSERT((div >= cmuClkDiv_1) && (div <= cmuClkDiv_512));
   7822          
   7823                /* Configure worst case wait states for flash access before setting the divisor. */
   7824                flashWaitStateMax();
   7825          
   7826          #if defined(CMU_MAX_FREQ_HFLE)
   7827                setHfLeConfig(SystemCoreClockGet() / div);
   7828          #endif
   7829          
   7830                /* Convert to the correct scale. */
   7831                div = CMU_DivToLog2(div);
   7832          
   7833                CMU->HFCORECLKDIV = (CMU->HFCORECLKDIV
   7834                                     & ~_CMU_HFCORECLKDIV_HFCORECLKDIV_MASK)
   7835                                    | (div << _CMU_HFCORECLKDIV_HFCORECLKDIV_SHIFT);
   7836          
   7837                /* Update the CMSIS core clock variable. */
   7838                /* (The function will update the global variable). */
   7839                freq = SystemCoreClockGet();
   7840          
   7841                /* Optimize wait state setting for the current core clk. */
   7842                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   7843          #if defined(CMU_MAX_FREQ_HFLE)
   7844                setHfLeConfig(freq);
   7845          #endif
   7846                break;
   7847          
   7848              case CMU_LFAPRESC0_REG:
   7849                switch (clock) {
   7850                  case cmuClock_RTC:
   7851                    EFM_ASSERT(div <= cmuClkDiv_32768);
   7852          
   7853                    /* LF register about to be modified requires sync. busy check. */
   7854                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7855          
   7856                    /* Convert to the correct scale. */
   7857                    div = CMU_DivToLog2(div);
   7858          
   7859                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_RTC_MASK)
   7860                                     | (div << _CMU_LFAPRESC0_RTC_SHIFT);
   7861                    break;
   7862          
   7863          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   7864                  case cmuClock_LETIMER0:
   7865                    EFM_ASSERT(div <= cmuClkDiv_32768);
   7866          
   7867                    /* LF register about to be modified requires sync. busy check. */
   7868                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7869          
   7870                    /* Convert to the correct scale. */
   7871                    div = CMU_DivToLog2(div);
   7872          
   7873                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LETIMER0_MASK)
   7874                                     | (div << _CMU_LFAPRESC0_LETIMER0_SHIFT);
   7875                    break;
   7876          #endif
   7877          
   7878          #if defined(LCD_PRESENT)
   7879                  case cmuClock_LCDpre:
   7880                    EFM_ASSERT((div >= cmuClkDiv_16) && (div <= cmuClkDiv_128));
   7881          
   7882                    /* LF register about to be modified requires sync. busy check. */
   7883                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7884          
   7885                    /* Convert to the correct scale. */
   7886                    div = CMU_DivToLog2(div);
   7887          
   7888                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LCD_MASK)
   7889                                     | ((div - CMU_DivToLog2(cmuClkDiv_16))
   7890                                        << _CMU_LFAPRESC0_LCD_SHIFT);
   7891                    break;
   7892          #endif /* defined(LCD_PRESENT) */
   7893          
   7894          #if defined(LESENSE_PRESENT)
   7895                  case cmuClock_LESENSE:
   7896                    EFM_ASSERT(div <= cmuClkDiv_8);
   7897          
   7898                    /* LF register about to be modified requires sync. busy check. */
   7899                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7900          
   7901                    /* Convert to the correct scale. */
   7902                    div = CMU_DivToLog2(div);
   7903          
   7904                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LESENSE_MASK)
   7905                                     | (div << _CMU_LFAPRESC0_LESENSE_SHIFT);
   7906                    break;
   7907          #endif /* defined(LESENSE_PRESENT) */
   7908          
   7909                  default:
   7910                    EFM_ASSERT(false);
   7911                    break;
   7912                }
   7913                break;
   7914          
   7915              case CMU_LFBPRESC0_REG:
   7916                switch (clock) {
   7917          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   7918                  case cmuClock_LEUART0:
   7919                    EFM_ASSERT(div <= cmuClkDiv_8);
   7920          
   7921                    /* LF register about to be modified requires sync. busy check. */
   7922                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   7923          
   7924                    /* Convert to the correct scale. */
   7925                    div = CMU_DivToLog2(div);
   7926          
   7927                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART0_MASK)
   7928                                     | (((uint32_t)div) << _CMU_LFBPRESC0_LEUART0_SHIFT);
   7929                    break;
   7930          #endif
   7931          
   7932          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   7933                  case cmuClock_LEUART1:
   7934                    EFM_ASSERT(div <= cmuClkDiv_8);
   7935          
   7936                    /* LF register about to be modified requires sync. busy check. */
   7937                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   7938          
   7939                    /* Convert to the correct scale. */
   7940                    div = CMU_DivToLog2(div);
   7941          
   7942                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART1_MASK)
   7943                                     | (((uint32_t)div) << _CMU_LFBPRESC0_LEUART1_SHIFT);
   7944                    break;
   7945          #endif
   7946          
   7947                  default:
   7948                    EFM_ASSERT(false);
   7949                    break;
   7950                }
   7951                break;
   7952          
   7953              default:
   7954                EFM_ASSERT(false);
   7955                break;
   7956            }
   7957          #endif
   7958          }
   7959          
   7960          /***************************************************************************//**
   7961           * @brief
   7962           *   Enable/disable a clock.
   7963           *
   7964           * @details
   7965           *   In general, module clocking is disabled after a reset. If a module
   7966           *   clock is disabled, the registers of that module are not accessible and
   7967           *   reading from such registers may return undefined values. Writing to
   7968           *   registers of clock-disabled modules has no effect.
   7969           *   Avoid accessing module registers of a module with a disabled clock.
   7970           *
   7971           * @note
   7972           *   If enabling/disabling an LF clock, synchronization into the low-frequency
   7973           *   domain is required. If the same register is modified before a previous
   7974           *   update has completed, this function will stall until the previous
   7975           *   synchronization has completed. See @ref CMU_FreezeEnable() for
   7976           *   a suggestion on how to reduce the stalling time in some use cases.
   7977           *
   7978           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   7979           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   7980           *
   7981           * @param[in] clock
   7982           *   The clock to enable/disable. Notice that not all defined clock
   7983           *   points have separate enable/disable control. See the CMU overview
   7984           *   in the reference manual.
   7985           *
   7986           * @param[in] enable
   7987           *   @li true - enable specified clock.
   7988           *   @li false - disable specified clock.
   7989           ******************************************************************************/
   7990          void CMU_ClockEnable(CMU_Clock_TypeDef clock, bool enable)
   7991          {
   7992            volatile uint32_t *reg;
   7993            uint32_t          bit;
   7994            uint32_t          sync = 0;
   7995          
   7996            /* Identify enable register */
   7997            switch (((unsigned)clock >> CMU_EN_REG_POS) & CMU_EN_REG_MASK) {
   7998          #if defined(_CMU_CTRL_HFPERCLKEN_MASK)
   7999              case CMU_CTRL_EN_REG:
   8000                reg = &CMU->CTRL;
   8001                break;
   8002          #endif
   8003          
   8004          #if defined(_CMU_HFCORECLKEN0_MASK)
   8005              case CMU_HFCORECLKEN0_EN_REG:
   8006                reg = &CMU->HFCORECLKEN0;
   8007          #if defined(CMU_MAX_FREQ_HFLE)
   8008                setHfLeConfig(SystemCoreClockGet());
   8009          #endif
   8010                break;
   8011          #endif
   8012          
   8013          #if defined(_CMU_HFBUSCLKEN0_MASK)
   8014              case CMU_HFBUSCLKEN0_EN_REG:
   8015                reg = &CMU->HFBUSCLKEN0;
   8016                break;
   8017          #endif
   8018          
   8019          #if defined(_CMU_HFPERCLKDIV_MASK)
   8020              case CMU_HFPERCLKDIV_EN_REG:
   8021                reg = &CMU->HFPERCLKDIV;
   8022                break;
   8023          #endif
   8024          
   8025              case CMU_HFPERCLKEN0_EN_REG:
   8026                reg = &CMU->HFPERCLKEN0;
   8027                break;
   8028          
   8029          #if defined(_CMU_HFPERCLKEN1_MASK)
   8030              case CMU_HFPERCLKEN1_EN_REG:
   8031                reg = &CMU->HFPERCLKEN1;
   8032                break;
   8033          #endif
   8034          
   8035              case CMU_LFACLKEN0_EN_REG:
   8036                reg  = &CMU->LFACLKEN0;
   8037                sync = CMU_SYNCBUSY_LFACLKEN0;
   8038                break;
   8039          
   8040              case CMU_LFBCLKEN0_EN_REG:
   8041                reg  = &CMU->LFBCLKEN0;
   8042                sync = CMU_SYNCBUSY_LFBCLKEN0;
   8043                break;
   8044          
   8045          #if defined(_CMU_LFCCLKEN0_MASK)
   8046              case CMU_LFCCLKEN0_EN_REG:
   8047                reg = &CMU->LFCCLKEN0;
   8048                sync = CMU_SYNCBUSY_LFCCLKEN0;
   8049                break;
   8050          #endif
   8051          
   8052          #if defined(_CMU_LFECLKEN0_MASK)
   8053              case CMU_LFECLKEN0_EN_REG:
   8054                reg  = &CMU->LFECLKEN0;
   8055                sync = CMU_SYNCBUSY_LFECLKEN0;
   8056                break;
   8057          #endif
   8058          
   8059          #if defined(_CMU_SDIOCTRL_MASK)
   8060              case CMU_SDIOREF_EN_REG:
   8061                reg = &CMU->SDIOCTRL;
   8062                enable = !enable;
   8063                break;
   8064          #endif
   8065          
   8066          #if defined(_CMU_QSPICTRL_MASK)
   8067              case CMU_QSPI0REF_EN_REG:
   8068                reg = &CMU->QSPICTRL;
   8069                enable = !enable;
   8070                break;
   8071          #endif
   8072          #if defined(_CMU_USBCTRL_MASK)
   8073              case CMU_USBRCLK_EN_REG:
   8074                reg = &CMU->USBCTRL;
   8075                break;
   8076          #endif
   8077          #if defined(_CMU_PDMCTRL_MASK)
   8078              case CMU_PDMREF_EN_REG:
   8079                reg = &CMU->PDMCTRL;
   8080                break;
   8081          #endif
   8082          
   8083              case CMU_PCNT_EN_REG:
   8084                reg = &CMU->PCNTCTRL;
   8085                break;
   8086          
   8087              default: /* Cannot enable/disable a clock point. */
   8088                EFM_ASSERT(false);
   8089                return;
   8090            }
   8091          
   8092            /* Get the bit position used to enable/disable. */
   8093            bit = ((unsigned)clock >> CMU_EN_BIT_POS) & CMU_EN_BIT_MASK;
   8094          
   8095            /* LF synchronization required. */
   8096            if (sync > 0UL) {
   8097              syncReg(sync);
   8098            }
   8099          
   8100            /* Set/clear bit as requested. */
   8101            BUS_RegBitWrite(reg, bit, (uint32_t)enable);
   8102          }
   8103          
   8104          /***************************************************************************//**
   8105           * @brief
   8106           *   Get the clock frequency for a clock point.
   8107           *
   8108           * @param[in] clock
   8109           *   A clock point to fetch the frequency for.
   8110           *
   8111           * @return
   8112           *   The current frequency in Hz.
   8113           ******************************************************************************/
   8114          uint32_t CMU_ClockFreqGet(CMU_Clock_TypeDef clock)
   8115          {
   8116            uint32_t ret;
   8117          
   8118            switch ((unsigned)clock & (CMU_CLK_BRANCH_MASK << CMU_CLK_BRANCH_POS)) {
   8119              case (CMU_HF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8120                ret = SystemHFClockGet();
   8121                break;
   8122          
   8123              case (CMU_HFPER_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8124                ret = SystemHFClockGet();
   8125                /* Calculate frequency after HFPER divider. */
   8126          #if defined(_CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   8127                ret >>= (CMU->HFPERCLKDIV & _CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   8128                        >> _CMU_HFPERCLKDIV_HFPERCLKDIV_SHIFT;
   8129          #endif
   8130          #if defined(_CMU_HFPERPRESC_PRESC_MASK)
   8131                ret /= 1U + ((CMU->HFPERPRESC & _CMU_HFPERPRESC_PRESC_MASK)
   8132                             >> _CMU_HFPERPRESC_PRESC_SHIFT);
   8133          #endif
   8134                break;
   8135          
   8136          #if defined(_CMU_HFPERPRESCB_MASK)
   8137              case (CMU_HFPERB_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8138                ret = SystemHFClockGet();
   8139                /* Calculate frequency after HFPERB prescaler. */
   8140                ret /= 1U + ((CMU->HFPERPRESCB & _CMU_HFPERPRESCB_PRESC_MASK)
   8141                             >> _CMU_HFPERPRESCB_PRESC_SHIFT);
   8142                break;
   8143          #endif
   8144          
   8145          #if defined(_CMU_HFPERPRESCC_MASK)
   8146              case (CMU_HFPERC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8147                ret = SystemHFClockGet();
   8148                /* Calculate frequency after HFPERC prescaler. */
   8149                ret /= 1U + ((CMU->HFPERPRESCC & _CMU_HFPERPRESCC_PRESC_MASK)
   8150                             >> _CMU_HFPERPRESCC_PRESC_SHIFT);
   8151                break;
   8152          #endif
   8153          
   8154          #if defined(_SILICON_LABS_32B_SERIES_1)
   8155          #if defined(CRYPTO_PRESENT)     \
   8156                || defined(LDMA_PRESENT)  \
   8157                || defined(GPCRC_PRESENT) \
   8158                || defined(PRS_PRESENT)   \
   8159                || defined(GPIO_PRESENT)
   8160              case (CMU_HFBUS_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8161                ret = SystemHFClockGet();
   8162          #if defined(_CMU_HFBUSPRESC_MASK)
   8163                ret /= 1U + ((CMU->HFBUSPRESC & _CMU_HFBUSPRESC_MASK)
   8164                             >> _CMU_HFBUSPRESC_PRESC_SHIFT);
   8165          #endif
   8166                break;
   8167          #endif
   8168          
   8169              case (CMU_HFCORE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8170                ret = SystemHFClockGet();
   8171                ret /= 1U + ((CMU->HFCOREPRESC & _CMU_HFCOREPRESC_PRESC_MASK)
   8172                             >> _CMU_HFCOREPRESC_PRESC_SHIFT);
   8173                break;
   8174          
   8175              case (CMU_HFEXP_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8176                ret = SystemHFClockGet();
   8177                ret /= 1U + ((CMU->HFEXPPRESC & _CMU_HFEXPPRESC_PRESC_MASK)
   8178                             >> _CMU_HFEXPPRESC_PRESC_SHIFT);
   8179                break;
   8180          #endif
   8181          
   8182          #if defined(_SILICON_LABS_32B_SERIES_0)
   8183          #if defined(AES_PRESENT)      \
   8184                || defined(DMA_PRESENT) \
   8185                || defined(EBI_PRESENT) \
   8186                || defined(USB_PRESENT)
   8187              case (CMU_HFCORE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8188              {
   8189                ret = SystemCoreClockGet();
   8190              } break;
   8191          #endif
   8192          #endif
   8193          
   8194              case (CMU_LFA_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8195                ret = lfClkGet(cmuClock_LFA);
   8196                break;
   8197          
   8198          #if defined(_CMU_LFACLKEN0_RTC_MASK)
   8199              case (CMU_RTC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8200                ret = lfClkGet(cmuClock_LFA);
   8201                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_RTC_MASK)
   8202                        >> _CMU_LFAPRESC0_RTC_SHIFT;
   8203                break;
   8204          #endif
   8205          
   8206          #if defined(_CMU_LFECLKEN0_RTCC_MASK)
   8207              case (CMU_RTCC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8208                ret = lfClkGet(cmuClock_LFE);
   8209                ret >>= (CMU->LFEPRESC0 & _CMU_LFEPRESC0_RTCC_MASK)
   8210                        >> _CMU_LFEPRESC0_RTCC_SHIFT;
   8211                break;
   8212          #endif
   8213          
   8214          #if defined(_CMU_LFACLKEN0_LETIMER0_MASK)
   8215              case (CMU_LETIMER0_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8216                ret = lfClkGet(cmuClock_LFA);
   8217          #if defined(_SILICON_LABS_32B_SERIES_0)
   8218                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   8219                        >> _CMU_LFAPRESC0_LETIMER0_SHIFT;
   8220          #else
   8221                ret /= SL_Log2ToDiv((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   8222                                    >> _CMU_LFAPRESC0_LETIMER0_SHIFT);
   8223          #endif
   8224                break;
   8225          #endif
   8226          
   8227          #if defined(_CMU_LFACLKEN0_LETIMER1_MASK)
   8228              case (CMU_LETIMER1_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8229                ret = lfClkGet(cmuClock_LFA);
   8230          #if defined(_SILICON_LABS_32B_SERIES_0)
   8231                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER1_MASK)
   8232                        >> _CMU_LFAPRESC0_LETIMER1_SHIFT;
   8233          #else
   8234                ret /= SL_Log2ToDiv((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER1_MASK)
   8235                                    >> _CMU_LFAPRESC0_LETIMER1_SHIFT);
   8236          #endif
   8237                break;
   8238          #endif
   8239          
   8240          #if defined(_CMU_LFACLKEN0_LCD_MASK)
   8241              case (CMU_LCDPRE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8242                ret = lfClkGet(cmuClock_LFA);
   8243          #if defined(_SILICON_LABS_32B_SERIES_0)
   8244                ret >>= ((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   8245                         >> _CMU_LFAPRESC0_LCD_SHIFT)
   8246                        + CMU_DivToLog2(cmuClkDiv_16);
   8247          #else
   8248                ret /= SL_Log2ToDiv((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   8249                                    >> _CMU_LFAPRESC0_LCD_SHIFT);
   8250          #endif
   8251                break;
   8252          
   8253          #if defined(_CMU_LCDCTRL_MASK)
   8254              case (CMU_LCD_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8255                ret = lfClkGet(cmuClock_LFA);
   8256                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   8257                        >> _CMU_LFAPRESC0_LCD_SHIFT;
   8258                ret /= 1U + ((CMU->LCDCTRL & _CMU_LCDCTRL_FDIV_MASK)
   8259                             >> _CMU_LCDCTRL_FDIV_SHIFT);
   8260                break;
   8261          #endif
   8262          #endif
   8263          
   8264          #if defined(_CMU_LFACLKEN0_LESENSE_MASK)
   8265              case (CMU_LESENSE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8266                ret = lfClkGet(cmuClock_LFA);
   8267                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LESENSE_MASK)
   8268                        >> _CMU_LFAPRESC0_LESENSE_SHIFT;
   8269                break;
   8270          #endif
   8271          
   8272              case (CMU_LFB_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8273                ret = lfClkGet(cmuClock_LFB);
   8274                break;
   8275          
   8276          #if defined(_CMU_LFBCLKEN0_LEUART0_MASK)
   8277              case (CMU_LEUART0_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8278                ret = lfClkGet(cmuClock_LFB);
   8279          #if defined(_SILICON_LABS_32B_SERIES_0)
   8280                ret >>= (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   8281                        >> _CMU_LFBPRESC0_LEUART0_SHIFT;
   8282          #else
   8283                ret /= SL_Log2ToDiv((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   8284                                    >> _CMU_LFBPRESC0_LEUART0_SHIFT);
   8285          #endif
   8286                break;
   8287          #endif
   8288          
   8289          #if defined(_CMU_LFBCLKEN0_LEUART1_MASK)
   8290              case (CMU_LEUART1_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8291                ret = lfClkGet(cmuClock_LFB);
   8292          #if defined(_SILICON_LABS_32B_SERIES_0)
   8293                ret >>= (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   8294                        >> _CMU_LFBPRESC0_LEUART1_SHIFT;
   8295          #else
   8296                ret /= SL_Log2ToDiv((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   8297                                    >> _CMU_LFBPRESC0_LEUART1_SHIFT);
   8298          #endif
   8299                break;
   8300          #endif
   8301          
   8302          #if defined(_CMU_LFBCLKEN0_CSEN_MASK)
   8303              case (CMU_CSEN_LF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8304                ret = lfClkGet(cmuClock_LFB);
   8305                ret /= SL_Log2ToDiv(((CMU->LFBPRESC0 & _CMU_LFBPRESC0_CSEN_MASK)
   8306                                     >> _CMU_LFBPRESC0_CSEN_SHIFT) + 4UL);
   8307                break;
   8308          #endif
   8309          
   8310          #if defined(CMU_LFCCLKEN0_USB)
   8311              case (CMU_USBLE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8312                ret = lfClkGet(cmuClock_LFC);
   8313                break;
   8314          #endif
   8315          
   8316          #if defined(_SILICON_LABS_32B_SERIES_1)
   8317              case (CMU_LFE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8318                ret = lfClkGet(cmuClock_LFE);
   8319                break;
   8320          #endif
   8321          
   8322              case (CMU_DBG_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8323                ret = dbgClkGet();
   8324                break;
   8325          
   8326              case (CMU_AUX_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8327                ret = auxClkGet();
   8328                break;
   8329          
   8330          #if defined(USBC_CLOCK_PRESENT)
   8331              case (CMU_USBC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8332                ret = usbCClkGet();
   8333                break;
   8334          #endif
   8335          
   8336          #if defined(_CMU_ADCCTRL_ADC0CLKSEL_MASK)
   8337              case (CMU_ADC0ASYNC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8338                ret = adcAsyncClkGet(0);
   8339          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8340                ret /= 1U + ((CMU->ADCCTRL & _CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8341                             >> _CMU_ADCCTRL_ADC0CLKDIV_SHIFT);
   8342          #endif
   8343                break;
   8344          #endif
   8345          
   8346          #if defined(_CMU_ADCCTRL_ADC1CLKSEL_MASK)
   8347              case (CMU_ADC1ASYNC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8348                ret = adcAsyncClkGet(1);
   8349          #if defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8350                ret /= 1U + ((CMU->ADCCTRL & _CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8351                             >> _CMU_ADCCTRL_ADC1CLKDIV_SHIFT);
   8352          #endif
   8353                break;
   8354          #endif
   8355          
   8356          #if defined(_CMU_SDIOCTRL_SDIOCLKSEL_MASK)
   8357              case (CMU_SDIOREF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8358                ret = sdioRefClkGet();
   8359                break;
   8360          #endif
   8361          
   8362          #if defined(_CMU_QSPICTRL_QSPI0CLKSEL_MASK)
   8363              case (CMU_QSPI0REF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8364                ret = qspiRefClkGet(0);
   8365                break;
   8366          #endif
   8367          
   8368          #if defined(USBR_CLOCK_PRESENT)
   8369              case (CMU_USBR_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8370                ret = usbRateClkGet();
   8371                break;
   8372          #endif
   8373          
   8374          #if defined(_CMU_PDMCTRL_PDMCLKSEL_MASK)
   8375              case (CMU_PDMREF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8376                ret = pdmRefClkGet();
   8377                break;
   8378          #endif
   8379          
   8380              case (CMU_HFLE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   8381          #if defined(_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   8382                ret = SystemCoreClockGet() / CMU_ClockDivGet(clock);
   8383          #elif defined(_CMU_HFPRESC_HFCLKLEPRESC_MASK)
   8384                ret = SystemHFClockGet() / CMU_ClockDivGet(clock);
   8385          #else
   8386                ret = SystemCoreClockGet() / 2;
   8387          #endif
   8388                break;
   8389          
   8390              default:
   8391                ret = 0;
   8392                EFM_ASSERT(false);
   8393                break;
   8394            }
   8395          
   8396            return ret;
   8397          }
   8398          
   8399          #if defined(_SILICON_LABS_32B_SERIES_1)
   8400          /***************************************************************************//**
   8401           * @brief
   8402           *   Get the clock prescaler.
   8403           *
   8404           * @param[in] clock
   8405           *   A clock point to get the prescaler for. Notice that not all clock points
   8406           *   have a prescaler. See the CMU overview in the reference manual.
   8407           *
   8408           * @return
   8409           *   The prescaler value of the current clock point. 0 is returned
   8410           *   if @p clock specifies a clock point without a prescaler.
   8411           ******************************************************************************/
   8412          uint32_t CMU_ClockPrescGet(CMU_Clock_TypeDef clock)
   8413          {
   8414            uint32_t  prescReg;
   8415            uint32_t  ret;
   8416          
   8417            /* Get the prescaler register ID. */
   8418            prescReg = ((unsigned)clock >> CMU_PRESC_REG_POS) & CMU_PRESC_REG_MASK;
   8419          
   8420            switch (prescReg) {
   8421              case CMU_HFPRESC_REG:
   8422                ret = (CMU->HFPRESC & _CMU_HFPRESC_PRESC_MASK)
   8423                      >> _CMU_HFPRESC_PRESC_SHIFT;
   8424                break;
   8425          
   8426              case CMU_HFEXPPRESC_REG:
   8427                ret = (CMU->HFEXPPRESC & _CMU_HFEXPPRESC_PRESC_MASK)
   8428                      >> _CMU_HFEXPPRESC_PRESC_SHIFT;
   8429                break;
   8430          
   8431              case CMU_HFCLKLEPRESC_REG:
   8432                ret = (CMU->HFPRESC & _CMU_HFPRESC_HFCLKLEPRESC_MASK)
   8433                      >> _CMU_HFPRESC_HFCLKLEPRESC_SHIFT;
   8434                ret = SL_Log2ToDiv(ret + 1U) - 1U;
   8435                break;
   8436          
   8437              case CMU_HFPERPRESC_REG:
   8438                ret = (CMU->HFPERPRESC & _CMU_HFPERPRESC_PRESC_MASK)
   8439                      >> _CMU_HFPERPRESC_PRESC_SHIFT;
   8440                break;
   8441          
   8442          #if defined(_CMU_HFPERPRESCB_MASK)
   8443              case CMU_HFPERPRESCB_REG:
   8444                ret = (CMU->HFPERPRESCB & _CMU_HFPERPRESCB_PRESC_MASK)
   8445                      >> _CMU_HFPERPRESCB_PRESC_SHIFT;
   8446                break;
   8447          #endif
   8448          
   8449          #if defined(_CMU_HFPERPRESCC_MASK)
   8450              case CMU_HFPERPRESCC_REG:
   8451                ret = (CMU->HFPERPRESCC & _CMU_HFPERPRESCC_PRESC_MASK)
   8452                      >> _CMU_HFPERPRESCC_PRESC_SHIFT;
   8453                break;
   8454          #endif
   8455          
   8456              case CMU_HFCOREPRESC_REG:
   8457                ret = (CMU->HFCOREPRESC & _CMU_HFCOREPRESC_PRESC_MASK)
   8458                      >> _CMU_HFCOREPRESC_PRESC_SHIFT;
   8459                break;
   8460          
   8461              case CMU_LFAPRESC0_REG:
   8462                switch (clock) {
   8463          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   8464                  case cmuClock_LETIMER0:
   8465                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   8466                          >> _CMU_LFAPRESC0_LETIMER0_SHIFT;
   8467                    /* Convert the exponent to a prescaler value. */
   8468                    ret = SL_Log2ToDiv(ret) - 1U;
   8469                    break;
   8470          #endif
   8471          
   8472          #if defined(_CMU_LFAPRESC0_LESENSE_MASK)
   8473                  case cmuClock_LESENSE:
   8474                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LESENSE_MASK)
   8475                          >> _CMU_LFAPRESC0_LESENSE_SHIFT;
   8476                    /* Convert the exponent to a prescaler value. */
   8477                    ret = SL_Log2ToDiv(ret) - 1U;
   8478                    break;
   8479          #endif
   8480          
   8481          #if defined(_CMU_LFAPRESC0_LETIMER1_MASK)
   8482                  case cmuClock_LETIMER1:
   8483                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER1_MASK)
   8484                          >> _CMU_LFAPRESC0_LETIMER1_SHIFT;
   8485                    ret = SL_Log2ToDiv(ret) - 1U;
   8486                    break;
   8487          #endif
   8488          
   8489          #if defined(_CMU_LFAPRESC0_LCD_MASK)
   8490                  case cmuClock_LCD:
   8491                  case cmuClock_LCDpre:
   8492                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   8493                          >> _CMU_LFAPRESC0_LCD_SHIFT;
   8494                    ret = SL_Log2ToDiv(ret) - 1U;
   8495                    break;
   8496          #endif
   8497          
   8498          #if defined(_CMU_LFAPRESC0_RTC_MASK)
   8499                  case cmuClock_RTC:
   8500                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_RTC_MASK)
   8501                          >> _CMU_LFAPRESC0_RTC_SHIFT;
   8502                    ret = SL_Log2ToDiv(ret) - 1U;
   8503                    break;
   8504          #endif
   8505          
   8506                  default:
   8507                    ret = 0U;
   8508                    EFM_ASSERT(false);
   8509                    break;
   8510                }
   8511                break;
   8512          
   8513              case CMU_LFBPRESC0_REG:
   8514                switch (clock) {
   8515          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   8516                  case cmuClock_LEUART0:
   8517                    ret = (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   8518                          >> _CMU_LFBPRESC0_LEUART0_SHIFT;
   8519                    /* Convert the exponent to a prescaler value. */
   8520                    ret = SL_Log2ToDiv(ret) - 1U;
   8521                    break;
   8522          #endif
   8523          
   8524          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   8525                  case cmuClock_LEUART1:
   8526                    ret = (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   8527                          >> _CMU_LFBPRESC0_LEUART1_SHIFT;
   8528                    /* Convert the exponent to a prescaler value. */
   8529                    ret = SL_Log2ToDiv(ret) - 1U;
   8530                    break;
   8531          #endif
   8532          
   8533          #if defined(_CMU_LFBPRESC0_CSEN_MASK)
   8534                  case cmuClock_CSEN_LF:
   8535                    ret = (CMU->LFBPRESC0 & _CMU_LFBPRESC0_CSEN_MASK)
   8536                          >> _CMU_LFBPRESC0_CSEN_SHIFT;
   8537                    /* Convert the exponent to a prescaler value. */
   8538                    ret = SL_Log2ToDiv(ret + 4U) - 1U;
   8539                    break;
   8540          #endif
   8541          
   8542                  default:
   8543                    ret = 0U;
   8544                    EFM_ASSERT(false);
   8545                    break;
   8546                }
   8547                break;
   8548          
   8549              case CMU_LFEPRESC0_REG:
   8550                switch (clock) {
   8551          #if defined(RTCC_PRESENT)
   8552                  case cmuClock_RTCC:
   8553                    ret = (CMU->LFEPRESC0 & _CMU_LFEPRESC0_RTCC_MASK)
   8554                          >> _CMU_LFEPRESC0_RTCC_SHIFT;
   8555                    break;
   8556          
   8557                  default:
   8558                    ret = 0U;
   8559                    EFM_ASSERT(false);
   8560                    break;
   8561          #endif
   8562                }
   8563                break;
   8564          
   8565          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK) \
   8566                || defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8567              case CMU_ADCASYNCDIV_REG:
   8568                switch (clock) {
   8569          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8570                  case cmuClock_ADC0ASYNC:
   8571                    ret = (CMU->ADCCTRL & _CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8572                          >> _CMU_ADCCTRL_ADC0CLKDIV_SHIFT;
   8573                    break;
   8574          #endif
   8575          #if defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8576                  case cmuClock_ADC1ASYNC:
   8577                    ret = (CMU->ADCCTRL & _CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8578                          >> _CMU_ADCCTRL_ADC1CLKDIV_SHIFT;
   8579                    break;
   8580          #endif
   8581                  default:
   8582                    ret = 0U;
   8583                    EFM_ASSERT(false);
   8584                    break;
   8585                }
   8586                break;
   8587          #endif
   8588          #if defined(_CMU_HFBUSPRESC_MASK)
   8589              case CMU_HFBUSPRESC_REG:
   8590                ret = (CMU->HFBUSPRESC & _CMU_HFBUSPRESC_MASK)
   8591                      >> _CMU_HFBUSPRESC_PRESC_SHIFT;
   8592                break;
   8593          #endif
   8594              default:
   8595                ret = 0U;
   8596                EFM_ASSERT(false);
   8597                break;
   8598            }
   8599          
   8600            return ret;
   8601          }
   8602          #endif
   8603          
   8604          #if defined(_SILICON_LABS_32B_SERIES_1)
   8605          /***************************************************************************//**
   8606           * @brief
   8607           *   Set the clock prescaler.
   8608           *
   8609           * @note
   8610           *   If setting an LF clock prescaler, synchronization into the low-frequency
   8611           *   domain is required. If the same register is modified before a previous
   8612           *   update has completed, this function will stall until the previous
   8613           *   synchronization has completed. See @ref CMU_FreezeEnable() for
   8614           *   a suggestion on how to reduce the stalling time in some use cases.
   8615           *
   8616           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   8617           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   8618           *
   8619           * @param[in] clock
   8620           *   A clock point to set the prescaler for. Notice that not all clock points
   8621           *   have a prescaler. See the CMU overview in the reference manual.
   8622           *
   8623           * @param[in] presc
   8624           *   The clock prescaler. The prescaler value is linked to the clock divider by:
   8625           *   divider = 'presc' + 1.
   8626           ******************************************************************************/
   8627          void CMU_ClockPrescSet(CMU_Clock_TypeDef clock, CMU_ClkPresc_TypeDef presc)
   8628          {
   8629            uint32_t freq;
   8630            uint32_t prescReg;
   8631          
   8632            /* Get the divisor reg ID. */
   8633            prescReg = ((unsigned)clock >> CMU_PRESC_REG_POS) & CMU_PRESC_REG_MASK;
   8634          
   8635            switch (prescReg) {
   8636              case CMU_HFPRESC_REG:
   8637                EFM_ASSERT(presc < 32U);
   8638          
   8639                /* Configure worst case wait-states for flash and HFLE, set safe HFPER
   8640                   clock-tree prescalers. */
   8641                flashWaitStateMax();
   8642                setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   8643                hfperClkSafePrescaler();
   8644          
   8645                CMU->HFPRESC = (CMU->HFPRESC & ~_CMU_HFPRESC_PRESC_MASK)
   8646                               | (presc << _CMU_HFPRESC_PRESC_SHIFT);
   8647          
   8648                /* Update the CMSIS core clock variable (this function updates the global
   8649                   variable). */
   8650                freq = SystemCoreClockGet();
   8651                /* Optimize flash and HFLE wait states and set optimized HFPER clock-tree
   8652                   prescalers. */
   8653                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   8654                setHfLeConfig(SystemHFClockGet());
   8655                hfperClkOptimizedPrescaler();
   8656                break;
   8657          
   8658              case CMU_HFEXPPRESC_REG:
   8659                EFM_ASSERT(presc < 32U);
   8660          
   8661                CMU->HFEXPPRESC = (CMU->HFEXPPRESC & ~_CMU_HFEXPPRESC_PRESC_MASK)
   8662                                  | (presc << _CMU_HFEXPPRESC_PRESC_SHIFT);
   8663                break;
   8664          
   8665              case CMU_HFCLKLEPRESC_REG:
   8666                presc = CMU_DivToLog2(presc);
   8667                CMU->HFPRESC = (CMU->HFPRESC & ~_CMU_HFPRESC_HFCLKLEPRESC_MASK)
   8668                               | (presc << _CMU_HFPRESC_HFCLKLEPRESC_SHIFT);
   8669                break;
   8670          
   8671              case CMU_HFPERPRESC_REG:
   8672                EFM_ASSERT(presc < 512U);
   8673                CMU->HFPERPRESC = (CMU->HFPERPRESC & ~_CMU_HFPERPRESC_PRESC_MASK)
   8674                                  | (presc << _CMU_HFPERPRESC_PRESC_SHIFT);
   8675                break;
   8676          
   8677          #if defined(_CMU_HFPERPRESCB_MASK)
   8678              case CMU_HFPERPRESCB_REG:
   8679                EFM_ASSERT(presc < 512U);
   8680                CMU->HFPERPRESCB = (CMU->HFPERPRESCB & ~_CMU_HFPERPRESCB_PRESC_MASK)
   8681                                   | (presc << _CMU_HFPERPRESCB_PRESC_SHIFT);
   8682                break;
   8683          #endif
   8684          
   8685          #if defined(_CMU_HFPERPRESCC_MASK)
   8686              case CMU_HFPERPRESCC_REG:
   8687                EFM_ASSERT(presc < 512U);
   8688                CMU->HFPERPRESCC = (CMU->HFPERPRESCC & ~_CMU_HFPERPRESCC_PRESC_MASK)
   8689                                   | (presc << _CMU_HFPERPRESCC_PRESC_SHIFT);
   8690                break;
   8691          #endif
   8692          
   8693              case CMU_HFCOREPRESC_REG:
   8694                EFM_ASSERT(presc < 512U);
   8695          
   8696                /* Configure worst case wait-states for flash. */
   8697                flashWaitStateMax();
   8698          
   8699                CMU->HFCOREPRESC = (CMU->HFCOREPRESC & ~_CMU_HFCOREPRESC_PRESC_MASK)
   8700                                   | (presc << _CMU_HFCOREPRESC_PRESC_SHIFT);
   8701          
   8702                /* Update the CMSIS core clock variable (this function updates the global variable).
   8703                   Optimize flash and HFLE wait states. */
   8704                freq = SystemCoreClockGet();
   8705                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   8706                break;
   8707          
   8708              case CMU_LFAPRESC0_REG:
   8709                switch (clock) {
   8710          #if defined(RTC_PRESENT)
   8711                  case cmuClock_RTC:
   8712                    EFM_ASSERT(presc <= 32768U);
   8713          
   8714                    /* Convert the prescaler value to a DIV exponent scale. */
   8715                    presc = CMU_PrescToLog2(presc);
   8716          
   8717                    /* LF register about to be modified requires sync. Busy check. */
   8718                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8719          
   8720                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_RTC_MASK)
   8721                                     | (presc << _CMU_LFAPRESC0_RTC_SHIFT);
   8722                    break;
   8723          #endif
   8724          
   8725          #if defined(RTCC_PRESENT)
   8726                  case cmuClock_RTCC:
   8727          #if defined(_CMU_LFEPRESC0_RTCC_MASK)
   8728          #if defined(_CMU_LFEPRESC0_RTCC_DIV4)
   8729                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV4);
   8730          #elif defined(_CMU_LFEPRESC0_RTCC_DIV2)
   8731                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV2);
   8732          #else
   8733                    EFM_ASSERT(presc <= 0U);
   8734          #endif
   8735          
   8736                    /* LF register about to be modified requires sync. Busy check. */
   8737                    syncReg(CMU_SYNCBUSY_LFEPRESC0);
   8738          
   8739                    CMU->LFEPRESC0 = (CMU->LFEPRESC0 & ~_CMU_LFEPRESC0_RTCC_MASK)
   8740                                     | (presc << _CMU_LFEPRESC0_RTCC_SHIFT);
   8741          #else
   8742                    EFM_ASSERT(presc <= 32768U);
   8743          
   8744                    /* Convert the prescaler value to a DIV exponent scale. */
   8745                    presc = CMU_PrescToLog2(presc);
   8746          
   8747                    /* LF register about to be modified requires sync. Busy check. */
   8748                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8749          
   8750                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_RTCC_MASK)
   8751                                     | (presc << _CMU_LFAPRESC0_RTCC_SHIFT);
   8752          #endif
   8753                    break;
   8754          #endif
   8755          
   8756          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   8757                  case cmuClock_LETIMER0:
   8758                    EFM_ASSERT(presc <= 32768U);
   8759          
   8760                    /* Convert the prescaler value to a DIV exponent scale. */
   8761                    presc = CMU_PrescToLog2(presc);
   8762          
   8763                    /* LF register about to be modified requires sync. Busy check. */
   8764                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8765          
   8766                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LETIMER0_MASK)
   8767                                     | (presc << _CMU_LFAPRESC0_LETIMER0_SHIFT);
   8768                    break;
   8769          #endif
   8770          
   8771          #if defined(_CMU_LFAPRESC0_LETIMER1_MASK)
   8772                  case cmuClock_LETIMER1:
   8773                    EFM_ASSERT(presc <= 32768U);
   8774          
   8775                    /* Convert the prescaler value to a DIV exponent scale. */
   8776                    presc = CMU_PrescToLog2(presc);
   8777          
   8778                    /* LF register about to be modified requires sync. Busy check. */
   8779                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8780          
   8781                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LETIMER1_MASK)
   8782                                     | (presc << _CMU_LFAPRESC0_LETIMER1_SHIFT);
   8783                    break;
   8784          #endif
   8785          
   8786          #if defined(_CMU_LFAPRESC0_LESENSE_MASK)
   8787                  case cmuClock_LESENSE:
   8788                    EFM_ASSERT(presc <= 8U);
   8789          
   8790                    /* Convert the prescaler value to a DIV exponent scale. */
   8791                    presc = CMU_PrescToLog2(presc);
   8792          
   8793                    /* LF register about to be modified requires sync. Busy check. */
   8794                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8795          
   8796                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LESENSE_MASK)
   8797                                     | (presc << _CMU_LFAPRESC0_LESENSE_SHIFT);
   8798                    break;
   8799          #endif
   8800          
   8801          #if defined(_CMU_LFAPRESC0_LCD_MASK)
   8802                  case cmuClock_LCDpre:
   8803                  case cmuClock_LCD:
   8804                    EFM_ASSERT(presc <= 32768U);
   8805          
   8806                    /* Convert the prescaler value to a DIV exponent scale. */
   8807                    presc = CMU_PrescToLog2(presc);
   8808          
   8809                    /* LF register about to be modified requires sync. Busy check. */
   8810                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8811          
   8812                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LCD_MASK)
   8813                                     | (presc << _CMU_LFAPRESC0_LCD_SHIFT);
   8814                    break;
   8815          #endif
   8816          
   8817                  default:
   8818                    EFM_ASSERT(false);
   8819                    break;
   8820                }
   8821                break;
   8822          
   8823              case CMU_LFBPRESC0_REG:
   8824                switch (clock) {
   8825          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   8826                  case cmuClock_LEUART0:
   8827                    EFM_ASSERT(presc <= 8U);
   8828          
   8829                    /* Convert the prescaler value to a DIV exponent scale. */
   8830                    presc = CMU_PrescToLog2(presc);
   8831          
   8832                    /* LF register about to be modified requires sync. Busy check. */
   8833                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   8834          
   8835                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART0_MASK)
   8836                                     | (presc << _CMU_LFBPRESC0_LEUART0_SHIFT);
   8837                    break;
   8838          #endif
   8839          
   8840          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   8841                  case cmuClock_LEUART1:
   8842                    EFM_ASSERT(presc <= 8U);
   8843          
   8844                    /* Convert the prescaler value to a DIV exponent scale. */
   8845                    presc = CMU_PrescToLog2(presc);
   8846          
   8847                    /* LF register about to be modified requires sync. Busy check. */
   8848                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   8849          
   8850                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART1_MASK)
   8851                                     | (presc << _CMU_LFBPRESC0_LEUART1_SHIFT);
   8852                    break;
   8853          #endif
   8854          
   8855          #if defined(_CMU_LFBPRESC0_CSEN_MASK)
   8856                  case cmuClock_CSEN_LF:
   8857                    EFM_ASSERT((presc <= 127U) && (presc >= 15U));
   8858          
   8859                    /* Convert the prescaler value to a DIV exponent scale.
   8860                     * DIV16 is the lowest supported prescaler. */
   8861                    presc = CMU_PrescToLog2(presc) - 4U;
   8862          
   8863                    /* LF register about to be modified requires sync. Busy check. */
   8864                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   8865          
   8866                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_CSEN_MASK)
   8867                                     | (presc << _CMU_LFBPRESC0_CSEN_SHIFT);
   8868                    break;
   8869          #endif
   8870          
   8871                  default:
   8872                    EFM_ASSERT(false);
   8873                    break;
   8874                }
   8875                break;
   8876          
   8877              case CMU_LFEPRESC0_REG:
   8878                switch (clock) {
   8879          #if defined(_CMU_LFEPRESC0_RTCC_MASK)
   8880                  case cmuClock_RTCC:
   8881          #if defined(_CMU_LFEPRESC0_RTCC_DIV4)
   8882                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV4);
   8883          #elif defined(_CMU_LFEPRESC0_RTCC_DIV2)
   8884                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV2);
   8885          #else
   8886                    EFM_ASSERT(presc <= 0U);
   8887          #endif
   8888          
   8889                    /* LF register about to be modified requires sync. Busy check. */
   8890                    syncReg(CMU_SYNCBUSY_LFEPRESC0);
   8891          
   8892                    CMU->LFEPRESC0 = (CMU->LFEPRESC0 & ~_CMU_LFEPRESC0_RTCC_MASK)
   8893                                     | (presc << _CMU_LFEPRESC0_RTCC_SHIFT);
   8894                    break;
   8895          #endif
   8896          
   8897                  default:
   8898                    EFM_ASSERT(false);
   8899                    break;
   8900                }
   8901                break;
   8902          
   8903          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK) \
   8904                ||  defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8905              case CMU_ADCASYNCDIV_REG:
   8906                switch (clock) {
   8907          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8908                  case cmuClock_ADC0ASYNC:
   8909                    EFM_ASSERT(presc <= 3);
   8910                    CMU->ADCCTRL = (CMU->ADCCTRL & ~_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8911                                   | (presc << _CMU_ADCCTRL_ADC0CLKDIV_SHIFT);
   8912                    break;
   8913          #endif
   8914          
   8915          #if defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8916                  case cmuClock_ADC1ASYNC:
   8917                    EFM_ASSERT(presc <= 3);
   8918                    CMU->ADCCTRL = (CMU->ADCCTRL & ~_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8919                                   | (presc << _CMU_ADCCTRL_ADC1CLKDIV_SHIFT);
   8920                    break;
   8921          #endif
   8922                  default:
   8923                    EFM_ASSERT(false);
   8924                    break;
   8925                }
   8926                break;
   8927          #endif
   8928          
   8929          #if defined(_CMU_HFBUSPRESC_MASK)
   8930              case CMU_HFBUSPRESC_REG:
   8931                EFM_ASSERT(presc <= _CMU_HFBUSPRESC_MASK >> _CMU_HFBUSPRESC_PRESC_SHIFT);
   8932                CMU->HFBUSPRESC = (CMU->HFBUSPRESC & ~_CMU_HFBUSPRESC_MASK)
   8933                                  | (presc << _CMU_HFBUSPRESC_PRESC_SHIFT);
   8934                break;
   8935          #endif
   8936          
   8937              default:
   8938                EFM_ASSERT(false);
   8939                break;
   8940            }
   8941          }
   8942          #endif
   8943          
   8944          /***************************************************************************//**
   8945           * @brief
   8946           *   Get the currently selected reference clock used for a clock branch.
   8947           *
   8948           * @param[in] clock
   8949           *   Clock branch to fetch selected ref. clock for. One of:
   8950           *   @li #cmuClock_HF
   8951           *   @li #cmuClock_LFA
   8952           *   @li #cmuClock_LFB @if _CMU_LFCLKSEL_LFAE_ULFRCO
   8953           *   @li #cmuClock_LFC
   8954           *   @endif            @if _SILICON_LABS_32B_SERIES_1
   8955           *   @li #cmuClock_LFE
   8956           *   @endif
   8957           *   @li #cmuClock_DBG @if DOXYDOC_USB_PRESENT
   8958           *   @li #cmuClock_USBC
   8959           *   @endif
   8960           *
   8961           * @return
   8962           *   The reference clock used for clocking the selected branch, #cmuSelect_Error if
   8963           *   invalid @p clock provided.
   8964           ******************************************************************************/
   8965          CMU_Select_TypeDef CMU_ClockSelectGet(CMU_Clock_TypeDef clock)
   8966          {
   8967            CMU_Select_TypeDef ret = cmuSelect_Disabled;
   8968            uint32_t selReg;
   8969          
   8970            selReg = ((unsigned)clock >> CMU_SEL_REG_POS) & CMU_SEL_REG_MASK;
   8971          
   8972            switch (selReg) {
   8973              case CMU_HFCLKSEL_REG:
   8974          #if defined(_CMU_HFCLKSTATUS_MASK)
   8975                switch (CMU->HFCLKSTATUS & _CMU_HFCLKSTATUS_SELECTED_MASK) {
   8976                  case CMU_HFCLKSTATUS_SELECTED_LFXO:
   8977                    ret = cmuSelect_LFXO;
   8978                    break;
   8979          
   8980                  case CMU_HFCLKSTATUS_SELECTED_LFRCO:
   8981                    ret = cmuSelect_LFRCO;
   8982                    break;
   8983          
   8984                  case CMU_HFCLKSTATUS_SELECTED_HFXO:
   8985                    ret = cmuSelect_HFXO;
   8986                    break;
   8987          
   8988          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
   8989                  case CMU_HFCLKSTATUS_SELECTED_HFRCODIV2:
   8990                    ret = cmuSelect_HFRCODIV2;
   8991                    break;
   8992          #endif
   8993          
   8994          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
   8995                  case CMU_HFCLKSTATUS_SELECTED_CLKIN0:
   8996                    ret = cmuSelect_CLKIN0;
   8997                    break;
   8998          #endif
   8999          
   9000          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
   9001                  case CMU_HFCLKSTATUS_SELECTED_USHFRCO:
   9002                    ret = cmuSelect_USHFRCO;
   9003                    break;
   9004          #endif
   9005          
   9006                  default:
   9007                    ret = cmuSelect_HFRCO;
   9008                    break;
   9009                }
   9010          #else
   9011                switch (CMU->STATUS
   9012                        & (CMU_STATUS_HFRCOSEL
   9013                           | CMU_STATUS_HFXOSEL
   9014                           | CMU_STATUS_LFRCOSEL
   9015          #if defined(CMU_STATUS_USHFRCODIV2SEL)
   9016                           | CMU_STATUS_USHFRCODIV2SEL
   9017          #endif
   9018                           | CMU_STATUS_LFXOSEL)) {
   9019                  case CMU_STATUS_LFXOSEL:
   9020                    ret = cmuSelect_LFXO;
   9021                    break;
   9022          
   9023                  case CMU_STATUS_LFRCOSEL:
   9024                    ret = cmuSelect_LFRCO;
   9025                    break;
   9026          
   9027                  case CMU_STATUS_HFXOSEL:
   9028                    ret = cmuSelect_HFXO;
   9029                    break;
   9030          
   9031          #if defined(CMU_STATUS_USHFRCODIV2SEL)
   9032                  case CMU_STATUS_USHFRCODIV2SEL:
   9033                    ret = cmuSelect_USHFRCODIV2;
   9034                    break;
   9035          #endif
   9036          
   9037                  default:
   9038                    ret = cmuSelect_HFRCO;
   9039                    break;
   9040                }
   9041          #endif
   9042                break;
   9043          
   9044          #if defined(_CMU_LFCLKSEL_MASK) || defined(_CMU_LFACLKSEL_MASK)
   9045              case CMU_LFACLKSEL_REG:
   9046          #if defined(_CMU_LFCLKSEL_MASK)
   9047                switch (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFA_MASK) {
   9048                  case CMU_LFCLKSEL_LFA_LFRCO:
   9049                    ret = cmuSelect_LFRCO;
   9050                    break;
   9051          
   9052                  case CMU_LFCLKSEL_LFA_LFXO:
   9053                    ret = cmuSelect_LFXO;
   9054                    break;
   9055          
   9056          #if defined(CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2)
   9057                  case CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2:
   9058                    ret = cmuSelect_HFCLKLE;
   9059                    break;
   9060          #endif
   9061          
   9062                  default:
   9063          #if defined(CMU_LFCLKSEL_LFAE)
   9064                    if (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFAE_MASK) {
   9065                      ret = cmuSelect_ULFRCO;
   9066                      break;
   9067                    }
   9068          #else
   9069                    ret = cmuSelect_Disabled;
   9070          #endif
   9071                    break;
   9072                }
   9073          
   9074          #elif defined(_CMU_LFACLKSEL_MASK)
   9075                switch (CMU->LFACLKSEL & _CMU_LFACLKSEL_LFA_MASK) {
   9076                  case CMU_LFACLKSEL_LFA_LFRCO:
   9077                    ret = cmuSelect_LFRCO;
   9078                    break;
   9079          
   9080                  case CMU_LFACLKSEL_LFA_LFXO:
   9081                    ret = cmuSelect_LFXO;
   9082                    break;
   9083          
   9084                  case CMU_LFACLKSEL_LFA_ULFRCO:
   9085                    ret = cmuSelect_ULFRCO;
   9086                    break;
   9087          
   9088          #if defined(PLFRCO_PRESENT)
   9089                  case CMU_LFACLKSEL_LFA_PLFRCO:
   9090                    ret = cmuSelect_PLFRCO;
   9091                    break;
   9092          #endif
   9093          
   9094                  default:
   9095                    ret = cmuSelect_Disabled;
   9096                    break;
   9097                }
   9098          #endif
   9099                break;
   9100          #endif /* _CMU_LFCLKSEL_MASK || _CMU_LFACLKSEL_MASK */
   9101          
   9102          #if defined(_CMU_LFCLKSEL_MASK) || defined(_CMU_LFBCLKSEL_MASK)
   9103              case CMU_LFBCLKSEL_REG:
   9104          #if defined(_CMU_LFCLKSEL_MASK)
   9105                switch (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFB_MASK) {
   9106                  case CMU_LFCLKSEL_LFB_LFRCO:
   9107                    ret = cmuSelect_LFRCO;
   9108                    break;
   9109          
   9110                  case CMU_LFCLKSEL_LFB_LFXO:
   9111                    ret = cmuSelect_LFXO;
   9112                    break;
   9113          
   9114          #if defined(CMU_LFCLKSEL_LFB_HFCORECLKLEDIV2)
   9115                  case CMU_LFCLKSEL_LFB_HFCORECLKLEDIV2:
   9116                    ret = cmuSelect_HFCLKLE;
   9117                    break;
   9118          #endif
   9119          
   9120          #if defined(CMU_LFCLKSEL_LFB_HFCLKLE)
   9121                  case CMU_LFCLKSEL_LFB_HFCLKLE:
   9122                    ret = cmuSelect_HFCLKLE;
   9123                    break;
   9124          #endif
   9125          
   9126                  default:
   9127          #if defined(CMU_LFCLKSEL_LFBE)
   9128                    if (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFBE_MASK) {
   9129                      ret = cmuSelect_ULFRCO;
   9130                      break;
   9131                    }
   9132          #else
   9133                    ret = cmuSelect_Disabled;
   9134          #endif
   9135                    break;
   9136                }
   9137          
   9138          #elif defined(_CMU_LFBCLKSEL_MASK)
   9139                switch (CMU->LFBCLKSEL & _CMU_LFBCLKSEL_LFB_MASK) {
   9140                  case CMU_LFBCLKSEL_LFB_LFRCO:
   9141                    ret = cmuSelect_LFRCO;
   9142                    break;
   9143          
   9144                  case CMU_LFBCLKSEL_LFB_LFXO:
   9145                    ret = cmuSelect_LFXO;
   9146                    break;
   9147          
   9148                  case CMU_LFBCLKSEL_LFB_ULFRCO:
   9149                    ret = cmuSelect_ULFRCO;
   9150                    break;
   9151          
   9152                  case CMU_LFBCLKSEL_LFB_HFCLKLE:
   9153                    ret = cmuSelect_HFCLKLE;
   9154                    break;
   9155          
   9156          #if defined(PLFRCO_PRESENT)
   9157                  case CMU_LFBCLKSEL_LFB_PLFRCO:
   9158                    ret = cmuSelect_PLFRCO;
   9159                    break;
   9160          #endif
   9161          
   9162                  default:
   9163                    ret = cmuSelect_Disabled;
   9164                    break;
   9165                }
   9166          #endif
   9167                break;
   9168          #endif /* _CMU_LFCLKSEL_MASK || _CMU_LFBCLKSEL_MASK */
   9169          
   9170          #if defined(_CMU_LFCLKSEL_LFC_MASK)
   9171              case CMU_LFCCLKSEL_REG:
   9172                switch (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFC_MASK) {
   9173                  case CMU_LFCLKSEL_LFC_LFRCO:
   9174                    ret = cmuSelect_LFRCO;
   9175                    break;
   9176          
   9177                  case CMU_LFCLKSEL_LFC_LFXO:
   9178                    ret = cmuSelect_LFXO;
   9179                    break;
   9180          
   9181                  default:
   9182                    ret = cmuSelect_Disabled;
   9183                    break;
   9184                }
   9185                break;
   9186          #endif
   9187          
   9188          #if defined(_CMU_LFECLKSEL_LFE_MASK)
   9189              case CMU_LFECLKSEL_REG:
   9190                switch (CMU->LFECLKSEL & _CMU_LFECLKSEL_LFE_MASK) {
   9191                  case CMU_LFECLKSEL_LFE_LFRCO:
   9192                    ret = cmuSelect_LFRCO;
   9193                    break;
   9194          
   9195                  case CMU_LFECLKSEL_LFE_LFXO:
   9196                    ret = cmuSelect_LFXO;
   9197                    break;
   9198          
   9199                  case CMU_LFECLKSEL_LFE_ULFRCO:
   9200                    ret = cmuSelect_ULFRCO;
   9201                    break;
   9202          
   9203          #if defined(PLFRCO_PRESENT)
   9204                  case CMU_LFECLKSEL_LFE_PLFRCO:
   9205                    ret = cmuSelect_PLFRCO;
   9206                    break;
   9207          #endif
   9208          
   9209                  default:
   9210                    ret = cmuSelect_Disabled;
   9211                    break;
   9212                }
   9213                break;
   9214          #endif /* CMU_LFECLKSEL_REG */
   9215          
   9216          #if defined(_CMU_LFCCLKSEL_LFC_MASK)
   9217              case CMU_LFCCLKSEL_REG:
   9218                switch (CMU->LFCCLKSEL & _CMU_LFCCLKSEL_LFC_MASK) {
   9219                  case CMU_LFCCLKSEL_LFC_LFRCO:
   9220                    ret = cmuSelect_LFRCO;
   9221                    break;
   9222          
   9223                  case CMU_LFCCLKSEL_LFC_LFXO:
   9224                    ret = cmuSelect_LFXO;
   9225                    break;
   9226          
   9227                  case CMU_LFCCLKSEL_LFC_ULFRCO:
   9228                    ret = cmuSelect_ULFRCO;
   9229                    break;
   9230          
   9231                  default:
   9232                    ret = cmuSelect_Disabled;
   9233                    break;
   9234                }
   9235                break;
   9236          #endif /* CMU_LFCCLKSEL_REG */
   9237          
   9238              case CMU_DBGCLKSEL_REG:
   9239          #if defined(_CMU_DBGCLKSEL_DBG_MASK)
   9240                switch (CMU->DBGCLKSEL & _CMU_DBGCLKSEL_DBG_MASK) {
   9241                  case CMU_DBGCLKSEL_DBG_HFCLK:
   9242                    ret = cmuSelect_HFCLK;
   9243                    break;
   9244          
   9245                  case CMU_DBGCLKSEL_DBG_AUXHFRCO:
   9246                    ret = cmuSelect_AUXHFRCO;
   9247                    break;
   9248          
   9249                  default:
   9250                    ret = cmuSelect_Disabled;
   9251                    break;
   9252                }
   9253          
   9254          #elif defined(_CMU_CTRL_DBGCLK_MASK)
   9255                switch (CMU->CTRL & _CMU_CTRL_DBGCLK_MASK) {
   9256                  case CMU_CTRL_DBGCLK_AUXHFRCO:
   9257                    ret = cmuSelect_AUXHFRCO;
   9258                    break;
   9259          
   9260                  case CMU_CTRL_DBGCLK_HFCLK:
   9261                    ret = cmuSelect_HFCLK;
   9262                    break;
   9263                }
   9264          #else
   9265                ret = cmuSelect_AUXHFRCO;
   9266          #endif
   9267                break;
   9268          
   9269          #if defined(USBC_CLOCK_PRESENT)
   9270              case CMU_USBCCLKSEL_REG:
   9271                switch (CMU->STATUS
   9272                        & (CMU_STATUS_USBCLFXOSEL
   9273          #if defined(_CMU_STATUS_USBCHFCLKSEL_MASK)
   9274                           | CMU_STATUS_USBCHFCLKSEL
   9275          #endif
   9276          #if defined(_CMU_STATUS_USBCUSHFRCOSEL_MASK)
   9277                           | CMU_STATUS_USBCUSHFRCOSEL
   9278          #endif
   9279                           | CMU_STATUS_USBCLFRCOSEL)) {
   9280          #if defined(_CMU_STATUS_USBCHFCLKSEL_MASK)
   9281                  case CMU_STATUS_USBCHFCLKSEL:
   9282                    ret = cmuSelect_HFCLK;
   9283                    break;
   9284          #endif
   9285          
   9286          #if defined(_CMU_STATUS_USBCUSHFRCOSEL_MASK)
   9287                  case CMU_STATUS_USBCUSHFRCOSEL:
   9288                    ret = cmuSelect_USHFRCO;
   9289                    break;
   9290          #endif
   9291          
   9292                  case CMU_STATUS_USBCLFXOSEL:
   9293                    ret = cmuSelect_LFXO;
   9294                    break;
   9295          
   9296                  case CMU_STATUS_USBCLFRCOSEL:
   9297                    ret = cmuSelect_LFRCO;
   9298                    break;
   9299          
   9300                  default:
   9301                    ret = cmuSelect_Disabled;
   9302                    break;
   9303                }
   9304                break;
   9305          #endif
   9306          
   9307          #if defined(_CMU_ADCCTRL_ADC0CLKSEL_MASK)
   9308              case CMU_ADC0ASYNCSEL_REG:
   9309                switch (CMU->ADCCTRL & _CMU_ADCCTRL_ADC0CLKSEL_MASK) {
   9310                  case CMU_ADCCTRL_ADC0CLKSEL_DISABLED:
   9311                    ret = cmuSelect_Disabled;
   9312                    break;
   9313          
   9314                  case CMU_ADCCTRL_ADC0CLKSEL_AUXHFRCO:
   9315                    ret = cmuSelect_AUXHFRCO;
   9316                    break;
   9317          
   9318                  case CMU_ADCCTRL_ADC0CLKSEL_HFXO:
   9319                    ret = cmuSelect_HFXO;
   9320                    break;
   9321          
   9322                  case CMU_ADCCTRL_ADC0CLKSEL_HFSRCCLK:
   9323                    ret = cmuSelect_HFSRCCLK;
   9324                    break;
   9325          
   9326                  default:
   9327                    ret = cmuSelect_Disabled;
   9328                    break;
   9329                }
   9330                break;
   9331          #endif
   9332          
   9333          #if defined(_CMU_ADCCTRL_ADC1CLKSEL_MASK)
   9334              case CMU_ADC1ASYNCSEL_REG:
   9335                switch (CMU->ADCCTRL & _CMU_ADCCTRL_ADC1CLKSEL_MASK) {
   9336                  case CMU_ADCCTRL_ADC1CLKSEL_DISABLED:
   9337                    ret = cmuSelect_Disabled;
   9338                    break;
   9339          
   9340                  case CMU_ADCCTRL_ADC1CLKSEL_AUXHFRCO:
   9341                    ret = cmuSelect_AUXHFRCO;
   9342                    break;
   9343          
   9344                  case CMU_ADCCTRL_ADC1CLKSEL_HFXO:
   9345                    ret = cmuSelect_HFXO;
   9346                    break;
   9347          
   9348                  case CMU_ADCCTRL_ADC1CLKSEL_HFSRCCLK:
   9349                    ret = cmuSelect_HFSRCCLK;
   9350                    break;
   9351                }
   9352                break;
   9353          #endif
   9354          
   9355          #if defined(_CMU_SDIOCTRL_SDIOCLKSEL_MASK)
   9356              case CMU_SDIOREFSEL_REG:
   9357                switch (CMU->SDIOCTRL & _CMU_SDIOCTRL_SDIOCLKSEL_MASK) {
   9358                  case CMU_SDIOCTRL_SDIOCLKSEL_HFRCO:
   9359                    ret = cmuSelect_HFRCO;
   9360                    break;
   9361          
   9362                  case CMU_SDIOCTRL_SDIOCLKSEL_HFXO:
   9363                    ret = cmuSelect_HFXO;
   9364                    break;
   9365          
   9366                  case CMU_SDIOCTRL_SDIOCLKSEL_AUXHFRCO:
   9367                    ret = cmuSelect_AUXHFRCO;
   9368                    break;
   9369          
   9370                  case CMU_SDIOCTRL_SDIOCLKSEL_USHFRCO:
   9371                    ret = cmuSelect_USHFRCO;
   9372                    break;
   9373                }
   9374                break;
   9375          #endif
   9376          
   9377          #if defined(_CMU_QSPICTRL_QSPI0CLKSEL_MASK)
   9378              case CMU_QSPI0REFSEL_REG:
   9379                switch (CMU->QSPICTRL & _CMU_QSPICTRL_QSPI0CLKSEL_MASK) {
   9380                  case CMU_QSPICTRL_QSPI0CLKSEL_HFRCO:
   9381                    ret = cmuSelect_HFRCO;
   9382                    break;
   9383          
   9384                  case CMU_QSPICTRL_QSPI0CLKSEL_HFXO:
   9385                    ret = cmuSelect_HFXO;
   9386                    break;
   9387          
   9388                  case CMU_QSPICTRL_QSPI0CLKSEL_AUXHFRCO:
   9389                    ret = cmuSelect_AUXHFRCO;
   9390                    break;
   9391          
   9392                  case CMU_QSPICTRL_QSPI0CLKSEL_USHFRCO:
   9393                    ret = cmuSelect_USHFRCO;
   9394                    break;
   9395                }
   9396                break;
   9397          #endif
   9398          
   9399          #if defined(_CMU_USBCTRL_USBCLKSEL_MASK)
   9400              case CMU_USBRCLKSEL_REG:
   9401                switch (CMU->USBCTRL & _CMU_USBCTRL_USBCLKSEL_MASK) {
   9402                  case CMU_USBCTRL_USBCLKSEL_USHFRCO:
   9403                    ret = cmuSelect_USHFRCO;
   9404                    break;
   9405          
   9406                  case CMU_USBCTRL_USBCLKSEL_HFXO:
   9407                    ret = cmuSelect_HFXO;
   9408                    break;
   9409          
   9410                  case CMU_USBCTRL_USBCLKSEL_HFXOX2:
   9411                    ret = cmuSelect_HFXOX2;
   9412                    break;
   9413          
   9414                  case CMU_USBCTRL_USBCLKSEL_HFRCO:
   9415                    ret = cmuSelect_HFRCO;
   9416                    break;
   9417          
   9418                  case CMU_USBCTRL_USBCLKSEL_LFXO:
   9419                    ret = cmuSelect_LFXO;
   9420                    break;
   9421          
   9422                  case CMU_USBCTRL_USBCLKSEL_LFRCO:
   9423                    ret = cmuSelect_LFRCO;
   9424                    break;
   9425                }
   9426                break;
   9427          #endif
   9428          
   9429          #if defined(_CMU_PDMCTRL_PDMCLKSEL_MASK)
   9430              case CMU_PDMREFSEL_REG:
   9431                switch (CMU->PDMCTRL & _CMU_PDMCTRL_PDMCLKSEL_MASK) {
   9432                  case CMU_PDMCTRL_PDMCLKSEL_USHFRCO:
   9433                    ret = cmuSelect_USHFRCO;
   9434                    break;
   9435          
   9436                  case CMU_PDMCTRL_PDMCLKSEL_HFXO:
   9437                    ret = cmuSelect_HFXO;
   9438                    break;
   9439          
   9440                  case CMU_PDMCTRL_PDMCLKSEL_HFRCO:
   9441                    ret = cmuSelect_HFRCO;
   9442                    break;
   9443                }
   9444                break;
   9445          #endif
   9446          
   9447              default:
   9448                ret = cmuSelect_Error;
   9449                EFM_ASSERT(false);
   9450                break;
   9451            }
   9452          
   9453            return ret;
   9454          }
