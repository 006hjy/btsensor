   5637          #if defined(_CMU_CANCLKCTRL_MASK)
   5638          /***************************************************************************//**
   5639           * @brief
   5640           *   Get selected oscillator and frequency for @ref cmuClock_CANCLK
   5641           *   clock tree.
   5642           *
   5643           * @param[out] freq
   5644           *   The frequency.
   5645           *
   5646           * @param[out] sel
   5647           *   The selected oscillator.
   5648           ******************************************************************************/
   5649          static void can0ClkGet(uint32_t *freq, CMU_Select_TypeDef *sel)
   5650          {
   5651            uint32_t f = 0U;
   5652            CMU_Select_TypeDef s = cmuSelect_Error;
   5653          
   5654            switch (CMU->CANCLKCTRL & _CMU_CANCLKCTRL_CLKSEL_MASK) {
   5655              case CMU_CANCLKCTRL_CLKSEL_HFRCODPLL:
   5656                f = SystemHFRCODPLLClockGet();
   5657                s = cmuSelect_HFRCODPLL;
   5658                break;
   5659              case CMU_CANCLKCTRL_CLKSEL_HFXO:
   5660                f = SystemHFXOClockGet();
   5661                s = cmuSelect_HFXO;
   5662                break;
   5663              case CMU_CANCLKCTRL_CLKSEL_CLKIN0:
   5664                f = SystemCLKIN0Get();
   5665                s = cmuSelect_CLKIN0;
   5666                break;
   5667              default:
   5668                s = cmuSelect_Error;
   5669                break;
   5670            }
   5671            f = f / CMU_ClockDivGet(cmuClock_CANCLK);
   5672          
   5673            if (freq != NULL) {
   5674              *freq = f;
   5675            }
   5676            if (sel != NULL) {
   5677              *sel = s;
   5678            }
   5679          }
   5680          #endif
   5681          
