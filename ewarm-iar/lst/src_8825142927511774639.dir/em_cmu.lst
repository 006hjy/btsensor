   4116          /***************************************************************************//**
   4117           * @brief
   4118           *   Configure wait state settings necessary to switch to a given core clock
   4119           *   frequency at a certain voltage scale level.
   4120           *
   4121           * @details
   4122           *   This function will set up the necessary flash wait states. Updating the
   4123           *   wait state configuration must be done before increasing the clock
   4124           *   frequency and it must be done after decreasing the clock frequency.
   4125           *   Updating the wait state configuration must be done before core voltage is
   4126           *   decreased and it must be done after a core voltage is increased.
   4127           *
   4128           * @param[in] freq
   4129           *   The core clock frequency to configure wait-states.
   4130           *
   4131           * @param[in] vscale
   4132           *   The voltage scale to configure wait-states. Expected values are
   4133           *   0 or 1, higher number is lower voltage.
   4134           *   @li 0 = 1.1 V (VSCALE2)
   4135           *   @li 1 = 1.0 V (VSCALE1)
   4136           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
   4137          void CMU_UpdateWaitStates(uint32_t freq, int vscale)
   4138          {
   4139            if (vscale > 0) {
   \                     CMU_UpdateWaitStates: (+1)
   \        0x0   0x2900             CMP      R1,#+0
   \        0x2   0xBFCC             ITE      GT
   \        0x4   0x2101             MOVGT    R1,#+1
   \        0x6   0x2100             MOVLE    R1,#+0
   4140              flashWaitStateControl(freq, VSCALE_EM01_LOW_POWER);
   4141            } else {
   4142              flashWaitStateControl(freq, VSCALE_EM01_HIGH_PERFORMANCE);
   \        0x8   0x....             B.N      flashWaitStateControl
   4143            }
   4144          }
