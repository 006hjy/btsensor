   6567          /***************************************************************************//**
   6568           * @brief
   6569           *   Configure flash access wait states to support the given core clock
   6570           *   frequency.
   6571           *
   6572           * @param[in] coreFreq
   6573           *   The core clock frequency to configure flash wait-states.
   6574           *
   6575           * @param[in] vscale
   6576           *   Voltage Scale level. Supported levels are 0 and 2 where 0 is the default.
   6577           ******************************************************************************/
   6578          static void flashWaitStateControl(uint32_t coreFreq, int vscale)
   6579          {
   6580            uint32_t mode;
   6581          #if defined(MSC_READCTRL_MODE_WS0SCBTP)
   6582            bool scbtpEn;   /* Suppressed Conditional Branch Target Prefetch setting. */
   6583          #endif
   6584            (void) vscale;  /* vscale parameter is only used on some devices. */
   6585          
   6586            /* Get mode and SCBTP enable. */
   6587            mode = MSC_ReadCTRLGet() & _MSC_READCTRL_MODE_MASK;
   6588          
   6589          #if defined(_SILICON_LABS_32B_SERIES_0)
   6590          #if defined(MSC_READCTRL_MODE_WS0SCBTP)
   6591            /* Devices with MODE and SCBTP in the same register field. */
   6592            switch (mode) {
   6593              case MSC_READCTRL_MODE_WS0:
   6594              case MSC_READCTRL_MODE_WS1:
   6595          #if defined(MSC_READCTRL_MODE_WS2)
   6596              case MSC_READCTRL_MODE_WS2:
   6597          #endif
   6598                scbtpEn = false;
   6599                break;
   6600          
   6601              default: /* WSxSCBTP */
   6602                scbtpEn = true;
   6603                break;
   6604            }
   6605          
   6606            /* Set mode based on the core clock frequency and SCBTP enable. */
   6607            if (false) {
   6608              // Intentional no-op for structure.
   6609            }
   6610          #if defined(MSC_READCTRL_MODE_WS2)
   6611            else if (coreFreq > CMU_MAX_FREQ_1WS) {
   6612              mode = (scbtpEn ? MSC_READCTRL_MODE_WS2SCBTP : MSC_READCTRL_MODE_WS2);
   6613            }
   6614          #endif
   6615            else if ((coreFreq <= CMU_MAX_FREQ_1WS) && (coreFreq > CMU_MAX_FREQ_0WS)) {
   6616              mode = (scbtpEn ? MSC_READCTRL_MODE_WS1SCBTP : MSC_READCTRL_MODE_WS1);
   6617            } else {
   6618              mode = (scbtpEn ? MSC_READCTRL_MODE_WS0SCBTP : MSC_READCTRL_MODE_WS0);
   6619            }
   6620          #else /* defined(MSC_READCTRL_MODE_WS0SCBTP) */
   6621          
   6622            if (coreFreq <= CMU_MAX_FREQ_0WS) {
   6623              mode = 0;
   6624            } else if (coreFreq <= CMU_MAX_FREQ_1WS) {
   6625              mode = 1;
   6626            }
   6627          #endif /* defined(MSC_READCTRL_MODE_WS0SCBTP) */
   6628          // End defined(_SILICON_LABS_32B_SERIES_0)
   6629          
   6630          #elif defined(_SILICON_LABS_32B_SERIES_1)
   6631          #if defined(_EMU_STATUS_VSCALE_MASK)
   6632          
   6633            /* These devices have specific requirements on the supported flash wait state
   6634             * depending on the frequency and voltage scale level. */
   6635            uint32_t i;
   6636            for (i = 0; i < FLASH_WS_TABLE_ENTRIES; i++) {
   6637              if ((flashWsTable[i].vscale == (uint8_t)vscale)
   6638                  && (coreFreq <= flashWsTable[i].maxFreq)) {
   6639                break; // Found a matching entry.
   6640              }
   6641            }
   6642          
   6643            if (i == FLASH_WS_TABLE_ENTRIES) {
   6644              mode = 3; // Worst case flash wait state for unsupported cases.
   6645              EFM_ASSERT(false);
   6646            } else {
   6647              mode = flashWsTable[i].ws;
   6648            }
   6649            mode = mode << _MSC_READCTRL_MODE_SHIFT;
   6650          
   6651          #else
   6652            /* Devices where MODE and SCBTP are in separate fields and where the device
   6653             * either does not support voltage scale or where the voltage scale does
   6654             * not impact the flash wait state configuration. */
   6655            if (coreFreq <= CMU_MAX_FREQ_0WS_1V2) {
   6656              mode = 0;
   6657            } else if (coreFreq <= CMU_MAX_FREQ_1WS_1V2) {
   6658              mode = 1;
   6659            }
   6660          #if defined(MSC_READCTRL_MODE_WS2)
   6661            else if (coreFreq <= CMU_MAX_FREQ_2WS) {
   6662              mode = 2;
   6663            }
   6664          #endif
   6665          #if defined(MSC_READCTRL_MODE_WS3)
   6666            else if (coreFreq <= CMU_MAX_FREQ_3WS) {
   6667              mode = 3;
   6668            }
   6669          #endif
   6670            mode = mode << _MSC_READCTRL_MODE_SHIFT;
   6671          #endif
   6672          // End defined(_SILICON_LABS_32B_SERIES_1)
   6673          
   6674          #else
   6675          #error "Undefined 32B SERIES!"
   6676          #endif
   6677          
   6678            mode = (MSC_ReadCTRLGet() & ~_MSC_READCTRL_MODE_MASK) | mode;
   6679            MSC_ReadCTRLSet(mode);
   6680          }
   6681          
   6682          /***************************************************************************//**
   6683           * @brief
   6684           *   Configure flash access wait states to the most conservative setting for
   6685           *   this target. Retain SCBTP (Suppressed Conditional Branch Target Prefetch)
   6686           *   setting.
   6687           ******************************************************************************/
   6688          static void flashWaitStateMax(void)
   6689          {
   6690            /* Make sure the MSC is unlocked */
   6691            bool mscLocked = MSC_LockGetLocked();
   6692            MSC_LockSetUnlocked();
   6693          
   6694            flashWaitStateControl(SystemMaxCoreClockGet(), 0);
   6695          
   6696            if (mscLocked) {
   6697              MSC_LockSetLocked();
   6698            }
   6699          }
   6700          
   6701          #if defined(_MSC_RAMCTRL_RAMWSEN_MASK)
   6702          /***************************************************************************//**
   6703           * @brief
   6704           *   Configure RAM access wait states to support the given core clock
   6705           *   frequency.
   6706           *
   6707           * @param[in] coreFreq
   6708           *   The core clock frequency to configure RAM wait-states.
   6709           *
   6710           * @param[in] vscale
   6711           *   A voltage scale level. Supported levels are 0 and 2 where 0 is the default.
   6712           ******************************************************************************/
   6713          static void setRamWaitState(uint32_t coreFreq, int vscale)
   6714          {
   6715            uint32_t limit = 38000000;
   6716            if (vscale == 2) {
   6717              limit = 16000000;
   6718            }
   6719          
   6720            if (coreFreq > limit) {
   6721              BUS_RegMaskedSet(&MSC->RAMCTRL, (MSC_RAMCTRL_RAMWSEN
   6722                                               | MSC_RAMCTRL_RAM1WSEN
   6723                                               | MSC_RAMCTRL_RAM2WSEN));
   6724            } else {
   6725              BUS_RegMaskedClear(&MSC->RAMCTRL, (MSC_RAMCTRL_RAMWSEN
   6726                                                 | MSC_RAMCTRL_RAM1WSEN
   6727                                                 | MSC_RAMCTRL_RAM2WSEN));
   6728            }
   6729          }
   6730          #endif
   6731          
   6732          #if defined(_MSC_CTRL_WAITMODE_MASK)
   6733          /***************************************************************************//**
   6734           * @brief
   6735           *   Configure the wait state for peripheral accesses over the bus to support
   6736           *   the given bus clock frequency.
   6737           *
   6738           * @param[in] busFreq
   6739           *   A peripheral bus clock frequency to configure wait-states.
   6740           *
   6741           * @param[in] vscale
   6742           *   The voltage scale to configure wait-states. Expected values are
   6743           *   0 or 2.
   6744           *
   6745           *   @li 0 = 1.2 V (VSCALE2)
   6746           *   @li 2 = 1.0 V (VSCALE0)
   6747           * ******************************************************************************/
   6748          static void setBusWaitState(uint32_t busFreq, int vscale)
   6749          {
   6750            if ((busFreq > 50000000) && (vscale == 0)) {
   6751              BUS_RegMaskedSet(&MSC->CTRL, MSC_CTRL_WAITMODE_WS1);
   6752            } else {
   6753              BUS_RegMaskedClear(&MSC->CTRL, MSC_CTRL_WAITMODE_WS1);
   6754            }
   6755          }
   6756          #endif
   6757          
   6758          #if defined(PLFRCO_PRESENT)
   6759          static bool deviceHasPlfrco(void)
   6760          {
   6761            SYSTEM_ChipRevision_TypeDef rev;
   6762          
   6763            if (_SILICON_LABS_GECKO_INTERNAL_SDID == 89) {
   6764              // check the xG13 rev and check if it's >= Rev A3
   6765              SYSTEM_ChipRevisionGet(&rev);
   6766              return (rev.major > 1) || (rev.minor >= 3);
   6767            } else {
   6768              return false;
   6769            }
   6770          }
   6771          #endif
   6772          
   6773          /***************************************************************************//**
   6774           * @brief
   6775           *   Configure various wait states to switch to a certain frequency
   6776           *   and a certain voltage scale.
   6777           *
   6778           * @details
   6779           *   This function will set up the necessary flash, bus, and RAM wait states.
   6780           *   Updating the wait state configuration must be done before
   6781           *   increasing the clock frequency and it must be done after decreasing the
   6782           *   clock frequency. Updating the wait state configuration must be done before
   6783           *   core voltage is decreased and it must be done after a core voltage is
   6784           *   increased.
   6785           *
   6786           * @param[in] freq
   6787           *   The core clock frequency to configure wait-states.
   6788           *
   6789           * @param[in] vscale
   6790           *   The voltage scale to configure wait-states. Expected values are
   6791           *   0 or 2, higher number is lower voltage.
   6792           *
   6793           *   @li 0 = 1.2 V (VSCALE2)
   6794           *   @li 2 = 1.0 V (VSCALE0)
   6795           *
   6796           ******************************************************************************/
   6797          void CMU_UpdateWaitStates(uint32_t freq, int vscale)
   6798          {
   6799            /* Make sure the MSC is unlocked */
   6800            bool mscLocked = MSC_LockGetLocked();
   6801            MSC_LockSetUnlocked();
   6802          
   6803            flashWaitStateControl(freq, vscale);
   6804          #if defined(_MSC_RAMCTRL_RAMWSEN_MASK)
   6805            setRamWaitState(freq, vscale);
   6806          #endif
   6807          #if defined(_MSC_CTRL_WAITMODE_MASK)
   6808            setBusWaitState(freq, vscale);
   6809          #endif
   6810          
   6811            if (mscLocked) {
   6812              MSC_LockSetLocked();
   6813            }
   6814          }
   6815          
   6816          #if defined(_CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK)
   6817          /***************************************************************************//**
   6818           * @brief
   6819           *   Return the upper value for CMU_HFXOSTEADYSTATECTRL_REGISH.
   6820           ******************************************************************************/
   6821          static uint32_t getRegIshUpperVal(uint32_t steadyStateRegIsh)
   6822          {
   6823            uint32_t regIshUpper;
   6824            const uint32_t upperMax = _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK
   6825                                      >> _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_SHIFT;
   6826            /* Add 3 as specified in the register description for CMU_HFXOSTEADYSTATECTRL_REGISHUPPER. */
   6827            regIshUpper = SL_MIN(steadyStateRegIsh + 3UL, upperMax);
   6828            regIshUpper <<= _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_SHIFT;
   6829            return regIshUpper;
   6830          }
   6831          #endif
   6832          
   6833          #if defined(_CMU_HFXOCTRL_MASK)
   6834          /***************************************************************************//**
   6835           * @brief
   6836           *   Get the HFXO tuning mode.
   6837           *
   6838           * @return
   6839           *   The current HFXO tuning mode from the HFXOCTRL register.
   6840           ******************************************************************************/
   6841          __STATIC_INLINE uint32_t getHfxoTuningMode(void)
   6842          {
   6843          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6844            return (CMU->HFXOCTRL & _CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6845                   >> _CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_SHIFT;
   6846          #else
   6847            return (CMU->HFXOCTRL & _CMU_HFXOCTRL_PEAKDETMODE_MASK)
   6848                   >> _CMU_HFXOCTRL_PEAKDETMODE_SHIFT;
   6849          #endif
   6850          }
   6851          
   6852          /***************************************************************************//**
   6853           * @brief
   6854           *   Set the HFXO tuning mode.
   6855           *
   6856           * @param[in] mode
   6857           *   The new HFXO tuning mode. This can be HFXO_TUNING_MODE_AUTO or
   6858           *   HFXO_TUNING_MODE_CMD.
   6859           ******************************************************************************/
   6860          __STATIC_INLINE void setHfxoTuningMode(uint32_t mode)
   6861          {
   6862          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6863            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6864                            | (mode << _CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_SHIFT);
   6865          #else
   6866            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_PEAKDETMODE_MASK)
   6867                            | (mode << _CMU_HFXOCTRL_PEAKDETMODE_SHIFT);
   6868          #endif
   6869          }
