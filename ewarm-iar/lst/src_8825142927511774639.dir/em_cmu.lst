   4183          /***************************************************************************//**
   4184           * @brief
   4185           *   Set HFRCOEM23 band and the tuning value based on the value in the
   4186           *   calibration table made during production.
   4187           *
   4188           * @param[in] freq
   4189           *   HFRCOEM23 frequency band to activate.
   4190           ******************************************************************************/
   4191          void CMU_HFRCOEM23BandSet(CMU_HFRCOEM23Freq_TypeDef freq)
   4192          {
   4193            uint32_t freqCal;
   4194          
   4195            // Get calibration data from DEVINFO
   4196            freqCal = HFRCOEM23DevinfoGet(freq);
   4197            EFM_ASSERT((freqCal != 0UL) && (freqCal != UINT_MAX));
   4198          #if defined(CMU_CLKEN0_HFRCOEM23)
   4199            CMU->CLKEN0_SET = CMU_CLKEN0_HFRCOEM23;
   4200          #endif
   4201          
   4202            // Set divider for 1, 2 and 4MHz bands
   4203            freqCal &= ~_HFRCO_CAL_CLKDIV_MASK;
   4204            switch (freq) {
   4205              case cmuHFRCOEM23Freq_1M0Hz:
   4206                freqCal |= HFRCO_CAL_CLKDIV_DIV4;
   4207                break;
   4208          
   4209              case cmuHFRCOEM23Freq_2M0Hz:
   4210                freqCal |= HFRCO_CAL_CLKDIV_DIV2;
   4211                break;
   4212          
   4213              default:
   4214                break;
   4215            }
   4216          
   4217            // Activate new band selection
   4218            HFRCOEM23->CAL = freqCal;
   4219          }
   4220          #endif // defined(HFRCOEM23_PRESENT)
