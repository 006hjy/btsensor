   3046          #if defined(USBPLL_PRESENT)
   3047          /***************************************************************************//**
   3048           * @brief
   3049           *   Initialize the USB PLL control registers.
   3050           *
   3051           * @note
   3052           *  The HFXO reference frequency must be updated if crystal value is
   3053           *  different from default value.
   3054           *
   3055           * @param[in] pllInit
   3056           *   USB PLL parameters
   3057           ******************************************************************************/
   3058          void CMU_USBPLLInit(const CMU_USBPLL_Init_TypeDef *pllInit)
   3059          {
   3060            CMU->CLKEN1_SET = CMU_CLKEN1_USB;
   3061          
   3062            USBPLL0->LOCK = USBPLL_LOCK_LOCKKEY_UNLOCK;
   3063          
   3064            // Stop the PLL for configuration purposes
   3065            USBPLL0->CTRL_SET = USBPLL_CTRL_DISONDEMAND;
   3066            USBPLL0->CTRL_CLR = USBPLL_CTRL_FORCEEN;
   3067          
   3068            while (USBPLL0->STATUS & USBPLL_STATUS_PLLLOCK) ;
   3069          
   3070            if (pllInit->hfxoRefFreq == cmuHFXORefFreq_39M0Hz) {
   3071              // Set DCO in low frequency mode for 39 MHz crystal.
   3072              USBPLL0->DCOCTRL_SET = _USBPLL_DCOCTRL_DCOBIASHALF_MASK;
   3073            } else {
   3074              USBPLL0->DCOCTRL_CLR = _USBPLL_DCOCTRL_DCOBIASHALF_MASK;
   3075            }
   3076          
   3077            while (USBPLL0->STATUS & USBPLL_STATUS_SYNCBUSY) ;
   3078          
   3079            USBPLL0->CTRL = (USBPLL0->CTRL & ~(_USBPLL_CTRL_SHUNTREGLPEN_MASK
   3080                                               | _USBPLL_CTRL_DIVR_MASK
   3081                                               | _USBPLL_CTRL_DIVX_MASK
   3082                                               | _USBPLL_CTRL_DIVN_MASK
   3083                                               | _USBPLL_CTRL_DISONDEMAND_MASK
   3084                                               | _USBPLL_CTRL_FORCEEN_MASK))
   3085                            | pllInit->hfxoRefFreq
   3086                            | pllInit->shuntRegEn  << _USBPLL_CTRL_SHUNTREGLPEN_SHIFT
   3087                            | pllInit->disOnDemand << _USBPLL_CTRL_DISONDEMAND_SHIFT
   3088                            | pllInit->forceEn     << _USBPLL_CTRL_FORCEEN_SHIFT;
   3089          
   3090            while (USBPLL0->STATUS & USBPLL_STATUS_SYNCBUSY) ;
   3091          
   3092            if (pllInit->forceEn) {
   3093              CMU_WaitUSBPLLLock();
   3094            }
   3095          
   3096            if (pllInit->regLock) {
   3097              USBPLL0->LOCK = ~USBPLL_LOCK_LOCKKEY_UNLOCK;
   3098            }
   3099          }
   3100          #endif
   3101          
   3102          #if defined(RFFPLL_PRESENT)
   3103          /***************************************************************************//**
   3104           * @brief
   3105           *   Initialize the RFFPLL control registers.
   3106           *
   3107           * @param[in] pllInit
   3108           *   RFF PLL parameters
   3109           ******************************************************************************/
   3110          void CMU_RFFPLLInit(const CMU_RFFPLL_Init_TypeDef *pllInit)
   3111          {
   3112            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_SYSCLK) != cmuSelect_RFFPLLSYS);
   3113            EFM_ASSERT(pllInit->dividerY >= 8 && pllInit->dividerY <= 31);
   3114            EFM_ASSERT(pllInit->dividerX >= 4 && pllInit->dividerX <= 15);
   3115            EFM_ASSERT(pllInit->dividerN >= 32 && pllInit->dividerN <= 127);
   3116          
   3117            CMU->CLKEN1_SET = CMU_CLKEN1_RFFPLL0;
   3118          
   3119            RFFPLL0->LOCK = RFFPLL_LOCK_LOCKKEY_UNLOCK;
   3120          
   3121            RFFPLL0->CTRL = (RFFPLL0->CTRL & ~(_RFFPLL_CTRL_DISONDEMAND_MASK | _RFFPLL_CTRL_FORCEEN_MASK))
   3122                            | (pllInit->disOnDemand << _RFFPLL_CTRL_DISONDEMAND_SHIFT)
   3123                            | (pllInit->forceEn     << _RFFPLL_CTRL_FORCEEN_SHIFT);
   3124          
   3125            RFFPLL0->RFFPLLCTRL1 = (RFFPLL0->RFFPLLCTRL1 & ~(_RFFPLL_RFFPLLCTRL1_DIVY_MASK | _RFFPLL_RFFPLLCTRL1_DIVX_MASK | _RFFPLL_RFFPLLCTRL1_DIVN_MASK))
   3126                                   | (pllInit->dividerY << _RFFPLL_RFFPLLCTRL1_DIVY_SHIFT)
   3127                                   | (pllInit->dividerX << _RFFPLL_RFFPLLCTRL1_DIVX_SHIFT)
   3128                                   | (pllInit->dividerN << _RFFPLL_RFFPLLCTRL1_DIVN_SHIFT);
   3129          
   3130            // Update CMSIS RFFPLL frequency.
   3131            SystemRFFPLLClockSet(pllInit->frequency);
   3132          
   3133            if (pllInit->forceEn) {
   3134              CMU_WaitRFFPLLLock();
   3135            }
   3136          
   3137            if (pllInit->regLock) {
   3138              RFFPLL0->LOCK = ~USBPLL_LOCK_LOCKKEY_UNLOCK;
   3139            }
   3140          }
   3141          #endif
