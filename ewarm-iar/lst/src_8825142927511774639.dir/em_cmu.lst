   6100          
   6101          #if defined(_SILICON_LABS_32B_SERIES_0) \
   6102            && (defined(_EFM32_GIANT_FAMILY)      \
   6103            || defined(_EZR32_LEOPARD_FAMILY))
   6104          /***************************************************************************//**
   6105           * @brief
   6106           *   Return maximum allowed frequency for low energy peripherals.
   6107           ******************************************************************************/
   6108          static uint32_t maxFreqHfle(void)
   6109          {
   6110            uint16_t majorMinorRev;
   6111          
   6112            switch (SYSTEM_GetFamily()) {
   6113              case systemPartFamilyEfm32Leopard:
   6114              case systemPartFamilyEzr32Leopard:
   6115                /* CHIP MAJOR bit [5:0] */
   6116                majorMinorRev = (((ROMTABLE->PID0 & _ROMTABLE_PID0_REVMAJOR_MASK)
   6117                                  >> _ROMTABLE_PID0_REVMAJOR_SHIFT) << 8);
   6118                /* CHIP MINOR bit [7:4] */
   6119                majorMinorRev |= (((ROMTABLE->PID2 & _ROMTABLE_PID2_REVMINORMSB_MASK)
   6120                                   >> _ROMTABLE_PID2_REVMINORMSB_SHIFT) << 4);
   6121                /* CHIP MINOR bit [3:0] */
   6122                majorMinorRev |=  ((ROMTABLE->PID3 & _ROMTABLE_PID3_REVMINORLSB_MASK)
   6123                                   >> _ROMTABLE_PID3_REVMINORLSB_SHIFT);
   6124          
   6125                if (majorMinorRev >= 0x0204) {
   6126                  return 24000000;
   6127                } else {
   6128                  return 32000000;
   6129                }
   6130          
   6131              case systemPartFamilyEfm32Giant:
   6132                return 32000000;
   6133          
   6134              default:
   6135                /* Invalid device family. */
   6136                EFM_ASSERT(false);
   6137                return 0;
   6138            }
   6139          }
   6140          #endif
   6141          
   6142          #if defined(CMU_MAX_FREQ_HFLE)
   6143          
   6144          /** @cond DO_NOT_INCLUDE_WITH_DOXYGEN */
   6145          /* Unified definitions for the HFLE wait-state and prescaler fields. */
   6146          #if defined(CMU_CTRL_HFLE)
   6147          #define _GENERIC_HFLE_WS_MASK           _CMU_CTRL_HFLE_MASK
   6148          #define _GENERIC_HFLE_WS_SHIFT          _CMU_CTRL_HFLE_SHIFT
   6149          #define GENERIC_HFLE_PRESC_REG          CMU->HFCORECLKDIV
   6150          #define _GENERIC_HFLE_PRESC_MASK        _CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK
   6151          #define _GENERIC_HFLE_PRESC_SHIFT       _CMU_HFCORECLKDIV_HFCORECLKLEDIV_SHIFT
   6152          #elif defined(CMU_CTRL_WSHFLE)
   6153          #define _GENERIC_HFLE_WS_MASK           _CMU_CTRL_WSHFLE_MASK
   6154          #define _GENERIC_HFLE_WS_SHIFT          _CMU_CTRL_WSHFLE_SHIFT
   6155          #define GENERIC_HFLE_PRESC_REG          CMU->HFPRESC
   6156          #define _GENERIC_HFLE_PRESC_MASK        _CMU_HFPRESC_HFCLKLEPRESC_MASK
   6157          #define _GENERIC_HFLE_PRESC_SHIFT       _CMU_HFPRESC_HFCLKLEPRESC_SHIFT
   6158          #endif
   6159          /** @endcond */
   6160          
   6161          /***************************************************************************//**
   6162           * @brief
   6163           *   Set HFLE wait-states and HFCLKLE prescaler according to wanted HF clock.
   6164           *
   6165           * @param[in] hfFreq
   6166           *   The HF clock frequency to use.
   6167           *   This is:
   6168           *     CORE clock on Series0 devices.
   6169           *     HF clock on on Series1 devices.
   6170           ******************************************************************************/
   6171          static void setHfLeConfig(uint32_t hfFreq)
   6172          {
   6173            unsigned int hfleWs;
   6174            uint32_t hflePresc;
   6175          
   6176            /* Check for 1 bit fields. @ref BUS_RegBitWrite() below are going to fail if the
   6177               fields are changed to more than 1 bit. */
   6178            EFM_ASSERT((_GENERIC_HFLE_WS_MASK >> _GENERIC_HFLE_WS_SHIFT) == 0x1U);
   6179          
   6180            /* - Enable HFLE wait-state to allow access to LE peripherals when HFBUSCLK is
   6181                 above maxLeFreq.
   6182               - Set HFLE prescaler. Allowed HFLE clock frequency is maxLeFreq. */
   6183          
   6184            hfleWs = 1;
   6185            if (hfFreq <= CMU_MAX_FREQ_HFLE) {
   6186              hfleWs = 0;
   6187              hflePresc = 0;
   6188            } else if (hfFreq <= (2UL * CMU_MAX_FREQ_HFLE)) {
   6189              hflePresc = 1;
   6190            } else {
   6191              hflePresc = 2;
   6192            }
   6193            BUS_RegBitWrite(&CMU->CTRL, _GENERIC_HFLE_WS_SHIFT, hfleWs);
   6194            GENERIC_HFLE_PRESC_REG = (GENERIC_HFLE_PRESC_REG & ~_GENERIC_HFLE_PRESC_MASK)
   6195                                     | (hflePresc << _GENERIC_HFLE_PRESC_SHIFT);
   6196          }
   6197          
   6198          #if defined(_CMU_CTRL_HFLE_MASK)
   6199          /***************************************************************************//**
   6200           * @brief
   6201           *   Get HFLE wait-state configuration.
   6202           *
   6203           * @return
   6204           *   The current wait-state configuration.
   6205           ******************************************************************************/
   6206          static uint32_t getHfLeConfig(void)
   6207          {
   6208            uint32_t ws = BUS_RegBitRead(&CMU->CTRL, _GENERIC_HFLE_WS_SHIFT);
   6209            return ws;
   6210          }
   6211          #endif
   6212          #endif
   6213          
   6214          /***************************************************************************//**
   6215           * @brief
   6216           *   Get the AUX clock frequency. Used by MSC flash programming and LESENSE,
   6217           *   by default also as a debug clock.
   6218           *
   6219           * @return
   6220           *   AUX Frequency in Hz.
   6221           ******************************************************************************/
   6222          static uint32_t auxClkGet(void)
   6223          {
   6224            uint32_t ret;
   6225          
   6226          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   6227            ret = (uint32_t)auxHfrcoFreq;
   6228          
   6229          #elif defined(_CMU_AUXHFRCOCTRL_BAND_MASK)
   6230            /* All series 0 families except EFM32G */
   6231            switch (CMU->AUXHFRCOCTRL & _CMU_AUXHFRCOCTRL_BAND_MASK) {
   6232              case CMU_AUXHFRCOCTRL_BAND_1MHZ:
   6233                if ( SYSTEM_GetProdRev() >= 19 ) {
   6234                  ret = 1200000;
   6235                } else {
   6236                  ret = 1000000;
   6237                }
   6238                break;
   6239          
   6240              case CMU_AUXHFRCOCTRL_BAND_7MHZ:
   6241                if ( SYSTEM_GetProdRev() >= 19 ) {
   6242                  ret = 6600000;
   6243                } else {
   6244                  ret = 7000000;
   6245                }
   6246                break;
   6247          
   6248              case CMU_AUXHFRCOCTRL_BAND_11MHZ:
   6249                ret = 11000000;
   6250                break;
   6251          
   6252              case CMU_AUXHFRCOCTRL_BAND_14MHZ:
   6253                ret = 14000000;
   6254                break;
   6255          
   6256              case CMU_AUXHFRCOCTRL_BAND_21MHZ:
   6257                ret = 21000000;
   6258                break;
   6259          
   6260          #if defined(_CMU_AUXHFRCOCTRL_BAND_28MHZ)
   6261              case CMU_AUXHFRCOCTRL_BAND_28MHZ:
   6262                ret = 28000000;
   6263                break;
   6264          #endif
   6265          
   6266              default:
   6267                ret = 0;
   6268                EFM_ASSERT(false);
   6269                break;
   6270            }
   6271          
   6272          #else
   6273            /* Gecko has a fixed 14 MHz AUXHFRCO clock. */
   6274            ret = 14000000;
   6275          
   6276          #endif
   6277          
   6278            return ret;
   6279          }
   6280          
   6281          #if defined (_CMU_ADCCTRL_ADC0CLKSEL_HFSRCCLK) \
   6282            || defined (_CMU_ADCCTRL_ADC1CLKSEL_HFSRCCLK)
