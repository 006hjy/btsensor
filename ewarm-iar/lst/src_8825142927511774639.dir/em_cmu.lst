   5102          __STATIC_INLINE uint32_t getWaitStatesByFrequencyAndVScale(uint32_t freq, int vscale)
   5103          {
   5104            uint32_t flashWs = MSC_READCTRL_MODE_WS3;
   5105          
   5106            if (vscale == 0) {
   5107              // VScale 1.1V core frequency ranges for wait-states configurations.
   5108              if (0) {
   5109                // Intentional no-op for structure.
   5110              }
   5111          #if defined(CMU_MAX_FREQ_2WS_1V1)
   5112              else if (freq > CMU_MAX_FREQ_2WS_1V1) {
   5113                flashWs = MSC_READCTRL_MODE_WS3;
   5114              }
   5115          #endif
   5116          #if defined(CMU_MAX_FREQ_1WS_1V1)
   5117              else if (freq > CMU_MAX_FREQ_1WS_1V1) {
   5118                flashWs = MSC_READCTRL_MODE_WS2;
   5119              }
   5120          #endif
   5121          #if defined(CMU_MAX_FREQ_0WS_1V1)
   5122              else if (freq > CMU_MAX_FREQ_0WS_1V1) {
   5123                flashWs = MSC_READCTRL_MODE_WS1;
   5124              }
   5125          #endif
   5126              else {
   5127                flashWs = MSC_READCTRL_MODE_WS0;
   5128              }
   5129            } else if (vscale >= 1) {
   5130              // VScale 1.0V core frequency ranges for wait-states configurations.
   5131              if (0) {
   5132                // Intentional no-op for structure.
   5133              }
   5134          #if defined(CMU_MAX_FREQ_2WS_1V0)
   5135              else if (freq > CMU_MAX_FREQ_2WS_1V0) {
   5136                flashWs = MSC_READCTRL_MODE_WS3;
   5137              }
   5138          #endif
   5139          #if defined(CMU_MAX_FREQ_1WS_1V0)
   5140              else if (freq > CMU_MAX_FREQ_1WS_1V0) {
   5141                flashWs = MSC_READCTRL_MODE_WS2;
   5142              }
   5143          #endif
   5144          #if defined(CMU_MAX_FREQ_0WS_1V0)
   5145              else if (freq > CMU_MAX_FREQ_0WS_1V0) {
   5146                flashWs = MSC_READCTRL_MODE_WS1;
   5147              }
   5148          #endif
   5149              else {
   5150                flashWs = MSC_READCTRL_MODE_WS0;
   5151              }
   5152            }
   5153            return flashWs;
   5154          }
