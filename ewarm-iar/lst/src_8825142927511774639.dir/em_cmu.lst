   4399                s = cmuSelect_Disabled;
   4400                break;
   4401          #endif
   4402          
   4403              default:
   4404                s = cmuSelect_Error;
   4405                EFM_ASSERT(false);
   4406                break;
   4407            }
   4408            if (freq != NULL) {
   4409              *freq = f;
   4410            }
   4411            if (sel != NULL) {
   4412              *sel = s;
   4413            }
   4414          }
