    320          #elif defined(_CMU_CALTOP_CALTOP_MASK)
    321            EFM_ASSERT(cycles <= (_CMU_CALTOP_CALTOP_MASK
    322                                  >> _CMU_CALTOP_CALTOP_SHIFT));
    323          #endif
    324          
    325            CMU_CalibrateConfig(cycles, cmuSelect_HCLK, ref);
   \                     ??CrossCallReturnLabel_43: (+1)
   \       0x14   0x462A             MOV      R2,R5
   \       0x16   0x210C             MOVS     R1,#+12
   \       0x18   0x4620             MOV      R0,R4
   \       0x1A   0x.... 0x....      BL       CMU_CalibrateConfig
    326            CMU_CalibrateStart();
