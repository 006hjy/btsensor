   4309              case CMU_EUART0CLKCTRL_CLKSEL_EM01GRPACLK:
   4310                em01GrpaClkGet(freq, sel);
   \                     ??euart0ClkGet_0: (+1)
   \       0x14   0x....             B.N      em01GrpaClkGet
   4311                break;
   4312          
   4313              case CMU_EUART0CLKCTRL_CLKSEL_EM23GRPACLK:
   4314                em23GrpaClkGet(freq, sel);
   \                     ??euart0ClkGet_1: (+1)
   \       0x16   0x....             B.N      em23GrpaClkGet
   4315                break;
   4316          
   4317              default:
   4318                if (freq != NULL) {
   \                     ??euart0ClkGet_2: (+1)
   \       0x18   0xB108             CBZ.N    R0,??euart0ClkGet_3
   4319                  *freq = 0U;
   \       0x1A   0x2200             MOVS     R2,#+0
   \       0x1C   0x6002             STR      R2,[R0, #+0]
   4320                }
   4321                if (sel != NULL) {
   \                     ??euart0ClkGet_3: (+1)
   \       0x1E   0xB109             CBZ.N    R1,??euart0ClkGet_4
   4322                  *sel = cmuSelect_Error;
   \       0x20   0x2000             MOVS     R0,#+0
   \       0x22   0x6008             STR      R0,[R1, #+0]
   4323                }
   4324                EFM_ASSERT(false);
   \                     ??euart0ClkGet_4: (+1)
   \       0x24   0xF241 0x01E4      MOVW     R1,#+4324
   \       0x28   0x.... 0x....      LDR.W    R0,??DataTable47_3
   \       0x2C   0x.... 0x....      B.W      assertEFM
   4325                break;
   4326            }
   4327          }
   4328          #endif
