    185          // CTUNE delta needed for some series 2 chips. This delta is added to the tuning capacitance on XO.
    186          // The inter-chip buffered crystal sharing feature added from the EFR32xG23 creates an imbalance
    187          // between XI and XO capacitance load internally on the chip. The delta allows to compensate for
    188          // the difference.
    189          #if defined(_SILICON_LABS_32B_SERIES_2)
    190          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_3)  \
    191            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_4) \
    192            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_5) \
    193            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_6) \
    194            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_8) \
    195            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_13)
    196          static int8_t ctuneDelta = 40; // Recommendation from analog team to counter the internal chip imbalance.
    197          #else

   \                                 In section .bss, align 1
    198          static int8_t ctuneDelta = 0;
   \                     ctuneDelta:
   \        0x0                      DS8 1
    199          #endif
    200          #endif
    201          

