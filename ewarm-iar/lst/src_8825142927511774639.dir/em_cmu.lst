   9797           *       the clock is HF and USHFRCO is selected as the clock source.
   9798           ******************************************************************************/
   9799          void sli_em_cmu_HFClockSelectUSHFRCO(void)
   9800          {
   9801            // Enable USHFRCO oscillator
   9802            CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
   9803            // Configure worst case wait-states for flash and set safe HFPER
   9804            // clock-tree prescalers.
   9805            flashWaitStateMax();
   9806            hfperClkSafePrescaler();
   9807          
   9808            // Select HF clock source.
   9809            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_USHFRCO;
   9810          #if defined(CMU_MAX_FREQ_HFLE)
   9811            setHfLeConfig(SystemHFClockGet());
   9812          #endif
   9813          
   9814            // Optimize flash access wait state setting for the currently selected core clk.
   9815            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9816            // Set optimized HFPER clock-tree prescalers.
   9817            hfperClkOptimizedPrescaler();
   9818          }
   9819          #endif
   9820          
   9821          /***************************************************************************//**
   9822           * @brief
   9823           *   Select the reference clock/oscillator used for a clock branch.
   9824           *
   9825           * @details
   9826           *   Notice that if a selected reference is not enabled prior to selecting its
   9827           *   use, it will be enabled and this function will wait for the selected
   9828           *   oscillator to be stable. It will however NOT be disabled if another
   9829           *   reference clock is selected later.
   9830           *
   9831           *   This feature is particularly important if selecting a new reference
   9832           *   clock for the clock branch clocking the core. Otherwise, the system
   9833           *   may halt.
   9834           *
   9835           * @note
   9836           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   9837           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   9838           *
   9839           * @param[in] clock
   9840           *   A clock branch to select reference clock for. One of:
   9841           *   @li #cmuClock_HF
   9842           *   @li #cmuClock_LFA
   9843           *   @li #cmuClock_LFB
   9844           *   @if _CMU_LFCCLKEN0_MASK
   9845           *   @li #cmuClock_LFC
   9846           *   @endif
   9847           *   @if _CMU_LFECLKEN0_MASK
   9848           *   @li #cmuClock_LFE
   9849           *   @endif
   9850           *   @li #cmuClock_DBG
   9851           *   @if _CMU_CMD_USBCLKSEL_MASK
   9852           *   @li #cmuClock_USBC
   9853           *   @endif
   9854           *   @if _CMU_USBCTRL_MASK
   9855           *   @li #cmuClock_USBR
   9856           *   @endif
   9857           *
   9858           * @param[in] ref
   9859           *   A reference selected for clocking. See the reference manual
   9860           *   for details about references available for a specific clock branch.
   9861           *   @li #cmuSelect_HFRCO
   9862           *   @li #cmuSelect_LFRCO
   9863           *   @li #cmuSelect_HFXO
   9864           *   @if _CMU_HFXOCTRL_HFXOX2EN_MASK
   9865           *   @li #cmuSelect_HFXOX2
   9866           *   @endif
   9867           *   @li #cmuSelect_LFXO
   9868           *   @li #cmuSelect_HFCLKLE
   9869           *   @li #cmuSelect_AUXHFRCO
   9870           *   @if _CMU_USHFRCOCTRL_MASK
   9871           *   @li #cmuSelect_USHFRCO
   9872           *   @endif
   9873           *   @li #cmuSelect_HFCLK
   9874           *   @ifnot DOXYDOC_EFM32_GECKO_FAMILY
   9875           *   @li #cmuSelect_ULFRCO
   9876           *   @endif
   9877           *   @if CMU_OSCENCMD_PLFRCOEN
   9878           *   @li #cmuSelect_PLFRCO
   9879           *   @endif
   9880           ******************************************************************************/
   9881          void CMU_ClockSelectSet(CMU_Clock_TypeDef clock, CMU_Select_TypeDef ref)
   9882          {
   9883            uint32_t              select = (uint32_t)cmuOsc_HFRCO;
   9884            CMU_Osc_TypeDef       osc    = cmuOsc_HFRCO;
   9885            uint32_t              freq;
   9886            uint32_t              tmp;
   9887            uint32_t              selRegId;
   9888          #if defined(_SILICON_LABS_32B_SERIES_1)
   9889            volatile uint32_t     *selReg = NULL;
   9890          #endif
   9891          #if defined(CMU_LFCLKSEL_LFAE_ULFRCO)
   9892            uint32_t              lfExtended = 0;
   9893          #endif
   9894          
   9895          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9896            uint32_t              vScaleFrequency = 0; /* Use default. */
   9897          
   9898            /* Start voltage upscaling before the clock is set. */
   9899            if (clock == cmuClock_HF) {
   9900              if (ref == cmuSelect_HFXO) {
   9901                vScaleFrequency = SystemHFXOClockGet();
   9902              } else if ((ref == cmuSelect_HFRCO)
   9903                         && ((uint32_t)CMU_HFRCOBandGet()
   9904                             > CMU_VSCALEEM01_LOWPOWER_VOLTAGE_CLOCK_MAX)) {
   9905                vScaleFrequency = (uint32_t)CMU_HFRCOBandGet();
   9906              } else {
   9907                /* Use the default frequency. */
   9908              }
   9909              if (vScaleFrequency != 0UL) {
   9910                EMU_VScaleEM01ByClock(vScaleFrequency, false);
   9911              }
   9912            }
   9913          #endif
   9914          
   9915            selRegId = ((unsigned)clock >> CMU_SEL_REG_POS) & CMU_SEL_REG_MASK;
   9916          
   9917            switch (selRegId) {
   9918              case CMU_HFCLKSEL_REG:
   9919                switch (ref) {
   9920                  case cmuSelect_LFXO:
   9921          #if defined(_SILICON_LABS_32B_SERIES_1)
   9922                    select = CMU_HFCLKSEL_HF_LFXO;
   9923          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9924                    select = CMU_CMD_HFCLKSEL_LFXO;
   9925          #endif
   9926                    osc = cmuOsc_LFXO;
   9927                    break;
   9928          
   9929                  case cmuSelect_LFRCO:
   9930          #if defined(_SILICON_LABS_32B_SERIES_1)
   9931                    select = CMU_HFCLKSEL_HF_LFRCO;
   9932          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9933                    select = CMU_CMD_HFCLKSEL_LFRCO;
   9934          #endif
   9935                    osc = cmuOsc_LFRCO;
   9936                    break;
   9937          
   9938                  case cmuSelect_HFXO:
   9939          #if defined(CMU_HFCLKSEL_HF_HFXO)
   9940                    select = CMU_HFCLKSEL_HF_HFXO;
   9941          #elif defined(CMU_CMD_HFCLKSEL_HFXO)
   9942                    select = CMU_CMD_HFCLKSEL_HFXO;
   9943          #endif
   9944                    osc = cmuOsc_HFXO;
   9945          #if defined(CMU_MAX_FREQ_HFLE)
   9946                    /* Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9947                       This is known after 'select' is written below. */
   9948                    setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9949          #endif
   9950          #if defined(CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ)
   9951                    /* Adjust HFXO buffer current for frequencies above 32 MHz. */
   9952                    if (SystemHFXOClockGet() > 32000000) {
   9953                      CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9954                                  | CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ;
   9955                    } else {
   9956                      CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9957                                  | CMU_CTRL_HFXOBUFCUR_BOOSTUPTO32MHZ;
   9958                    }
   9959          #endif
   9960                    break;
   9961          
   9962                  case cmuSelect_HFRCO:
   9963          #if defined(_SILICON_LABS_32B_SERIES_1)
   9964                    select = CMU_HFCLKSEL_HF_HFRCO;
   9965          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9966                    select = CMU_CMD_HFCLKSEL_HFRCO;
   9967          #endif
   9968                    osc = cmuOsc_HFRCO;
   9969          #if defined(CMU_MAX_FREQ_HFLE)
   9970                    /* Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9971                       This is known after 'select' is written below. */
   9972                    setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9973          #endif
   9974                    break;
   9975          
   9976          #if defined(CMU_CMD_HFCLKSEL_USHFRCODIV2)
   9977                  case cmuSelect_USHFRCODIV2:
   9978                    select = CMU_CMD_HFCLKSEL_USHFRCODIV2;
   9979                    osc = cmuOsc_USHFRCO;
   9980                    break;
   9981          #endif
   9982          
   9983          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
   9984                  case cmuSelect_HFRCODIV2:
   9985                    select = CMU_HFCLKSEL_HF_HFRCODIV2;
   9986                    osc = cmuOsc_HFRCO;
   9987                    break;
   9988          #endif
   9989          
   9990          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
   9991                  case cmuSelect_CLKIN0:
   9992                    select = CMU_HFCLKSEL_HF_CLKIN0;
   9993                    osc = cmuOsc_CLKIN0;
   9994                    break;
   9995          #endif
   9996          
   9997          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
   9998                  case cmuSelect_USHFRCO:
   9999                    select = CMU_HFCLKSEL_HF_USHFRCO;
  10000                    osc = cmuOsc_USHFRCO;
  10001                    break;
  10002          #endif
  10003          
  10004          #if defined(CMU_LFCLKSEL_LFAE_ULFRCO) || defined(CMU_LFACLKSEL_LFA_ULFRCO)
  10005                  case cmuSelect_ULFRCO:
  10006                    /* ULFRCO cannot be used as HFCLK.  */
  10007                    EFM_ASSERT(false);
  10008                    return;
  10009          #endif
  10010          
  10011                  default:
  10012                    EFM_ASSERT(false);
  10013                    return;
  10014                }
  10015          
  10016                /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10017          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
  10018                if (osc != cmuOsc_CLKIN0) {
  10019                  CMU_OscillatorEnable(osc, true, true);
  10020                }
  10021          #else
  10022                CMU_OscillatorEnable(osc, true, true);
  10023          #endif
  10024          
  10025                /* Configure worst case wait-states for flash and set safe HFPER
  10026                   clock-tree prescalers. */
  10027                flashWaitStateMax();
  10028                hfperClkSafePrescaler();
  10029          
  10030          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10031                /* Wait for voltage upscaling to complete before the clock is set. */
  10032                if (vScaleFrequency != 0UL) {
  10033                  EMU_VScaleWait();
  10034                }
  10035          #endif
  10036          
  10037                /* Switch to the selected oscillator. */
  10038          #if defined(_CMU_HFCLKSEL_MASK)
  10039                CMU->HFCLKSEL = select;
  10040          #else
  10041                CMU->CMD = select;
  10042          #endif
  10043                /* Update the CMSIS core clock variable. */
  10044                /* (The function will update the global variable). */
  10045                freq = SystemCoreClockGet();
  10046          
  10047          #if defined(CMU_MAX_FREQ_HFLE)
  10048                /* Update the HFLE configuration after 'select' is set.
  10049                   Note that the HFCLKLE clock is connected differently on platforms 1 and 2. */
  10050          #if defined(_SILICON_LABS_32B_SERIES_0)
  10051                setHfLeConfig(freq);
  10052          #else
  10053                setHfLeConfig(SystemHFClockGet());
  10054          #endif
  10055          #endif
  10056          
  10057                /* Optimize flash access wait state setting for the currently selected core clk. */
  10058                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
  10059          
  10060          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10061                /* Keep EMU module informed on the source HF clock frequency. This will apply voltage
  10062                   downscaling after clock is set if downscaling is configured. */
  10063                if (vScaleFrequency == 0UL) {
  10064                  EMU_VScaleEM01ByClock(0, true);
  10065                }
  10066          #endif
  10067                /* Set optimized HFPER clock-tree prescalers. */
  10068                hfperClkOptimizedPrescaler();
  10069                break;
  10070          
  10071          #if defined(_SILICON_LABS_32B_SERIES_1)
  10072              case CMU_LFACLKSEL_REG:
  10073                selReg = &CMU->LFACLKSEL;
  10074                /* HFCLKCLE can't be used as LFACLK. */
  10075                EFM_ASSERT(ref != cmuSelect_HFCLKLE);
  10076                SL_FALLTHROUGH
  10077                /* Fall through and select the clock source. */
  10078          
  10079          #if defined(_CMU_LFCCLKSEL_MASK)
  10080              case CMU_LFCCLKSEL_REG:
  10081                selReg = (selReg == NULL) ? &CMU->LFCCLKSEL : selReg;
  10082                /* HFCLKCLE can't be used as LFCCLK. */
  10083                EFM_ASSERT(ref != cmuSelect_HFCLKLE);
  10084                SL_FALLTHROUGH
  10085          #endif
  10086              /* Fall through and select the clock source. */
  10087          
  10088              case CMU_LFECLKSEL_REG:
  10089                selReg = (selReg == NULL) ? &CMU->LFECLKSEL : selReg;
  10090                /* HFCLKCLE can't be used as LFECLK. */
  10091                EFM_ASSERT(ref != cmuSelect_HFCLKLE);
  10092                SL_FALLTHROUGH
  10093              /* Fall through and select the clock source. */
  10094          
  10095              case CMU_LFBCLKSEL_REG:
  10096                selReg = (selReg == NULL) ? &CMU->LFBCLKSEL : selReg;
  10097                switch (ref) {
  10098                  case cmuSelect_Disabled:
  10099                    tmp = _CMU_LFACLKSEL_LFA_DISABLED;
  10100                    break;
  10101          
  10102                  case cmuSelect_LFXO:
  10103                    /* Ensure that thes elected oscillator is enabled, waiting for it to stabilize. */
  10104                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
  10105                    tmp = _CMU_LFACLKSEL_LFA_LFXO;
  10106                    break;
  10107          
  10108                  case cmuSelect_LFRCO:
  10109                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10110                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
  10111                    tmp = _CMU_LFACLKSEL_LFA_LFRCO;
  10112                    break;
  10113          
  10114                  case cmuSelect_HFCLKLE:
  10115                    /* Ensure the correct HFLE wait-states and enable HFCLK to LE.*/
  10116                    setHfLeConfig(SystemHFClockGet());
  10117                    BUS_RegBitWrite(&CMU->HFBUSCLKEN0, _CMU_HFBUSCLKEN0_LE_SHIFT, 1);
  10118                    tmp = _CMU_LFBCLKSEL_LFB_HFCLKLE;
  10119                    break;
  10120          
  10121                  case cmuSelect_ULFRCO:
  10122                    /* ULFRCO is always on, there is no need to enable it. */
  10123                    tmp = _CMU_LFACLKSEL_LFA_ULFRCO;
  10124                    break;
  10125          
  10126          #if defined(PLFRCO_PRESENT)
  10127                  case cmuSelect_PLFRCO:
  10128                    CMU_OscillatorEnable(cmuOsc_PLFRCO, true, true);
  10129                    tmp = _CMU_LFACLKSEL_LFA_PLFRCO;
  10130                    break;
  10131          #endif
  10132          
  10133                  default:
  10134                    EFM_ASSERT(false);
  10135                    return;
  10136                }
  10137                *selReg = tmp;
  10138                break;
  10139          
  10140          #elif defined(_SILICON_LABS_32B_SERIES_0)
  10141              case CMU_LFACLKSEL_REG:
  10142              case CMU_LFBCLKSEL_REG:
  10143                switch (ref) {
  10144                  case cmuSelect_Disabled:
  10145                    tmp = _CMU_LFCLKSEL_LFA_DISABLED;
  10146                    break;
  10147          
  10148                  case cmuSelect_LFXO:
  10149                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10150                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
  10151                    tmp = _CMU_LFCLKSEL_LFA_LFXO;
  10152                    break;
  10153          
  10154                  case cmuSelect_LFRCO:
  10155                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10156                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
  10157                    tmp = _CMU_LFCLKSEL_LFA_LFRCO;
  10158                    break;
  10159          
  10160                  case cmuSelect_HFCLKLE:
  10161          #if defined(CMU_MAX_FREQ_HFLE)
  10162                    /* Set the HFLE wait-state and divider. */
  10163                    freq = SystemCoreClockGet();
  10164                    setHfLeConfig(freq);
  10165          #endif
  10166                    /* Ensure HFCORE to LE clocking is enabled. */
  10167                    BUS_RegBitWrite(&CMU->HFCORECLKEN0, _CMU_HFCORECLKEN0_LE_SHIFT, 1);
  10168                    tmp = _CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2;
  10169                    break;
  10170          
  10171          #if defined(CMU_LFCLKSEL_LFAE_ULFRCO)
  10172                  case cmuSelect_ULFRCO:
  10173                    /* ULFRCO is always enabled. */
  10174                    tmp = _CMU_LFCLKSEL_LFA_DISABLED;
  10175                    lfExtended = 1;
  10176                    break;
  10177          #endif
  10178          
  10179                  default:
  10180                    /* An illegal clock source for LFA/LFB selected. */
  10181                    EFM_ASSERT(false);
  10182                    return;
  10183                }
  10184          
  10185                /* Apply select. */
  10186                if (selRegId == CMU_LFACLKSEL_REG) {
  10187          #if defined(_CMU_LFCLKSEL_LFAE_MASK)
  10188                  CMU->LFCLKSEL = (CMU->LFCLKSEL
  10189                                   & ~(_CMU_LFCLKSEL_LFA_MASK | _CMU_LFCLKSEL_LFAE_MASK))
  10190                                  | (tmp << _CMU_LFCLKSEL_LFA_SHIFT)
  10191                                  | (lfExtended << _CMU_LFCLKSEL_LFAE_SHIFT);
  10192          #else
  10193                  CMU->LFCLKSEL = (CMU->LFCLKSEL & ~_CMU_LFCLKSEL_LFA_MASK)
  10194                                  | (tmp << _CMU_LFCLKSEL_LFA_SHIFT);
  10195          #endif
  10196                } else {
  10197          #if defined(_CMU_LFCLKSEL_LFBE_MASK)
  10198                  CMU->LFCLKSEL = (CMU->LFCLKSEL
  10199                                   & ~(_CMU_LFCLKSEL_LFB_MASK | _CMU_LFCLKSEL_LFBE_MASK))
  10200                                  | (tmp << _CMU_LFCLKSEL_LFB_SHIFT)
  10201                                  | (lfExtended << _CMU_LFCLKSEL_LFBE_SHIFT);
  10202          #else
  10203                  CMU->LFCLKSEL = (CMU->LFCLKSEL & ~_CMU_LFCLKSEL_LFB_MASK)
  10204                                  | (tmp << _CMU_LFCLKSEL_LFB_SHIFT);
  10205          #endif
  10206                }
  10207                break;
  10208          
  10209          #if defined(_CMU_LFCLKSEL_LFC_MASK)
  10210              case CMU_LFCCLKSEL_REG:
  10211                switch (ref) {
  10212                  case cmuSelect_Disabled:
  10213                    tmp = _CMU_LFCLKSEL_LFA_DISABLED;
  10214                    break;
  10215          
  10216                  case cmuSelect_LFXO:
  10217                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10218                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
  10219                    tmp = _CMU_LFCLKSEL_LFC_LFXO;
  10220                    break;
  10221          
  10222                  case cmuSelect_LFRCO:
  10223                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10224                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
  10225                    tmp = _CMU_LFCLKSEL_LFC_LFRCO;
  10226                    break;
  10227          
  10228                  default:
  10229                    /* An illegal clock source for LFC selected. */
  10230                    EFM_ASSERT(false);
  10231                    return;
  10232                }
  10233          
  10234                /* Apply select. */
  10235                CMU->LFCLKSEL = (CMU->LFCLKSEL & ~_CMU_LFCLKSEL_LFC_MASK)
  10236                                | (tmp << _CMU_LFCLKSEL_LFC_SHIFT);
  10237                break;
  10238          #endif
  10239          #endif
  10240          
  10241          #if defined(_CMU_DBGCLKSEL_DBG_MASK) || defined(CMU_CTRL_DBGCLK)
  10242              case CMU_DBGCLKSEL_REG:
  10243                switch (ref) {
  10244          #if defined(_CMU_DBGCLKSEL_DBG_MASK)
  10245                  case cmuSelect_AUXHFRCO:
  10246                    /* Select AUXHFRCO as a debug clock. */
  10247                    CMU->DBGCLKSEL = CMU_DBGCLKSEL_DBG_AUXHFRCO;
  10248                    break;
  10249          
  10250                  case cmuSelect_HFCLK:
  10251                    /* Select divided HFCLK as a debug clock. */
  10252                    CMU->DBGCLKSEL = CMU_DBGCLKSEL_DBG_HFCLK;
  10253                    break;
  10254          #endif
  10255          
  10256          #if defined(CMU_CTRL_DBGCLK)
  10257                  case cmuSelect_AUXHFRCO:
  10258                    /* Select AUXHFRCO as a debug clock. */
  10259                    CMU->CTRL = (CMU->CTRL & ~(_CMU_CTRL_DBGCLK_MASK))
  10260                                | CMU_CTRL_DBGCLK_AUXHFRCO;
  10261                    break;
  10262          
  10263                  case cmuSelect_HFCLK:
  10264                    /* Select divided HFCLK as a debug clock. */
  10265                    CMU->CTRL = (CMU->CTRL & ~(_CMU_CTRL_DBGCLK_MASK))
  10266                                | CMU_CTRL_DBGCLK_HFCLK;
  10267                    break;
  10268          #endif
  10269          
  10270                  default:
  10271                    /* An illegal clock source for debug selected. */
  10272                    EFM_ASSERT(false);
  10273                    return;
  10274                }
  10275                break;
  10276          #endif
  10277          
  10278          #if defined(USBC_CLOCK_PRESENT)
  10279              case CMU_USBCCLKSEL_REG:
  10280                switch (ref) {
  10281                  case cmuSelect_LFXO:
  10282                    /* Select LFXO as a clock source for USB. It can only be used in sleep mode. */
  10283                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10284                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
  10285          
  10286                    /* Switch the oscillator. */
  10287                    CMU->CMD = CMU_CMD_USBCCLKSEL_LFXO;
  10288          
  10289                    /* Wait until the clock is activated. */
  10290                    while ((CMU->STATUS & CMU_STATUS_USBCLFXOSEL) == 0) {
  10291                      // Wait for USB CLFXO select.
  10292                    }
  10293                    break;
  10294          
  10295                  case cmuSelect_LFRCO:
  10296                    /* Select LFRCO as a clock source for USB. It can only be used in sleep mode. */
  10297                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10298                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
  10299          
  10300                    /* Switch the oscillator. */
  10301                    CMU->CMD = CMU_CMD_USBCCLKSEL_LFRCO;
  10302          
  10303                    /* Wait until the clock is activated. */
  10304                    while ((CMU->STATUS & CMU_STATUS_USBCLFRCOSEL) == 0) {
  10305                      // Wait for USB CLFRCO select.
  10306                    }
  10307                    break;
  10308          
  10309          #if defined(CMU_STATUS_USBCHFCLKSEL)
  10310                  case cmuSelect_HFCLK:
  10311                    /* Select undivided HFCLK as a clock source for USB. */
  10312                    /* The oscillator must already be enabled to avoid a core lockup. */
  10313                    CMU->CMD = CMU_CMD_USBCCLKSEL_HFCLKNODIV;
  10314                    /* Wait until the clock is activated. */
  10315                    while ((CMU->STATUS & CMU_STATUS_USBCHFCLKSEL) == 0) {
  10316                      // Wait for USB HF clock select.
  10317                    }
  10318                    break;
  10319          #endif
  10320          
  10321          #if defined(CMU_CMD_USBCCLKSEL_USHFRCO)
  10322                  case cmuSelect_USHFRCO:
  10323                    /* Select USHFRCO as a clock source for USB. */
  10324                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10325                    CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
  10326          
  10327                    /* Switch the oscillator. */
  10328                    CMU->CMD = CMU_CMD_USBCCLKSEL_USHFRCO;
  10329          
  10330                    /* Wait until the clock is activated. */
  10331                    while ((CMU->STATUS & CMU_STATUS_USBCUSHFRCOSEL) == 0) {
  10332                      // Wait for USB USHFRCO select.
  10333                    }
  10334                    break;
  10335          #endif
  10336          
  10337                  default:
  10338                    /* An illegal clock source for USB. */
  10339                    EFM_ASSERT(false);
  10340                    return;
  10341                }
  10342                break;
  10343          #endif
  10344          
  10345          #if defined(_CMU_ADCCTRL_ADC0CLKSEL_MASK)
  10346              case CMU_ADC0ASYNCSEL_REG:
  10347                switch (ref) {
  10348                  case cmuSelect_Disabled:
  10349                    tmp = _CMU_ADCCTRL_ADC0CLKSEL_DISABLED;
  10350                    break;
  10351          
  10352                  case cmuSelect_AUXHFRCO:
  10353                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10354                    CMU_OscillatorEnable(cmuOsc_AUXHFRCO, true, true);
  10355                    tmp = _CMU_ADCCTRL_ADC0CLKSEL_AUXHFRCO;
  10356                    break;
  10357          
  10358                  case cmuSelect_HFXO:
  10359                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10360                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10361                    tmp = _CMU_ADCCTRL_ADC0CLKSEL_HFXO;
  10362                    break;
  10363          
  10364                  case cmuSelect_HFSRCCLK:
  10365                    tmp = _CMU_ADCCTRL_ADC0CLKSEL_HFSRCCLK;
  10366                    break;
  10367          
  10368                  default:
  10369                    /* An illegal clock source for ADC0ASYNC selected. */
  10370                    EFM_ASSERT(false);
  10371                    return;
  10372                }
  10373          
  10374                /* Apply select. */
  10375                CMU->ADCCTRL = (CMU->ADCCTRL & ~_CMU_ADCCTRL_ADC0CLKSEL_MASK)
  10376                               | (tmp << _CMU_ADCCTRL_ADC0CLKSEL_SHIFT);
  10377                break;
  10378          #endif
  10379          
  10380          #if defined(_CMU_ADCCTRL_ADC1CLKSEL_MASK)
  10381              case CMU_ADC1ASYNCSEL_REG:
  10382                switch (ref) {
  10383                  case cmuSelect_Disabled:
  10384                    tmp = _CMU_ADCCTRL_ADC1CLKSEL_DISABLED;
  10385                    break;
  10386          
  10387                  case cmuSelect_AUXHFRCO:
  10388                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10389                    CMU_OscillatorEnable(cmuOsc_AUXHFRCO, true, true);
  10390                    tmp = _CMU_ADCCTRL_ADC1CLKSEL_AUXHFRCO;
  10391                    break;
  10392          
  10393                  case cmuSelect_HFXO:
  10394                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10395                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10396                    tmp = _CMU_ADCCTRL_ADC1CLKSEL_HFXO;
  10397                    break;
  10398          
  10399                  case cmuSelect_HFSRCCLK:
  10400                    tmp = _CMU_ADCCTRL_ADC1CLKSEL_HFSRCCLK;
  10401                    break;
  10402          
  10403                  default:
  10404                    /* An illegal clock source for ADC1ASYNC selected. */
  10405                    EFM_ASSERT(false);
  10406                    return;
  10407                }
  10408          
  10409                /* Apply select. */
  10410                CMU->ADCCTRL = (CMU->ADCCTRL & ~_CMU_ADCCTRL_ADC1CLKSEL_MASK)
  10411                               | (tmp << _CMU_ADCCTRL_ADC1CLKSEL_SHIFT);
  10412                break;
  10413          #endif
  10414          
  10415          #if defined(_CMU_SDIOCTRL_SDIOCLKSEL_MASK)
  10416              case CMU_SDIOREFSEL_REG:
  10417                switch (ref) {
  10418                  case cmuSelect_HFRCO:
  10419                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10420                    CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
  10421                    tmp = _CMU_SDIOCTRL_SDIOCLKSEL_HFRCO;
  10422                    break;
  10423          
  10424                  case cmuSelect_HFXO:
  10425                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10426                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10427                    tmp = _CMU_SDIOCTRL_SDIOCLKSEL_HFXO;
  10428                    break;
  10429          
  10430                  case cmuSelect_AUXHFRCO:
  10431                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10432                    CMU_OscillatorEnable(cmuOsc_AUXHFRCO, true, true);
  10433                    tmp = _CMU_SDIOCTRL_SDIOCLKSEL_AUXHFRCO;
  10434                    break;
  10435          
  10436                  case cmuSelect_USHFRCO:
  10437                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10438                    CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
  10439                    tmp = _CMU_SDIOCTRL_SDIOCLKSEL_USHFRCO;
  10440                    break;
  10441          
  10442                  default:
  10443                    /* An illegal clock source for SDIOREF selected. */
  10444                    EFM_ASSERT(false);
  10445                    return;
  10446                }
  10447          
  10448                /* Apply select. */
  10449                CMU->SDIOCTRL = (CMU->SDIOCTRL & ~_CMU_SDIOCTRL_SDIOCLKSEL_MASK)
  10450                                | (tmp << _CMU_SDIOCTRL_SDIOCLKSEL_SHIFT);
  10451                break;
  10452          #endif
  10453          
  10454          #if defined(_CMU_QSPICTRL_QSPI0CLKSEL_MASK)
  10455              case CMU_QSPI0REFSEL_REG:
  10456                switch (ref) {
  10457                  case cmuSelect_HFRCO:
  10458                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10459                    CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
  10460                    tmp = _CMU_QSPICTRL_QSPI0CLKSEL_HFRCO;
  10461                    break;
  10462          
  10463                  case cmuSelect_HFXO:
  10464                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10465                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10466                    tmp = _CMU_QSPICTRL_QSPI0CLKSEL_HFXO;
  10467                    break;
  10468          
  10469                  case cmuSelect_AUXHFRCO:
  10470                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10471                    CMU_OscillatorEnable(cmuOsc_AUXHFRCO, true, true);
  10472                    tmp = _CMU_QSPICTRL_QSPI0CLKSEL_AUXHFRCO;
  10473                    break;
  10474          
  10475                  case cmuSelect_USHFRCO:
  10476                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10477                    CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
  10478                    tmp = _CMU_QSPICTRL_QSPI0CLKSEL_USHFRCO;
  10479                    break;
  10480          
  10481                  default:
  10482                    /* An illegal clock source for QSPI0REF selected. */
  10483                    EFM_ASSERT(false);
  10484                    return;
  10485                }
  10486          
  10487                /* Apply select. */
  10488                CMU->QSPICTRL = (CMU->QSPICTRL & ~_CMU_QSPICTRL_QSPI0CLKSEL_MASK)
  10489                                | (tmp << _CMU_QSPICTRL_QSPI0CLKSEL_SHIFT);
  10490                break;
  10491          #endif
  10492          
  10493          #if defined(_CMU_USBCTRL_USBCLKSEL_MASK)
  10494              case CMU_USBRCLKSEL_REG:
  10495                switch (ref) {
  10496                  case cmuSelect_USHFRCO:
  10497                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10498                    CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
  10499                    tmp = _CMU_USBCTRL_USBCLKSEL_USHFRCO;
  10500                    break;
  10501          
  10502                  case cmuSelect_HFXO:
  10503                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10504                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10505                    tmp = _CMU_USBCTRL_USBCLKSEL_HFXO;
  10506                    break;
  10507          
  10508                  case cmuSelect_HFXOX2:
  10509                    /* Only allowed for HFXO frequencies up to 25 MHz. */
  10510                    EFM_ASSERT(SystemHFXOClockGet() <= 25000000u);
  10511          
  10512                    /* Enable HFXO X2. */
  10513                    CMU->HFXOCTRL |= CMU_HFXOCTRL_HFXOX2EN;
  10514          
  10515                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10516                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10517          
  10518                    tmp = _CMU_USBCTRL_USBCLKSEL_HFXOX2;
  10519                    break;
  10520          
  10521                  case cmuSelect_HFRCO:
  10522                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10523                    CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
  10524                    tmp = _CMU_USBCTRL_USBCLKSEL_HFRCO;
  10525                    break;
  10526          
  10527                  case cmuSelect_LFXO:
  10528                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10529                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
  10530                    tmp = _CMU_USBCTRL_USBCLKSEL_LFXO;
  10531                    break;
  10532          
  10533                  case cmuSelect_LFRCO:
  10534                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10535                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
  10536                    tmp = _CMU_USBCTRL_USBCLKSEL_LFRCO;
  10537                    break;
  10538          
  10539                  default:
  10540                    /* An illegal clock source for USBR selected. */
  10541                    EFM_ASSERT(false);
  10542                    return;
  10543                }
  10544          
  10545                /* Apply select. */
  10546                CMU->USBCTRL = (CMU->USBCTRL & ~_CMU_USBCTRL_USBCLKSEL_MASK)
  10547                               | (tmp << _CMU_USBCTRL_USBCLKSEL_SHIFT);
  10548                break;
  10549          #endif
  10550          
  10551          #if defined(_CMU_PDMCTRL_PDMCLKSEL_MASK)
  10552              case CMU_PDMREFSEL_REG:
  10553                switch (ref) {
  10554                  case cmuSelect_USHFRCO:
  10555                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10556                    CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
  10557                    tmp = _CMU_PDMCTRL_PDMCLKSEL_USHFRCO;
  10558                    break;
  10559          
  10560                  case cmuSelect_HFXO:
  10561                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10562                    CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10563                    tmp = _CMU_PDMCTRL_PDMCLKSEL_HFXO;
  10564                    break;
  10565          
  10566                  case cmuSelect_HFRCO:
  10567                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
  10568                    CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
  10569                    tmp = _CMU_PDMCTRL_PDMCLKSEL_HFRCO;
  10570                    break;
  10571          
  10572                  default:
  10573                    /* An illegal clock source for PDMREF selected. */
  10574                    EFM_ASSERT(false);
  10575                    return;
  10576                }
  10577          
  10578                /* Apply select. */
  10579                CMU->PDMCTRL = (CMU->PDMCTRL & ~_CMU_PDMCTRL_PDMCLKSEL_MASK)
  10580                               | (tmp << _CMU_PDMCTRL_PDMCLKSEL_SHIFT);
  10581                break;
  10582          #endif
  10583          
  10584              default:
  10585                EFM_ASSERT(false);
  10586                break;
  10587            }
  10588          }
  10589          
  10590          /***************************************************************************//**
  10591           * @brief
  10592           *   Gets the precision (in PPM) of the specified low frequency clock branch.
  10593           *
  10594           * @param[in] clock
  10595           *   Clock branch.
  10596           *
  10597           * @return
  10598           *   Precision, in PPM, of the specified clock branch.
  10599           *
  10600           * @note
  10601           *   This function is only for internal usage.
  10602           *
  10603           * @note
  10604           *   The current implementation of this function is used to determine if the
  10605           *   clock has a precision <= 500 ppm or not (which is the minimum required
  10606           *   for BLE). Future version of this function should provide more accurate
  10607           *   precision numbers to allow for further optimizations from the stacks.
  10608           ******************************************************************************/
  10609          uint16_t CMU_LF_ClockPrecisionGet(CMU_Clock_TypeDef clock)
  10610          {
  10611            CMU_Select_TypeDef src = CMU_ClockSelectGet(clock);
  10612            uint16_t precision;
  10613          
  10614            switch (src) {
  10615              case cmuSelect_LFXO:
  10616                precision = lfxo_precision;
  10617                break;
  10618          
  10619          #if defined(_SILICON_LABS_32B_SERIES_1) && defined(PLFRCO_PRESENT)
  10620              case cmuSelect_PLFRCO:
  10621                precision = 500;
  10622                break;
  10623          #endif
  10624          
  10625              default:
  10626                precision = 0xFFFF;
  10627                break;
  10628            }
  10629          
  10630            return precision;
  10631          }
  10632          
  10633          /***************************************************************************//**
  10634           * @brief
  10635           *   Gets the precision (in PPM) of the specified high frequency clock branch.
  10636           *
  10637           * @param[in] clock
  10638           *   Clock branch.
  10639           *
  10640           * @return
  10641           *   Precision, in PPM, of the specified clock branch.
  10642           *
  10643           * @note
  10644           *   This function is only for internal usage.
  10645           *
  10646           * @note
  10647           *   The current implementation of this function is used to determine if the
  10648           *   clock has a precision <= 500 ppm or not (which is the minimum required
  10649           *   for BLE). Future version of this function should provide more accurate
  10650           *   precision numbers to allow for further optimizations from the stacks.
  10651           ******************************************************************************/
  10652          uint16_t CMU_HF_ClockPrecisionGet(CMU_Clock_TypeDef clock)
  10653          {
  10654            CMU_Select_TypeDef src = CMU_ClockSelectGet(clock);
  10655            uint16_t precision;
  10656          
  10657            switch (src) {
  10658              case cmuSelect_HFXO:
  10659                precision = hfxo_precision;
  10660                break;
  10661          
  10662              case cmuSelect_HFRCO:
  10663                precision = 0xFFFF;
  10664                break;
  10665          
  10666              default:
  10667                precision = 0xFFFF;
  10668                break;
  10669            }
  10670          
  10671            return precision;
  10672          }
  10673          
  10674          #if defined(CMU_OSCENCMD_DPLLEN)
  10675          /**************************************************************************//**
  10676           * @brief
  10677           *   Lock the DPLL to a given frequency.
  10678           *
  10679           *   The frequency is given by: Fout = Fref * (N+1) / (M+1).
  10680           *
  10681           * @note
  10682           *   This function does not check if the given N & M values will actually
  10683           *   produce the desired target frequency. @n
  10684           *   N & M limitations: @n
  10685           *     300 < N <= 4095 @n
  10686           *     0 <= M <= 4095 @n
  10687           *   Any peripheral running off HFRCO should be switched to HFRCODIV2 prior to
  10688           *   calling this function to avoid over-clocking.
  10689           *
  10690           *   HFCLKLE prescaler is automatically modified before updating HFRCO
  10691           *   based on the maximum HFLE frequency allowed.
  10692           *
  10693           * @param[in] init
  10694           *    DPLL setup parameters.
  10695           *
  10696           * @return
  10697           *   Returns false on invalid target frequency or DPLL locking error.
  10698           *****************************************************************************/
  10699          bool CMU_DPLLLock(const CMU_DPLLInit_TypeDef *init)
  10700          {
  10701            int index = 0;
  10702            unsigned int i;
  10703            bool hfrcoDiv2override = false;
  10704            uint32_t hfrcoCtrlVal, lockStatus, sysFreq;
  10705          
  10706            EFM_ASSERT(init->frequency >= hfrcoCtrlTable[0].minFreq);
  10707            EFM_ASSERT(init->frequency
  10708                       <= hfrcoCtrlTable[HFRCOCTRLTABLE_ENTRIES - 1U].maxFreq);
  10709            EFM_ASSERT(init->n > 300U);
  10710            EFM_ASSERT(init->n <= (_CMU_DPLLCTRL1_N_MASK >> _CMU_DPLLCTRL1_N_SHIFT));
  10711            EFM_ASSERT(init->m <= (_CMU_DPLLCTRL1_M_MASK >> _CMU_DPLLCTRL1_M_SHIFT));
  10712            EFM_ASSERT(init->ssInterval  <= (_CMU_HFRCOSS_SSINV_MASK
  10713                                             >> _CMU_HFRCOSS_SSINV_SHIFT));
  10714            EFM_ASSERT(init->ssAmplitude <= (_CMU_HFRCOSS_SSAMP_MASK
  10715                                             >> _CMU_HFRCOSS_SSAMP_SHIFT));
  10716          
  10717          #if defined(_EMU_STATUS_VSCALE_MASK)
  10718            if ((EMU_VScaleGet() == emuVScaleEM01_LowPower)
  10719                && (init->frequency > CMU_VSCALEEM01_LOWPOWER_VOLTAGE_CLOCK_MAX)) {
  10720              EFM_ASSERT(false);
  10721              return false;
  10722            }
  10723          #endif
  10724          
  10725            // Find the correct HFRCO band and retrieve a HFRCOCTRL value.
  10726            for (i = 0; i < HFRCOCTRLTABLE_ENTRIES; i++) {
  10727              if ((init->frequency    >= hfrcoCtrlTable[i].minFreq)
  10728                  && (init->frequency <= hfrcoCtrlTable[i].maxFreq)) {
  10729                index = (int)i;                       // Correct band found
  10730                break;
  10731              }
  10732            }
  10733            if ((uint32_t)index == HFRCOCTRLTABLE_ENTRIES) {
  10734              EFM_ASSERT(false);
  10735              return false;                           // Target frequency out of spec.
  10736            }
  10737            hfrcoCtrlVal = hfrcoCtrlTable[index].value;
  10738          
  10739            // Check if a calibrated HFRCOCTRL.TUNING value is in device DI page.
  10740            if (hfrcoCtrlTable[index].band != (CMU_HFRCOFreq_TypeDef)0) {
  10741              uint32_t tuning;
  10742          
  10743              tuning = (CMU_HFRCODevinfoGet(hfrcoCtrlTable[index].band)
  10744                        & _CMU_HFRCOCTRL_TUNING_MASK)
  10745                       >> _CMU_HFRCOCTRL_TUNING_SHIFT;
  10746          
  10747              // When HFRCOCTRL.FINETUNINGEN is enabled, the center frequency
  10748              // of the band shifts down by 5.8%. 9 is subtracted to compensate.
  10749              if (tuning > 9UL) {
  10750                tuning -= 9UL;
  10751              } else {
  10752                tuning = 0UL;
  10753              }
  10754          
  10755              hfrcoCtrlVal |= tuning << _CMU_HFRCOCTRL_TUNING_SHIFT;
  10756            }
  10757          
  10758            // Update the CMSIS frequency SystemHfrcoFreq value.
  10759            SystemHfrcoFreq = init->frequency;
  10760          
  10761            // Set maximum wait-states while changing the core clock.
  10762            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10763              flashWaitStateMax();
  10764            }
  10765          
  10766            // Update the HFLE configuration before updating HFRCO, use new DPLL frequency.
  10767            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10768              setHfLeConfig(init->frequency);
  10769          
  10770              // Switch to HFRCO/2 before setting DPLL to avoid over-clocking.
  10771              hfrcoDiv2override = true;
  10772              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCODIV2;
  10773            }
  10774          
  10775            CMU->OSCENCMD  = CMU_OSCENCMD_DPLLDIS;
  10776            while ((CMU->STATUS & (CMU_STATUS_DPLLENS | CMU_STATUS_DPLLRDY)) != 0UL) {
  10777              // Wait for DPLL disabled.
  10778            }
  10779            CMU->IFC       = CMU_IFC_DPLLRDY | CMU_IFC_DPLLLOCKFAILLOW
  10780                             | CMU_IFC_DPLLLOCKFAILHIGH;
  10781            CMU->DPLLCTRL1 = ((uint32_t)init->n   << _CMU_DPLLCTRL1_N_SHIFT)
  10782                             | ((uint32_t)init->m << _CMU_DPLLCTRL1_M_SHIFT);
  10783            CMU->HFRCOCTRL = hfrcoCtrlVal;
  10784            CMU->DPLLCTRL  = ((uint32_t)init->refClk << _CMU_DPLLCTRL_REFSEL_SHIFT)
  10785                             | ((init->autoRecover ? 1UL : 0UL)
  10786                                << _CMU_DPLLCTRL_AUTORECOVER_SHIFT)
  10787                             | ((uint32_t)init->edgeSel << _CMU_DPLLCTRL_EDGESEL_SHIFT)
  10788                             | ((uint32_t)init->lockMode << _CMU_DPLLCTRL_MODE_SHIFT);
  10789            CMU->OSCENCMD  = CMU_OSCENCMD_DPLLEN;
  10790            while ((lockStatus = (CMU->IF & (CMU_IF_DPLLRDY
  10791                                             | CMU_IF_DPLLLOCKFAILLOW
  10792                                             | CMU_IF_DPLLLOCKFAILHIGH))) == 0UL) {
  10793              // Wait for DPLL lock status.
  10794            }
  10795          
  10796            // Restore to HFRCO
  10797            if ((CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCODIV2)
  10798                && (hfrcoDiv2override == true)) {
  10799              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCO;
  10800            }
  10801          
  10802            // If HFRCO is selected as an HF clock, optimize the flash access wait-state
  10803            // configuration for this frequency and update the CMSIS core clock variable.
  10804            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10805              // Call @ref SystemCoreClockGet() to update the CMSIS core clock variable.
  10806              sysFreq = SystemCoreClockGet();
  10807              EFM_ASSERT(sysFreq <= init->frequency);
  10808              EFM_ASSERT(sysFreq <= SystemHfrcoFreq);
  10809              EFM_ASSERT(init->frequency == SystemHfrcoFreq);
  10810              CMU_UpdateWaitStates(sysFreq, VSCALE_DEFAULT);
  10811            }
  10812          
  10813            // Reduce HFLE frequency if possible.
  10814            setHfLeConfig(SystemHFClockGet());
  10815          
  10816          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10817            // Update voltage scaling.
  10818            EMU_VScaleEM01ByClock(0, true);
  10819          #endif
  10820          
  10821            if (lockStatus == CMU_IF_DPLLRDY) {
  10822              return true;
  10823            }
  10824            return false;
  10825          }
  10826          #endif // CMU_OSCENCMD_DPLLEN
  10827          
  10828          /**************************************************************************//**
  10829           * @brief
  10830           *   CMU low frequency register synchronization freeze control.
  10831           *
  10832           * @details
  10833           *   Some CMU registers require synchronization into the low-frequency (LF)
  10834           *   domain. The freeze feature allows for several such registers to be
  10835           *   modified before passing them to the LF domain simultaneously (which
  10836           *   takes place when the freeze mode is disabled).
  10837           *
  10838           *   Another use case for this feature is using an API (such
  10839           *   as the CMU API) for modifying several bit fields consecutively in the
  10840           *   same register. If freeze mode is enabled during this sequence, stalling
  10841           *   can be avoided.
  10842           *
  10843           * @note
  10844           *   When enabling freeze mode, this function will wait for all current
  10845           *   ongoing CMU synchronization to LF domain to complete (normally
  10846           *   synchronization will not be in progress.) However, for this reason, when
  10847           *   using freeze mode, modifications of registers requiring LF synchronization
  10848           *   should be done within one freeze enable/disable block to avoid unnecessary
  10849           *   stalling.
  10850           *
  10851           * @param[in] enable
  10852           *   @li true - enable freeze, modified registers are not propagated to the
  10853           *       LF domain
  10854           *   @li false - disable freeze, modified registers are propagated to the LF
  10855           *       domain
  10856           *****************************************************************************/
  10857          void CMU_FreezeEnable(bool enable)
  10858          {
  10859            if (enable) {
  10860              /* Wait for any ongoing LF synchronizations to complete. This */
  10861              /* protects against the rare case when a user                            */
  10862              /* - modifies a register requiring LF sync                              */
  10863              /* - then enables freeze before LF sync completed                       */
  10864              /* - then modifies the same register again                              */
  10865              /* since modifying a register while it is in sync progress should be    */
  10866              /* avoided.                                                             */
  10867              while (CMU->SYNCBUSY != 0UL) {
  10868                // Wait for LF sync.
  10869              }
  10870          
  10871              CMU->FREEZE = CMU_FREEZE_REGFREEZE;
  10872            } else {
  10873              CMU->FREEZE = 0;
  10874            }
  10875          }
  10876          
  10877          #if defined(_CMU_HFRCOCTRL_BAND_MASK)
  10878          /***************************************************************************//**
  10879           * @brief
  10880           *   Get HFRCO band in use.
  10881           *
  10882           * @return
  10883           *   HFRCO band in use.
  10884           ******************************************************************************/
  10885          CMU_HFRCOBand_TypeDef CMU_HFRCOBandGet(void)
  10886          {
  10887            return (CMU_HFRCOBand_TypeDef)((CMU->HFRCOCTRL & _CMU_HFRCOCTRL_BAND_MASK)
  10888                                           >> _CMU_HFRCOCTRL_BAND_SHIFT);
  10889          }
  10890          #endif /* _CMU_HFRCOCTRL_BAND_MASK */
  10891          
  10892          #if defined(_CMU_HFRCOCTRL_BAND_MASK)
  10893          /***************************************************************************//**
  10894           * @brief
  10895           *   Set HFRCO band and the tuning value based on the value in the calibration
  10896           *   table made during production.
  10897           *
  10898           * @note
  10899           *   HFCLKLE prescaler is automatically modified based on the maximum
  10900           *   HFLE frequency allowed.
  10901           *
  10902           * @param[in] band
  10903           *   HFRCO band to activate.
  10904           ******************************************************************************/
  10905          void CMU_HFRCOBandSet(CMU_HFRCOBand_TypeDef band)
  10906          {
  10907            uint32_t           tuning;
  10908            uint32_t           freq;
  10909            CMU_Select_TypeDef osc;
  10910          
  10911            /* Read the tuning value from the calibration table. */
  10912            switch (band) {
  10913              case cmuHFRCOBand_1MHz:
  10914                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND1_MASK)
  10915                         >> _DEVINFO_HFRCOCAL0_BAND1_SHIFT;
  10916                break;
  10917          
  10918              case cmuHFRCOBand_7MHz:
  10919                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND7_MASK)
  10920                         >> _DEVINFO_HFRCOCAL0_BAND7_SHIFT;
  10921                break;
  10922          
  10923              case cmuHFRCOBand_11MHz:
  10924                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND11_MASK)
  10925                         >> _DEVINFO_HFRCOCAL0_BAND11_SHIFT;
  10926                break;
  10927          
  10928              case cmuHFRCOBand_14MHz:
  10929                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND14_MASK)
  10930                         >> _DEVINFO_HFRCOCAL0_BAND14_SHIFT;
  10931                break;
  10932          
  10933              case cmuHFRCOBand_21MHz:
  10934                tuning = (DEVINFO->HFRCOCAL1 & _DEVINFO_HFRCOCAL1_BAND21_MASK)
  10935                         >> _DEVINFO_HFRCOCAL1_BAND21_SHIFT;
  10936                break;
  10937          
  10938          #if defined(_CMU_HFRCOCTRL_BAND_28MHZ)
  10939              case cmuHFRCOBand_28MHz:
  10940                tuning = (DEVINFO->HFRCOCAL1 & _DEVINFO_HFRCOCAL1_BAND28_MASK)
  10941                         >> _DEVINFO_HFRCOCAL1_BAND28_SHIFT;
  10942                break;
  10943          #endif
  10944          
  10945              default:
  10946                EFM_ASSERT(false);
  10947                return;
  10948            }
  10949          
  10950            /* If HFRCO is used for the core clock, flash access WS has to be considered. */
  10951            osc = CMU_ClockSelectGet(cmuClock_HF);
  10952            if (osc == cmuSelect_HFRCO) {
  10953              /* Configure worst case wait states for flash access before setting the divider. */
  10954              flashWaitStateMax();
  10955            }
  10956          
  10957            /* Set band/tuning. */
  10958            CMU->HFRCOCTRL = (CMU->HFRCOCTRL
  10959                              & ~(_CMU_HFRCOCTRL_BAND_MASK | _CMU_HFRCOCTRL_TUNING_MASK))
  10960                             | (band << _CMU_HFRCOCTRL_BAND_SHIFT)
  10961                             | (tuning << _CMU_HFRCOCTRL_TUNING_SHIFT);
  10962          
  10963            /* If HFRCO is used for the core clock, optimize flash WS. */
  10964            if (osc == cmuSelect_HFRCO) {
  10965              /* Call @ref SystemCoreClockGet() to update the CMSIS core clock variable. */
  10966              freq = SystemCoreClockGet();
  10967              CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
  10968            }
  10969          
  10970          #if defined(CMU_MAX_FREQ_HFLE)
  10971            /* Reduce HFLE frequency if possible. */
  10972            setHfLeConfig(SystemCoreClockGet());
  10973          #endif
  10974          }
  10975          #endif /* _CMU_HFRCOCTRL_BAND_MASK */
  10976          
  10977          #if defined(_CMU_HFRCOCTRL_FREQRANGE_MASK)
  10978          /**************************************************************************//**
  10979           * @brief
  10980           *   Get the HFRCO frequency calibration word in DEVINFO.
  10981           *
  10982           * @param[in] freq
  10983           *   Frequency in Hz.
  10984           *
  10985           * @return
  10986           *   HFRCO calibration word for a given frequency.
  10987           *****************************************************************************/
  10988          static uint32_t CMU_HFRCODevinfoGet(CMU_HFRCOFreq_TypeDef freq)
  10989          {
  10990            switch (freq) {
  10991              /* 1, 2, and 4 MHz share the same calibration word. */
  10992              case cmuHFRCOFreq_1M0Hz:
  10993              case cmuHFRCOFreq_2M0Hz:
  10994              case cmuHFRCOFreq_4M0Hz:
  10995                return DEVINFO->HFRCOCAL0;
  10996          
  10997              case cmuHFRCOFreq_7M0Hz:
  10998                return DEVINFO->HFRCOCAL3;
  10999          
  11000              case cmuHFRCOFreq_13M0Hz:
  11001                return DEVINFO->HFRCOCAL6;
  11002          
  11003              case cmuHFRCOFreq_16M0Hz:
  11004                return DEVINFO->HFRCOCAL7;
  11005          
  11006              case cmuHFRCOFreq_19M0Hz:
  11007                return DEVINFO->HFRCOCAL8;
  11008          
  11009              case cmuHFRCOFreq_26M0Hz:
  11010                return DEVINFO->HFRCOCAL10;
  11011          
  11012              case cmuHFRCOFreq_32M0Hz:
  11013                return DEVINFO->HFRCOCAL11;
  11014          
  11015              case cmuHFRCOFreq_38M0Hz:
  11016                return DEVINFO->HFRCOCAL12;
  11017          
  11018          #if defined(_DEVINFO_HFRCOCAL13_MASK)
  11019              case cmuHFRCOFreq_48M0Hz:
  11020                return DEVINFO->HFRCOCAL13;
  11021          #endif
  11022          
  11023          #if defined(_DEVINFO_HFRCOCAL14_MASK)
  11024              case cmuHFRCOFreq_56M0Hz:
  11025                return DEVINFO->HFRCOCAL14;
  11026          #endif
  11027          
  11028          #if defined(_DEVINFO_HFRCOCAL15_MASK)
  11029              case cmuHFRCOFreq_64M0Hz:
  11030                return DEVINFO->HFRCOCAL15;
  11031          #endif
  11032          
  11033          #if defined(_DEVINFO_HFRCOCAL16_MASK)
  11034              case cmuHFRCOFreq_72M0Hz:
  11035                return DEVINFO->HFRCOCAL16;
  11036          #endif
  11037          
  11038              default: /* cmuHFRCOFreq_UserDefined */
  11039                return 0;
  11040            }
  11041          }
  11042          
  11043          /***************************************************************************//**
  11044           * @brief
  11045           *   Get the current HFRCO frequency.
  11046           *
  11047           * @return
  11048           *   HFRCO frequency.
  11049           ******************************************************************************/
  11050          CMU_HFRCOFreq_TypeDef CMU_HFRCOBandGet(void)
  11051          {
  11052            return (CMU_HFRCOFreq_TypeDef)SystemHfrcoFreq;
  11053          }
  11054          
  11055          /***************************************************************************//**
  11056           * @brief
  11057           *   Set the HFRCO calibration for the selected target frequency.
  11058           *
  11059           * @note
  11060           *   HFCLKLE prescaler is automatically modified based on the maximum
  11061           *   HFLE frequency allowed.
  11062           *
  11063           * @param[in] setFreq
  11064           *   HFRCO frequency to set.
  11065           ******************************************************************************/
  11066          void CMU_HFRCOBandSet(CMU_HFRCOFreq_TypeDef setFreq)
  11067          {
  11068            uint32_t freqCal;
  11069            uint32_t sysFreq;
  11070            uint32_t prevFreq;
  11071          
  11072            /* Get the DEVINFO index and set the CMSIS frequency SystemHfrcoFreq. */
  11073            freqCal = CMU_HFRCODevinfoGet(setFreq);
  11074            EFM_ASSERT((freqCal != 0UL) && (freqCal != UINT_MAX));
  11075            prevFreq = SystemHfrcoFreq;
  11076            SystemHfrcoFreq = (uint32_t)setFreq;
  11077          
  11078            /* Set maximum wait-states and set safe HFPER clock-tree prescalers while
  11079               changing the core clock. */
  11080            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  11081              flashWaitStateMax();
  11082              hfperClkSafePrescaler();
  11083            }
  11084          
  11085            /* Wait for any previous sync to complete and set calibration data
  11086               for the selected frequency.  */
  11087            while (BUS_RegBitRead(&CMU->SYNCBUSY, _CMU_SYNCBUSY_HFRCOBSY_SHIFT) != 0UL) {
  11088              // Wait for HFRCO sync.
  11089            }
  11090          
  11091            /* Check for valid calibration data. */
  11092            EFM_ASSERT(freqCal != UINT_MAX);
  11093          
  11094            /* Set divider in HFRCOCTRL for 1, 2, and 4 MHz. */
  11095            switch (setFreq) {
  11096              case cmuHFRCOFreq_1M0Hz:
  11097                freqCal = (freqCal & ~_CMU_HFRCOCTRL_CLKDIV_MASK)
  11098                          | CMU_HFRCOCTRL_CLKDIV_DIV4;
  11099                break;
  11100          
  11101              case cmuHFRCOFreq_2M0Hz:
  11102                freqCal = (freqCal & ~_CMU_HFRCOCTRL_CLKDIV_MASK)
  11103                          | CMU_HFRCOCTRL_CLKDIV_DIV2;
  11104                break;
  11105          
  11106              case cmuHFRCOFreq_4M0Hz:
  11107                freqCal = (freqCal & ~_CMU_HFRCOCTRL_CLKDIV_MASK)
  11108                          | CMU_HFRCOCTRL_CLKDIV_DIV1;
  11109                break;
  11110          
  11111              default:
  11112                break;
  11113            }
  11114          
  11115            /* Update HFLE configuration before updating HFRCO.
  11116               Use the new set frequency. */
  11117            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  11118              /* setFreq is worst-case as dividers may reduce the HFLE frequency. */
  11119              setHfLeConfig((uint32_t)setFreq);
  11120            }
  11121          
  11122            if ((uint32_t)setFreq > prevFreq) {
  11123          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  11124              /* When increasing frequency voltage scale must be done before the change. */
  11125              EMU_VScaleEM01ByClock((uint32_t)setFreq, true);
  11126          #endif
  11127            }
  11128          
  11129            CMU->HFRCOCTRL = freqCal;
  11130          
  11131            /* If HFRCO is selected as an HF clock, optimize the flash access wait-state configuration
  11132               for this frequency and update the CMSIS core clock variable. */
  11133            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  11134              /* Call @ref SystemCoreClockGet() to update the CMSIS core clock variable. */
  11135              sysFreq = SystemCoreClockGet();
  11136              EFM_ASSERT(sysFreq <= (uint32_t)setFreq);
  11137              EFM_ASSERT(sysFreq <= SystemHfrcoFreq);
  11138              EFM_ASSERT((uint32_t)setFreq == SystemHfrcoFreq);
  11139              CMU_UpdateWaitStates(sysFreq, VSCALE_DEFAULT);
  11140            }
  11141          
  11142            /* Reduce HFLE frequency if possible. */
  11143            setHfLeConfig(SystemHFClockGet());
  11144          
  11145            if ((uint32_t)setFreq <= prevFreq) {
  11146          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  11147              /* When decreasing frequency voltage scale must be done after the change */
  11148              EMU_VScaleEM01ByClock(0, true);
  11149          #endif
  11150            }
  11151            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  11152              /* Set optimized HFPER clock-tree prescalers. */
  11153              hfperClkOptimizedPrescaler();
  11154            }
  11155          }
  11156          #endif /* _CMU_HFRCOCTRL_FREQRANGE_MASK */
  11157          
  11158          #if defined(_CMU_HFRCOCTRL_SUDELAY_MASK)
  11159          /***************************************************************************//**
  11160           * @brief
  11161           *   Get the HFRCO startup delay.
  11162           *
  11163           * @details
  11164           *   See the reference manual for more details.
  11165           *
  11166           * @return
  11167           *   The startup delay in use.
  11168           ******************************************************************************/
  11169          uint32_t CMU_HFRCOStartupDelayGet(void)
  11170          {
  11171            return (CMU->HFRCOCTRL & _CMU_HFRCOCTRL_SUDELAY_MASK)
  11172                   >> _CMU_HFRCOCTRL_SUDELAY_SHIFT;
  11173          }
  11174          
  11175          /***************************************************************************//**
  11176           * @brief
  11177           *   Set the HFRCO startup delay.
  11178           *
  11179           * @details
  11180           *   See the reference manual for more details.
  11181           *
  11182           * @param[in] delay
  11183           *   The startup delay to set (<= 31).
  11184           ******************************************************************************/
  11185          void CMU_HFRCOStartupDelaySet(uint32_t delay)
  11186          {
  11187            EFM_ASSERT(delay <= 31);
  11188          
  11189            delay &= _CMU_HFRCOCTRL_SUDELAY_MASK >> _CMU_HFRCOCTRL_SUDELAY_SHIFT;
  11190            CMU->HFRCOCTRL = (CMU->HFRCOCTRL & ~(_CMU_HFRCOCTRL_SUDELAY_MASK))
  11191                             | (delay << _CMU_HFRCOCTRL_SUDELAY_SHIFT);
  11192          }
  11193          #endif
  11194          
  11195          #if defined(_CMU_USHFRCOCTRL_FREQRANGE_MASK)
  11196          /**************************************************************************//**
  11197           * @brief
  11198           *   Get the USHFRCO frequency calibration word in DEVINFO.
  11199           *
  11200           * @param[in] freq
  11201           *   Frequency in Hz.
  11202           *
  11203           * @return
  11204           *   USHFRCO calibration word for a given frequency.
  11205           *****************************************************************************/
  11206          static uint32_t CMU_USHFRCODevinfoGet(CMU_USHFRCOFreq_TypeDef freq)
  11207          {
  11208            switch (freq) {
  11209              case cmuUSHFRCOFreq_16M0Hz:
  11210                return DEVINFO->USHFRCOCAL7;
  11211          
  11212              case cmuUSHFRCOFreq_32M0Hz:
  11213                return DEVINFO->USHFRCOCAL11;
  11214          
  11215              case cmuUSHFRCOFreq_48M0Hz:
  11216                return DEVINFO->USHFRCOCAL13;
  11217          
  11218              case cmuUSHFRCOFreq_50M0Hz:
  11219                return DEVINFO->USHFRCOCAL14;
  11220          
  11221              default: /* cmuUSHFRCOFreq_UserDefined */
  11222                return 0;
  11223            }
  11224          }
  11225          
  11226          /***************************************************************************//**
  11227           * @brief
  11228           *   Get the current USHFRCO frequency.
  11229           *
  11230           * @return
  11231           *   HFRCO frequency.
  11232           ******************************************************************************/
  11233          CMU_USHFRCOFreq_TypeDef CMU_USHFRCOBandGet(void)
  11234          {
  11235            return (CMU_USHFRCOFreq_TypeDef) ushfrcoFreq;
  11236          }
  11237          
  11238          /***************************************************************************//**
  11239           * @brief
  11240           *   Get USHFRCO frequency.
  11241           *
  11242           * @return
  11243           *   USHFRCO frequency.
  11244           ******************************************************************************/
  11245          uint32_t CMU_USHFRCOFreqGet(void)
  11246          {
  11247            return ushfrcoFreq;
  11248          }
  11249          
  11250          /***************************************************************************//**
  11251           * @brief
  11252           *   Set the USHFRCO calibration for the selected target frequency.
  11253           *
  11254           * @param[in] setFreq
  11255           *   USHFRCO frequency to set.
  11256           ******************************************************************************/
  11257          void CMU_USHFRCOBandSet(CMU_USHFRCOFreq_TypeDef setFreq)
  11258          {
  11259            uint32_t freqCal;
  11260          
  11261            /* Get DEVINFO calibration values. */
  11262            freqCal = CMU_USHFRCODevinfoGet(setFreq);
  11263            EFM_ASSERT((freqCal != 0) && (freqCal != UINT_MAX));
  11264            ushfrcoFreq = (uint32_t)setFreq;
  11265          
  11266            /* Wait for any previous sync to complete and set calibration data
  11267               for the selected frequency.  */
  11268            while (BUS_RegBitRead(&CMU->SYNCBUSY, _CMU_SYNCBUSY_USHFRCOBSY_SHIFT)) ;
  11269          
  11270            CMU->USHFRCOCTRL = freqCal;
  11271          }
  11272          #endif /* _CMU_USHFRCOCTRL_FREQRANGE_MASK  */
  11273          
  11274          #if defined(_CMU_HFXOCTRL_AUTOSTARTEM0EM1_MASK)
  11275          /***************************************************************************//**
  11276           * @brief
  11277           *   Enable or disable HFXO autostart.
  11278           *
  11279           * @param[in] userSel
  11280           *   Additional user specified enable bit.
  11281           *
  11282           * @param[in] enEM0EM1Start
  11283           *   If true, HFXO is automatically started upon entering EM0/EM1 entry from
  11284           *   EM2/EM3. HFXO selection has to be handled by the user.
  11285           *   If false, HFXO is not started automatically when entering EM0/EM1.
  11286           *
  11287           * @param[in] enEM0EM1StartSel
  11288           *   If true, HFXO is automatically started and immediately selected upon
  11289           *   entering EM0/EM1 entry from EM2/EM3. Note that this option stalls the use of
  11290           *   HFSRCCLK until HFXO becomes ready. HFCLKLE prescaler is also automatically
  11291           *   modified if userSel is specified.
  11292           *   If false, HFXO is not started or selected automatically when entering
  11293           *   EM0/EM1.
  11294           ******************************************************************************/
  11295          void CMU_HFXOAutostartEnable(uint32_t userSel,
  11296                                       bool enEM0EM1Start,
  11297                                       bool enEM0EM1StartSel)
  11298          {
  11299            uint32_t hfxoFreq;
  11300            uint32_t hfxoCtrl;
  11301          
  11302          #if defined(_EMU_CTRL_EM23VSCALE_MASK)
  11303            if (enEM0EM1StartSel) {
  11304              /* Voltage scaling is not compatible with HFXO auto start and select. */
  11305              EFM_ASSERT((EMU->CTRL & _EMU_CTRL_EM23VSCALE_MASK) == EMU_CTRL_EM23VSCALE_VSCALE2);
  11306            }
  11307          #endif
  11308          
  11309            /* Mask supported enable bits. */
  11310          #if defined(_CMU_HFXOCTRL_AUTOSTARTRDYSELRAC_MASK)
  11311            userSel &= _CMU_HFXOCTRL_AUTOSTARTRDYSELRAC_MASK;
  11312          #else
  11313            userSel = 0;
  11314          #endif
  11315          
  11316            hfxoFreq = SystemHFXOClockGet();
  11317          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  11318            // Update voltage scaling.
  11319            EMU_VScaleEM01ByClock(hfxoFreq, true);
  11320          #endif
  11321            /* Set wait-states for HFXO if automatic start and select is configured. */
  11322            if ((userSel > 0UL) || enEM0EM1StartSel) {
  11323              CMU_UpdateWaitStates(hfxoFreq, VSCALE_DEFAULT);
  11324              setHfLeConfig(hfxoFreq / CMU_ClockDivGet(cmuClock_HF));
  11325            }
  11326          
  11327            if (enEM0EM1Start || enEM0EM1StartSel) {
  11328              /* Enable the HFXO once in order to finish first time calibrations. */
  11329              CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  11330            }
  11331          
  11332            /* Since call to CMU_OscillatorEnable() can change the CMU->HFXOCTRL register,
  11333             * it's important to read the CMU->HFXOCTRL register after the call to CMU_OscillatorEnable(). */
  11334            hfxoCtrl = CMU->HFXOCTRL & ~(userSel
  11335                                         | _CMU_HFXOCTRL_AUTOSTARTEM0EM1_MASK
  11336                                         | _CMU_HFXOCTRL_AUTOSTARTSELEM0EM1_MASK);
  11337          
  11338            hfxoCtrl |= userSel
  11339                        | (enEM0EM1Start ? CMU_HFXOCTRL_AUTOSTARTEM0EM1 : 0UL)
  11340                        | (enEM0EM1StartSel ? CMU_HFXOCTRL_AUTOSTARTSELEM0EM1 : 0UL);
  11341          
  11342            /* Update HFXOCTRL after wait-states are updated as HF may automatically switch
  11343               to HFXO when automatic select is enabled . */
  11344            CMU->HFXOCTRL = hfxoCtrl;
  11345          }
  11346          #endif
  11347          
  11348          /**************************************************************************//**
  11349           * @brief
  11350           *   Set HFXO control registers.
  11351           *
  11352           * @note
  11353           *   HFXO configuration should be obtained from a configuration tool,
  11354           *   app note, or crystal data sheet. This function disables the HFXO to
  11355           *   ensure a valid state before update.
  11356           *
  11357           * @param[in] hfxoInit
  11358           *    HFXO setup parameters.
  11359           *****************************************************************************/
  11360          void CMU_HFXOInit(const CMU_HFXOInit_TypeDef *hfxoInit)
  11361          {
  11362            /* Do not disable HFXO if it is currently selected as the HF/Core clock. */
  11363            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_HF) != cmuSelect_HFXO);
  11364          
  11365            /* HFXO must be disabled before reconfiguration. */
  11366            CMU_OscillatorEnable(cmuOsc_HFXO, false, true);
  11367          
  11368          #if defined(_SILICON_LABS_32B_SERIES_1) \
  11369            && (_SILICON_LABS_GECKO_INTERNAL_SDID >= 100)
  11370            uint32_t tmp = CMU_HFXOCTRL_MODE_XTAL;
  11371          
  11372            switch (hfxoInit->mode) {
  11373              case cmuOscMode_Crystal:
  11374                tmp = CMU_HFXOCTRL_MODE_XTAL;
  11375                break;
  11376              case cmuOscMode_External:
  11377                tmp = CMU_HFXOCTRL_MODE_DIGEXTCLK;
  11378                break;
  11379              case cmuOscMode_AcCoupled:
  11380                tmp = CMU_HFXOCTRL_MODE_ACBUFEXTCLK;
  11381                break;
  11382              default:
  11383                EFM_ASSERT(false); /* Unsupported configuration */
  11384                break;
  11385            }
  11386            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_MODE_MASK) | tmp;
  11387          
  11388          #if defined(CMU_HFXOCTRL_HFXOX2EN)
  11389            /* HFXO Doubler can only be enabled on crystals up to max 25 MHz. */
  11390            tmp = 0;
  11391            if (SystemHFXOClockGet() <= 25000000) {
  11392              tmp |= CMU_HFXOCTRL_HFXOX2EN;
  11393            }
  11394          
  11395            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_HFXOX2EN_MASK) | tmp;
  11396          #endif
  11397          
  11398            /* Set tuning for startup and steady state. */
  11399            CMU->HFXOSTARTUPCTRL = (hfxoInit->ctuneStartup
  11400                                    << _CMU_HFXOSTARTUPCTRL_CTUNE_SHIFT)
  11401                                   | (hfxoInit->xoCoreBiasTrimStartup
  11402                                      << _CMU_HFXOSTARTUPCTRL_IBTRIMXOCORE_SHIFT);
  11403          
  11404            CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  11405                                        & ~(_CMU_HFXOSTEADYSTATECTRL_CTUNE_MASK
  11406                                            | _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK))
  11407                                       | (hfxoInit->ctuneSteadyState
  11408                                          << _CMU_HFXOSTEADYSTATECTRL_CTUNE_SHIFT)
  11409                                       | (hfxoInit->xoCoreBiasTrimSteadyState
  11410                                          << _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_SHIFT);
  11411          
  11412            /* Set timeouts */
  11413            CMU->HFXOTIMEOUTCTRL = (hfxoInit->timeoutPeakDetect
  11414                                    << _CMU_HFXOTIMEOUTCTRL_PEAKDETTIMEOUT_SHIFT)
  11415                                   | (hfxoInit->timeoutSteady
  11416                                      << _CMU_HFXOTIMEOUTCTRL_STEADYTIMEOUT_SHIFT)
  11417                                   | (hfxoInit->timeoutStartup
  11418                                      << _CMU_HFXOTIMEOUTCTRL_STARTUPTIMEOUT_SHIFT);
  11419          
  11420          #elif defined(_CMU_HFXOCTRL_MASK)
  11421            uint32_t tmp = CMU_HFXOCTRL_MODE_XTAL;
  11422          
  11423            /* AC coupled external clock not supported. */
  11424            EFM_ASSERT(hfxoInit->mode != cmuOscMode_AcCoupled);
  11425            if (hfxoInit->mode == cmuOscMode_External) {
  11426              tmp = CMU_HFXOCTRL_MODE_DIGEXTCLK;
  11427            }
  11428          
  11429            /* Apply control settings. */
  11430            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_MODE_MASK)
  11431                            | tmp;
  11432            BUS_RegBitWrite(&CMU->HFXOCTRL,
  11433                            _CMU_HFXOCTRL_LOWPOWER_SHIFT,
  11434                            (unsigned)hfxoInit->lowPowerMode);
  11435          
  11436            /* Set XTAL tuning parameters. */
  11437          
  11438          #if defined(_CMU_HFXOCTRL1_PEAKDETTHR_MASK)
  11439            /* Set peak detection threshold. */
  11440            CMU->HFXOCTRL1 = (CMU->HFXOCTRL1 & ~_CMU_HFXOCTRL1_PEAKDETTHR_MASK)
  11441                             | (hfxoInit->thresholdPeakDetect
  11442                                << _CMU_HFXOCTRL1_PEAKDETTHR_SHIFT);
  11443          #endif
  11444            /* Set tuning for startup and steady state. */
  11445            CMU->HFXOSTARTUPCTRL = ((uint32_t)hfxoInit->ctuneStartup
  11446                                    << _CMU_HFXOSTARTUPCTRL_CTUNE_SHIFT)
  11447                                   | ((uint32_t)hfxoInit->xoCoreBiasTrimStartup
  11448                                      << _CMU_HFXOSTARTUPCTRL_IBTRIMXOCORE_SHIFT);
  11449          
  11450            CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  11451                                        & ~(_CMU_HFXOSTEADYSTATECTRL_CTUNE_MASK
  11452                                            | _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK
  11453                                            | _CMU_HFXOSTEADYSTATECTRL_REGISH_MASK
  11454                                            | _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK))
  11455                                       | ((uint32_t)hfxoInit->ctuneSteadyState
  11456                                          << _CMU_HFXOSTEADYSTATECTRL_CTUNE_SHIFT)
  11457                                       | ((uint32_t)hfxoInit->xoCoreBiasTrimSteadyState
  11458                                          << _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_SHIFT)
  11459                                       | ((uint32_t)hfxoInit->regIshSteadyState
  11460                                          << _CMU_HFXOSTEADYSTATECTRL_REGISH_SHIFT)
  11461                                       | getRegIshUpperVal(hfxoInit->regIshSteadyState);
  11462          
  11463            /* Set timeouts. */
  11464            CMU->HFXOTIMEOUTCTRL = ((uint32_t)hfxoInit->timeoutPeakDetect
  11465                                    << _CMU_HFXOTIMEOUTCTRL_PEAKDETTIMEOUT_SHIFT)
  11466                                   | ((uint32_t)hfxoInit->timeoutSteady
  11467                                      << _CMU_HFXOTIMEOUTCTRL_STEADYTIMEOUT_SHIFT)
  11468                                   | ((uint32_t)hfxoInit->timeoutStartup
  11469                                      << _CMU_HFXOTIMEOUTCTRL_STARTUPTIMEOUT_SHIFT)
  11470                                   | ((uint32_t)hfxoInit->timeoutShuntOptimization
  11471                                      << _CMU_HFXOTIMEOUTCTRL_SHUNTOPTTIMEOUT_SHIFT);
  11472          
  11473          #else
  11474            CMU->CTRL = (CMU->CTRL & ~(_CMU_CTRL_HFXOTIMEOUT_MASK
  11475                                       | _CMU_CTRL_HFXOBOOST_MASK
  11476                                       | _CMU_CTRL_HFXOMODE_MASK
  11477                                       | _CMU_CTRL_HFXOGLITCHDETEN_MASK))
  11478                        | (hfxoInit->timeout << _CMU_CTRL_HFXOTIMEOUT_SHIFT)
  11479                        | (hfxoInit->boost << _CMU_CTRL_HFXOBOOST_SHIFT)
  11480                        | (hfxoInit->mode << _CMU_CTRL_HFXOMODE_SHIFT)
  11481                        | (hfxoInit->glitchDetector ? CMU_CTRL_HFXOGLITCHDETEN : 0);
  11482          #endif
  11483          }
  11484          
  11485          /***************************************************************************//**
  11486           * @brief
  11487           *   Get the LCD framerate divisor (FDIV) setting.
  11488           *
  11489           * @return
  11490           *   The LCD framerate divisor.
  11491           ******************************************************************************/
  11492          uint32_t CMU_LCDClkFDIVGet(void)
  11493          {
  11494          #if defined(LCD_PRESENT) && defined(_CMU_LCDCTRL_MASK)
  11495            return (CMU->LCDCTRL & _CMU_LCDCTRL_FDIV_MASK) >> _CMU_LCDCTRL_FDIV_SHIFT;
  11496          #else
  11497            return 0;
  11498          #endif /* defined(LCD_PRESENT) */
  11499          }
  11500          
  11501          /***************************************************************************//**
  11502           * @brief
  11503           *   Set the LCD framerate divisor (FDIV) setting.
  11504           *
  11505           * @note
  11506           *   The FDIV field (CMU LCDCTRL register) should only be modified while the
  11507           *   LCD module is clock disabled (CMU LFACLKEN0.LCD bit is 0). This function
  11508           *   will NOT modify FDIV if the LCD module clock is enabled. See
  11509           *   @ref CMU_ClockEnable() for disabling/enabling LCD clock.
  11510           *
  11511           * @param[in] div
  11512           *   The FDIV setting to use.
  11513           ******************************************************************************/
  11514          void CMU_LCDClkFDIVSet(uint32_t div)
  11515          {
  11516          #if defined(LCD_PRESENT) && defined(_CMU_LCDCTRL_MASK)
  11517            EFM_ASSERT(div <= cmuClkDiv_128);
  11518          
  11519            /* Do not allow modification if LCD clock enabled. */
  11520            if (CMU->LFACLKEN0 & CMU_LFACLKEN0_LCD) {
  11521              return;
  11522            }
  11523          
  11524            div        <<= _CMU_LCDCTRL_FDIV_SHIFT;
  11525            div         &= _CMU_LCDCTRL_FDIV_MASK;
  11526            CMU->LCDCTRL = (CMU->LCDCTRL & ~_CMU_LCDCTRL_FDIV_MASK) | div;
  11527          #else
  11528            (void)div; /* Unused parameter. */
  11529          #endif /* defined(LCD_PRESENT) */
  11530          }
  11531          
  11532          /**************************************************************************//**
  11533           * @brief
  11534           *   Set LFXO control registers.
  11535           *
  11536           * @note
  11537           *   LFXO configuration should be obtained from a configuration tool,
  11538           *   app note, or crystal data sheet. This function disables the LFXO when
  11539           *   necessary to ensure a valid state before update.
  11540           *
  11541           * @param[in] lfxoInit
  11542           *    LFXO setup parameters.
  11543           *****************************************************************************/
  11544          void CMU_LFXOInit(const CMU_LFXOInit_TypeDef *lfxoInit)
  11545          {
  11546            /* Do not disable LFXO if it is currently selected as the HF/Core clock. */
  11547            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_HF) != cmuSelect_LFXO);
  11548          
  11549          #if defined(_SILICON_LABS_32B_SERIES_1)
  11550            uint32_t reg = (CMU->LFXOCTRL & ~(_CMU_LFXOCTRL_TUNING_MASK
  11551                                              | _CMU_LFXOCTRL_GAIN_MASK
  11552                                              | _CMU_LFXOCTRL_TIMEOUT_MASK
  11553                                              | _CMU_LFXOCTRL_MODE_MASK))
  11554                           | ((uint32_t)lfxoInit->ctune << _CMU_LFXOCTRL_TUNING_SHIFT)
  11555                           | ((uint32_t)lfxoInit->gain << _CMU_LFXOCTRL_GAIN_SHIFT)
  11556                           | ((uint32_t)lfxoInit->timeout << _CMU_LFXOCTRL_TIMEOUT_SHIFT)
  11557                           | ((uint32_t)lfxoInit->mode << _CMU_LFXOCTRL_MODE_SHIFT);
  11558          
  11559            /* If LFXO already contains the correct configuration then there is no need
  11560             * to stop the oscillator and apply new settings. The LFXO can be running out
  11561             * of reset, in which case there is no need to disable it unless necessary. */
  11562            if (reg != CMU->LFXOCTRL) {
  11563              CMU_OscillatorEnable(cmuOsc_LFXO, false, true);
  11564              CMU->LFXOCTRL = reg;
  11565            }
  11566          #elif defined(_SILICON_LABS_32B_SERIES_0)
  11567            /* LFXO must be disabled before reconfiguration. */
  11568            CMU_OscillatorEnable(cmuOsc_LFXO, false, true);
  11569          
  11570            bool cmuBoost  = (lfxoInit->boost & 0x2);
  11571            BUS_RegMaskedWrite(&CMU->CTRL,
  11572                               _CMU_CTRL_LFXOTIMEOUT_MASK
  11573                               | _CMU_CTRL_LFXOBOOST_MASK
  11574                               | _CMU_CTRL_LFXOMODE_MASK,
  11575                               ((uint32_t)lfxoInit->timeout
  11576                                << _CMU_CTRL_LFXOTIMEOUT_SHIFT)
  11577                               | ((cmuBoost ? 1 : 0) << _CMU_CTRL_LFXOBOOST_SHIFT)
  11578                               | ((uint32_t)lfxoInit->mode << _CMU_CTRL_LFXOMODE_SHIFT));
  11579          #if defined(_EMU_AUXCTRL_REDLFXOBOOST_MASK)
  11580            /* EFM32GG has a "reduce startup boost" field in the EMU */
  11581            bool emuReduce = (lfxoInit->boost & 0x1);
  11582            BUS_RegBitWrite(&EMU->AUXCTRL, _EMU_AUXCTRL_REDLFXOBOOST_SHIFT, emuReduce ? 1 : 0);
  11583          #endif
  11584          #endif
  11585          }
  11586          
  11587          /**************************************************************************//**
  11588           * @brief
  11589           *   Sets LFXO's crystal precision, in PPM.
  11590           *
  11591           * @note
  11592           *   LFXO precision should be obtained from a crystal datasheet.
  11593           *
  11594           * @details
  11595           *   This function does not affect the hardware, it only stores the precision
  11596           *   in a variable that can be retrieved later using CMU_LFXOPrecisionGet().
  11597           *   This is used by certain wireless stacks to optimize wakeup time for scheduled
  11598           *   events (such as Bluetooth advertising).
  11599           *
  11600           * @param[in] precision
  11601           *    LFXO's crystal precision, in PPM.
  11602           *****************************************************************************/
  11603          void CMU_LFXOPrecisionSet(uint16_t precision)
  11604          {
  11605            lfxo_precision = precision;
  11606          }
  11607          
  11608          /**************************************************************************//**
  11609           * @brief
  11610           *   Gets LFXO's crystal precision, in PPM.
  11611           *
  11612           * @param[in] precision
  11613           *    LFXO's crystal precision, in PPM.
  11614           *****************************************************************************/
  11615          uint16_t CMU_LFXOPrecisionGet(void)
  11616          {
  11617            return lfxo_precision;
  11618          }
  11619          
  11620          /**************************************************************************//**
  11621           * @brief
  11622           *   Sets HFXO's crystal precision, in PPM.
  11623           *
  11624           * @note
  11625           *   HFXO precision should be obtained from a crystal datasheet.
  11626           *
  11627           * @details
  11628           *   This function does not affect the hardware, it only stores the precision
  11629           *   in a variable that can be retrieved later using CMU_HFXOPrecisionGet().
  11630           *
  11631           * @param[in] precision
  11632           *    HFXO's crystal precision, in PPM.
  11633           *****************************************************************************/
  11634          void CMU_HFXOPrecisionSet(uint16_t precision)
  11635          {
  11636            hfxo_precision = precision;
  11637          }
  11638          
  11639          /**************************************************************************//**
  11640           * @brief
  11641           *   Gets HFXO's crystal precision, in PPM.
  11642           *
  11643           * @param[in] precision
  11644           *    HFXO's crystal precision, in PPM.
  11645           *****************************************************************************/
  11646          uint16_t CMU_HFXOPrecisionGet(void)
  11647          {
  11648            return hfxo_precision;
  11649          }
  11650          
  11651          /***************************************************************************//**
  11652           * @brief
  11653           *   Enable/disable oscillator.
  11654           *
  11655           * @note
  11656           *   WARNING: When this function is called to disable either cmuOsc_LFXO or
  11657           *   cmuOsc_HFXO, the LFXOMODE or HFXOMODE fields of the CMU_CTRL register
  11658           *   are reset to the reset value. In other words, if external clock sources are selected
  11659           *   in either LFXOMODE or HFXOMODE fields, the configuration will be cleared
  11660           *   and needs to be reconfigured if needed later.
  11661           *
  11662           * @param[in] osc
  11663           *   The oscillator to enable/disable.
  11664           *
  11665           * @param[in] enable
  11666           *   @li true - enable specified oscillator.
  11667           *   @li false - disable specified oscillator.
  11668           *
  11669           * @param[in] wait
  11670           *   Only used if @p enable is true.
  11671           *   @li true - wait for oscillator start-up time to timeout before returning.
  11672           *   @li false - do not wait for oscillator start-up time to timeout before
  11673           *     returning.
  11674           ******************************************************************************/
  11675          void CMU_OscillatorEnable(CMU_Osc_TypeDef osc, bool enable, bool wait)
  11676          {
  11677            uint32_t rdyBitPos;
  11678          #if defined(_SILICON_LABS_32B_SERIES_1)
  11679            uint32_t ensBitPos;
  11680          #endif
  11681          #if defined(_CMU_STATUS_HFXOPEAKDETRDY_MASK)
  11682            uint32_t hfxoTrimStatus;
  11683          #endif
  11684          
  11685            uint32_t enBit;
  11686            uint32_t disBit;
  11687          
  11688            switch (osc) {
  11689              case cmuOsc_HFRCO:
  11690                enBit  = CMU_OSCENCMD_HFRCOEN;
  11691                disBit = CMU_OSCENCMD_HFRCODIS;
  11692                rdyBitPos = _CMU_STATUS_HFRCORDY_SHIFT;
  11693          #if defined(_SILICON_LABS_32B_SERIES_1)
  11694                ensBitPos = _CMU_STATUS_HFRCOENS_SHIFT;
  11695          #endif
  11696                break;
  11697          
  11698              case cmuOsc_HFXO:
  11699                enBit  = CMU_OSCENCMD_HFXOEN;
  11700                disBit = CMU_OSCENCMD_HFXODIS;
  11701                rdyBitPos = _CMU_STATUS_HFXORDY_SHIFT;
  11702          #if defined(_SILICON_LABS_32B_SERIES_1)
  11703                ensBitPos = _CMU_STATUS_HFXOENS_SHIFT;
  11704          #endif
  11705                break;
  11706          
  11707              case cmuOsc_AUXHFRCO:
  11708                enBit  = CMU_OSCENCMD_AUXHFRCOEN;
  11709                disBit = CMU_OSCENCMD_AUXHFRCODIS;
  11710                rdyBitPos = _CMU_STATUS_AUXHFRCORDY_SHIFT;
  11711          #if defined(_SILICON_LABS_32B_SERIES_1)
  11712                ensBitPos = _CMU_STATUS_AUXHFRCOENS_SHIFT;
  11713          #endif
  11714                break;
  11715          
  11716              case cmuOsc_LFRCO:
  11717                enBit  = CMU_OSCENCMD_LFRCOEN;
  11718                disBit = CMU_OSCENCMD_LFRCODIS;
  11719                rdyBitPos = _CMU_STATUS_LFRCORDY_SHIFT;
  11720          #if defined(_SILICON_LABS_32B_SERIES_1)
  11721                ensBitPos = _CMU_STATUS_LFRCOENS_SHIFT;
  11722          #endif
  11723                break;
  11724          
  11725              case cmuOsc_LFXO:
  11726                enBit  = CMU_OSCENCMD_LFXOEN;
  11727                disBit = CMU_OSCENCMD_LFXODIS;
  11728                rdyBitPos = _CMU_STATUS_LFXORDY_SHIFT;
  11729          #if defined(_SILICON_LABS_32B_SERIES_1)
  11730                ensBitPos = _CMU_STATUS_LFXOENS_SHIFT;
  11731          #endif
  11732                break;
  11733          
  11734          #if defined(_CMU_STATUS_USHFRCOENS_MASK)
  11735              case cmuOsc_USHFRCO:
  11736                enBit  = CMU_OSCENCMD_USHFRCOEN;
  11737                disBit = CMU_OSCENCMD_USHFRCODIS;
  11738                rdyBitPos = _CMU_STATUS_USHFRCORDY_SHIFT;
  11739          #if defined(_SILICON_LABS_32B_SERIES_1)
  11740                ensBitPos = _CMU_STATUS_USHFRCOENS_SHIFT;
  11741          #endif
  11742                break;
  11743          #endif
  11744          
  11745          #if defined(PLFRCO_PRESENT)
  11746              case cmuOsc_PLFRCO:
  11747                if (!deviceHasPlfrco()) {
  11748                  while (true) { // PLFRCO is not available
  11749                    EFM_ASSERT(false);
  11750                  }
  11751                }
  11752                enBit = CMU_OSCENCMD_PLFRCOEN;
  11753                disBit = CMU_OSCENCMD_PLFRCODIS;
  11754                rdyBitPos = _CMU_STATUS_PLFRCORDY_SHIFT;
  11755                ensBitPos = _CMU_STATUS_PLFRCOENS_SHIFT;
  11756                break;
  11757          #endif
  11758          
  11759              default:
  11760                /* Undefined clock source, cmuOsc_CLKIN0 or cmuOsc_ULFRCO. ULFRCO is always enabled
  11761                   and cannot be disabled. In other words,the definition of cmuOsc_ULFRCO is primarily
  11762                   intended for information: the ULFRCO is always on.  */
  11763                EFM_ASSERT(false);
  11764                return;
  11765            }
  11766          
  11767            if (enable) {
  11768           #if defined(_CMU_HFXOCTRL_MASK)
  11769              bool firstHfxoEnable = false;
  11770          
  11771              /* Enabling the HFXO for the first time requires special handling.
  11772               * PEAKDETSHUTOPTMODE field of the HFXOCTRL register is used to see if this is the
  11773               * first time the HFXO is enabled. */
  11774              if (osc == cmuOsc_HFXO) {
  11775                if (getHfxoTuningMode() == HFXO_TUNING_MODE_AUTO) {
  11776                  /* REGPWRSEL must be set to DVDD before the HFXO can be enabled. */
  11777          #if defined(_EMU_PWRCTRL_REGPWRSEL_MASK)
  11778                  EFM_ASSERT((EMU->PWRCTRL & EMU_PWRCTRL_REGPWRSEL_DVDD) != 0UL);
  11779          #endif
  11780          
  11781                  firstHfxoEnable = true;
  11782                  /* The first time that an external clock is enabled, switch to CMD mode to make sure that
  11783                   * only SCO and not PDA tuning is performed. */
  11784                  if ((CMU->HFXOCTRL & (_CMU_HFXOCTRL_MODE_MASK)) == CMU_HFXOCTRL_MODE_DIGEXTCLK) {
  11785                    setHfxoTuningMode(HFXO_TUNING_MODE_CMD);
  11786                  }
  11787                }
  11788              }
  11789          #endif
  11790              CMU->OSCENCMD = enBit;
  11791          
  11792          #if defined(_SILICON_LABS_32B_SERIES_1)
  11793              /* Always wait for ENS to go high. */
  11794              while (BUS_RegBitRead(&CMU->STATUS, ensBitPos) == 0UL) {
  11795                // Wait for oscillator enable.
  11796              }
  11797          #endif
  11798          
  11799              /* Wait for the clock to become ready after enable. */
  11800              if (wait) {
  11801                while (BUS_RegBitRead(&CMU->STATUS, rdyBitPos) == 0UL) {
  11802                  // Wait for oscillator ready.
  11803                }
  11804          #if defined(_SILICON_LABS_32B_SERIES_1)
  11805                if ((osc == cmuOsc_HFXO) && firstHfxoEnable) {
  11806                  if ((CMU->HFXOCTRL & _CMU_HFXOCTRL_MODE_MASK)
  11807                      == CMU_HFXOCTRL_MODE_DIGEXTCLK) {
  11808          #if defined(CMU_CMD_HFXOSHUNTOPTSTART)
  11809                    /* External clock mode should only do shunt current optimization. */
  11810                    (void)CMU_OscillatorTuningOptimize(cmuOsc_HFXO,
  11811                                                       cmuHFXOTuningMode_ShuntCommand,
  11812                                                       true);
  11813          #endif
  11814                  } else {
  11815                    /* Wait for the peak detection and shunt current optimization
  11816                       to complete. */
  11817                    (void)CMU_OscillatorTuningWait(cmuOsc_HFXO, cmuHFXOTuningMode_Auto);
  11818                  }
  11819          
  11820                  /* Disable the HFXO again to apply the trims. Apply trim from
  11821                     HFXOTRIMSTATUS when disabled. */
  11822                  hfxoTrimStatus = CMU_OscillatorTuningGet(cmuOsc_HFXO);
  11823                  CMU_OscillatorEnable(cmuOsc_HFXO, false, true);
  11824                  CMU_OscillatorTuningSet(cmuOsc_HFXO, hfxoTrimStatus);
  11825          
  11826                  /* Restart in CMD mode. */
  11827                  CMU->OSCENCMD = enBit;
  11828                  while (BUS_RegBitRead(&CMU->STATUS, rdyBitPos) == 0UL) {
  11829                    // Wait for oscillator ready.
  11830                  }
  11831                }
  11832          #endif
  11833              }
  11834            } else {
  11835              CMU->OSCENCMD = disBit;
  11836          
  11837          #if defined(_SILICON_LABS_32B_SERIES_1)
  11838              /* Always wait for ENS to go low. */
  11839              while ((CMU->STATUS & (0x1 << ensBitPos)) != 0U) {
  11840                // Wait for oscillator disable.
  11841              }
  11842          
  11843              if (wait) {
  11844                /* Wait for RDY to go low as well. */
  11845                while ((CMU->STATUS & (0x1 << rdyBitPos)) != 0U) {
  11846                  // Wait for RDY low.
  11847                }
  11848              }
  11849          #endif
  11850            }
  11851          }
  11852          
  11853          /***************************************************************************//**
  11854           * @brief
  11855           *   Get the oscillator frequency tuning setting.
  11856           *
  11857           * @param[in] osc
  11858           *   An oscillator to get tuning value for, one of the following:
  11859           *   @li #cmuOsc_LFRCO
  11860           *   @li #cmuOsc_HFRCO @if _CMU_USHFRCOCTRL_TUNING_MASK
  11861           *   @li #cmuOsc_USHFRCO
  11862           *   @endif
  11863           *   @li #cmuOsc_AUXHFRCO
  11864           *   @li #cmuOsc_HFXO if CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE is defined
  11865           *
  11866           * @return
  11867           *   The oscillator frequency tuning setting in use.
  11868           ******************************************************************************/
  11869          uint32_t CMU_OscillatorTuningGet(CMU_Osc_TypeDef osc)
  11870          {
  11871            uint32_t ret;
  11872          
  11873            switch (osc) {
  11874              case cmuOsc_LFRCO:
  11875                ret = (CMU->LFRCOCTRL & _CMU_LFRCOCTRL_TUNING_MASK)
  11876                      >> _CMU_LFRCOCTRL_TUNING_SHIFT;
  11877                break;
  11878          
  11879              case cmuOsc_HFRCO:
  11880                ret = (CMU->HFRCOCTRL & _CMU_HFRCOCTRL_TUNING_MASK)
  11881                      >> _CMU_HFRCOCTRL_TUNING_SHIFT;
  11882                break;
  11883          
  11884          #if defined (_CMU_USHFRCOCTRL_TUNING_MASK)
  11885              case cmuOsc_USHFRCO:
  11886                ret = (CMU->USHFRCOCTRL & _CMU_USHFRCOCTRL_TUNING_MASK)
  11887                      >> _CMU_USHFRCOCTRL_TUNING_SHIFT;
  11888                break;
  11889          #endif
  11890          
  11891              case cmuOsc_AUXHFRCO:
  11892                ret = (CMU->AUXHFRCOCTRL & _CMU_AUXHFRCOCTRL_TUNING_MASK)
  11893                      >> _CMU_AUXHFRCOCTRL_TUNING_SHIFT;
  11894                break;
  11895          
  11896          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
  11897              case cmuOsc_HFXO:
  11898                ret = CMU->HFXOTRIMSTATUS & (_CMU_HFXOTRIMSTATUS_IBTRIMXOCORE_MASK
  11899          #if defined(_CMU_HFXOTRIMSTATUS_REGISH_MASK)
  11900                                             | _CMU_HFXOTRIMSTATUS_REGISH_MASK
  11901          #endif
  11902                                             );
  11903                break;
  11904          #endif
  11905          
  11906          #if defined(_SILICON_LABS_32B_SERIES_1) && !defined(_EFR32_ZEN_FAMILY)
  11907              case cmuOsc_LFXO:
  11908                ret = (CMU->LFXOCTRL & _CMU_LFXOCTRL_TUNING_MASK) >> _CMU_LFXOCTRL_TUNING_SHIFT;
  11909                break;
  11910          #endif
  11911          
  11912              default:
  11913                ret = 0;
  11914                EFM_ASSERT(false);
  11915                break;
  11916            }
  11917          
  11918            return ret;
  11919          }
  11920          
  11921          /***************************************************************************//**
  11922           * @brief
  11923           *   Set the oscillator frequency tuning control.
  11924           *
  11925           * @note
  11926           *   Oscillator tuning is done during production and the tuning value is
  11927           *   automatically loaded after reset. Changing the tuning value from the
  11928           *   calibrated value is for more advanced use. Certain oscillators also have
  11929           *   build-in tuning optimization.
  11930           *
  11931           * @param[in] osc
  11932           *   An oscillator to set tuning value for, one of the following:
  11933           *   @li #cmuOsc_LFRCO
  11934           *   @li #cmuOsc_HFRCO @if _CMU_USHFRCOCTRL_TUNING_MASK
  11935           *   @li #cmuOsc_USHFRCO
  11936           *   @endif
  11937           *   @li #cmuOsc_AUXHFRCO
  11938           *   @li #cmuOsc_HFXO if PEAKDETSHUNTOPTMODE is available. Note that CMD mode is set.
  11939           *
  11940           * @param[in] val
  11941           *   The oscillator frequency tuning setting to use.
  11942           ******************************************************************************/
  11943          void CMU_OscillatorTuningSet(CMU_Osc_TypeDef osc, uint32_t val)
  11944          {
  11945          #if defined(_SILICON_LABS_32B_SERIES_1) && !defined(_EFR32_ZEN_FAMILY)
  11946            uint8_t ctune = 0;
  11947          #endif
  11948          
  11949          #if defined(_CMU_HFXOSTEADYSTATECTRL_REGISH_MASK)
  11950            uint32_t regIshUpper;
  11951          #endif
  11952          
  11953            switch (osc) {
  11954              case cmuOsc_LFRCO:
  11955                EFM_ASSERT(val <= (_CMU_LFRCOCTRL_TUNING_MASK
  11956                                   >> _CMU_LFRCOCTRL_TUNING_SHIFT));
  11957                val &= (_CMU_LFRCOCTRL_TUNING_MASK >> _CMU_LFRCOCTRL_TUNING_SHIFT);
  11958          #if defined(_SILICON_LABS_32B_SERIES_1)
  11959                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  11960                                      _CMU_SYNCBUSY_LFRCOBSY_SHIFT) != 0UL) {
  11961                  // Wait for LFRCO sync.
  11962                }
  11963          #endif
  11964                CMU->LFRCOCTRL = (CMU->LFRCOCTRL & ~(_CMU_LFRCOCTRL_TUNING_MASK))
  11965                                 | (val << _CMU_LFRCOCTRL_TUNING_SHIFT);
  11966                break;
  11967          
  11968              case cmuOsc_HFRCO:
  11969                EFM_ASSERT(val <= (_CMU_HFRCOCTRL_TUNING_MASK
  11970                                   >> _CMU_HFRCOCTRL_TUNING_SHIFT));
  11971                val &= (_CMU_HFRCOCTRL_TUNING_MASK >> _CMU_HFRCOCTRL_TUNING_SHIFT);
  11972          #if defined(_SILICON_LABS_32B_SERIES_1)
  11973                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  11974                                      _CMU_SYNCBUSY_HFRCOBSY_SHIFT) != 0UL) {
  11975                  // Wait for HFRCO sync.
  11976                }
  11977          #endif
  11978                CMU->HFRCOCTRL = (CMU->HFRCOCTRL & ~(_CMU_HFRCOCTRL_TUNING_MASK))
  11979                                 | (val << _CMU_HFRCOCTRL_TUNING_SHIFT);
  11980                break;
  11981          
  11982          #if defined (_CMU_USHFRCOCTRL_TUNING_MASK)
  11983              case cmuOsc_USHFRCO:
  11984                EFM_ASSERT(val <= (_CMU_USHFRCOCTRL_TUNING_MASK
  11985                                   >> _CMU_USHFRCOCTRL_TUNING_SHIFT));
  11986                val &= (_CMU_USHFRCOCTRL_TUNING_MASK >> _CMU_USHFRCOCTRL_TUNING_SHIFT);
  11987          #if defined(_SILICON_LABS_32B_SERIES_1)
  11988                while (BUS_RegBitRead(&CMU->SYNCBUSY, _CMU_SYNCBUSY_USHFRCOBSY_SHIFT)) {
  11989                  // Wait for USHFRCO sync.
  11990                }
  11991          #endif
  11992                CMU->USHFRCOCTRL = (CMU->USHFRCOCTRL & ~(_CMU_USHFRCOCTRL_TUNING_MASK))
  11993                                   | (val << _CMU_USHFRCOCTRL_TUNING_SHIFT);
  11994                break;
  11995          #endif
  11996          
  11997              case cmuOsc_AUXHFRCO:
  11998                EFM_ASSERT(val <= (_CMU_AUXHFRCOCTRL_TUNING_MASK
  11999                                   >> _CMU_AUXHFRCOCTRL_TUNING_SHIFT));
  12000                val &= (_CMU_AUXHFRCOCTRL_TUNING_MASK >> _CMU_AUXHFRCOCTRL_TUNING_SHIFT);
  12001          #if defined(_SILICON_LABS_32B_SERIES_1)
  12002                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  12003                                      _CMU_SYNCBUSY_AUXHFRCOBSY_SHIFT) != 0UL) {
  12004                  // Wait for AUXHFRCO sync.
  12005                }
  12006          #endif
  12007                CMU->AUXHFRCOCTRL = (CMU->AUXHFRCOCTRL & ~(_CMU_AUXHFRCOCTRL_TUNING_MASK))
  12008                                    | (val << _CMU_AUXHFRCOCTRL_TUNING_SHIFT);
  12009                break;
  12010          
  12011          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
  12012              case cmuOsc_HFXO:
  12013          
  12014                /* Do set PEAKDETSHUNTOPTMODE or HFXOSTEADYSTATECTRL if HFXO is enabled. */
  12015                EFM_ASSERT((CMU->STATUS & CMU_STATUS_HFXOENS) == 0UL);
  12016          
  12017                /* Switch to command mode. Automatic SCO and PDA calibration is not done
  12018                   at the next enable. Set user REGISH, REGISHUPPER, and IBTRIMXOCORE. */
  12019                CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
  12020                                | CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_CMD;
  12021          
  12022          #if defined(_CMU_HFXOSTEADYSTATECTRL_REGISH_MASK)
  12023                regIshUpper = getRegIshUpperVal((val & _CMU_HFXOSTEADYSTATECTRL_REGISH_MASK)
  12024                                                >> _CMU_HFXOSTEADYSTATECTRL_REGISH_SHIFT);
  12025                CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  12026                                            & ~(_CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK
  12027                                                | _CMU_HFXOSTEADYSTATECTRL_REGISH_MASK
  12028                                                | _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK))
  12029                                           | val
  12030                                           | regIshUpper;
  12031          #else
  12032                CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  12033                                            & ~_CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK)
  12034                                           | val;
  12035          #endif
  12036          
  12037                break;
  12038          #endif
  12039          
  12040          #if defined(_SILICON_LABS_32B_SERIES_1) && !defined(_EFR32_ZEN_FAMILY)
  12041              case cmuOsc_LFXO:
  12042                EFM_ASSERT(val <= (_CMU_LFXOCTRL_TUNING_MASK >> _CMU_LFXOCTRL_TUNING_SHIFT));
  12043                // Max internal capacitance tuning value is 0x4F (20 pF)
  12044                ctune = (uint8_t) SL_MIN(0x4FU, val);
  12045          
  12046                // Wait for the CMU_LFXOCTRL is ready for update
  12047                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  12048                                      _CMU_SYNCBUSY_LFXOBSY_SHIFT) != 0UL) {
  12049                  // Wait for LFXO sync.
  12050                }
  12051                CMU->LFXOCTRL = (CMU->LFXOCTRL & ~(_CMU_LFXOCTRL_TUNING_MASK))
  12052                                | ((uint32_t)ctune << _CMU_LFXOCTRL_TUNING_SHIFT);
  12053                break;
  12054          #endif
  12055          
  12056              default:
  12057                EFM_ASSERT(false);
  12058                break;
  12059            }
  12060          }
  12061          
  12062          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK) || defined(_CMU_HFXOCTRL_PEAKDETMODE_MASK)
  12063          /***************************************************************************//**
  12064           * @brief
  12065           *   Wait for the oscillator tuning optimization.
  12066           *
  12067           * @param[in] osc
  12068           *   An oscillator to set tuning value for, one of the following:
  12069           *   @li #cmuOsc_HFXO
  12070           *
  12071           * @param[in] mode
  12072           *   Tuning optimization mode.
  12073           *
  12074           * @return
  12075           *   Returns false on invalid parameters or oscillator error status.
  12076           ******************************************************************************/
  12077          bool CMU_OscillatorTuningWait(CMU_Osc_TypeDef osc,
  12078                                        CMU_HFXOTuningMode_TypeDef mode)
  12079          {
  12080            uint32_t waitFlags;
  12081            EFM_ASSERT(osc == cmuOsc_HFXO);
  12082          
  12083            /* Currently implemented for HFXO with PEAKDETSHUNTOPTMODE only. */
  12084            (void)osc;
  12085          
  12086            if (getHfxoTuningMode() == HFXO_TUNING_MODE_AUTO) {
  12087              waitFlags = HFXO_TUNING_READY_FLAGS;
  12088            } else {
  12089              /* Set wait flags for each command and wait. */
  12090              switch (mode) {
  12091          #if defined(_CMU_STATUS_HFXOSHUNTOPTRDY_MASK)
  12092                case cmuHFXOTuningMode_ShuntCommand:
  12093                  waitFlags = CMU_STATUS_HFXOSHUNTOPTRDY;
  12094                  break;
  12095          #endif
  12096                case cmuHFXOTuningMode_Auto:
  12097                  waitFlags = HFXO_TUNING_READY_FLAGS;
  12098                  break;
  12099          
  12100          #if defined(CMU_CMD_HFXOSHUNTOPTSTART)
  12101                case cmuHFXOTuningMode_PeakShuntCommand:
  12102                  waitFlags = HFXO_TUNING_READY_FLAGS;
  12103                  break;
  12104          #endif
  12105          
  12106                default:
  12107                  waitFlags = _CMU_STATUS_MASK;
  12108                  EFM_ASSERT(false);
  12109                  break;
  12110              }
  12111            }
  12112            while ((CMU->STATUS & waitFlags) != waitFlags) {
  12113              // Wait for HFXO tuning ready.
  12114            }
  12115          
  12116          #if defined(CMU_IF_HFXOPEAKDETERR)
  12117            /* Check error flags. */
  12118            if ((waitFlags & CMU_STATUS_HFXOPEAKDETRDY) != 0UL) {
  12119              return (CMU->IF & CMU_IF_HFXOPEAKDETERR) != 0UL ? true : false;
  12120            }
  12121          #endif
  12122            return true;
  12123          }
  12124          
  12125          /***************************************************************************//**
  12126           * @brief
  12127           *   Start and optionally wait for the oscillator tuning optimization.
  12128           *
  12129           * @param[in] osc
  12130           *   An oscillator to set tuning value for, one of the following:
  12131           *   @li #cmuOsc_HFXO
  12132           *
  12133           * @param[in] mode
  12134           *   Tuning optimization mode.
  12135           *
  12136           * @param[in] wait
  12137           *   Wait for tuning optimization to complete.
  12138           *   true - wait for tuning optimization to complete.
  12139           *   false - return without waiting.
  12140           *
  12141           * @return
  12142           *   Returns false on invalid parameters or oscillator error status.
  12143           ******************************************************************************/
  12144          bool CMU_OscillatorTuningOptimize(CMU_Osc_TypeDef osc,
  12145                                            CMU_HFXOTuningMode_TypeDef mode,
  12146                                            bool wait)
  12147          {
  12148            switch (osc) {
  12149              case cmuOsc_HFXO:
  12150                if ((unsigned)mode != 0U) {
  12151          #if defined(CMU_IF_HFXOPEAKDETERR)
  12152                  /* Clear the error flag before command write. */
  12153                  CMU->IFC = CMU_IFC_HFXOPEAKDETERR;
  12154          #endif
  12155                  CMU->CMD = (uint32_t)mode;
  12156                }
  12157                if (wait) {
  12158                  return CMU_OscillatorTuningWait(osc, mode);
  12159                }
  12160                break;
  12161          
  12162              default:
  12163                EFM_ASSERT(false);
  12164                break;
  12165            }
  12166            return true;
  12167          }
  12168          #endif
  12169          
  12170          /**************************************************************************//**
  12171           * @brief
  12172           *   Determine if the currently selected PCNTn clock used is external or LFBCLK.
  12173           *
  12174           * @param[in] instance
  12175           *   PCNT instance number to get currently selected clock source for.
  12176           *
  12177           * @return
  12178           *   @li true - selected clock is external clock.
  12179           *   @li false - selected clock is LFBCLK.
  12180           *****************************************************************************/
  12181          bool CMU_PCNTClockExternalGet(unsigned int instance)
  12182          {
  12183            uint32_t setting;
  12184          
  12185            switch (instance) {
  12186          #if defined(_CMU_PCNTCTRL_PCNT0CLKEN_MASK)
  12187              case 0:
  12188                setting = CMU->PCNTCTRL & CMU_PCNTCTRL_PCNT0CLKSEL_PCNT0S0;
  12189                break;
  12190          
  12191          #if defined(_CMU_PCNTCTRL_PCNT1CLKEN_MASK)
  12192              case 1:
  12193                setting = CMU->PCNTCTRL & CMU_PCNTCTRL_PCNT1CLKSEL_PCNT1S0;
  12194                break;
  12195          
  12196          #if defined(_CMU_PCNTCTRL_PCNT2CLKEN_MASK)
  12197              case 2:
  12198                setting = CMU->PCNTCTRL & CMU_PCNTCTRL_PCNT2CLKSEL_PCNT2S0;
  12199                break;
  12200          #endif
  12201          #endif
  12202          #endif
  12203          
  12204              default:
  12205                setting = 0;
  12206                break;
  12207            }
  12208            return setting > 0UL ? true : false;
  12209          }
  12210          
  12211          /**************************************************************************//**
  12212           * @brief
  12213           *   Select the PCNTn clock.
  12214           *
  12215           * @param[in] instance
  12216           *   PCNT instance number to set selected clock source for.
  12217           *
  12218           * @param[in] external
  12219           *   Set to true to select the external clock, false to select LFBCLK.
  12220           *****************************************************************************/
  12221          void CMU_PCNTClockExternalSet(unsigned int instance, bool external)
  12222          {
  12223          #if defined(PCNT_PRESENT)
  12224            uint32_t setting = 0;
  12225          
  12226            EFM_ASSERT(instance < (unsigned)PCNT_COUNT);
  12227          
  12228            if (external) {
  12229              setting = 1;
  12230            }
  12231          
  12232            BUS_RegBitWrite(&(CMU->PCNTCTRL), (instance * 2U) + 1U, setting);
  12233          
  12234          #else
  12235            (void)instance; /* An unused parameter */
  12236            (void)external; /* An unused parameter */
  12237          #endif
  12238          }
  12239          
  12240          #if defined(_CMU_USHFRCOCONF_BAND_MASK)
  12241          /***************************************************************************//**
  12242           * @brief
  12243           *   Get USHFRCO band in use.
  12244           *
  12245           * @return
  12246           *   USHFRCO band in use.
  12247           ******************************************************************************/
  12248          CMU_USHFRCOBand_TypeDef CMU_USHFRCOBandGet(void)
  12249          {
  12250            return (CMU_USHFRCOBand_TypeDef)((CMU->USHFRCOCONF
  12251                                              & _CMU_USHFRCOCONF_BAND_MASK)
  12252                                             >> _CMU_USHFRCOCONF_BAND_SHIFT);
  12253          }
  12254          
  12255          /***************************************************************************//**
  12256           * @brief
  12257           *   Get USHFRCO frequency.
  12258           *
  12259           * @return
  12260           *   USHFRCO frequency.
  12261           ******************************************************************************/
  12262          uint32_t CMU_USHFRCOFreqGet(void)
  12263          {
  12264            return ushfrcoFreq;
  12265          }
  12266          #endif
  12267          
  12268          #if defined(_CMU_USHFRCOCONF_BAND_MASK)
  12269          /***************************************************************************//**
  12270           * @brief
  12271           *   Set the USHFRCO band to use.
  12272           *
  12273           * @param[in] band
  12274           *   USHFRCO band to activate.
  12275           ******************************************************************************/
  12276          void CMU_USHFRCOBandSet(CMU_USHFRCOBand_TypeDef band)
  12277          {
  12278            uint32_t           tuning;
  12279            uint32_t           fineTuning;
  12280          
  12281            /* Cannot switch band if USHFRCO is already selected as HF clock. */
  12282            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_HF) != cmuSelect_USHFRCODIV2);
  12283          
  12284            /* Read tuning value from calibration table. */
  12285            switch (band) {
  12286              case cmuUSHFRCOBand_24MHz:
  12287                tuning = (DEVINFO->USHFRCOCAL0 & _DEVINFO_USHFRCOCAL0_BAND24_TUNING_MASK)
  12288                         >> _DEVINFO_USHFRCOCAL0_BAND24_TUNING_SHIFT;
  12289                fineTuning = (DEVINFO->USHFRCOCAL0
  12290                              & _DEVINFO_USHFRCOCAL0_BAND24_FINETUNING_MASK)
  12291                             >> _DEVINFO_USHFRCOCAL0_BAND24_FINETUNING_SHIFT;
  12292                ushfrcoFreq = 24000000UL;
  12293                break;
  12294          
  12295              case cmuUSHFRCOBand_48MHz:
  12296                tuning = (DEVINFO->USHFRCOCAL0 & _DEVINFO_USHFRCOCAL0_BAND48_TUNING_MASK)
  12297                         >> _DEVINFO_USHFRCOCAL0_BAND48_TUNING_SHIFT;
  12298                fineTuning = (DEVINFO->USHFRCOCAL0
  12299                              & _DEVINFO_USHFRCOCAL0_BAND48_FINETUNING_MASK)
  12300                             >> _DEVINFO_USHFRCOCAL0_BAND48_FINETUNING_SHIFT;
  12301                /* Enable the clock divider before switching the band from 24 to 48 MHz */
  12302                BUS_RegBitWrite(&CMU->USHFRCOCONF, _CMU_USHFRCOCONF_USHFRCODIV2DIS_SHIFT, 0);
  12303                ushfrcoFreq = 48000000UL;
  12304                break;
  12305          
  12306              default:
  12307                EFM_ASSERT(false);
  12308                return;
  12309            }
  12310          
  12311            /* Set band and tuning. */
  12312            CMU->USHFRCOCONF = (CMU->USHFRCOCONF & ~_CMU_USHFRCOCONF_BAND_MASK)
  12313                               | (band << _CMU_USHFRCOCONF_BAND_SHIFT);
  12314            CMU->USHFRCOCTRL = (CMU->USHFRCOCTRL & ~_CMU_USHFRCOCTRL_TUNING_MASK)
  12315                               | (tuning << _CMU_USHFRCOCTRL_TUNING_SHIFT);
  12316            CMU->USHFRCOTUNE = (CMU->USHFRCOTUNE & ~_CMU_USHFRCOTUNE_FINETUNING_MASK)
  12317                               | (fineTuning << _CMU_USHFRCOTUNE_FINETUNING_SHIFT);
  12318          
  12319            /* Disable the clock divider after switching the band from 48 to 24 MHz. */
  12320            if (band == cmuUSHFRCOBand_24MHz) {
  12321              BUS_RegBitWrite(&CMU->USHFRCOCONF, _CMU_USHFRCOCONF_USHFRCODIV2DIS_SHIFT, 1);
  12322            }
  12323          }
  12324          #endif
  12325          
  12326          #endif // defined(_SILICON_LABS_32B_SERIES_2)
  12327          /** @} (end addtogroup cmu) */
  12328          #endif /* defined(CMU_PRESENT) */

