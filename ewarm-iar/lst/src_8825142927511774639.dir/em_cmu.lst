   6022            { 34800000UL, 40000000UL, 0x996C1F00UL, cmuHFRCOFreq_38M0Hz      }
   6023          #elif defined(_SILICON_LABS_GECKO_INTERNAL_SDID_100) \
   6024            || defined(_SILICON_LABS_GECKO_INTERNAL_SDID_106)
   6025            { 34800000UL, 42800000UL, 0x996C1F00UL, cmuHFRCOFreq_38M0Hz      },
   6026            { 42800000UL, 51600000UL, 0x996D1F00UL, cmuHFRCOFreq_48M0Hz      },
   6027            { 51600000UL, 60500000UL, 0x998E1F00UL, cmuHFRCOFreq_56M0Hz      },
