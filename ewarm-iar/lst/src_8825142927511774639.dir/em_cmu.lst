   9488          /***************************************************************************//**
   9489           * @brief This function is used to initialize the HF clock and selecting
   9490           *        an LF clock source.
   9491           *
   9492           * @note FOR INTERNAL USE ONLY.
   9493           *
   9494           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9495           *       the clock is HF and LFXO or LFRCO is selected as the clock source.
   9496           ******************************************************************************/
   9497          void sli_em_cmu_HFClockSelectLFOsc(uint8_t osc)
   9498          {
   9499            if (osc == (uint8_t)cmuOsc_LFXO) {
   9500              // Enable LFXO oscillator
   9501              CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
   9502            } else if (osc == (uint8_t)cmuOsc_LFRCO) {
   9503              // Enable LFRCO oscillator
   9504              CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
   9505            } else {
   9506              EFM_ASSERT(false);
   9507            }
   9508          
   9509            // Configure worst case wait-states for flash and set safe HFPER
   9510            // clock-tree prescalers.
   9511            flashWaitStateMax();
   9512            hfperClkSafePrescaler();
   9513          
   9514          #if defined(_SILICON_LABS_32B_SERIES_1)
   9515            // Select HF clock source.
   9516            if (osc == (uint8_t)cmuOsc_LFXO) {
   9517              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_LFXO;
   9518            } else if (osc == (uint8_t)cmuOsc_LFRCO) {
   9519              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_LFRCO;
   9520            }
   9521          #if defined(CMU_MAX_FREQ_HFLE)
   9522            // Set HFLE clock.
   9523            setHfLeConfig(SystemHFClockGet());
   9524          #endif
   9525          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9526            // Select HF clock source.
   9527            if (osc == (uint8_t)cmuOsc_LFXO) {
   9528              CMU->CMD = CMU_CMD_HFCLKSEL_LFXO;
   9529            } else if (osc == (uint8_t)cmuOsc_LFRCO) {
   9530              CMU->CMD = CMU_CMD_HFCLKSEL_LFRCO;
   9531            }
   9532          #if defined(CMU_MAX_FREQ_HFLE)
   9533            // Set HFLE clock.
   9534            setHfLeConfig(SystemCoreClockGet());
   9535          #endif
   9536          #endif
   9537          
   9538            // Optimize flash access wait state setting for the currently selected core clk.
   9539            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9540            // Set optimized HFPER clock-tree prescalers.
   9541            hfperClkOptimizedPrescaler();
   9542          }
   9543          
   9544          /***************************************************************************//**
   9545           * @brief This function is used to initialize the HF clock and selecting
   9546           *        HFXO as the clock source.
   9547           *
   9548           * @note FOR INTERNAL USE ONLY.
   9549           *
   9550           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9551           *       the clock is HF and HFXO is selected as the clock source.
   9552           ******************************************************************************/
   9553          void sli_em_cmu_HFClockSelectHFXO(void)
   9554          {
   9555          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9556            uint32_t vScaleFrequency = SystemHFXOClockGet();
   9557            EMU_VScaleEM01ByClock(vScaleFrequency, false);
   9558          #endif
   9559          
   9560          #if defined(CMU_MAX_FREQ_HFLE)
   9561            // Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9562            // This is known after 'select' is written below.
   9563            setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9564          #endif
   9565          #if defined(CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ)
   9566            // Adjust HFXO buffer current for frequencies above 32 MHz.
   9567            if (SystemHFXOClockGet() > 32000000) {
   9568              CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9569                          | CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ;
   9570            } else {
   9571              CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9572                          | CMU_CTRL_HFXOBUFCUR_BOOSTUPTO32MHZ;
   9573            }
   9574          #endif
   9575          
   9576            // Enable HFXO oscillator
   9577            CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
   9578          
   9579            // Configure worst case wait-states for flash and set safe HFPER
   9580            // clock-tree prescalers.
   9581            flashWaitStateMax();
   9582            hfperClkSafePrescaler();
   9583          
   9584          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9585            // Wait for voltage upscaling to complete before the clock is set.
   9586            if (vScaleFrequency != 0UL) {
   9587              EMU_VScaleWait();
   9588            }
   9589          #endif
   9590          
   9591          #if defined(CMU_HFCLKSEL_HF_HFXO)
   9592            // Select HF clock source.
   9593            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFXO;
   9594          #if defined(CMU_MAX_FREQ_HFLE)
   9595            // Set HFLE clock.
   9596            setHfLeConfig(SystemHFClockGet());
   9597          #endif
   9598          #elif defined(CMU_CMD_HFCLKSEL_HFXO)
   9599            // Select HF clock source.
   9600            CMU->CMD = CMU_CMD_HFCLKSEL_HFXO;
   9601          #if defined(CMU_MAX_FREQ_HFLE)
   9602            // Set HFLE clock.
   9603            setHfLeConfig(SystemCoreClockGet());
   9604          #endif
   9605          #endif
   9606          
   9607            // Optimize flash access wait state setting for the currently selected core clk.
   9608            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9609          
   9610          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9611            // Keep EMU module informed on the source HF clock frequency. This will apply voltage
   9612            // downscaling after clock is set if downscaling is configured.
   9613            if (vScaleFrequency == 0UL) {
   9614              EMU_VScaleEM01ByClock(0, true);
   9615            }
   9616          #endif
   9617          
   9618            // Set optimized HFPER clock-tree prescalers.
   9619            hfperClkOptimizedPrescaler();
   9620          }
   9621          
   9622          /***************************************************************************//**
   9623           * @brief This function is used to initialize the HF clock and selecting
   9624           *        HFRCO as the clock source.
   9625           *
   9626           * @note FOR INTERNAL USE ONLY.
   9627           *
   9628           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9629           *       the clock is HF and HFRCO is selected as the clock source.
   9630           ******************************************************************************/
   9631          void sli_em_cmu_HFClockSelectHFRCO(void)
   9632          {
   9633          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9634            uint32_t vScaleFrequency = 0;    /* Use default. */
   9635            if (((uint32_t)CMU_HFRCOBandGet() > CMU_VSCALEEM01_LOWPOWER_VOLTAGE_CLOCK_MAX)) {
   9636              vScaleFrequency = (uint32_t)CMU_HFRCOBandGet();
   9637            }
   9638            if (vScaleFrequency != 0UL) {
   9639              EMU_VScaleEM01ByClock(vScaleFrequency, false);
   9640            }
   9641          #endif
   9642          
   9643          #if defined(CMU_MAX_FREQ_HFLE)
   9644            // Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9645            // This is known after 'select' is written below.
   9646            setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9647          #endif
   9648          
   9649            // Enable HFRCO oscillator
   9650            CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
   9651          
   9652            // Configure worst case wait-states for flash and set safe HFPER
   9653            // clock-tree prescalers.
   9654            flashWaitStateMax();
   9655            hfperClkSafePrescaler();
   9656          
   9657          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9658            // Wait for voltage upscaling to complete before the clock is set.
   9659            if (vScaleFrequency != 0UL) {
   9660              EMU_VScaleWait();
   9661            }
   9662          #endif
   9663          
   9664          #if defined(_SILICON_LABS_32B_SERIES_1)
   9665            // Select HF clock source.
   9666            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCO;
   9667          #if defined(CMU_MAX_FREQ_HFLE)
   9668            // Set HFLE clock.
   9669            setHfLeConfig(SystemHFClockGet());
   9670          #endif
   9671          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9672            // Select HF clock source.
   9673            CMU->CMD = CMU_CMD_HFCLKSEL_HFRCO;
   9674          #if defined(CMU_MAX_FREQ_HFLE)
   9675            // Set HFLE clock.
   9676            setHfLeConfig(SystemCoreClockGet());
   9677          #endif
   9678          #endif
   9679          
   9680            // Optimize flash access wait state setting for the currently selected core clk.
   9681            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9682          
   9683          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9684            // Keep EMU module informed on the source HF clock frequency. This will apply voltage
   9685            // downscaling after clock is set if downscaling is configured.
   9686            if (vScaleFrequency == 0UL) {
   9687              EMU_VScaleEM01ByClock(0, true);
   9688            }
   9689          #endif
   9690          
   9691            // Set optimized HFPER clock-tree prescalers.
   9692            hfperClkOptimizedPrescaler();
   9693          }
