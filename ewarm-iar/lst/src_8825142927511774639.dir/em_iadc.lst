    229            float offsetAnaBase;
    230            float gainSysHiAcc;
    231            float refVoltage = 0;
    232            // Over sampling ratio for high accuracy conversions
    233            const float osrHiAcc[6] = { 16.0, 32.0, 64.0, 92.0, 128.0, 256.0 };
