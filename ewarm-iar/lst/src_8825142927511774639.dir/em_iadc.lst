    217            uint8_t timebase;
    218            unsigned uiAnaGain;
    219            uint16_t uiGainCAna;
    220            IADC_CfgAdcMode_t adcMode;
    221          #if defined(_IADC_CFG_ADCMODE_HIGHACCURACY)
    222            float anaGain;
