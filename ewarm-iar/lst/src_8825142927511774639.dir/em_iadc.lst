   \        0x0   0xE92D 0x4FF8      PUSH     {R3-R11,LR}
   \        0x4   0x4614             MOV      R4,R2
   \        0x6   0xED2D 0x8B02      VPUSH    {D8}
   \        0xA   0x4683             MOV      R11,R0
