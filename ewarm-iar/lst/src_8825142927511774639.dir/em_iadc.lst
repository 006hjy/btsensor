     40          /***************************************************************************//**
     41           * @addtogroup iadc IADC - Incremental ADC
     42           * @brief Incremental Analog to Digital Converter (IADC) Peripheral API
     43           * @details
     44           *  This module contains functions to control the IADC peripheral of Silicon
     45           *  Labs 32-bit MCUs and SoCs. The IADC is used to convert analog signals into a
     46           *  digital representation.
     47           * @{
     48           ******************************************************************************/
     49          
     50          /*******************************************************************************
     51           *******************************   DEFINES   ***********************************
     52           ******************************************************************************/
     53          
     54          /** @cond DO_NOT_INCLUDE_WITH_DOXYGEN */
     55          
     56          // Validation of IADC register block pointer reference for assert statements.
     57          #if defined(IADC_NUM)
     58          #define IADC_REF_VALID(ref)    (IADC_NUM(ref) != -1)
     59          #else
     60          #if (IADC_COUNT == 1)
     61          #define IADC_REF_VALID(ref)    ((ref) == IADC0)
     62          #define IADC_NUM(ref)          (((ref) == IADC0) ? 0 : -1)
     63          #elif (IADC_COUNT == 2)
     64          #define IADC_REF_VALID(ref)    (((ref) == IADC0) || ((ref) == IADC1))
     65          #define IADC_NUM(ref)          (((ref) == IADC0) ? 0 : ((ref) == IADC1) ? 1 : -1)
     66          #endif
     67          #endif
     68          
     69          // Max IADC clock rates
     70          #define IADC_CLK_MAX_FREQ                   40000000UL
     71          #define IADC_ANA_CLK_HIGH_SPEED_MAX_FREQ    20000000UL
     72          #define IADC_ANA_CLK_NORMAL_MAX_FREQ        10000000UL
     73          #define IADC_ANA_CLK_HIGH_ACCURACY_MAX_FREQ  5000000UL
     74          #if defined (_IADC_CFG_ADCMODE_HIGHSPEED)
     75          #define IADC_ANA_CLK_MAX_FREQ(adcMode) (                          \
     76              (adcMode) == iadcCfgModeNormal ? IADC_ANA_CLK_NORMAL_MAX_FREQ \
     77              : ((adcMode) == iadcCfgModeHighSpeed                          \
     78                 ? IADC_ANA_CLK_HIGH_SPEED_MAX_FREQ                         \
     79                 : IADC_ANA_CLK_HIGH_ACCURACY_MAX_FREQ)                     \
     80              )
     81          #else
     82          #define IADC_ANA_CLK_MAX_FREQ(adcMode) (                          \
     83              (adcMode) == iadcCfgModeNormal ? IADC_ANA_CLK_NORMAL_MAX_FREQ \
     84              : IADC_ANA_CLK_HIGH_ACCURACY_MAX_FREQ                         \
     85              )
     86          #endif
     87          
     88          #define IADC_ROUND_D2I(n) (int)((n) < 0.0f ? ((n) - 0.5f) : ((n) + 0.5f))
     89          
     90          #define IADC0_SCANENTRIES IADC0_ENTRIES
     91          #define IADC0_FIFOENTRIES 0x4UL
     92          
     93          #define IADC1_SCANENTRIES IADC1_ENTRIES
     94          #define IADC1_FIFOENTRIES 0x4UL
     95          
     96          #if defined(IADC_ENTRIES)
     97          #define IADC_SCANENTRIES(iadc) IADC_ENTRIES(IADC_NUM(iadc))
     98          #else
     99          #define IADC_SCANENTRIES(iadc) (        \
    100              (iadc) == IADC0 ? IADC0_SCANENTRIES \
    101              : 0UL)
    102          #endif
    103          
    104          #if !defined(IADC_CONFIGNUM)
    105          #define IADC_CONFIGNUM(iadc) (    \
    106              (iadc) == 0 ? IADC0_CONFIGNUM \
    107              : 0UL)
    108          #endif
    109          
    110          #define IADC_FIFOENTRIES(iadc) (        \
    111              (iadc) == IADC0 ? IADC0_FIFOENTRIES \
    112              : 0UL)
    113          
    114          #define IADC_CMU_CLOCK(iadc) (       \
    115              (iadc) == IADC0 ? cmuClock_IADC0 \
    116              : cmuClock_IADC0)
    117          
    118          /** @endcond */
