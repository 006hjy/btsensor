    202          #if defined(USART_IRCTRL_IRPRSEN)
    203          /***************************************************************************//**
    204           * @brief
    205           *   Configure a PRS channel as USART Ir input
    206           *
    207           * @param[in] usart
    208           *   A pointer to the USART/UART peripheral register block.
    209           *
    210           * @param[in] ch
    211           *   PRS channel.
    212           ******************************************************************************/
    213          static void prsIrInput(USART_TypeDef *usart, USART_PRS_Channel_t ch)
    214          {
    215          #if defined(_USART_IRCTRL_IRPRSSEL_SHIFT)
    216            #if defined(USART_HAS_SET_CLEAR)
    217            usart->IRCTRL_SET = ((uint32_t)ch << _USART_IRCTRL_IRPRSSEL_SHIFT)
    218                                | USART_IRCTRL_IRPRSEN;
    219            #else
    220            usart->IRCTRL |= ((uint32_t)ch << _USART_IRCTRL_IRPRSSEL_SHIFT)
    221                             | USART_IRCTRL_IRPRSEN;
    222            #endif
    223          
    224          #else
    225            (void)ch;
    226            #if defined(USART_HAS_SET_CLEAR)
    227            usart->IRCTRL_SET = USART_IRCTRL_IRPRSEN;
    228            #else
    229            usart->IRCTRL |= USART_IRCTRL_IRPRSEN;
    230            #endif
    231          #endif
    232          }
    233          #endif
    234          
    235          #if defined(USART_IRCTRL_IRPRSEN) && defined(CONSUMER_USART0_IR)
    236          /***************************************************************************//**
    237           * @brief
    238           *   Configure a PRS channel as USART Ir input
    239           *
    240           * @param[in] usart
    241           *   A pointer to the USART/UART peripheral register block.
    242           *
    243           * @param[in] ch
    244           *   PRS channel.
    245           ******************************************************************************/
    246          static void prsIrInput(USART_TypeDef *usart, USART_PRS_Channel_t ch)
    247          {
    248            if (usart == USART0) {
    249              PRS->CONSUMER_USART0_IR = ch;
    250            }
    251          #if defined(USART1)
    252            else if (usart == USART1) {
    253              PRS->CONSUMER_USART1_IR = ch;
    254            }
    255          #endif
    256          #if defined(USART2)
    257            else if (usart == USART2) {
    258              PRS->CONSUMER_USART2_IR = ch;
    259            }
    260          #endif
    261          #if defined(USART_HAS_SET_CLEAR)
    262            usart->IRCTRL_SET = USART_IRCTRL_IRPRSEN;
    263          #else
    264            usart->IRCTRL |= USART_IRCTRL_IRPRSEN;
    265          #endif
    266          }
    267          #endif
    268          
    269          /***************************************************************************//**
    270           * @brief
    271           *   Configure a PRS channel as USART Trigger input
    272           *
    273           * @param[in] usart
    274           *   A pointer to the USART/UART peripheral register block.
    275           *
    276           * @param[in] ch
    277           *   PRS channel.
    278           ******************************************************************************/
    279          static void prsTriggerInput(USART_TypeDef *usart, USART_PRS_Channel_t ch)
    280          {
    281          #if defined(_USART_IRCTRL_IRPRSSEL_MASK)
    282            usart->TRIGCTRL = (usart->TRIGCTRL & ~_USART_TRIGCTRL_TSEL_MASK)
    283                              | (ch << _USART_TRIGCTRL_TSEL_SHIFT);
    284          #else
    285            if (usart == USART0) {
    286              PRS->CONSUMER_USART0_TRIGGER = ch;
    287            }
    288          #if (USART_COUNT > 1)
    289            else if (usart == USART1) {
    290              PRS->CONSUMER_USART1_TRIGGER = ch;
    291            }
    292          #endif
    293          #if (USART_COUNT > 2)
    294            else if (usart == USART2) {
    295              PRS->CONSUMER_USART2_TRIGGER = ch;
    296            }
    297          #endif
    298          #endif
    299          }
