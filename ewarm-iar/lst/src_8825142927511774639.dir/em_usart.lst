    163          /***************************************************************************//**
    164           * @brief
    165           *   Configure a PRS channel as USART Rx input
    166           *
    167           * @param[in] usart
    168           *   A pointer to the USART/UART peripheral register block.
    169           *
    170           * @param[in] ch
    171           *   PRS channel.
    172           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    173          static void prsRxInput(USART_TypeDef *usart, USART_PRS_Channel_t ch)
    174          {
    175          #if defined(_USART_INPUT_MASK)
    176            usart->INPUT = ((uint32_t)ch << _USART_INPUT_RXPRSSEL_SHIFT)
    177                           | USART_INPUT_RXPRS;
    178          #elif defined(USART_CTRLX_RXPRSEN)
    179            if (usart == USART0) {
   \                     prsRxInput: (+1)
   \        0x0   0x.... 0x....      LDR.W    R3,??DataTable12
   \        0x4   0xB510             PUSH     {R4,LR}
   \        0x6   0x.... 0x....      LDR.W    R2,??DataTable12_1
   \        0xA   0x4298             CMP      R0,R3
   \        0xC   0xBF08             IT       EQ
   \        0xE   0x6011             STREQ    R1,[R2, #+0]
    180              PRS->CONSUMER_USART0_RX = ch;
   \       0x10   0xD004             BEQ.N    ??prsRxInput_0
    181            }
    182          #if defined(USART1)
    183            else if (usart == USART1) {
   \       0x12   0x.... 0x....      LDR.W    R4,??DataTable12_2
   \       0x16   0x42A0             CMP      R0,R4
   \       0x18   0xBF08             IT       EQ
   \       0x1A   0x6111             STREQ    R1,[R2, #+16]
    184              PRS->CONSUMER_USART1_RX = ch;
    185            }
    186          #endif
    187          #if defined(USART2)
    188            else if (usart == USART2) {
    189              PRS->CONSUMER_USART2_RX = ch;
    190            }
    191          #endif
    192          #if defined(USART_HAS_SET_CLEAR)
    193            usart->CTRLX_SET = USART_CTRLX_RXPRSEN;
   \                     ??prsRxInput_0: (+1)
   \       0x1C   0x2180             MOVS     R1,#+128
   \       0x1E   0xF241 0x025C      MOVW     R2,#+4188
   \       0x22   0x5081             STR      R1,[R0, R2]
    194          #else
    195            usart->CTRLX |= USART_CTRLX_RXPRSEN;
    196          #endif
    197          
    198          #endif
    199          }
   \       0x24   0xBD10             POP      {R4,PC}
    200          #endif
