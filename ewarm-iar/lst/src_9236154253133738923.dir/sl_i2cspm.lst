    228          
    229          /***************************************************************************//**
    230           * @brief
    231           *   Map I2C port to peripheral enum
    232           ******************************************************************************/
    233          static sl_peripheral_t get_peripheral_from_i2c_port(I2C_TypeDef *port)
    234          {
    235            // Use I2C_NUM to get instance number, then switch on it
    236            int8_t i2c_instance = I2C_NUM(port);
    237          
    238            switch (i2c_instance) {
    239          #if defined(I2C0)
    240              case 0:
    241                return SL_PERIPHERAL_I2C0;
    242          #endif
    243          #if defined(I2C1)
    244              case 1:
    245                return SL_PERIPHERAL_I2C1;
    246          #endif
    247          #if defined(I2C2)
    248              case 2:
    249                return SL_PERIPHERAL_I2C2;
    250          #endif
    251          #if defined(I2C3)
    252              case 3:
    253                return SL_PERIPHERAL_I2C3;
    254          #endif
    255              default:
    256                // Invalid I2C instance - this should never happen with proper usage
    257                EFM_ASSERT(false);
    258                return NULL; // Return NULL to indicate invalid peripheral
    259            }
    260          }
    261          
    262          /***************************************************************************//**
    263           * @brief
    264           *   Map frequency value to frequency mode enum
    265           ******************************************************************************/
    266          static sl_i2c_freq_mode_t map_frequency_to_mode(uint32_t frequency)
    267          {
    268            if (frequency <= 100000) {
    269              return SL_I2C_FREQ_STANDARD_MODE;
    270            } else if (frequency <= 400000) {
    271              return SL_I2C_FREQ_FAST_MODE;
    272            } else {
    273              return SL_I2C_FREQ_FASTPLUS_MODE;
    274            }
    275          }

