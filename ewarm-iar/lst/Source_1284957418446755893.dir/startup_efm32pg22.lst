    297          #if defined(__clang__)
    298            typedef struct { uint32_t const* src; uint32_t* dest; uint32_t wlen; }   __copy_table_t;
    299            extern const __copy_table_t __copy_table_start__;
    300            extern const __copy_table_t __copy_table_end__;
    301          
    302            for (__copy_table_t const* pTable = &__copy_table_start__; pTable < &__copy_table_end__; ++pTable) {
    303              for (uint32_t i = 0u; i < pTable->wlen; ++i) {
    304                pTable->dest[i] = pTable->src[i];
    305              }
    306            }
    307          #else
    308            uint32_t        *pSrc;
    309            uint32_t        *pDest;
    310            extern uint32_t __etext;
    311            extern uint32_t __data_start__;
    312            extern uint32_t __data_end__;
    313          
    314            pSrc  = &__etext;
    315            pDest = &__data_start__;
    316          
    317            for (; pDest < &__data_end__; ) {
    318              *pDest++ = *pSrc++;
    319            }
    320          #endif // defined(__clang__)
    321          }
