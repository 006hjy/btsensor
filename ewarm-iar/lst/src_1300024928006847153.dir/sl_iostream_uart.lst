    515          /**************************************************************************//**
    516           * Set read blocking mode
    517           *****************************************************************************/
    518          static void set_read_block(void *context,
    519                                     bool on)
    520          {
    521            sl_iostream_uart_context_t *uart_context = (sl_iostream_uart_context_t *)context;
    522            bool block;
    523            osKernelState_t state;
    524            osStatus_t status;
    525            uint32_t set_flags;
    526          
    527            sl_atomic_load(block, uart_context->block);
    528            state = osKernelGetState();
    529            if (state == osKernelRunning) {
    530              // When re-enabling block mode, re-initialize the event flag to reflect the current state
    531              if (on == true && block == false) {
    532                // Read-signal should have been deinit when non-blocking
    533                EFM_ASSERT(uart_context->rx_data_flag == NULL);
    534          
    535                // Init the rx_data_flag boolean event flag
    536                osEventFlagsAttr_t f_attr;
    537                f_attr.name = "RX Data Available Flag";
    538                f_attr.attr_bits = 0u;
    539                f_attr.cb_mem = uart_context->rx_data_flag_cb;
    540                f_attr.cb_size = osEventFlagsCbSize;
    541                uart_context->rx_data_flag = osEventFlagsNew(&f_attr);
    542                EFM_ASSERT(uart_context->rx_data_flag != NULL);
    543          
    544                // Set the event flag to reflect the current state
    545                if (!rx_buffer_empty(uart_context)) {
    546                  set_flags = osEventFlagsSet(uart_context->rx_data_flag, RX_DATA_AVAILABLE_FLAG);
    547                  EFM_ASSERT(set_flags == RX_DATA_AVAILABLE_FLAG);
    548                }
    549              }
    550              // When disabling block mode, deinit the rx_data_flag event flag
    551              else if (on == false && block == true) {
    552                status = osEventFlagsDelete(uart_context->rx_data_flag);
    553                EFM_ASSERT(status == osOK);
    554                uart_context->rx_data_flag = NULL;
    555              }
    556            }
    557            // Set the block context variable
    558            sl_atomic_store(uart_context->block, on);
    559          }
    560          #endif
    561          
