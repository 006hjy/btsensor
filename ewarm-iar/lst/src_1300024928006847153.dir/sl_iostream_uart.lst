    685          /***************************************************************************//**
    686           * Scan the RX buffer in reverse to find a new control character.
    687           ******************************************************************************/
    688          static void scan_for_ctrl_char(sl_iostream_uart_context_t * uart_context)
    689          {
    690            // Since RX is buffered, everytime a TX is attempted, a check must be made to validate if a control
    691            // character was received since the last TX call. Check between the last scanned data, and the
    692            // newest data received from the bus.
    693            //
    694            // [scanned data| unscanned data | reception room ]
    695            //      scan ptr^     newest byte^
    696            //               <=====Scan======
    697            //
    698            // Scan in reverse order, as only the latest control character is of interest. For example, if
    699            // [XOFF,XOFF,XON] is received, only the last XON byte is to be considered. Once scan is complete,
    700            // move the scan pointer to the end of the newest data section so that the next scan will only check
    701            // unscanned data, making the check faster.
    702            //
    703            // [     scanned unread data     | reception room ]
    704            //                       scan ptr^
    705            //                    newest byte^
    706            //
    707            // Note: The scan pointer will also be updated when RX buffer is read by user to accelerate the scan.
    708          
    709            const uint8_t *current_byte;
    710            uint8_t *newest_byte;
    711            bool rx_empty;
    712            sl_status_t status;
    713            CORE_DECLARE_IRQ_STATE;
    714          
    715            // No data to be scanned
    716            if (rx_buffer_empty(uart_context)) {
    717              EFM_ASSERT(uart_context->ctrl_char_scan_ptr == uart_context->rx_read_ptr);
    718              return;
    719            }
    720          
    721            CORE_ENTER_ATOMIC();
    722            status = sli_iostream_dmadrv_pause_transfer(uart_context->rx_dma.channel);
    723            EFM_ASSERT(status == SL_STATUS_OK);
    724          
    725            // Get the newest byte received
    726            newest_byte = __get_write_ptr(uart_context) - 1;
    727            if (newest_byte < uart_context->rx_buffer) {
    728              // Wrap newest byte ptr around the ring buffer
    729              newest_byte = uart_context->rx_buffer + (uart_context->rx_buffer_len - 1);
    730            }
    731          
    732            rx_empty = uart_context->rx_empty;
    733          
    734            status = sli_iostream_dmadrv_resume_transfer(uart_context->rx_dma.channel);
    735            EFM_ASSERT(status == SL_STATUS_OK);
    736          
    737            // No data to be scanned
    738            if (rx_empty) {
    739              // Sanity check
    740              EFM_ASSERT(uart_context->ctrl_char_scan_ptr == uart_context->rx_read_ptr);
    741          
    742              goto exit;
    743            }
    744          
    745            // Scan the entire buffer until we reach the position of the last scan,
    746            // or until we find the newest control character
    747            current_byte = newest_byte;
    748            while (current_byte != uart_context->ctrl_char_scan_ptr) {
    749              if (*current_byte == UARTXON || *current_byte == UARTXOFF) {
    750                // Found latest control character, apply it and break early.
    751                sl_atomic_store(uart_context->xon, (*current_byte == UARTXON));
    752                break;
    753              }
    754          
    755              // Decrement and wrap current byte ptr around the ring buffer
    756              current_byte--;
    757              if (current_byte < uart_context->rx_buffer) {
    758                current_byte = uart_context->rx_buffer + (uart_context->rx_buffer_len - 1);
    759              }
    760            }
    761          
    762            // Update scan pointer
    763            uart_context->ctrl_char_scan_ptr = newest_byte;
    764          
    765            exit:
    766            CORE_EXIT_ATOMIC();
    767          }
    768          
    769          /***************************************************************************//**
    770           * Internal stream write implementation
    771           ******************************************************************************/
    772          static sl_status_t nolock_uart_write(void *context,
    773                                               const void *buffer,
    774                                               size_t buffer_length)
    775          {
    776            sl_iostream_uart_context_t *uart_context = (sl_iostream_uart_context_t *)context;
    777            char *c = (char *)buffer;
    778            bool lf_to_crlf = false;
    779            sl_status_t status = SL_STATUS_FAIL;
    780          
    781            sl_atomic_load(lf_to_crlf, uart_context->lf_to_crlf);
    782          
    783          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT) && !defined(SL_IOSTREAM_UART_FLUSH_TX_BUFFER)
    784            CORE_DECLARE_IRQ_STATE;
    785            CORE_ENTER_ATOMIC();
    786            if (uart_context->tx_idle == true && uart_context->enable_high_frequency) {
    787              uart_context->tx_idle = false;
    788              sl_power_manager_add_em_requirement(SL_POWER_MANAGER_EM1);
    789            }
    790            CORE_EXIT_ATOMIC();
    791          #endif
    792          
    793            uint32_t i = 0;
    794            while (i < buffer_length) {
    795              bool xon = false;
    796              if (uart_context->sw_flow_control == true) {
    797                scan_for_ctrl_char(uart_context);
    798              }
    799              sl_atomic_load(xon, uart_context->xon);
    800              if (xon) {
    801                if ((lf_to_crlf == true) && (*c == '\n')) {
    802                  status = uart_context->uart_periph->tx(uart_context, '\r');
    803                  if (status != SL_STATUS_OK) {
    804                    return status;
    805                  }
    806                }
    807                status = uart_context->uart_periph->tx(uart_context, *c);
    808                if (status != SL_STATUS_OK) {
    809                  return status;
    810                }
    811                c++;
    812                i++;
    813              }         // Active wait if xon is false
    814            }
    815          
    816          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT) && !defined(SL_IOSTREAM_UART_FLUSH_TX_BUFFER)
    817            uart_context->uart_periph->tx_completed(context, true);
    818          #endif
    819          
    820            return status;
    821          }
