    394          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT) && !defined(SL_CATALOG_KERNEL_PRESENT)
    395          /**************************************************************************//**
    396           * Check if MCU was woken up by new data on UART.
    397           *****************************************************************************/
    398          static bool wakeup_from_rx(const sl_iostream_uart_context_t *uart_context)
    399          {
    400            sl_status_t status;
    401            const uint8_t *write_ptr;
    402            const uint8_t channel = uart_context->rx_dma.channel;
    403            bool rx_wakeup;
    404          
    405            status = sli_iostream_dmadrv_pause_transfer(channel);
    406            EFM_ASSERT(status == SL_STATUS_OK);
    407          
    408            write_ptr = (uint8_t*)LDMA_PERIPH->CH[channel].DST;
    409          
    410            // If the bus was the source of the IRQ that just woke the core up, the DMA should
    411            // no longer be waiting on the null_byte, since the DMA will have received at
    412            // least one byte.
    413            rx_wakeup = !(write_ptr == &null_byte);
    414          
    415            status = sli_iostream_dmadrv_resume_transfer(channel);
    416            EFM_ASSERT(status == SL_STATUS_OK);
    417          
    418            return rx_wakeup;
    419          }
