   1277          /***************************************************************************//**
   1278           * Tries to read the requested amount of data.
   1279           * Returns the number of bytes read.
   1280           ******************************************************************************/
   1281          static size_t read_rx_buffer(sl_iostream_uart_context_t * uart_context,
   1282                                       uint8_t * buffer,
   1283                                       size_t buffer_len)
   1284          {
   1285            bool update_xon = false;
   1286            bool send_xon = false;
   1287            size_t read_size = 0;
   1288            size_t ret_val = 0;
   1289            CORE_DECLARE_IRQ_STATE;
   1290          
   1291            if (buffer_len == 0 || buffer == NULL) {
   1292              return 0;
   1293            }
   1294          
   1295            if (rx_buffer_empty(uart_context)) {
   1296              // RX buffer is empty
   1297              return 0;
   1298            }
   1299          
   1300            // Compute number of bytes available
   1301            read_size = __get_bytes_available(uart_context);
   1302          
   1303            // Limit read size to buffer size
   1304            read_size = read_size > buffer_len ? buffer_len : read_size;
   1305            EFM_ASSERT(read_size > 0);
   1306          
   1307            // Number of bytes written to user buffer can be different if control character are present
   1308            ret_val = read_size;
   1309          
   1310            // Copy data to ouput buffer
   1311            {
   1312              // Handle control character and copy data to the user buffer
   1313              if (uart_context->sw_flow_control) {
   1314                CORE_ENTER_ATOMIC();
   1315          
   1316                const uint8_t *curr_char = uart_context->rx_read_ptr;
   1317          
   1318                // When the RX buffer was filled up, sent a XOFF. Just made some room in the buffer, signal
   1319                // the remote it can resume TX.
   1320                send_xon = __rx_buffer_full(uart_context);
   1321          
   1322                for (size_t bytes_read = 0; bytes_read < read_size; bytes_read++, curr_char++) {
   1323                  if (curr_char == uart_context->ctrl_char_scan_ptr) {
   1324                    // Caught up to most recent scanned byte, increment the scan ptr
   1325                    uart_context->ctrl_char_scan_ptr++;
   1326                    update_xon = true;
   1327                  }
   1328          
   1329                  if (*curr_char != (uint8_t)UARTXON && *curr_char != (uint8_t)UARTXOFF) {
   1330                    // No control character, read data and increment user buffer
   1331                    *buffer++ = *curr_char;
   1332                    continue;
   1333                  }
   1334          
   1335                  // Received a control character, don't copy it to the user buffer
   1336                  ret_val--;
   1337          
   1338                  if (update_xon) {
   1339                    // Current byte is the most recent scanned byte. Apply control character
   1340                    sl_atomic_store(uart_context->xon, (*curr_char == (uint8_t)UARTXON));
   1341                  }
   1342                }
   1343          
   1344                // Wrap ctrl_char_scan_ptr around the rx_buffer
   1345                if (uart_context->ctrl_char_scan_ptr == (uart_context->rx_buffer + uart_context->rx_buffer_len)) {
   1346                  uart_context->ctrl_char_scan_ptr = uart_context->rx_buffer;
   1347                }
   1348          
   1349                EFM_ASSERT(uart_context->ctrl_char_scan_ptr >= uart_context->rx_buffer
   1350                           && uart_context->ctrl_char_scan_ptr < (uart_context->rx_buffer + uart_context->rx_buffer_len));
   1351          
   1352                CORE_EXIT_ATOMIC();
   1353              }
   1354              // Copy the data to the output buffer
   1355              else {
   1356                memcpy(buffer, uart_context->rx_read_ptr, read_size);
   1357              }
   1358            }
   1359          
   1360            // Update the ring buffer after read
   1361            update_ring_buffer(uart_context, read_size);
   1362          
   1363            if (uart_context->sw_flow_control && send_xon) {
   1364              // Just made some room in RX buffer, signal remote it can resume TX.
   1365              uart_context->uart_periph->tx(uart_context, UARTXON);
   1366            }
   1367          
   1368            return ret_val;
   1369          }
