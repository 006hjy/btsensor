    805          /***************************************************************************//**
    806           * @brief
    807           *  Start an LDMA transfer.
    808           ******************************************************************************/
    809          static sl_status_t start_transfer(unsigned int          channelId,
    810                                            sl_dma_signal_t       peripheralSignal,
    811                                            void                  *buf0,
    812                                            void                  *buf1,
    813                                            bool                  bufInc,
    814                                            int                   len,
    815                                            sl_dma_ctrl_size_t    size,
    816                                            sl_iostream_dmadrv_callback_t callback,
    817                                            void                  *cbUserParam)
    818          {
    819            ChTable_t *ch;
    820            sl_hal_ldma_transfer_config_t xfer;
    821            sl_hal_ldma_descriptor_t *desc;
    822          
    823            if ( !initialized ) {
    824              return SL_STATUS_NOT_INITIALIZED;
    825            }
    826          
    827            if ( (channelId >= DMA_CHAN_COUNT)
    828                 || (buf0 == NULL)
    829                 || (buf1 == NULL)
    830                 || (len < 0)
    831                 || ((unsigned long)len > SL_HAL_LDMA_DESCRIPTOR_MAX_XFER_SIZE) ) {
    832              return SL_STATUS_INVALID_PARAMETER;
    833            }
    834          
    835            ch = &chTable[channelId];
    836            if ( ch->allocated == false ) {
    837              return SL_STATUS_INVALID_HANDLE;
    838            }
    839          
    840            xfer = xferCfgPeripheral;
    841            desc = &dmaXfer[channelId].desc[0];
    842          
    843            // peripheral to mem
    844            *desc = p2m;
    845            if ( !bufInc ) {
    846              desc->xfer.dst_inc = SL_HAL_LDMA_CTRL_DST_INC_NONE;
    847            }
    848          
    849            xfer.request_sel      = *peripheralSignal;
    850            desc->xfer.xfer_count = len - 1;
    851            desc->xfer.dst_addr   = (uint32_t)(uint8_t *)buf0;
    852            desc->xfer.src_addr   = (uint32_t)(uint8_t *)buf1;
    853            desc->xfer.size       = size;
    854          
    855            /* Whether an interrupt is needed. */
    856            if (callback == NULL) {
    857              desc->xfer.done_ifs = 0;
    858            }
    859          
    860            ch->callback      = callback;
    861            ch->userParam     = cbUserParam;
    862            ch->callbackCount = 0;
    863          
    864            sl_dma_manager_register_channel_irq_callback(dmadrv_dma_manager_handle, (uint8_t)channelId, internalCallbacks[channelId]);
    865          
    866            sl_hal_ldma_init_transfer(LDMA0, channelId, &xfer, desc);
    867            sl_hal_ldma_start_transfer(LDMA0, channelId);
    868            if (channelId < 16) {
    869              sl_hal_ldma_enable_interrupts(LDMA0, (0x1UL << channelId));
    870            }
    871          #if defined(_LDMA_IFH_MASK)
    872            else {
    873              sl_hal_ldma_enable_high_interrupts(LDMA0, (0x1UL << (channelId - 16)));
    874            }
    875          #endif
    876          
    877            return SL_STATUS_OK;
    878          }

