    149          #if defined(_SILICON_LABS_32B_SERIES_3)
    150          static inline sl_hal_eusart_parity_t iostream_to_hal_parity(sl_iostream_eusart_uart_parity_t parity)
    151          {
    152            switch (parity) {
    153              case SL_IOSTREAM_EUSART_UART_NO_PARITY:
    154                return SL_HAL_EUSART_NO_PARITY;
    155              case SL_IOSTREAM_EUSART_UART_EVEN_PARITY:
    156                return SL_HAL_EUSART_NO_PARITY;
    157              case SL_IOSTREAM_EUSART_UART_ODD_PARITY:
    158                return SL_HAL_EUSART_NO_PARITY;
    159              default:
    160                // Unknown parity type
    161                EFM_ASSERT(false);
    162                return SL_HAL_EUSART_NO_PARITY;
    163            }
    164          }
    165          
    166          static inline sl_hal_eusart_stop_bits_t iostream_to_hal_stop(sl_iostream_eusart_uart_stop_bits_t stop)
    167          {
    168            switch (stop) {
    169              case SL_IOSTREAM_EUSART_UART_STOP_BITS_0P5:
    170                return SL_HAL_EUSART_STOP_BITS_0P5;
    171              case SL_IOSTREAM_EUSART_UART_STOP_BITS_1P5:
    172                return SL_HAL_EUSART_STOP_BITS_1P5;
    173              case SL_IOSTREAM_EUSART_UART_STOP_BITS_1:
    174                return SL_HAL_EUSART_STOP_BITS_1;
    175              case SL_IOSTREAM_EUSART_UART_STOP_BITS_2:
    176                return SL_HAL_EUSART_STOP_BITS_2;
    177              default:
    178                // Unknown stop bit type
    179                EFM_ASSERT(false);
    180                return SL_HAL_EUSART_STOP_BITS_1;
    181            }
    182          }
    183          
    184          static inline sl_hal_eusart_hw_flow_control_t iostream_to_hal_flow_control(sl_iostream_eusart_uart_flow_control_t fc)
    185          {
    186            switch (fc) {
    187              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_SOFT:
    188              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_NONE:
    189                return SL_HAL_EUSART_HW_FLOW_CONTROL_NONE;
    190              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_CTS:
    191                return SL_HAL_EUSART_HW_FLOW_CONTROL_CTS;
    192              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_RTS:
    193                return SL_HAL_EUSART_HW_FLOW_CONTROL_RTS;
    194              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_CTS_RTS:
    195                return SL_HAL_EUSART_HW_FLOW_CONTROL_CTS_RTS;
    196              default:
    197                // Unknown flow control type
    198                EFM_ASSERT(false);
    199                return SL_HAL_EUSART_HW_FLOW_CONTROL_NONE;
    200            }
    201          }
    202          
    203           #else
    204          static inline EUSART_Parity_TypeDef iostream_to_hal_parity(sl_iostream_eusart_uart_parity_t parity)
    205          {
    206            switch (parity) {
    207              case SL_IOSTREAM_EUSART_UART_NO_PARITY:
    208                return eusartNoParity;
    209              case SL_IOSTREAM_EUSART_UART_EVEN_PARITY:
    210                return eusartEvenParity;
    211              case SL_IOSTREAM_EUSART_UART_ODD_PARITY:
    212                return eusartOddParity;
    213              default:
    214                // Unknown parity type
    215                EFM_ASSERT(false);
    216                return eusartNoParity;
    217            }
    218          }
    219          
    220          static inline EUSART_Stopbits_TypeDef iostream_to_hal_stop(sl_iostream_eusart_uart_stop_bits_t stop)
    221          {
    222            switch (stop) {
    223              case SL_IOSTREAM_EUSART_UART_STOP_BITS_0P5:
    224                return eusartStopbits0p5;
    225              case SL_IOSTREAM_EUSART_UART_STOP_BITS_1P5:
    226                return eusartStopbits1p5;
    227              case SL_IOSTREAM_EUSART_UART_STOP_BITS_1:
    228                return eusartStopbits1;
    229              case SL_IOSTREAM_EUSART_UART_STOP_BITS_2:
    230                return eusartStopbits2;
    231              default:
    232                // Unknown stop bit type
    233                EFM_ASSERT(false);
    234                return eusartStopbits1;
    235            }
    236          }
    237          
    238          static inline EUSART_HwFlowControl_TypeDef iostream_to_hal_flow_control(sl_iostream_eusart_uart_flow_control_t fc)
    239          {
    240            switch (fc) {
    241              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_SOFT:
    242              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_NONE:
    243                return eusartHwFlowControlNone;
    244              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_CTS:
    245                return eusartHwFlowControlCts;
    246              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_RTS:
    247                return eusartHwFlowControlRts;
    248              case SL_IOSTREAM_EUSART_UART_FLOW_CTRL_CTS_RTS:
    249                return eusartHwFlowControlCtsAndRts;
    250              default:
    251                // Unknown flow control type
    252                EFM_ASSERT(false);
    253                return eusartHwFlowControlNone;
    254            }
    255          }
    256          #if !defined(SL_CATALOG_CLOCK_MANAGER_PRESENT)
    257          
    258          #if defined(EUART_COUNT) && (EUART_COUNT > 0)
    259          #define SL_IOSTREAM_EUSART_PERIPHERAL_NAME               EUART_COUNT
    260          #define SL_IOSTREAM_EUSART_CLOCK_REF(periph_nbr)         SL_CONCAT_PASTER_3(cmuClock_, EUART, periph_nbr)
    261          #else
    262          #define SL_IOSTREAM_EUSART_PERIPHERAL_COUNT              EUSART_COUNT
    263          #define SL_IOSTREAM_EUSART_CLOCK_REF(periph_nbr)         SL_CONCAT_PASTER_3(cmuClock_, EUSART, periph_nbr)
    264          #endif
    265          
    266          static inline CMU_Clock_TypeDef get_cmu_clock(uint8_t eusart_nbr)
    267          {
    268            switch (eusart_nbr) {
    269              case 0:
    270                return SL_IOSTREAM_EUSART_CLOCK_REF(0);
    271              #if SL_IOSTREAM_EUSART_PERIPHERAL_COUNT > 1
    272              case 1:
    273                return SL_IOSTREAM_EUSART_CLOCK_REF(1);
    274              #if SL_IOSTREAM_EUSART_PERIPHERAL_COUNT > 2
    275              case 2:
    276                return SL_IOSTREAM_EUSART_CLOCK_REF(2);
    277              #if SL_IOSTREAM_EUSART_PERIPHERAL_COUNT > 3
    278              case 3:
    279                return SL_IOSTREAM_EUSART_CLOCK_REF(3);
    280              #if SL_IOSTREAM_EUSART_PERIPHERAL_COUNT > 4
    281              case 4:
    282                return SL_IOSTREAM_EUSART_CLOCK_REF(4);
    283              #endif // > 4
    284              #endif // > 3
    285              #endif // > 2
    286              #endif // > 1
    287              default:
    288                // Invalid EUSART peripheral number
    289                EFM_ASSERT(false);
    290                return SL_IOSTREAM_EUSART_CLOCK_REF(0);
    291            }
    292          }
    293          
    294          static inline void init_hf_clocks(sl_iostream_eusart_config_t *eusart_config)
    295          {
    296            CMU_Clock_TypeDef eusart_clock = get_cmu_clock(eusart_config->eusart_nbr);
    297            CMU_ClockEnable(eusart_clock, true);
    298            // Use high frequency clock branch
    299            #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2) \
    300            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7)  \
    301            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) \
    302            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_11) \
    303            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_14)
    304              #if defined(EUART_PRESENT)
    305            CMU_CLOCK_SELECT_SET(EUART0CLK, EM01GRPACLK);
    306              #elif defined(EUSART_PRESENT)
    307            CMU_CLOCK_SELECT_SET(EUSART0CLK, EM01GRPACLK);
    308              #else
    309              #error Missing EU(S)ART peripheral
    310              #endif
    311            #elif (_SILICON_LABS_32B_SERIES_2_CONFIG >= 3)
    312            CMU_CLOCK_SELECT_SET(EM01GRPCCLK, HFRCODPLL);
    313            if (eusart_clock == cmuClock_EUSART0) {
    314              CMU_CLOCK_SELECT_SET(EUSART0CLK, EM01GRPCCLK);
    315            }
    316            #else
    317            #error Unsupported board configuration
    318            #endif
    319          }
    320          
    321          static inline void init_lf_clocks(sl_iostream_eusart_config_t *eusart_config)
    322          {
    323            CMU_Clock_TypeDef eusart_clock = get_cmu_clock(eusart_config->eusart_nbr);
    324            CMU_ClockEnable(eusart_clock, true);
    325            // Use low frequency clock branch
    326            #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2) \
    327            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7)  \
    328            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) \
    329            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_11) \
    330            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_14)
    331            #if defined(EUART_PRESENT)
    332            CMU_CLOCK_SELECT_SET(EUART0CLK, EM23GRPACLK);
    333            #elif defined(EUSART_PRESENT)
    334            CMU_CLOCK_SELECT_SET(EUSART0CLK, EM23GRPACLK);
    335            #else
    336            #error Missing EU(S)ART peripheral
    337            #endif
    338            #elif (_SILICON_LABS_32B_SERIES_2_CONFIG >= 3)
    339            CMU_ClockEnable(cmuClock_LFRCO, true);
    340            if (eusart_clock == cmuClock_EUSART0) {
    341              CMU_CLOCK_SELECT_SET(EUSART0CLK, LFRCO);
    342            }
    343            #else
    344            #error Unsupported board configuration
    345            #endif // _SILICON_LABS_32B_SERIES_2_CONFIG
    346          }
    347          #endif // SL_CATALOG_CLOCK_MANAGER_PRESENT
    348          #endif // _SILICON_LABS_32B_SERIES < 3
