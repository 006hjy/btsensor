    220          /******************************************************************************
    221           * @brief Internal function used to aggregate driver, services stacks and internal apps
    222           * initialization function.
    223           *
    224           * @details If a kernel is present, these components init functions will be
    225           * executed in the start task.
    226           *****************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    227          void sl_main_second_stage_init(void)
    228          {
   \                     sl_main_second_stage_init: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    229            sl_platform_init();
   \        0x2   0x.... 0x....      BL       sl_platform_init
    230            sl_driver_init();
   \        0x6   0x.... 0x....      BL       sl_driver_init
    231            sl_service_init();
   \        0xA   0x.... 0x....      BL       sl_service_init
    232            app_init_post_platform();
   \        0xE   0x.... 0x....      BL       app_init_post_platform
    233            sl_stack_init();
   \       0x12   0x.... 0x....      BL       sl_stack_init
    234            sl_internal_app_init();
   \       0x16   0xE8BD 0x4001      POP      {R0,LR}
   \       0x1A   0x.... 0x....      B.W      sl_internal_app_init
    235          #if defined(SL_CATALOG_KERNEL_PRESENT) && (SL_MAIN_ENABLE_START_TASK_PRIORITY_CHANGE == 1)
    236            osThreadSetPriority(osThreadGetId(), SL_MAIN_START_TASK_PRIORITY);
    237          #endif
    238          }
