    231          
    232          /***************************************************************************//**
    233           * @brief
    234           *   Map I2C port to peripheral enum
    235           ******************************************************************************/
    236          static sl_peripheral_t get_peripheral_from_i2c_port(I2C_TypeDef *port)
    237          {
    238            // Use I2C_NUM to get instance number, then switch on it
    239            int8_t i2c_instance = I2C_NUM(port);
    240          
    241            switch (i2c_instance) {
    242          #if defined(I2C0)
    243              case 0:
    244                return SL_PERIPHERAL_I2C0;
    245          #endif
    246          #if defined(I2C1)
    247              case 1:
    248                return SL_PERIPHERAL_I2C1;
    249          #endif
    250          #if defined(I2C2)
    251              case 2:
    252                return SL_PERIPHERAL_I2C2;
    253          #endif
    254          #if defined(I2C3)
    255              case 3:
    256                return SL_PERIPHERAL_I2C3;
    257          #endif
    258              default:
    259                // Invalid I2C instance - this should never happen with proper usage
    260                EFM_ASSERT(false);
    261                return NULL; // Return NULL to indicate invalid peripheral
    262            }
    263          }
    264          
    265          /***************************************************************************//**
    266           * @brief
    267           *   Map frequency value to frequency mode enum
    268           ******************************************************************************/
    269          static sl_i2c_freq_mode_t map_frequency_to_mode(uint32_t frequency)
    270          {
    271            if (frequency <= 100000) {
    272              return SL_I2C_FREQ_STANDARD_MODE;
    273            } else if (frequency <= 400000) {
    274              return SL_I2C_FREQ_FAST_MODE;
    275            } else {
    276              return SL_I2C_FREQ_FASTPLUS_MODE;
    277            }
    278          }

