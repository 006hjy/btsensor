    253          /***************************************************************************//**
    254           * Read and write existing values in RAM (for ECC initialization).
    255           *
    256           * @param[in] ecc_bank Pointer to ECC RAM bank (sli_hal_syscfg_ecc_bank_t)
    257           *
    258           * @details This function uses core to load and store the existing data
    259           *    values in the given RAM bank.
    260           ******************************************************************************/
    261          static void sli_hal_syscfg_ecc_read_write_existing_pio(const sli_hal_syscfg_ecc_bank_t *ecc_bank)
    262          {
    263            EFM_ASSERT(ecc_bank != NULL);
    264            EFM_ASSERT(ecc_bank->base < (ecc_bank->base + ecc_bank->size));
    265          
    266            volatile const uint32_t *ram_ptr = (volatile const uint32_t *) ecc_bank->base;
    267            const uint32_t *end_ptr = (const uint32_t *) (ecc_bank->base + ecc_bank->size);
    268            volatile const uint32_t *ctrl_reg;
    269            uint32_t enable_ecc;
    270          
    271          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    272            if (ecc_bank->base == ECC_RAM0_MEM_BASE) {
    273              ctrl_reg = &ECC_CTRL0_REG;
    274            } else if (ecc_bank->base == ECC_RAM1_MEM_BASE) {
    275              ctrl_reg = &ECC_CTRL1_REG;
    276            } else {
    277              EFM_ASSERT(0);
    278              return;
    279            }
    280          #else
    281            ctrl_reg = &ECC_CTRL_REG;
    282          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
    283          
    284          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)  \
    285            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7) \
    286            || (defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) && !defined(_MPAHBRAM_CTRL_MASK)) \
    287            || (defined(_SILICON_LABS_32B_SERIES_2_CONFIG_11) && !defined(_MPAHBRAM_CTRL_MASK))
    288            enable_ecc = ecc_bank->init_syndrome_enable;
    289          #elif defined(_MPAHBRAM_CTRL_MASK)
    290            // MPAHBRAM ECC requires both ECCEN and ECCWEN to be set for the syndromes
    291            // to be written in ECC.
    292            enable_ecc = ecc_bank->correction_enable;
    293          
    294          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    295            // Enable ECC syndrome write.
    296            if (ecc_bank->base == ECC_RAM0_MEM_BASE) {
    297              ECC_CTRL0_REG |= ecc_bank->init_syndrome_enable;
    298              ECC_IFC0_REG = ECC_IFC_MASK;
    299            } else if (ecc_bank->base == ECC_RAM1_MEM_BASE) {
    300              ECC_CTRL1_REG |= ecc_bank->init_syndrome_enable;
    301              ECC_IFC1_REG = ECC_IFC_MASK;
    302            }
    303          #else
    304            ECC_CTRL_REG |= ecc_bank->init_syndrome_enable;
    305            ECC_IFC_REG = ECC_IFC_MASK;
    306          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
    307          
    308          #endif
    309          
    310          #ifndef __GNUC__
    311          #define __asm__        asm
    312          #endif
    313          
    314            // Performs a read and write of all RAM address to initialize
    315            // ECC syndromes. ECC is initialized by reading a RAM address
    316            // while ECC is disabled and write it back while ECC is enabled.
    317            //
    318            // HardFault could occur if we try to read values from RAM while ECC
    319            // is enabled and not initialized. In this case, ECC tries to correct the
    320            // value and ended giving the wrong value which could be sometimes an
    321            // non-existing address.
    322            //
    323            // So for ECC initialization to work properly, this must ensures that while
    324            // ECC is enabled, RAM will be accessed only through writes, no reads shall
    325            // occur. It's hard to have such guarantee with C code, because the C
    326            // compiler with optimization settings, can get in the way
    327            // and do some unwanted reads while ECC is enabled. Assembly allows such
    328            // guarantee and let ECC be initialized without triggering errors.
    329          
    330            __asm__ volatile (
    331              "1:\n\t"                              // Define label 1.
    332              "LDR r1, [%[ram_ptr]]\n\t"            // Load content of ram_ptr into R1, ECC
    333                                                    //   is disabled to get a correct value.
    334              "LDR r0, [%[ctrl_reg]]\n\t"           // Load ctrl_reg content into R0
    335              "ORR r0, r0, %[enable_ecc]\n\t"       // OR R0 and enable_ecc, and store result
    336                                                    //   in R0
    337              "STR r0, [%[ctrl_reg]]\n\t"           // Write R0 into ctrl_reg, ECC is
    338                                                    //   enabled from now on
    339              "STR r1, [%[ram_ptr]]\n\t"            // Write back ram content where it was,
    340                                                    //  syndrome will be written in ECC
    341              "BIC r0, r0, %[enable_ecc]\n\t"       // Bit clear enable_ecc from R0, and store
    342                                                    //   result in R0.
    343              "STR r0, [%[ctrl_reg]]\n\t"           // Write R0 into ctrl_reg, ECC is
    344                                                    //   disabled.
    345              "ADDS %[ram_ptr], %[ram_ptr], #4\n\t" // Increment ram_ptr by 4 (size of
    346                                                    //   a word).
    347              "CMP %[ram_ptr], %[end_ptr]\n\t"      // Compare ram_ptr and end_ptr...
    348              "BCC 1b\n\t"                          //... and jump back to label 1 if Carrry.
    349                                                    // Clear (meaning ram_ptr < end_ptr).
    350              "ORR r0, r0, %[enable_ecc]\n\t"       // And re-enable ECC ASAP to be sure no.
    351              "STR r0, [%[ctrl_reg]]\n\t"           // STR occurs with ECC disabled.
    352              :[ram_ptr] "+r" (ram_ptr)
    353              :[end_ptr] "r" (end_ptr),
    354              [ctrl_reg] "r" (ctrl_reg),
    355              [enable_ecc] "r" (enable_ecc)
    356              : "r0", "r1",                         // R0 and R1 used as temporary registers.
    357              "memory"                              // Memory pointed by ram_ptr is modified.
    358              );
    359          }
    360          
    361          #else
    362          
    363          /***************************************************************************//**
    364           * DMA read and write existing values (for ECC initialization).
    365           *
    366           * @param[in] start Start address of address range in RAM to read/write.
    367           * @param[in] size Size of address range in RAM to read/write.
    368           * @param[in] channels[2] Array of 2 DMA channels to use.
    369           *
    370           * @details This function uses DMA to read and write the existing data values in
    371           *          the RAM region specified by start and size. The function will use the
    372           *          2 DMA channels specified by the channels[2] array.
    373           ******************************************************************************/
    374          static void sli_hal_syscfg_ecc_read_write_existing_dma(uint32_t start,
    375                                                                 uint32_t size,
    376                                                                 const uint32_t channels[2])
    377          {
    378            // Assert that the 2 DMA channel numbers are different.
    379            EFM_ASSERT(channels[0] != channels[1]);
    380            // Make sure ECC_RAM_SIZE_MAX is a multiple of ECC_DMA_DESC_SIZE in order
    381            // to match the total xfer size of the descriptor chain with the largest
    382            // ECC RAM bank.
    383            EFM_ASSERT((ECC_RAM_SIZE_MAX % ECC_DMA_DESC_SIZE) == 0);
    384          
    385            uint32_t desc_cnt = 0;
    386            volatile uint32_t dma_desc[ECC_DMA_DESCS][4];
    387            uint32_t ch_mask = (1 << channels[0]) | (1 << channels[1]);
    388          
    389            // Initialize LDMA descriptor chain.
    390            do {
    391              dma_desc[desc_cnt][0] = (LDMA_CH_CTRL_STRUCTTYPE_TRANSFER  // DMA desc CTRL word.
    392                                       | LDMA_CH_CTRL_STRUCTREQ
    393                                       | _LDMA_CH_CTRL_XFERCNT_MASK
    394                                       | LDMA_CH_CTRL_BLOCKSIZE_ALL
    395                                       | LDMA_CH_CTRL_REQMODE_ALL
    396                                       | LDMA_CH_CTRL_SRCINC_ONE
    397                                       | LDMA_CH_CTRL_SIZE_WORD
    398                                       | LDMA_CH_CTRL_DSTINC_ONE);
    399          
    400              // source and destination address.
    401              dma_desc[desc_cnt][1] = start;
    402              dma_desc[desc_cnt][2] = start;
    403              // link to next descriptor.
    404              dma_desc[desc_cnt][3] = LDMA_CH_LINK_LINK
    405                                      | (((uint32_t) &dma_desc[desc_cnt + 1][0])
    406                                         & _LDMA_CH_LINK_LINKADDR_MASK);
    407          
    408              start += ECC_DMA_DESC_SIZE;
    409              size  -= ECC_DMA_DESC_SIZE;
    410              desc_cnt++;
    411            } while (size);
    412          
    413            // Make sure desc_cnt is valid to avoid out-of-bounds access when writing to
    414            // dma_desc array.
    415            if ((desc_cnt < 2) || (desc_cnt > ECC_DMA_DESCS)) {
    416              while (true) {
    417                EFM_ASSERT(false);
    418              }
    419            }
    420            // Now, divide the descriptor list in two parts, one for each channel,
    421            // by setting the link bit and address 0 of the descriptor in the middle
    422            // to 0.
    423            dma_desc[(desc_cnt / 2) - 1][3] = 0;
    424          
    425            // Set last descriptor link bit and address to 0.
    426            dma_desc[desc_cnt - 1][3] = 0;
    427            // Round robin scheduling for all channels (0 = no fixed priority channels).
    428            LDMA->CTRL    = 0 << _LDMA_CTRL_NUMFIXED_SHIFT;
    429            LDMA->EN      = LDMA_EN_EN;
    430            LDMA->CHEN    = 0;
    431            LDMA->DBGHALT = 0;
    432            LDMA->REQDIS  = 0;
    433          
    434            // Disable LDMA interrupts, and clear interrupt status.
    435            LDMA->IEN = 0;
    436            LDMA->IF_CLR = ch_mask;
    437          
    438            // Disable looping.
    439            LDMA->CH[channels[0]].LOOP = 0;
    440            LDMA->CH[channels[1]].LOOP = 0;
    441          
    442            // Set descriptor address for first channel.
    443            LDMA->CH[channels[0]].LINK = ((uint32_t)&dma_desc[0][0])
    444                                         & _LDMA_CH_LINK_LINKADDR_MASK;
    445            // Set descriptor address for second channel.
    446            LDMA->CH[channels[1]].LINK = ((uint32_t)&dma_desc[desc_cnt / 2][0])
    447                                         & _LDMA_CH_LINK_LINKADDR_MASK;
    448            // Clear the channel done flags.
    449            sl_hal_bus_reg_clear_mask(&LDMA->CHDONE, ch_mask);
    450          
    451            // Start transfer by loading descriptors.
    452            LDMA->LINKLOAD = ch_mask;
    453            while (!(((LDMA->CHSTATUS & ch_mask) == 0)
    454                     && ((LDMA->CHDONE & ch_mask) == ch_mask))) {
    455              // Wait until finished.
    456            }
    457          }
    458          #endif /* #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2) || defined(_MPAHBRAM_CTRL_MASK) */
    459          
    460          /***************************************************************************//**
    461           * This function initializes ECC for a given memory bank which is specified
    462           * with the sli_hal_syscfg_ecc_bank_t structure input parameter.
    463           *
    464           * @param[in] ecc_bank ECC memory bank device structure.
    465           * @param[in] dma_channels Array of 2 DMA channels that may be used during ECC
    466           *                         initialization.
    467           ******************************************************************************/
    468          static void sli_hal_syscfg_ecc_init_bank(const sli_hal_syscfg_ecc_bank_t *ecc_bank,
    469                                                   const uint32_t dma_channels[2])
    470          {
    471            EFM_ASSERT(ecc_bank != NULL);
    472            EFM_ASSERT(dma_channels[0] != dma_channels[1]);
    473          
    474            CORE_DECLARE_IRQ_STATE;
    475            CORE_ENTER_CRITICAL();
    476          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)  \
    477            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7) \
    478            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) \
    479            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_11) \
    480            || defined(_MPAHBRAM_CTRL_MASK)
    481          
    482            (void) dma_channels;
    483          #if !defined(_MPAHBRAM_CTRL_MASK)
    484            // Disable ECC write.
    485            ECC_CTRL_REG &= ~ecc_bank->init_syndrome_enable;
    486          #endif
    487            // Initialize ECC syndromes by using core cpu to load and store the existing
    488            // data values in RAM.
    489            sli_hal_syscfg_ecc_read_write_existing_pio(ecc_bank);
    490          #else
    491            // Enable ECC write.
    492            ECC_CTRL_REG |= ecc_bank->init_syndrome_enable;
    493            // Initialize ECC syndromes by using DMA to read and write the existing
    494            // data values in RAM.
    495            sli_hal_syscfg_ecc_read_write_existing_dma(ecc_bank->base, ecc_bank->size, dma_channels);
    496          #endif
    497          
    498            // Clear any ECC errors that may have been reported before or during
    499            // initialization.
    500          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    501            if (ecc_bank->base == ECC_RAM0_MEM_BASE) {
    502              ECC_IFC0_REG = ECC_IFC_MASK;
    503            } else if (ecc_bank->base == ECC_RAM1_MEM_BASE) {
    504              ECC_IFC1_REG = ECC_IFC_MASK;
    505            }
    506          #else
    507            ECC_IFC_REG = ECC_IFC_MASK;
    508          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
    509          
    510          #if !defined(_MPAHBRAM_CTRL_MASK)
    511            // Enable ECC decoder to detect and report ECC errors.
    512            ECC_CTRL_REG |= ecc_bank->correction_enable;
    513          #endif
    514          
    515            CORE_EXIT_CRITICAL();
    516          }
    517          
    518          /***************************************************************************//**
    519           * Disable ECC for a given memory bank.
    520           *
    521           * @param[in] ecc_bank ECC memory bank device structure.
    522           ******************************************************************************/
    523          static void sli_hal_syscfg_ecc_disable_bank(const sli_hal_syscfg_ecc_bank_t *ecc_bank)
    524          {
    525            EFM_ASSERT(ecc_bank != NULL);
    526          
    527          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    528            // Disable ECC write (encoder) and checking (decoder).
    529            if (ecc_bank->base == ECC_RAM0_MEM_BASE) {
    530              ECC_CTRL0_REG &= ~(ecc_bank->init_syndrome_enable | ecc_bank->correction_enable);
    531            } else if (ecc_bank->base == ECC_RAM1_MEM_BASE) {
    532              ECC_CTRL1_REG &= ~(ecc_bank->init_syndrome_enable | ecc_bank->correction_enable);
    533            }
    534          #else
    535            ECC_CTRL_REG &= ~(ecc_bank->init_syndrome_enable | ecc_bank->correction_enable);
    536          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
    537          }
