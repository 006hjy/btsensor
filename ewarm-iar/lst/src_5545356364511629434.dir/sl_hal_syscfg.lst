    565          #if defined(_SYSCFG_DMEM0PORTMAPSEL_MASK)
    566          /***************************************************************************//**
    567           * Set MPAHBRAM port to use to access DMEM.
    568           ******************************************************************************/
    569          void sl_hal_syscfg_set_dmem_port_map(sl_hal_syscfg_dmem_master_t master,
    570                                               uint8_t port)
    571          {
    572            // make sure master is within the mask of port map that can be changed
    573            // and make sure port is a sensible value.
    574            EFM_ASSERT(((1 << master) & _SYSCFG_DMEM0PORTMAPSEL_MASK) != 0x0);
    575          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    576            EFM_ASSERT(port < DMEM_NUM_PORTS);
    577          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    578            EFM_ASSERT(port < DMEM0_NUM_PORTS);
    579          #endif
    580          
    581          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    582            uint32_t bit_field_mask = DMEM_NUM_PORTS - 1;
    583          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    584            uint32_t bit_field_mask = DMEM0_NUM_PORTS - 1;
    585          #endif
    586          
    587            sl_hal_bus_reg_write_mask(&SYSCFG->DMEM0PORTMAPSEL,
    588                                      bit_field_mask << master,
    589                                      (uint32_t)port << master);
    590          }
    591          #endif
    592          
    593          #if defined(_MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK)
    594          /***************************************************************************//**
    595           * Set MPAHBRAM port priority for arbitration when multiple concurrent
    596           * transactions to DMEM.
    597           ******************************************************************************/
    598          void sl_hal_syscfg_set_port_priority(sl_hal_syscfg_port_priority_t port_priority)
    599          {
    600          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    601            EFM_ASSERT(port_priority < ((DMEM_NUM_PORTS + 1) << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT));
    602          
    603            sl_hal_bus_reg_write_mask(&DMEM->CTRL,
    604                                      _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
    605                                      (uint32_t)port_priority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    606          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    607            EFM_ASSERT(port_priority < ((DMEM0_NUM_PORTS + 1) << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT));
    608          
    609            sl_hal_bus_reg_write_mask(&DMEM0->CTRL,
    610                                      _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
    611                                      (uint32_t)port_priority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    612            sl_hal_bus_reg_write_mask(&DMEM1->CTRL,
    613                                      _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
    614                                      (uint32_t)port_priority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    615          #endif
    616          }
    617          
    618          /***************************************************************************//**
    619           * Get MPAHBRAM port arbitration priority selection.
    620           ******************************************************************************/
    621          sl_hal_syscfg_port_priority_t sl_hal_syscfg_get_port_priority(void)
    622          {
    623            uint32_t port = 0;
    624          
    625          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    626            port = sl_hal_bus_reg_read_mask(&DMEM->CTRL,
    627                                            _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK);
    628          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    629            port = sl_hal_bus_reg_read_mask(&DMEM0->CTRL,
    630                                            _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK);
    631          #endif
    632          
    633            return (sl_hal_syscfg_port_priority_t)(port >> _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    634          }
    635          #endif /* if defined(_MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK) */
