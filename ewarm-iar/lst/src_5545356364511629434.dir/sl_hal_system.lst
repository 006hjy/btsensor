    173          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_1)
    174            sl_hal_system_chip_revision_t chipRev;
    175            sl_hal_system_get_chip_revision(&chipRev);
    176          
    177            if (chipRev.major == 0x01 && (HFXO0->STATUS & HFXO_STATUS_ENS) == 0U) {
    178              // Change HFXO default peak detector settings.
    179              *(volatile uint32_t*)(HFXO0_BASE + 0x34U) =
    180                (*(volatile uint32_t*)(HFXO0_BASE + 0x34U) & 0xFF8000FFU)
    181                | 0x00178500U;
    182              // Change HFXO low power control settings.
    183              *(volatile uint32_t*)(HFXO0_BASE + 0x30U) =
    184                (*(volatile uint32_t*)(HFXO0_BASE + 0x30U) & 0xFFFF0FFFU)
    185                | 0x0000C000U;
    186              // Change default SQBUF bias current.
    187              *(volatile uint32_t*)(HFXO0_BASE + 0x30U) |= 0x700;
    188            }
    189          
    190            if (chipRev.major == 0x01 && chipRev.minor == 0x0) {
    191              // Trigger RAM read for each RAM instance.
    192              volatile uint32_t *dmem = (volatile uint32_t *) DMEM_RAM0_RAM_MEM_BASE;
    193              for (uint32_t i = 0U; i < DMEM_NUM_BANK; i++) {
    194                // Force memory read
    195                *dmem;
    196                dmem += (DMEM_BANK0_SIZE / 4U);
    197              }
    198            }
    199          
    200            // Set TRACE clock to intended reset value.
    201            CMU->TRACECLKCTRL = (CMU->TRACECLKCTRL & ~_CMU_TRACECLKCTRL_CLKSEL_MASK)
    202                                | CMU_TRACECLKCTRL_CLKSEL_HFRCOEM23;
