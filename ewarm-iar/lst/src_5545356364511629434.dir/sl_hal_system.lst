   \       0x24   0xBF5C             ITT      PL
   \       0x26   0x....             LDRPL.N  R2,??DataTable19_5
   \       0x28   0x6010             STRPL    R0,[R2, #+0]
    218                CMU->CLKEN0_CLR = CMU_CLKEN0_HFRCO0;
    219              }
