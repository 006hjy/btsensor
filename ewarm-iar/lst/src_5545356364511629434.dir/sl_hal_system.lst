    229              bool dcdcClkIsOff = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) == 0);
    230              CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
    231          
    232              bool dcdcIsLock = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK_LOCKED) != 0);
    233              DCDC->LOCK = DCDC_LOCK_LOCKKEY_UNLOCKKEY;
    234          
    235              while (DCDC->SYNCBUSY & DCDC_SYNCBUSY_CTRL) {
    236                // Wait for previous synchronization to finish.
    237              }
    238          
    239              DCDC->CTRL_CLR = DCDC_CTRL_MODE;
    240              while ((DCDC->STATUS & DCDC_STATUS_BYPSW) == 0U) {
    241                // Wait for BYPASS switch enable.
    242              }
    243          
    244              if (dcdcIsLock) {
    245                DCDC->LOCK = ~DCDC_LOCK_LOCKKEY_UNLOCKKEY;
    246              }
    247          
    248              if (dcdcClkIsOff) {
    249                CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
    250              }
    251          
    252              if (syscfgClkIsOff) {
    253                CMU->CLKEN0_CLR = CMU_CLKEN0_SYSCFG;
    254              }
    255            }
    256          #endif
    257          
    258          // PM-5163.
    259          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_215)    \
