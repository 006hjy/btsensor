    144          /**************************************************************************//**
    145           * @brief
    146           *   Initialize the system.
    147           *
    148           * @details
    149           *   Do required generic HW system init.
    150           *
    151           * @note
    152           *   This function is invoked during system init, before the main() routine
    153           *   and any data has been initialized. For this reason, it cannot do any
    154           *   initialization of variables etc.
    155           *****************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    156          void SystemInit(void)
    157          {
   \                     SystemInit: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
    158          #if defined (__VTOR_PRESENT) && (__VTOR_PRESENT == 1U)
    159            SCB->VTOR = (uint32_t) (&__VECTOR_TABLE[0]);
   \        0x2   0x....             LDR.N    R0,??DataTable3
   \        0x4   0x....             LDR.N    R1,??DataTable3_1
   \        0x6   0x6008             STR      R0,[R1, #+0]
    160          #endif
    161          
    162          #if defined(UNALIGNED_SUPPORT_DISABLE)
    163            SCB->CCR |= SCB_CCR_UNALIGN_TRP_Msk;
    164          #endif
    165          
    166          #if (__FPU_PRESENT == 1)
    167            SCB->CPACR |= ((3U << 10U * 2U)           /* set CP10 Full Access */
    168                           | (3U << 11U * 2U));       /* set CP11 Full Access */
   \        0x8   0x....             LDR.N    R0,??DataTable3_2
   \        0xA   0x6803             LDR      R3,[R0, #+0]
    169          #endif
    170          
    171          /* Secure app takes care of moving between the security states.
    172           * SL_TRUSTZONE_SECURE MACRO is for secure access.
    173           * SL_TRUSTZONE_NONSECURE MACRO is for non-secure access.
    174           * When both the MACROS are not defined, during start-up below code makes sure
    175           * that all the peripherals are accessed from non-secure address except SMU,
    176           * as SMU is used to configure the trustzone state of the system. */
    177          #if !defined(SL_TRUSTZONE_SECURE) && !defined(SL_TRUSTZONE_NONSECURE) \
    178            && defined(__TZ_PRESENT)
    179            CMU->CLKEN1_SET = CMU_CLKEN1_SMU;
   \        0xC   0xF44F 0x4100      MOV      R1,#+32768
   \       0x10   0x....             LDR.N    R2,??DataTable3_3
   \       0x12   0xF443 0x0370      ORR      R3,R3,#0xF00000
   \       0x16   0x6003             STR      R3,[R0, #+0]
   \       0x18   0x6011             STR      R1,[R2, #+0]
    180            // config SMU to Secure and other peripherals to Non-Secure.
    181            SMU->PPUSATD0_CLR = _SMU_PPUSATD0_MASK;
   \       0x1A   0x....             LDR.N    R4,??DataTable3_4
   \       0x1C   0xF04F 0x33FF      MOV      R3,#+4294967295
   \       0x20   0x6563             STR      R3,[R4, #+84]
    182          #if defined (SEMAILBOX_PRESENT)
    183            SMU->PPUSATD1_CLR = (_SMU_PPUSATD1_MASK & (~SMU_PPUSATD1_SMU & ~SMU_PPUSATD1_SEMAILBOX));
    184          #else
    185            SMU->PPUSATD1_CLR = (_SMU_PPUSATD1_MASK & ~SMU_PPUSATD1_SMU);
   \       0x22   0xF64F 0x71DF      MOVW     R1,#+65503
   \       0x26   0x65A1             STR      R1,[R4, #+88]
    186          #endif
    187          
    188            // SAU treats all accesses as non-secure
    189          #if defined(__ARM_FEATURE_CMSE) && (__ARM_FEATURE_CMSE == 3U)
    190            SAU->CTRL = SAU_CTRL_ALLNS_Msk;
   \       0x28   0x2202             MOVS     R2,#+2
   \       0x2A   0x6482             STR      R2,[R0, #+72]
    191            __DSB();
   \       0x2C   0xF3BF 0x8F4F      DSB      SY
    192            __ISB();
   \       0x30   0xF3BF 0x8F6F      ISB      SY
    193          #else
    194            #error "The startup code requires access to the CMSE toolchain extension to set proper SAU settings."
    195          #endif // __ARM_FEATURE_CMSE
    196          
    197          // Clear and Enable the SMU PPUSEC and BMPUSEC interrupt.
    198            NVIC_ClearPendingIRQ(SMU_SECURE_IRQn);
   \       0x34   0x2003             MOVS     R0,#+3
   \       0x36   0x.... 0x....      BL       sl_interrupt_manager_clear_irq_pending
    199            SMU->IF_CLR = SMU_IF_PPUSEC | SMU_IF_BMPUSEC;
   \       0x3A   0xF44F 0x3540      MOV      R5,#+196608
   \       0x3E   0x6025             STR      R5,[R4, #+0]
    200            NVIC_EnableIRQ(SMU_SECURE_IRQn);
   \       0x40   0x2003             MOVS     R0,#+3
   \       0x42   0x.... 0x....      BL       sl_interrupt_manager_enable_irq
    201            SMU->IEN = SMU_IEN_PPUSEC | SMU_IEN_BMPUSEC;
   \       0x46   0x....             LDR.N    R0,??DataTable3_5
   \       0x48   0x6005             STR      R5,[R0, #+0]
    202          #endif //SL_TRUSTZONE_SECURE
    203          }
   \       0x4A   0xBD31             POP      {R0,R4,R5,PC}
    204          
    205          /**************************************************************************//**
    206           * @brief
    207           *   Get current HFRCODPLL frequency.
    208           *
    209           * @note
    210           *   This is a EFM32PG22 specific function, not part of the
    211           *   CMSIS definition.
    212           *
    213           * @return
    214           *   HFRCODPLL frequency in Hz.
    215           *****************************************************************************/

   \                                 In section text_system_timecritical19198, align 4, keep-with-next
    216          uint32_t SystemHFRCODPLLClockGet(void)
    217          {
    218          #if !defined(SYSTEM_NO_STATIC_MEMORY)
    219            return SystemHFRCODPLLClock;
   \                     SystemHFRCODPLLClockGet: (+1)
   \        0x0   0x4801             LDR.N    R0,??SystemHFRCODPLLClockGet_0
   \        0x2   0x6800             LDR      R0,[R0, #+0]
   \        0x4   0x4770             BX       LR
   \        0x6   0xBF00             Nop
   \                     ??SystemHFRCODPLLClockGet_0:
   \        0x8   0x....'....        DC32     SystemHFRCODPLLClock
    220          #else
    221            uint32_t ret = 0UL;
    222            uint32_t mdiv = 0UL, ndiv = 0UL;
    223            uint32_t dpll_ref_clk = 0UL;
    224          
    225            CMU->CLKEN0_SET = CMU_CLKEN0_HFRCO0 | CMU_CLKEN0_DPLL0;
    226          
    227            if (DPLL0->STATUS & DPLL_STATUS_RDY) {
    228              switch ((CMU->DPLLREFCLKCTRL & _CMU_DPLLREFCLKCTRL_MASK)) {
    229                case _CMU_DPLLREFCLKCTRL_CLKSEL_HFXO:
    230                  dpll_ref_clk = HFXO_FREQ;
    231                  break;
    232                case _CMU_DPLLREFCLKCTRL_CLKSEL_LFXO:
    233                  dpll_ref_clk = LFXO_FREQ;
    234                  break;
    235                case _CMU_DPLLREFCLKCTRL_CLKSEL_CLKIN0:
    236                  dpll_ref_clk = CLKIN0_FREQ;
    237                  break;
    238                default:
    239                  return 0UL;
    240              }
    241          
    242              mdiv = DPLL0->CFG1 & _DPLL_CFG1_M_MASK;
    243              ndiv = (DPLL0->CFG1 & _DPLL_CFG1_N_MASK) >> _DPLL_CFG1_N_SHIFT;
    244              ret  = (dpll_ref_clk / mdiv) * ndiv;
    245              return ret;
    246            }
    247          
    248            // Get oscillator frequency band
    249            switch ((HFRCO0->CAL & _HFRCO_CAL_FREQRANGE_MASK)
    250                    >> _HFRCO_CAL_FREQRANGE_SHIFT) {
    251              case 0:
    252                switch (HFRCO0->CAL & _HFRCO_CAL_CLKDIV_MASK) {
    253                  case HFRCO_CAL_CLKDIV_DIV1:
    254                    ret = 4000000UL;
    255                    break;
    256          
    257                  case HFRCO_CAL_CLKDIV_DIV2:
    258                    ret = 2000000UL;
    259                    break;
    260          
    261                  case HFRCO_CAL_CLKDIV_DIV4:
    262                    ret = 1000000UL;
    263                    break;
    264          
    265                  default:
    266                    ret = 0UL;
    267                    break;
    268                }
    269                break;
    270          
    271              case 1:
    272                ret = 5000000UL;
    273                break;
    274          
    275              case 3:
    276                ret = 7000000UL;
    277                break;
    278          
    279              case 4:
