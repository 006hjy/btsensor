    160            sl_status_t staWrite;
    161            sl_status_t sta = SL_STATUS_OK;
    162          
    163            // Create header
    164            devInfo = ((pageSizeToField(halInfo->pageSize) << H5_PAGESIZE_SHIFT) & H5_PAGESIZE_MASK)
    165                      + (((halInfo->memoryMapped) << H5_MEMORYMAPPED_SHIFT) & H5_MEMORYMAPPED_MASK)
    166                      + (((halInfo->writeSize) << H5_WRITESIZE_SHIFT) & H5_WRITESIZE_MASK)
    167                      + ((halInfo->deviceFamilyPartNumber) & H5_DEVICE_FAMILY_MASK);
   \        0x8   0x6858             LDR      R0,[R3, #+4]
   \        0xA   0x460E             MOV      R6,R1
   \        0xC   0x4690             MOV      R8,R2
   \        0xE   0x2400             MOVS     R4,#+0
   \       0x10   0x2100             MOVS     R1,#+0
   \       0x12   0x0A40             LSRS     R0,R0,#+9
   \       0x14   0xE000             B.N      ??nvm3_pageHeaderWrite_0
   \                     ??nvm3_pageHeaderWrite_1: (+1)
   \       0x16   0x1C49             ADDS     R1,R1,#+1
   \                     ??nvm3_pageHeaderWrite_0: (+1)
   \       0x18   0x0840             LSRS     R0,R0,#+1
   \       0x1A   0xD1FC             BNE.N    ??nvm3_pageHeaderWrite_1
   \       0x1C   0x78D8             LDRB     R0,[R3, #+3]
   \       0x1E   0xB289             UXTH     R1,R1
   \       0x20   0x881F             LDRH     R7,[R3, #+0]
   \       0x22   0x0300             LSLS     R0,R0,#+12
   \       0x24   0xF400 0x5080      AND      R0,R0,#0x1000
   \       0x28   0xEB00 0x3041      ADD      R0,R0,R1, LSL #+13
   \       0x2C   0x7899             LDRB     R1,[R3, #+2]
   \       0x2E   0xF3C7 0x070A      UBFX     R7,R7,#+0,#+11
    168          #if defined(NVM3_SECURITY)
    169            formatInfo = ((secType == NVM3_SECURITY_AEAD) ? 0 : 1) + 0xFFFEU;
    170          #else
    171            formatInfo = 0xFFFFU;
    172          #endif
    173            pageHdr.data[0] = (H1_MAGIC_V1 << H1_MAGIC_SHIFT) | H1_VERSION_V1;
   \       0x32   0x....             LDR.N    R2,??DataTable1
   \       0x34   0x02C9             LSLS     R1,R1,#+11
