     68          //============================================================================
     69          
     70          typedef enum {
     71            eraseCntNormal,
     72            eraseCntInverted
     73          } EraseCnt_t;
     74          
     75          //============================================================================
     76          
     77          __STATIC_INLINE bool pageHdrErased(nvm3_PageHdr_t *pageHdr)
     78          {
     79            return (pageHdr->data[0] == 0xFFFFFFFFU);
     80          }
     81          
     82          __STATIC_INLINE bool pageHdrMagicAndVersion(nvm3_PageHdr_t *pageHdr)
     83          {
     84            uint16_t magic;
     85            uint16_t version;
     86          
     87            magic = (uint16_t)(pageHdr->data[0] >> H1_MAGIC_SHIFT);
     88            version = (uint16_t)pageHdr->data[0];
     89            return (magic == H1_MAGIC_V1) && (version == H1_VERSION_V1);
     90          }
     91          
     92          __STATIC_INLINE bool pageHdrIsPageBad(nvm3_PageHdr_t *pageHdr)
     93          {
     94            uint32_t badPage = (pageHdr->data[3] & H4_BAD_MASK) >> H4_BAD_SHIFT;
     95          
     96            return badPage != H4_BAD_GOOD;
     97          }
     98          
     99          __STATIC_INLINE bool pageHdrIsEraseInProgress(nvm3_PageHdr_t *pageHdr)
    100          {
    101            uint16_t EIP = (pageHdr->data[3]);
    102          
    103            return EIP != H4_EIP_CLEAR;
    104          }
    105          
    106          __STATIC_INLINE uint32_t pageHdrGetCounterBcod(uint32_t h)
    107          {
    108            return (h >> NVM3_PAGE_COUNTER_SIZE) & NVM3_PAGE_BCCB_MASK;
    109          }
    110          

   \                                 In section .text, align 2, keep-with-next
    111          __STATIC_INLINE uint32_t pageHdrGetCounterVal(uint32_t h, EraseCnt_t level)
    112          {
    113            uint32_t cnt = (level == eraseCntInverted) ? ~h : h;
   \                     pageHdrGetCounterVal: (+1)
   \        0x0   0x2901             CMP      R1,#+1
   \        0x2   0xBF08             IT       EQ
   \        0x4   0x43C0             MVNEQ    R0,R0
    114            return cnt & NVM3_PAGE_COUNTER_MASK;
   \        0x6   0xF020 0x4078      BIC      R0,R0,#0xF8000000
   \        0xA   0x4770             BX       LR
    115          }
    116          

   \                                 In section .text, align 2, keep-with-next
    117          __STATIC_INLINE uint32_t pageHdrCounterMake(uint32_t cnt, EraseCnt_t level)
    118          {
   \                     pageHdrCounterMake: (+1)
   \        0x0   0xB501             PUSH     {R0,LR}
   \        0x2   0xB082             SUB      SP,SP,#+8
    119            uint8_t  BCCB;
    120          
    121            if (level == eraseCntInverted) {
   \        0x4   0x2901             CMP      R1,#+1
   \        0x6   0xBF04             ITT      EQ
   \        0x8   0x43C0             MVNEQ    R0,R0
   \        0xA   0x9002             STREQ    R0,[SP, #+8]
    122              cnt = ~cnt;
    123            }
    124            cnt &= NVM3_PAGE_COUNTER_MASK;
   \        0xC   0x9802             LDR      R0,[SP, #+8]
    125            BCCB = 0;
   \        0xE   0x2300             MOVS     R3,#+0
   \       0x10   0xF88D 0x3000      STRB     R3,[SP, #+0]
   \       0x14   0xF020 0x4078      BIC      R0,R0,#0xF8000000
   \       0x18   0x9002             STR      R0,[SP, #+8]
    126            nvm3_utilsComputeBergerCode(&BCCB, &cnt, NVM3_PAGE_COUNTER_SIZE);
   \       0x1A   0x221B             MOVS     R2,#+27
   \       0x1C   0xA902             ADD      R1,SP,#+8
   \       0x1E   0x4668             MOV      R0,SP
   \       0x20   0x.... 0x....      BL       nvm3_utilsComputeBergerCode
    127            return ((uint32_t)BCCB << NVM3_PAGE_COUNTER_SIZE) | cnt;
   \       0x24   0xF89D 0x1000      LDRB     R1,[SP, #+0]
   \       0x28   0x9802             LDR      R0,[SP, #+8]
   \       0x2A   0xEA40 0x60C1      ORR      R0,R0,R1, LSL #+27
   \       0x2E   0xBD0E             POP      {R1-R3,PC}
    128          }
    129          
    130          // The page size field has a value from 0 to 7 describing page sizes from 512
    131          // to 65536 bytes. Note: The page size must be a power of 2.
    132          static uint16_t pageSizeToField(size_t pageSize)
    133          {
    134            uint16_t field = 0U;
    135          
    136            pageSize /= 512U;
    137            for (;; ) {
    138              pageSize /= 2U;
    139              if (pageSize == 0U) {
    140                break;
    141              }
    142              field++;
    143            }
    144          
    145            return field;
    146          }
