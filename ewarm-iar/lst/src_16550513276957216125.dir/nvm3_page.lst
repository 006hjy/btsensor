     42          
     43          #define H1_MAGIC_SHIFT          16          // The magic shift
     44          #define H1_MAGIC_V1             0xB29AU     // The magic marker
     45          #define H1_VERSION_V1           0x01U       // The first version of NVM3
     46          #define H4_BAD_MASK             0xffff0000U // The BAD mask
     47          #define H4_BAD_SHIFT            16          // The BAD shift
     48          #define H4_BAD_GOOD             0xFFFFU     // The page is good
     49          #define H4_BAD_NOTGOOD          0x0000U     // The page is not good
     50          #define H4_EIP_MASK             0xffffU     // The EIP mask
     51          #define H4_EIP_SET              0xA5A5U     // The page is scheduled for erase
     52          #define H4_EIP_CLEAR            0xFFFFU     // The page is not sceduled for erase
     53          #define H5_DEVICE_FAMILY_MASK   0x07FFU
     54          #define H5_WRITESIZE_SHIFT      11
     55          #define H5_WRITESIZE_MASK       0x0800U
     56          #define H5_MEMORYMAPPED_SHIFT   12
     57          #define H5_MEMORYMAPPED_MASK    0x1000U
     58          #define H5_PAGESIZE_SHIFT       13
     59          #define H5_PAGESIZE_MASK        0xE000U
     60          #define H5_DEVINFO_MASK         (H5_DEVICE_FAMILY_MASK | H5_WRITESIZE_MASK | H5_MEMORYMAPPED_MASK | H5_PAGESIZE_MASK)
     61          #if defined(NVM3_SECURITY)
     62          #define H5_SECTYPE_AEAD_SHIFT   16          // The AEAD shift
     63          #define H5_SECTYPE_AEAD_MASK    0x10000U    // The AEAD mask
     64          #define H5_SECTYPE_ENC_SHIFT    17          // The encryption shift
     65          #define H5_SECTYPE_ENC_MASK     0x20000U    // The encryption mask
     66          #endif
