   \                                 In section .text, align 2, keep-with-next
     35          void nvm3_utilsComputeBergerCode(uint8_t *pResult, void *pInput, uint8_t numberOfBits)
     36          {
   \                     nvm3_utilsComputeBergerCode: (+1)
   \        0x0   0xB530             PUSH     {R4,R5,LR}
     37            uint8_t sum;
     38            uint32_t word = *((uint32_t *)pInput);
   \        0x2   0x680B             LDR      R3,[R1, #+0]
     39            uint32_t mask;
     40          
     41            // Clear bits that are outside the wanted bits
     42            if (numberOfBits < 32U) {
   \        0x4   0x2A20             CMP      R2,#+32
   \        0x6   0xD203             BCS.N    ??nvm3_utilsComputeBergerCode_0
     43              mask = (1UL << numberOfBits) - 1U;
     44              word = word & mask;
   \        0x8   0x2401             MOVS     R4,#+1
   \        0xA   0x4094             LSLS     R4,R4,R2
   \        0xC   0x1E64             SUBS     R4,R4,#+1
   \        0xE   0x4023             ANDS     R3,R4,R3
     45            }
     46          
     47            // Count bits set:
     48            // From http://graphics.stanford.edu/~seander/bithacks.html#CountBitsSetNaive
     49            word = word - ((word >> 1) & 0x55555555U);
   \                     ??nvm3_utilsComputeBergerCode_0: (+1)
   \       0x10   0x0859             LSRS     R1,R3,#+1
   \       0x12   0xF021 0x31AA      BIC      R1,R1,#0xAAAAAAAA
   \       0x16   0x1A5B             SUBS     R3,R3,R1
     50            word = (word & 0x33333333U) + ((word >> 2) & 0x33333333U);
   \       0x18   0xF023 0x34CC      BIC      R4,R3,#0xCCCCCCCC
   \       0x1C   0x089B             LSRS     R3,R3,#+2
   \       0x1E   0xF023 0x33CC      BIC      R3,R3,#0xCCCCCCCC
   \       0x22   0x191B             ADDS     R3,R3,R4
     51            sum = (uint8_t)((((word + (word >> 4)) & 0xF0F0F0FU) * 0x1010101U) >> 24U);
     52          
     53            // Count bit cleared and accumulate
     54            *pResult = *pResult + (numberOfBits - sum);
   \       0x24   0xEB03 0x1313      ADD      R3,R3,R3, LSR #+4
   \       0x28   0x7805             LDRB     R5,[R0, #+0]
   \       0x2A   0xF04F 0x3101      MOV      R1,#+16843009
   \       0x2E   0xF023 0x33F0      BIC      R3,R3,#0xF0F0F0F0
   \       0x32   0x434B             MULS     R3,R1,R3
   \       0x34   0x1952             ADDS     R2,R2,R5
   \       0x36   0xEBA2 0x6213      SUB      R2,R2,R3, LSR #+24
   \       0x3A   0x7002             STRB     R2,[R0, #+0]
     55          }
   \       0x3C   0xBD30             POP      {R4,R5,PC}
     56          
