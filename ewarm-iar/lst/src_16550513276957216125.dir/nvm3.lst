   2067          /* Read object data (as a word) from the position given by the index. */
   2068          static uint32_t getObjContent(nvm3_Handle_t *h, size_t hdrLen, nvm3_Obj_t *obj, size_t ofs)
   2069          {
   2070            nvm3_HalPtr_t adr = obj->objAdr;
   2071            uint32_t word;
   2072            size_t offset;
   2073          
   2074            if (!obj->isFragmented) {
   2075              adr = calcAdr(obj->objAdr, hdrLen + ofs);
   2076            } else {
   2077              offset = ofs;
   2078              for (uint8_t i = 0; i < obj->frag.idx; i++) {
   2079                if (obj->frag.detail[i].len > offset) {
   2080                  adr = calcAdr(obj->frag.detail[i].adr, hdrLen + offset);
   2081                  break;
   2082                } else {
   2083                  offset -= obj->frag.detail[i].len;
   2084                }
   2085              }
   2086            }
   2087            nvm3_halReadWords(HAL, adr, &word, 1);
   2088          
   2089            return word;
   2090          }
   2091          #endif
