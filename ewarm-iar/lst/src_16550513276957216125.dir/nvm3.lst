    103          //************************************
    104          // Misc thresholds
    105          
    106          // Small objects use a smaller header, but simplify by assuming all are using the large header
    107          #define OBJ_FRAGMENTS(pageSize, objSize)    (((objSize + NVM3_OBJ_HEADER_SIZE_LARGE - 1) / (pageSize - NVM3_PAGE_HEADER_SIZE)) + 1U)
    108          #define OBJ_LEN_REQ(pageSize, objSize)      (objSize + (OBJ_FRAGMENTS(pageSize, objSize) * NVM3_OBJ_HEADER_SIZE_LARGE))
    109          #define OBJ_PAGES_REQ(pageSize, objSize)    ((OBJ_LEN_REQ(pageSize, objSize) - 1) / (pageSize - NVM3_PAGE_HEADER_SIZE) + 1)
    110          
    111          #define EXTRA_HARD_PAGES                    (0)         // The number of spare pages for repack write errors
    112          #define EXTRA_SIZE                          (4U)        // Just an arbitrary value
