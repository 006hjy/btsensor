   2931                if (incField == 0xFFFFU) {
   2932                  freeIncIdx = (uint8_t)idx;
   2933                  break;
   2934                } else if ((incField & 0xFFU) == 0U) {
   2935                  idx += 2U;
   2936                } else {
   2937                  // Do nothing.
   2938                }
   2939              } else {
