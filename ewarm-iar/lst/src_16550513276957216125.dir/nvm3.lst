   2657          // Run repack until the hard threshold is reached or the FIFO has been passed through.
   2658          static sl_status_t repackUntilGood(nvm3_Handle_t *h)
   2659          {
   2660            size_t i = 0;
   2661            nvm3_PageState_t pageState = nvm3_PageStateGood;
   2662            sl_status_t sta = SL_STATUS_OK;
   2663          #if NVM3_TRACE_ENABLED
   2664            size_t freePre;
   2665          #endif
   2666          
   2667            nvm3_tracePrint(TRACE_LEVEL_REPACK, "  repackUntilGood: Begin, unusedNvmSize=%u, thrHard=%u.\n", h->unusedNvmSize, thrHard(h, h->maxObjectSize));
   2668          
   2669            while ((!writeHardAllowed(h, h->maxObjectSize)) && (i < (h->validNvmPageCnt * 2U))) {
   2670          #if NVM3_TRACE_ENABLED
   2671              freePre = h->unusedNvmSize;
   2672          #endif
   2673              sta = repackWorker(h, &pageState, repackCopyAll);
   2674              if (sta != SL_STATUS_OK) {
   2675                break;
   2676              }
   2677              nvm3_tracePrint(TRACE_LEVEL_REPACK, "  repackUntilGood: Work, unusedNvmSize=%u -> %u.\n", freePre, h->unusedNvmSize);
   2678              i++;
   2679            }
   2680            if (pageState == nvm3_PageStateGoodEip) {
   2681              nvm3_tracePrint(TRACE_LEVEL_REPACK, "  repackUntilGood: One extra Work round is needed.\n");
   2682              sta = repackWorker(h, &pageState, repackCopyAll);
   2683              (void)pageState;
   2684            }
   2685            nvm3_tracePrint(TRACE_LEVEL_REPACK, "  repackUntilGood: End,   unusedNvmSize=%u, nextObj=%p.\n", h->unusedNvmSize, h->fifoNextObj);
   2686          
   2687            return sta;
   2688          }
