   \                                 In section .text, align 2, keep-with-next
    216          __STATIC_INLINE size_t pagesRepack(nvm3_Handle_t *h)
    217          {
    218            // A repack may require for maximum:
    219            // All objects in the first page
    220            // And the last object may span to the next page(s). In this case at least
    221            // 4 bytes of the last object will be in the first page.
    222            size_t cntRepackA = 1;
    223            size_t objSizeRepack = h->maxObjectSize - 4;
   \                     pagesRepack: (+1)
   \        0x0   0x6941             LDR      R1,[R0, #+20]
    224            size_t cntRepackB = OBJ_PAGES_REQ(h->halInfo.pageSize, objSizeRepack);
   \        0x2   0x6C42             LDR      R2,[R0, #+68]
   \        0x4   0x1F09             SUBS     R1,R1,#+4
   \        0x6   0x1DCB             ADDS     R3,R1,#+7
   \        0x8   0xF1A2 0x0014      SUB      R0,R2,#+20
   \        0xC   0xFBB3 0xF3F0      UDIV     R3,R3,R0
   \       0x10   0xEB01 0x01C3      ADD      R1,R1,R3, LSL #+3
   \       0x14   0x1DC9             ADDS     R1,R1,#+7
   \       0x16   0xFBB1 0xF0F0      UDIV     R0,R1,R0
   \       0x1A   0x1C40             ADDS     R0,R0,#+1
    225            // For a 4096-byte page size, cap at one page to keep it consistent across all max object sizes.
    226            if (h->halInfo.pageSize == PAGE_SIZE_4096 && cntRepackB > 1U) {
   \       0x1C   0xF5B2 0x5F80      CMP      R2,#+4096
   \       0x20   0xD102             BNE.N    ??pagesRepack_0
   \       0x22   0x2801             CMP      R0,#+1
   \       0x24   0xBF88             IT       HI
   \       0x26   0x2001             MOVHI    R0,#+1
    227              cntRepackB = 1U;
    228            }
    229            size_t cntExtra = EXTRA_HARD_PAGES;
    230          
    231            return cntRepackA + cntRepackB + cntExtra;
   \                     ??pagesRepack_0: (+1)
   \       0x28   0x1C40             ADDS     R0,R0,#+1
   \       0x2A   0x4770             BX       LR
    232          }
    233          
    234          __STATIC_INLINE size_t thrFull(nvm3_Handle_t *h, size_t objSize)
    235          {
    236            // The full threshold is just the object size
    237            return OBJ_LEN_REQ(h->halInfo.pageSize, objSize);
    238          }
    239          
    240          __STATIC_INLINE size_t thrRepack(nvm3_Handle_t *h)
    241          {
    242            // The repack threshold is the size of the pages required for a repack
    243            size_t repackSz = pagesRepack(h) * (h->halInfo.pageSize - NVM3_PAGE_HEADER_SIZE);
    244          
