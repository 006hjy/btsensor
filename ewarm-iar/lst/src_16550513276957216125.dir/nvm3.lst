   2382          // Repack the FIFO first page. Copy objects if a newer object does not exist.
   2383          static sl_status_t repackFirstPage(nvm3_Handle_t *h, repackCopyMode_t copyMode)
   2384          {
   2385            nvm3_HalPtr_t pageAdr;
   2386            nvm3_PageHdr_t pageHdr;
   2387            repackFirstPageParameters parameters;
   2388          
   2389            pageAdr = pageAdrFromIdx(h, h->fifoFirstIdx);
   2390            nvm3_tracePrint(TRACE_LEVEL_REPACK, "    repackFirstPage: idx=%d, adr=%p.\n", h->fifoFirstIdx, pageAdr);
   2391          
   2392            nvm3_halReadWords(HAL, pageAdr, &pageHdr, NVM3_PAGE_HEADER_WSIZE);
   2393            nvm3_PageState_t pageState = nvm3_pageGetState(&pageHdr);
   2394            if (pageState == nvm3_PageStateGoodEip) {
   2395              nvm3_tracePrint(NVM3_TRACE_LEVEL_WARNING, "NVM3 WARNING - repackFirstPage: EIP was already set, no operation.\n");
   2396              return SL_STATUS_OK;
   2397            }
   2398          
   2399            parameters.h = h;
   2400            parameters.status = SL_STATUS_OK;
   2401            parameters.copyMode = copyMode;
   2402            parameters.copyAccumulated = 0;
   2403            parameters.copyAllDone = true;
   2404            if (h->fifoFirstObj == h->fifoNextObj) {
   2405              // First page is empty
   2406              h->fifoNextObj = getFirstObjAdrInNextGoodPage(h, h->fifoFirstObj);
   2407              h->unusedNvmSize -= (h->halInfo.pageSize - NVM3_PAGE_HEADER_SIZE);
