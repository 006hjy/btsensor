    692          /* Write object to media, handle object type, fragmentation, and so on. */
    693          #if defined(NVM3_SECURITY)
    694          static sl_status_t writeObj(nvm3_Handle_t *h, nvm3_Obj_t *srcObj, nvm3_Obj_t *dstObj,
    695                                      nvm3_HalPtr_t dstAdr, bool copyObj,
    696                                      nvm3_ObjGroup_t objGroup,
    697                                      WriteFailure_t *wrFailure)
    698          {
    699            sl_status_t sta = SL_STATUS_OK;
    700            size_t srcLen = srcObj->totalLen;
    701            size_t pageFreeBytes;
    702            nvm3_ObjPtr_t fragAdr;
    703            size_t fragLen;
    704            nvm3_ObjFragType_t fragTyp = fragTypeNone;
    705            const uint8_t *ptrSrc = srcObj->srcPtr;
    706            nvm3_ObjHdrLarge_t objHdrLarge;
    707            bool dstHdrIsLarge;
    708            size_t dstHdrLen;
    709            size_t dstHdrAux = 0;
    710            size_t offset = 0;
    711            uint32_t baseVal;
    712            bool baseWr = false;
    713            uint8_t *decBufPtr = nvm3_decBuf;
    714          
    715          #if NVM3_TRACE_ENABLED
    716            size_t tmpIdx = pageIdxFromAdr(h, dstAdr);
    717            void *tmpAdr = pageAdrFromIdx(h, tmpIdx);
    718            size_t ofs = (size_t)dstAdr - (size_t)tmpAdr;
    719          #endif
    720            nvm3_tracePrint(TRACE_LEVEL_WRITE, "  writeObj: dstAdr=%p, srcObjTotLen=%u, (dst: idx=%u, adr=%p, ofs=0x%x).\n", dstAdr, srcObj->totalLen, tmpIdx, tmpAdr, ofs);
    721          
    722            if ((objGroup == objGroupCounter) && (srcLen != COUNTER_SIZE)) {
    723              nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - writeObj: src len mismatch, exp=%u, act=%u.\n", COUNTER_SIZE, srcLen);
    724              NVM3_ERROR_ASSERT();
    725              return SL_STATUS_NVM3_SIZE_ERROR;
    726            }
    727          
    728            if (objGroup == objGroupCounter) {
    729              if (copyObj) {
    730                // Get counter value if this is a counter copy
    731                baseVal = readCounter(h, srcObj);
    732              } else {
    733                baseVal = *(uint32_t *)srcObj->srcPtr;
    734              }
    735            }
    736          
    737          // To copy obj, read authenticated decrypted data into a buffer first
    738            if (copyObj) {
    739              if (objGroup == objGroupData) {
    740                sta = fifoReadObj(h, (void *)decBufPtr, 0, srcLen, srcObj, read_data);
    741                if (sta != SL_STATUS_OK) {
    742                  nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - writeObj: read encrypted data failed during copy obj, key=%lu, sta=0x%lx.\n", srcObj->key, sta);
    743                  NVM3_ERROR_ASSERT();
    744                  return sta;
    745                } else {
    746                  if ((srcObj->totalLen > 0U) && (srcObj->isFragmented)) {
    747                    if (h->secType == NVM3_SECURITY_AEAD) {
    748                      size_t overhead = (srcObj->frag.idx - 1U) * NVM3_GCM_SIZE_OVERHEAD;
    749                      if (srcLen >= overhead) {
    750                        srcLen -= overhead;
    751                      }
    752                    } else {
    753                      NVM3_ERROR_ASSERT();
    754                      return SL_STATUS_INVALID_TYPE;
    755                    }
    756                  }
    757                }
    758              }
    759            }
    760          
    761            pageFreeBytes = pageFreeSize(h, dstAdr);
    762            dstHdrIsLarge = (srcLen > NVM3_OBJ_SMALL_MAX_SIZE);
    763            if (!dstHdrIsLarge) {
    764              if (pageFreeBytes < (srcLen + NVM3_OBJ_HEADER_SIZE_SMALL)) {
    765                // In this case, normally the object will be fragmented.
    766                // But if the first fragment is empty it is still small - starting in the next page.
    767                if ((srcLen > 0) && (pageFreeBytes > NVM3_OBJ_HEADER_SIZE_LARGE)) {
    768                  dstHdrIsLarge = true;
    769                } else {
    770                  dstHdrAux = NVM3_OBJ_HEADER_SIZE_LARGE - NVM3_OBJ_HEADER_SIZE_SMALL;
    771                }
    772              }
    773            }
    774            dstHdrLen = dstHdrIsLarge ? NVM3_OBJ_HEADER_SIZE_LARGE : NVM3_OBJ_HEADER_SIZE_SMALL;
    775            if (objGroup == objGroupData) {
    776              if (h->secType == NVM3_SECURITY_AEAD) {
    777                dstHdrAux += NVM3_GCM_SIZE_OVERHEAD;
    778              } else {
    779                NVM3_ERROR_ASSERT();
    780                return SL_STATUS_INVALID_TYPE;
    781              }
    782            }
    783          
    784            dstObj->key = srcObj->key;
    785            dstObj->totalLen = srcLen;
    786            dstObj->objType = (uint8_t)nvm3_objGroupToType(objGroup, dstHdrIsLarge);
    787          
    788            nvm3_tracePrint(TRACE_LEVEL_WRITE, "    object len=%u.\n", dstObj->totalLen);
    789          
    790            // Write all object fragments.
    791            do {
    792              bool pageHasRoom;
    793          
    794              pageFreeBytes = pageFreeSize(h, dstAdr);
    795          
    796              nvm3_tracePrint(TRACE_LEVEL_WRITE, "    pageFreeBytes=%u, dstHdrLen=%u.\n", pageFreeBytes, dstHdrLen);
    797          
    798              //  Make sure there is room for the header and optional data.
    799              pageHasRoom = (srcLen > 0U) ? (pageFreeBytes > (dstHdrLen + dstHdrAux)) : (pageFreeBytes >= dstHdrLen);
    800              dstHdrAux = 0;
    801              if (pageHasRoom) {
    802                pageFreeBytes -= dstHdrLen;
    803                fragLen = (srcLen > pageFreeBytes) ? pageFreeBytes : srcLen;
    804                fragAdr = dstAdr;
    805                dstAdr = calcAdr(dstAdr, dstHdrLen);
    806                nvm3_tracePrint(TRACE_LEVEL_WRITE, "    there is room, free=%u, fragLen=%d.\n", pageFreeBytes, fragLen);
    807          
    808                // Compute fragmentation type.
    809                if (fragLen != srcLen) {
    810                  dstObj->isFragmented = true;
    811                  if (srcLen == dstObj->totalLen) {
    812                    fragTyp = fragTypeFirst;
    813                    dstObj->objAdr = fragAdr;
    814                  } else {
    815                    fragTyp = fragTypeNext;
    816                  }
    817                } else if (fragTyp != fragTypeNone) {
    818                  fragTyp = fragTypeLast;
    819                } else {
    820                  fragTyp = fragTypeNone;
    821                }
    822          
    823                // Set object information.
    824                if (dstObj->isFragmented) {
    825                  dstObj->frag.detail[dstObj->frag.idx].adr = fragAdr;
    826                  dstObj->frag.detail[dstObj->frag.idx].len = (uint16_t)fragLen;
    827                  dstObj->frag.detail[dstObj->frag.idx].typ = (uint8_t)fragTyp;
    828                  dstObj->frag.idx++;
    829                } else {
    830                  dstObj->objAdr = fragAdr;
    831                }
    832          
    833                // Write payload.
    834                if (fragLen > 0U) {
    835                  if (objGroup == objGroupCounter) {
    836                    //nvm3_tracePrint(TRACE_LEVEL_WRITE, "      cntWr: adr=%p.\n", dstAdr);
    837                    // For counter objects write only the base value.
    838                    if (!baseWr && ((offset + fragLen) >= COUNTER_SIZE_BASE)) {
    839                      sta = nvm3_halWriteWords(HAL, dstAdr, &baseVal, 1);
    840                      nvm3_tracePrint(TRACE_LEVEL_COUNTER, "      cntWr: key=%lu, fAdr=%p, bAdr=%p, base=%lu.\n", srcObj->key, fragAdr, dstAdr, baseVal);
    841                      if (sta != SL_STATUS_OK) {
    842                        break;
    843                      }
    844                      baseWr = true;
    845                    }
    846                  } else {
    847                    nvm3_tracePrint(TRACE_LEVEL_WRITE, "      cntWr: adr=%p, len=%u, copy=%s.\n", dstAdr, fragLen, copyObj ? "true" : "false");
    848                    // Source is a continuous memory.
    849                    // pSrc is initialized with ptrSrc to avoid compiler warnings, it is later updated with enc data
    850                    uint32_t *pSrc = (uint32_t *)ptrSrc;
    851                    uint32_t *pDst = dstAdr;
    852                    size_t byteCnt = fragLen;
    853                    size_t wordCnt = byteCnt / sizeof(uint32_t);
    854                    if (wordCnt > 0) {
    855                      (void)nvm3_objHdrInit(&objHdrLarge, srcObj->key, (nvm3_ObjType_t)dstObj->objType, fragLen, dstHdrIsLarge, fragTyp);
    856                      uint8_t objHdr[NVM3_OBJ_HEADER_SIZE_LARGE];
    857                      memcpy(objHdr, &objHdrLarge, dstHdrLen);
    858                      uint8_t nonceVal[NVM3_NONCE_SIZE];
    859                      uint8_t tag[NVM3_GCM_TAG_SIZE];
    860                      memset(nonceVal, 0, sizeof(nonceVal));
    861                      createNonce(h, dstAdr, &nonceVal[0]);
    862                      if (!copyObj) {
    863                        if (h->secType == NVM3_SECURITY_AEAD) {
    864                          sta = nvm3_halCryptoEncrypt(HAL_CRYPTO, &nonceVal[0], objHdr, dstHdrLen, ptrSrc, (fragLen - NVM3_GCM_SIZE_OVERHEAD), &nvm3_encBuf[NVM3_DATA_OFFSET], tag, convertSecTypeToCryptoAlgo(h->secType));
    865                        } else {
    866                          NVM3_ERROR_ASSERT();
    867                          return SL_STATUS_INVALID_TYPE;
    868                        }
    869                      } else {
    870                        if (h->secType == NVM3_SECURITY_AEAD) {
    871                          sta = nvm3_halCryptoEncrypt(HAL_CRYPTO, &nonceVal[0], objHdr, dstHdrLen, decBufPtr, (fragLen - NVM3_GCM_SIZE_OVERHEAD), &nvm3_encBuf[NVM3_DATA_OFFSET], tag, convertSecTypeToCryptoAlgo(h->secType));
    872                        } else {
    873                          NVM3_ERROR_ASSERT();
    874                          return SL_STATUS_INVALID_TYPE;
    875                        }
    876                      }
    877                      if (sta == SL_STATUS_OK) {
    878                        memcpy(&nvm3_encBuf[NVM3_NONCE_OFFSET], &nonceVal[0], NVM3_RANDOM_NUM_SIZE);
    879                        if (h->secType == NVM3_SECURITY_AEAD) {
    880                          memcpy(&nvm3_encBuf[fragLen - NVM3_GCM_TAG_SIZE], &tag[0], NVM3_GCM_TAG_SIZE);
    881                        }
    882                        pSrc = (uint32_t *)nvm3_encBuf;
    883                        if (copyObj) {
    884                          if (h->secType == NVM3_SECURITY_AEAD) {
    885                            decBufPtr += (fragLen - NVM3_GCM_SIZE_OVERHEAD);
    886                          } else {
    887                            NVM3_ERROR_ASSERT();
    888                            return SL_STATUS_INVALID_TYPE;
    889                          }
    890                        }
    891                      } else {
    892                        nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - writeObj: data encryption failed, key=%lu, sta=0x%lx.\n", srcObj->key, sta);
    893                        NVM3_ERROR_ASSERT();
    894                        return sta;
    895                      }
    896                      sta = nvm3_halWriteWords(HAL, pDst, pSrc, wordCnt);
    897                      pSrc += wordCnt;
    898                      pDst += wordCnt;
    899                      byteCnt -= (wordCnt * sizeof(uint32_t));
    900                    }
    901                    if ((sta == SL_STATUS_OK) && (byteCnt > 0)) {
    902                      uint32_t lastWord = 0xffffffffLU;
    903                      memcpy(&lastWord, pSrc, byteCnt);
    904                      sta = nvm3_halWriteWords(HAL, pDst, &lastWord, 1);
    905                    }
    906                    if (h->secType == NVM3_SECURITY_AEAD) {
    907                      ptrSrc += (fragLen - NVM3_GCM_SIZE_OVERHEAD);
    908                    } else {
    909                      NVM3_ERROR_ASSERT();
    910                      return SL_STATUS_INVALID_TYPE;
    911                    }
    912                  }
    913                }
    914                if (sta != SL_STATUS_OK) {
    915                  nvm3_tracePrint(NVM3_TRACE_LEVEL_WARNING, "    write object body: ERROR in payload.\n");
    916                  wrFailure->addrError = dstAdr;
    917                }
    918          
    919                // Write header.
    920                if (sta == SL_STATUS_OK) {
    921                  nvm3_tracePrint(TRACE_LEVEL_WRITE, "    write object header: adr=%p, hdrLen=%u, fragType=%u.\n", fragAdr, dstHdrLen, fragTyp);
    922                  (void)nvm3_objHdrInit(&objHdrLarge, srcObj->key, (nvm3_ObjType_t)dstObj->objType, fragLen, dstHdrIsLarge, fragTyp);
    923                  sta = nvm3_halWriteWords(HAL, fragAdr, &objHdrLarge, dstHdrLen / sizeof(uint32_t));
    924                  if (sta != SL_STATUS_OK) {
    925                    nvm3_tracePrint(NVM3_TRACE_LEVEL_WARNING, "    write object header: ERROR in header.\n");
    926                    wrFailure->addrError = fragAdr;
    927                  }
    928                }
    929          
    930                dstObj->nextObjAdr = getNextObj(h, fragAdr, dstHdrLen, fragLen);
    931                h->unusedNvmSize -= (dstHdrLen + lenAdjustedForWords(fragLen));
    932          
    933                if (sta != SL_STATUS_OK) {
    934                  break;
    935                }
    936          
    937                srcLen -= fragLen;
    938                offset += fragLen;
    939                if ((srcObj->totalLen > 0U) && (objGroup == objGroupData) && ((fragTyp == fragTypeFirst) || (fragTyp == fragTypeNext))) {
    940                  if (h->secType == NVM3_SECURITY_AEAD) {
    941                    srcLen += NVM3_GCM_SIZE_OVERHEAD;
    942                  } else {
    943                    NVM3_ERROR_ASSERT();
    944                    return SL_STATUS_INVALID_TYPE;
    945                  }
    946                }
    947              } else {
    948                nvm3_tracePrint(TRACE_LEVEL_WRITE, "    the page has not space for any object fragments.\n");
    949                h->unusedNvmSize -= pageFreeBytes;
    950              }
    951          
    952              dstAdr = getFirstObjAdrInNextGoodPage(h, dstAdr);
    953            } while (srcLen > 0U);
    954          
    955            return sta;
    956          }
    957          #else
    958          static sl_status_t writeObj(nvm3_Handle_t *h, nvm3_Obj_t *srcObj, nvm3_Obj_t *dstObj,
    959                                      nvm3_HalPtr_t dstAdr, bool copyObj,
    960                                      nvm3_ObjGroup_t objGroup,
    961                                      WriteFailure_t *wrFailure)
    962          {
    963            sl_status_t sta = SL_STATUS_OK;
    964            size_t srcLen = srcObj->totalLen;
    965            size_t pageFreeBytes;
    966            size_t rdOfs = 0;
    967            nvm3_ObjPtr_t fragAdr;
    968            size_t fragLen;
    969            nvm3_ObjFragType_t fragTyp = fragTypeNone;
    970            uint32_t data;
    971            const uint8_t *ptrSrc = srcObj->srcPtr;
    972            size_t dstLen;
    973            nvm3_ObjHdrLarge_t objHdrLarge;
    974            bool srcHdrIsLarge;
    975            size_t srcHdrLen;
    976            bool dstHdrIsLarge;
    977            size_t dstHdrLen;
    978            size_t dstHdrAux = 0;
    979            size_t offset = 0;
    980            uint32_t baseVal;
    981            bool baseWr = false;
    982          
    983          #if NVM3_TRACE_ENABLED
    984            size_t tmpIdx = pageIdxFromAdr(h, dstAdr);
    985            void *tmpAdr = pageAdrFromIdx(h, tmpIdx);
    986            size_t ofs = (size_t)dstAdr - (size_t)tmpAdr;
    987          #endif
    988            nvm3_tracePrint(TRACE_LEVEL_WRITE, "  writeObj: dstAdr=%p, srcObjTotLen=%u, (dst: idx=%u, adr=%p, ofs=0x%x).\n", dstAdr, srcObj->totalLen, tmpIdx, tmpAdr, ofs);
    989          
    990            if ((objGroup == objGroupCounter) && (srcLen != COUNTER_SIZE)) {
    991              nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - writeObj: src len mismatch, exp=%u, act=%u.\n", COUNTER_SIZE, srcLen);
    992              NVM3_ERROR_ASSERT();
    993              return SL_STATUS_NVM3_SIZE_ERROR;
    994            }
    995          
    996            if (objGroup == objGroupCounter) {
    997              if (copyObj) {
    998                // Get counter value if this is a counter copy
    999                baseVal = readCounter(h, srcObj);
   1000              } else {
   1001                baseVal = *(uint32_t *)srcObj->srcPtr;
   1002              }
   1003            }
   1004          
   1005            pageFreeBytes = pageFreeSize(h, dstAdr);
   1006          
   1007            srcHdrIsLarge = (srcLen > NVM3_OBJ_SMALL_MAX_SIZE) || (srcObj->isFragmented);
   1008            if (copyObj) {
   1009              nvm3_ObjHdrSmall_t srcHdrSmall;
   1010              nvm3_halReadWords(HAL, srcObj->objAdr, &srcHdrSmall, NVM3_OBJ_HEADER_SIZE_WSMALL);
   1011              srcHdrIsLarge = nvm3_objHdrGetHdrIsLarge(&srcHdrSmall);
   1012            }
   1013            srcHdrLen = srcHdrIsLarge ? NVM3_OBJ_HEADER_SIZE_LARGE : NVM3_OBJ_HEADER_SIZE_SMALL;
   1014          
   1015            dstHdrIsLarge = (srcLen > NVM3_OBJ_SMALL_MAX_SIZE);
   1016            if (!dstHdrIsLarge) {
   1017              if (pageFreeBytes < (srcLen + NVM3_OBJ_HEADER_SIZE_SMALL)) {
   1018                // In this case, normally the object will be fragmented.
   1019                // But if the first fragment is empty it is still small - starting in the next page.
   1020                if ((srcLen > 0) && (pageFreeBytes > NVM3_OBJ_HEADER_SIZE_LARGE)) {
   1021                  dstHdrIsLarge = true;
   1022                } else {
   1023                  dstHdrAux = NVM3_OBJ_HEADER_SIZE_LARGE - NVM3_OBJ_HEADER_SIZE_SMALL;
   1024                }
   1025              }
   1026            }
   1027            dstHdrLen = dstHdrIsLarge ? NVM3_OBJ_HEADER_SIZE_LARGE : NVM3_OBJ_HEADER_SIZE_SMALL;
   1028          
   1029            dstObj->key = srcObj->key;
   1030            dstObj->totalLen = srcLen;
   1031            dstObj->objType = (uint8_t)nvm3_objGroupToType(objGroup, dstHdrIsLarge);
   1032          
   1033            nvm3_tracePrint(TRACE_LEVEL_WRITE, "    object len=%u.\n", dstObj->totalLen);
   1034          
   1035            // Write all object fragments.
   1036            do {
   1037              bool pageHasRoom;
   1038          
   1039              pageFreeBytes = pageFreeSize(h, dstAdr);
   1040          
   1041              nvm3_tracePrint(TRACE_LEVEL_WRITE, "    pageFreeBytes=%u, dstHdrLen=%u.\n", pageFreeBytes, dstHdrLen);
   1042          
   1043              //  Make sure there is room for the header and optional data.
   1044              pageHasRoom = (srcLen > 0U) ? (pageFreeBytes > (dstHdrLen + dstHdrAux)) : (pageFreeBytes >= dstHdrLen);
   1045              dstHdrAux = 0;
   1046              if (pageHasRoom) {
   1047                pageFreeBytes -= dstHdrLen;
   1048                fragLen = (srcLen > pageFreeBytes) ? pageFreeBytes : srcLen;
   1049                fragAdr = dstAdr;
   1050                dstAdr = calcAdr(dstAdr, dstHdrLen);
   1051                nvm3_tracePrint(TRACE_LEVEL_WRITE, "    there is room, free=%u, fragLen=%d.\n", pageFreeBytes, fragLen);
   1052          
   1053                // Compute fragmentation type.
   1054                if (fragLen != srcLen) {
   1055                  dstObj->isFragmented = true;
   1056                  if (srcLen == dstObj->totalLen) {
   1057                    fragTyp = fragTypeFirst;
   1058                    dstObj->objAdr = fragAdr;
   1059                  } else {
   1060                    fragTyp = fragTypeNext;
   1061                  }
   1062                } else if (fragTyp != fragTypeNone) {
   1063                  fragTyp = fragTypeLast;
   1064                } else {
   1065                  fragTyp = fragTypeNone;
   1066                }
   1067          
   1068                // Set object information.
   1069                if (dstObj->isFragmented) {
   1070                  dstObj->frag.detail[dstObj->frag.idx].adr = fragAdr;
   1071                  dstObj->frag.detail[dstObj->frag.idx].len = (uint16_t)fragLen;
   1072                  dstObj->frag.detail[dstObj->frag.idx].typ = (uint8_t)fragTyp;
   1073                  dstObj->frag.idx++;
   1074                } else {
   1075                  dstObj->objAdr = fragAdr;
   1076                }
   1077          
   1078                // Write payload.
   1079                if (fragLen > 0U) {
   1080                  if (objGroup == objGroupCounter) {
   1081                    //nvm3_tracePrint(TRACE_LEVEL_WRITE, "      cntWr: adr=%p.\n", dstAdr);
   1082                    // For counter objects write only the base value.
   1083                    if (!baseWr && ((offset + fragLen) >= COUNTER_SIZE_BASE)) {
   1084                      sta = nvm3_halWriteWords(HAL, dstAdr, &baseVal, 1);
   1085                      nvm3_tracePrint(TRACE_LEVEL_COUNTER, "      cntWr: key=%lu, fAdr=%p, bAdr=%p, base=%lu.\n", srcObj->key, fragAdr, dstAdr, baseVal);
   1086                      if (sta != SL_STATUS_OK) {
   1087                        break;
   1088                      }
   1089                      baseWr = true;
   1090                    }
   1091                  } else {
   1092                    nvm3_tracePrint(TRACE_LEVEL_WRITE, "      cntWr: adr=%p, len=%u, copy=%s.\n", dstAdr, fragLen, copyObj ? "true" : "false");
   1093                    if (!copyObj) {
   1094                      // Source is a continous memory.
   1095                      uint32_t *pSrc = (uint32_t *)ptrSrc;
   1096                      uint32_t *pDst = dstAdr;
   1097                      size_t byteCnt = fragLen;
   1098                      size_t wordCnt = byteCnt / sizeof(uint32_t);
   1099                      if (wordCnt > 0) {
   1100                        sta = nvm3_halWriteWords(HAL, pDst, pSrc, wordCnt);
   1101                        pSrc += wordCnt;
   1102                        pDst += wordCnt;
   1103                        byteCnt -= (wordCnt * sizeof(uint32_t));
   1104                      }
   1105                      if ((sta == SL_STATUS_OK) && (byteCnt > 0)) {
   1106                        uint32_t lastWord = 0xffffffffLU;
   1107                        memcpy(&lastWord, pSrc, byteCnt);
   1108                        sta = nvm3_halWriteWords(HAL, pDst, &lastWord, 1);
   1109                      }
   1110                      ptrSrc += fragLen;
   1111                    } else {
   1112                      // Source is an object that can be fragmented.
   1113                      dstLen = fragLen;
   1114                      for (;; ) {
   1115                        data = getObjContent(h, srcHdrLen, srcObj, rdOfs);
   1116                        rdOfs += NVM3_WORD_SIZE;
   1117                        sta = nvm3_halWriteWords(HAL, dstAdr, &data, 1);
   1118                        if ((dstLen <= 4U) || (sta != SL_STATUS_OK)) {
   1119                          break;
   1120                        }
   1121                        dstLen -= NVM3_WORD_SIZE;
   1122                        dstAdr = calcAdr(dstAdr, NVM3_WORD_SIZE);
   1123                      }
   1124                    }
   1125                  }
   1126                }
   1127                if (sta != SL_STATUS_OK) {
   1128                  nvm3_tracePrint(NVM3_TRACE_LEVEL_WARNING, "    write object body: ERROR in payload.\n");
   1129                  wrFailure->addrError = dstAdr;
   1130                }
   1131          
   1132                // Write header.
   1133                if (sta == SL_STATUS_OK) {
   1134                  nvm3_tracePrint(TRACE_LEVEL_WRITE, "    write object header: adr=%p, hdrLen=%u, fragType=%u.\n", fragAdr, dstHdrLen, fragTyp);
   1135                  (void)nvm3_objHdrInit(&objHdrLarge, srcObj->key, (nvm3_ObjType_t)dstObj->objType, fragLen, dstHdrIsLarge, fragTyp);
   1136                  sta = nvm3_halWriteWords(HAL, fragAdr, &objHdrLarge, dstHdrLen / sizeof(uint32_t));
   1137                  if (sta != SL_STATUS_OK) {
   1138                    nvm3_tracePrint(NVM3_TRACE_LEVEL_WARNING, "    write object header: ERROR in header.\n");
   1139                    wrFailure->addrError = fragAdr;
   1140                  }
   1141                }
   1142          
   1143                dstObj->nextObjAdr = getNextObj(h, fragAdr, dstHdrLen, fragLen);
   1144                h->unusedNvmSize -= (dstHdrLen + lenAdjustedForWords(fragLen));
   1145          
   1146                if (sta != SL_STATUS_OK) {
   1147                  break;
   1148                }
   1149          
   1150                srcLen -= fragLen;
   1151                offset += fragLen;
   1152              } else {
   1153                nvm3_tracePrint(TRACE_LEVEL_WRITE, "    the page has not space for any object fragments.\n");
   1154                h->unusedNvmSize -= pageFreeBytes;
   1155              }
   1156          
   1157              dstAdr = getFirstObjAdrInNextGoodPage(h, dstAdr);
   1158            } while (srcLen > 0U);
   1159          
   1160            return sta;
   1161          }
   1162          #endif
   1163          
   1164          /* Write object to NVM. */
   1165          #if defined(NVM3_SECURITY)
   1166          static sl_status_t fifoWriteObj(nvm3_Handle_t *h, nvm3_Obj_t *srcObj, bool copyObj,
   1167                                          nvm3_ObjGroup_t objGroup)
   1168          {
   1169            sl_status_t sta;
   1170            nvm3_ObjPtr_t dstAdr;
   1171            WriteFailure_t wrFailure = { NULL };
   1172            nvm3_ObjPtr_t nextObj;
   1173            NVM3_OBJ_T_ALLOCATION(ObjC);
   1174          
   1175            nvm3_tracePrint(TRACE_LEVEL_LOW, "  fifoWriteObj: copy=%u, objGroup=%u.\n", copyObj, objGroup);
   1176          
   1177            if (!writeFullAllowed(h, srcObj->totalLen)) {
   1178              nvm3_tracePrint(NVM3_TRACE_LEVEL_WARNING, "  fifoWriteObj: Storage full, objLen=%u, unused=%u.\n", srcObj->totalLen, h->unusedNvmSize);
   1179              return SL_STATUS_FULL;
   1180            }
   1181          
   1182            objBegin(pObjC);
   1183            do {
   1184              dstAdr = h->fifoNextObj;
   1185              nvm3_objInit(pObjC, dstAdr);
   1186              sta = writeObj(h, srcObj, pObjC, dstAdr, copyObj, objGroup, &wrFailure);
   1187              if (sta == SL_STATUS_OK) {
   1188                h->fifoNextObj = pObjC->nextObjAdr;
   1189              } else if (sta == SL_STATUS_FLASH_PROGRAM_FAILED) {
   1190                sl_status_t staCpy = SL_STATUS_OK;
   1191          
   1192                // Handle a write error.
   1193                // Copy any objects in front of the failing object, then rewrite the object.
   1194                // Src
   1195                size_t curIdx = pageIdxFromAdr(h, dstAdr);
   1196                nvm3_HalPtr_t curAdr = nvm3_pageGetFirstObj(pageAdrFromIdx(h, curIdx));
   1197                // Dst
   1198                nextObj = getFirstObjAdrInNextGoodPage(h, h->fifoNextObj);
   1199                if (nextObj != h->fifoFirstObj) {
   1200                  h->fifoNextObj = nextObj;
   1201                  h->unusedNvmSize -= pageFreeSize(h, pObjC->nextObjAdr);
   1202                  // Length
   1203                  size_t len = (size_t)dstAdr - (size_t)curAdr;
   1204                  // Use idx and len to check if the error is on a page with previous data.
   1205                  size_t badIdx = pageIdxFromAdr(h, wrFailure.addrError);
   1206                  if ((badIdx == curIdx) && (len > 0U)) {
   1207                    // To copy obj to a new page, decrypt the obj first then encrypt the obj with obj and page info.
   1208                    NVM3_OBJ_T_ALLOCATION(pObjD);
   1209                    nvm3_ObjHdrSmall_t fraHdrSmall;
   1210                    nvm3_ObjGroup_t group;
   1211                    nvm3_ObjectKey_t key;
   1212                    objBegin(pObjD);
   1213                    objBegin(pObjE);
   1214                    while (len != 0U) {
   1215                      nvm3_objInit(pObjD, NVM3_OBJ_PTR_INVALID);
   1216                      nvm3_halReadWords(HAL, curAdr, &fraHdrSmall, NVM3_OBJ_HEADER_SIZE_WSMALL);
   1217                      key = nvm3_objHdrGetKey(&fraHdrSmall);
   1218                      staCpy = findObj(h, key, pObjD, &group);
   1219                      if (staCpy != SL_STATUS_OK) {
   1220                        nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - fifoWriteObj: find obj failed during copy obj, key=%lu, staCpy=0x%lx.\n", key, staCpy);
   1221                        NVM3_ERROR_ASSERT();
   1222                        objEnd(pObjD);
   1223                        objEnd(pObjE);
   1224                        return staCpy;
   1225                      }
   1226                      if (pObjD->isFragmented) {
