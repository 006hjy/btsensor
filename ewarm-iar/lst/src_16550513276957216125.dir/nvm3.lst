     47          // Macros
     48          
     49          // NVM3 is designed for memories with 32-bit interface.
     50          #define NVM3_WORD_SIZE                              (4U)
     51          
     52          #define TRACE_LEVEL_INFO                            NVM3_TRACE_LEVEL_INFO
     53          #define TRACE_LEVEL_LOW                             NVM3_TRACE_LEVEL_LOW
     54          #define TRACE_LEVEL_INIT                            TRACE_LEVEL_LOW
     55          #define TRACE_LEVEL_COUNTER                         TRACE_LEVEL_LOW
     56          #define TRACE_LEVEL_REPACK                          TRACE_LEVEL_LOW
     57          #define TRACE_LEVEL_RESIZE                          TRACE_LEVEL_LOW
     58          #define TRACE_LEVEL_WRITE                           TRACE_LEVEL_LOW
     59          
     60          // Bit masking of the page size. pageSize MUST be power of 2.
     61          #define PAGE_SIZE_MASK(pageSize)                    ((pageSize) - 1U)
     62          
     63          // NVM3 counter size definition in number of bytes, must be multiple of 4.
     64          #define COUNTER_SIZE                                (204U)
     65          #define COUNTER_MAX_INC_VAL_32                      (0xFFFFU)
     66          #define COUNTER_MAX_INC_VAL_16                      (0xFFU)
     67          #define COUNTER_MAX_NO_INC_16                       ((COUNTER_SIZE - sizeof(uint32_t)) / sizeof(uint16_t))
     68          #define COUNTER_MAX_NO_INC_32                       ((COUNTER_SIZE - sizeof(uint32_t)) / sizeof(uint32_t))
     69          #define COUNTER_NO_INC_PER_NEW_MEM_LOC_16           2U
     70          #define COUNTER_NO_INC_PER_NEW_MEM_LOC_32           1U
     71          
     72          // Define special Key to use for searching FIFO last valid location.
     73          #define SEARCH_KEY                                  (0xFFFFFFFEU)
     74          
     75          #define PAGE_WORD_UNUSED                            0xFFFFFFFFU
     76          
     77          // Helper define to make code more readable.
     78          #define COPY_OBJ_TRUE                               true
     79          #define COPY_OBJ_FALSE                              false
     80          
     81          #define COUNTER_SIZE_BASE                           (4U)
     82          
     83          #if defined(NVM3_SECURITY)
     84          #define NVM3_NONCE_OFFSET                           (0U)
     85          #define NVM3_DATA_OFFSET                            (4U)
     86          #define NVM3_RANDOM_NUM_SIZE                        (4U)
     87          #define NVM3_GCM_SIZE_OVERHEAD                      (NVM3_RANDOM_NUM_SIZE + NVM3_GCM_TAG_SIZE)
     88          
     89          uint8_t nvm3_encBuf[NVM3_RANDOM_NUM_SIZE + NVM3_MAX_OBJECT_SIZE_HIGH_LIMIT + NVM3_GCM_TAG_SIZE];
     90          uint8_t nvm3_decBuf[NVM3_MAX_OBJECT_SIZE_HIGH_LIMIT];
