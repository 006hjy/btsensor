    611          /*****************************************************************************************************************//**
    612           * Check if page is empty starting from the startAddr.
    613           *
    614           * @param[in]  h          A pointer to an NVM3 driver handle.
    615           *
    616           * @param[in]  startAdr   Start address of the page.
    617           *
    618           * @return                Returns 0 if the page is not empty or (page size - page header size) if the page is empty.
    619           ********************************************************************************************************************/
    620          static uint32_t checkIfUnusedPage(nvm3_Handle_t *h, void *startAdr)
    621          {
    622            uint8_t *currentAdr = startAdr;
    623            uint32_t cnt = 0;
    624            uint32_t val;
    625            uint8_t readWordCnt = 0;
    626          
    627            while (samePage(h, startAdr, currentAdr)) {
    628              nvm3_halReadWords(HAL, currentAdr, &val, 1);
    629              if (val != PAGE_WORD_UNUSED) {
    630                cnt = 0;
    631                break;
    632              } else {
    633                // Reading first 3 words of a page for FF's to check if page is empty or not
    634                if (readWordCnt == 2) {
    635                  cnt = (h->halInfo.pageSize - sizeof(nvm3_PageHdr_t));
    636                  break;
    637                }
    638                currentAdr += sizeof(uint32_t);
    639                readWordCnt++;
    640              }
    641            }
    642          
    643            return cnt;
    644          }
    645          #endif
