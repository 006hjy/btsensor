    360          #if defined(NVM3_SECURITY)
    361          /******************************************************************************************************//**
    362           * Get the security type from a valid page.
    363           * This function reads the security type from a valid page and updates it in NVM3 handler struct.
    364           *
    365           * @param[in]  h           A pointer to an NVM3 driver handle.
    366           *
    367           * @param[out] secType     A pointer to NVM3 security type which is updated by this function.
    368           *
    369           *********************************************************************************************************/
    370          static void getSecType(nvm3_Handle_t *h, nvm3_SecurityType_t *secType)
    371          {
    372            nvm3_HalPtr_t pageAdr;
    373            nvm3_PageHdr_t pageHdr;
    374            nvm3_PageState_t pageState;
    375            size_t idx;
    376          
    377            for (idx = 0; idx < h->totalNvmPageCnt; idx++) {
    378              pageAdr = pageAdrFromIdx(h, idx);
    379              nvm3_halReadWords(HAL, pageAdr, &pageHdr, NVM3_PAGE_HEADER_WSIZE);
    380              pageState = nvm3_pageGetState(&pageHdr);
    381              if (nvm3_pageStateIsGood(pageState)) {
    382                *secType = nvm3_pageGetSecType(&pageHdr);
    383                nvm3_tracePrint(TRACE_LEVEL_INFO, "getSecType: secType=%u.\n", *secType);
    384                break;
    385              }
    386            }
    387          }
    388          
    389          /*****************************************************************************************************************//**
    390           * Create nonce for encryption.
    391           *
    392           * @param[in]  h           A pointer to an NVM3 driver handle.
    393           *
    394           * @param[in]  objAdr      Object address in NVM.
    395           *
    396           * @param[out] nonceVal    A pointer to nonce buffer which is updated by this function.
    397           *
    398           * @return                 Returns SL_STATUS_OK on success or SL_STATUS_SECURITY_RANDOM_NUM_GEN_ERROR on failure.
    399           ********************************************************************************************************************/
    400          static sl_status_t createNonce(nvm3_Handle_t *h, nvm3_HalPtr_t objAdr, uint8_t *nonceVal)
    401          {
    402            sl_status_t sta;
    403            uint8_t nonce[NVM3_NONCE_SIZE];
    404            size_t eraseCnt;
    405            nvm3_PageHdr_t pageHdr;
    406          
    407            // Construct nonce from random number, obj adr and page erase count
    408            sta = nvm3_halCryptoGenRandNum(HAL_CRYPTO, &nonce[0], NVM3_RANDOM_NUM_SIZE);
    409            if (sta != SL_STATUS_OK) {
    410              nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - random number generation failed, sta=0x%lx.\n", sta);
    411              NVM3_ERROR_ASSERT();
    412              return sta;
    413            }
    414            nonce[4] = ((uint32_t) objAdr & 0xFF000000) >> 24;
    415            nonce[5] = ((uint32_t) objAdr & 0x00FF0000) >> 16;
    416            nonce[6] = ((uint32_t) objAdr & 0x0000FF00) >> 8;
    417            nonce[7] = ((uint32_t) objAdr & 0x000000FF);
    418            // Get the page erase count
    419            size_t pageIdx = pageIdxFromAdr(h, objAdr);
    420            void *pageAdr = pageAdrFromIdx(h, pageIdx);
    421            nvm3_halReadWords(HAL, pageAdr, &pageHdr, NVM3_PAGE_HEADER_WSIZE);
    422            eraseCnt = nvm3_pageGetEraseCnt(&pageHdr);
    423            nonce[8] = (eraseCnt & 0xFF000000) >> 24;
    424            nonce[9] = (eraseCnt & 0x00FF0000) >> 16;
    425            nonce[10] = (eraseCnt & 0x0000FF00) >> 8;
    426            nonce[11] = (eraseCnt & 0x000000FF);
    427            memcpy(&nonceVal[0], &nonce[0], sizeof(nonce));
    428          
    429            return SL_STATUS_OK;
    430          }
    431          
    432          /*****************************************************************************************************************//**
    433           * Get nonce for decryption.
    434           *
    435           * @param[in]  h           A pointer to an NVM3 driver handle.
    436           *
    437           * @param[in]  objAdr      Object address in NVM.
    438           *
    439           * @param[out] nonceVal    A pointer to nonce buffer which is updated by this function.
    440           ********************************************************************************************************************/
    441          static void getNonce(nvm3_Handle_t *h, nvm3_HalPtr_t objAdr, uint8_t *nonceVal)
    442          {
    443            uint8_t nonce[NVM3_NONCE_SIZE];
    444            size_t eraseCnt;
    445            nvm3_PageHdr_t pageHdr;
    446          
    447            // Construct nonce from random number, obj adr and page erase count
    448            nvm3_halReadWords(HAL, objAdr, &nonce[0], 1);
    449            nonce[4] = ((uint32_t) objAdr & 0xFF000000) >> 24;
    450            nonce[5] = ((uint32_t) objAdr & 0x00FF0000) >> 16;
    451            nonce[6] = ((uint32_t) objAdr & 0x0000FF00) >> 8;
    452            nonce[7] = ((uint32_t) objAdr & 0x000000FF);
    453            // Get the page erase count
    454            size_t pageIdx = pageIdxFromAdr(h, objAdr);
    455            void *pageAdr = pageAdrFromIdx(h, pageIdx);
    456            nvm3_halReadWords(HAL, pageAdr, &pageHdr, NVM3_PAGE_HEADER_WSIZE);
    457            eraseCnt = nvm3_pageGetEraseCnt(&pageHdr);
    458            nonce[8] = (eraseCnt & 0xFF000000) >> 24;
    459            nonce[9] = (eraseCnt & 0x00FF0000) >> 16;
    460            nonce[10] = (eraseCnt & 0x0000FF00) >> 8;
    461            nonce[11] = (eraseCnt & 0x000000FF);
    462            memcpy(&nonceVal[0], &nonce[0], sizeof(nonce));
    463          }
    464          
    465          /*****************************************************************************************************************//**
    466           * Convert NVM3 security type to crypto algorithm.
    467           *
    468           * @param[in]  secType     NVM3 security type.
    469           *
    470           * @return                 Returns remapped crypto algorithm.
    471           ********************************************************************************************************************/
    472          static nvm3_halCryptoAlgo_t convertSecTypeToCryptoAlgo(nvm3_SecurityType_t secType)
    473          {
    474            nvm3_halCryptoAlgo_t algo;
    475          
    476            switch (secType) {
    477              case NVM3_SECURITY_NONE:
    478                algo = NVM3_HAL_CRYPTO_ALGO_NONE;
    479                break;
    480              case NVM3_SECURITY_AEAD:
    481                algo = NVM3_HAL_CRYPTO_ALGO_AEAD;
    482                break;
    483              case NVM3_SECURITY_ENC:
    484                algo = NVM3_HAL_CRYPTO_ALGO_ENC;
    485                break;
    486              default:
    487                algo = NVM3_HAL_CRYPTO_ALGO_AEAD;
    488                break;
    489            }
    490          
    491            return algo;
    492          }
    493          #endif
    494          
    495          static size_t getNextGoodPage(nvm3_Handle_t *h, size_t idx)
    496          {
    497            nvm3_HalPtr_t pageAdr;
    498            nvm3_PageHdr_t pageHdr;
    499            nvm3_PageState_t pageState;
    500          
    501            /* Loop through all pages minus 1, which is the current page. */
    502            for (size_t i = 0U; i < (h->totalNvmPageCnt - 1U); i++) {
    503              idx = pageIdxIncrement(h, idx);
    504              pageAdr = pageAdrFromIdx(h, idx);
    505              nvm3_halReadWords(HAL, pageAdr, &pageHdr, NVM3_PAGE_HEADER_WSIZE);
    506              pageState = nvm3_pageGetState(&pageHdr);
    507              if (nvm3_pageStateIsGood(pageState)) {
    508                break;
    509              }
    510            }
    511          
    512            return idx;
    513          }
