     43          // Max IADC clock rates.
     44          #define IADC_CLK_MAX_FREQ                    40000000UL
     45          #define IADC_ANA_CLK_HIGH_SPEED_MAX_FREQ     20000000UL
     46          #define IADC_ANA_CLK_NORMAL_MAX_FREQ         10000000UL
     47          #define IADC_ANA_CLK_HIGH_ACCURACY_MAX_FREQ  5000000UL
     48          #if defined(_IADC_CFG_ADCMODE_HIGHSPEED)
     49          #define IADC_ANA_CLK_MAX_FREQ(adc_mode) ((adc_mode) == SL_HAL_IADC_CFG_ADC_MODE_NORMAL ? IADC_ANA_CLK_NORMAL_MAX_FREQ            \
     50                                                   : ((adc_mode) == SL_HAL_IADC_CFG_ADC_MODE_HIGH_SPEED ? IADC_ANA_CLK_HIGH_SPEED_MAX_FREQ \
     51                                                      : IADC_ANA_CLK_HIGH_ACCURACY_MAX_FREQ))
     52          #else
     53          #define IADC_ANA_CLK_MAX_FREQ(adc_mode) ((adc_mode) == SL_HAL_IADC_CFG_ADC_MODE_NORMAL ? IADC_ANA_CLK_NORMAL_MAX_FREQ \
     54                                                   : IADC_ANA_CLK_HIGH_ACCURACY_MAX_FREQ)
     55          #endif
     56          
     57          #define IADC_ROUND_D2I(n) (int)((n) < 0.0f ? ((n) - 0.5f) : ((n) + 0.5f))
     58          
     59          #define IADC0_SCANENTRIES IADC0_ENTRIES
     60          #define IADC0_FIFOENTRIES 0x4UL
     61          
     62          #define IADC1_SCANENTRIES IADC1_ENTRIES
     63          #define IADC1_FIFOENTRIES 0x4UL
     64          
     65          #if defined(IADC_ENTRIES)
     66          #define IADC_SCANENTRIES(iadc) IADC_ENTRIES(IADC_NUM(iadc))
     67          #else
     68          #define IADC_SCANENTRIES(iadc) ((iadc) == IADC0 ? IADC0_SCANENTRIES \
     69                                          : 0UL)
     70          #endif
     71          
     72          #if !defined(IADC_CONFIGNUM)
     73          #define IADC_CONFIGNUM(iadc) ((iadc) == 0 ? IADC0_CONFIGNUM \
     74                                        : 0UL)
     75          #endif
     76          
     77          #define IADC_FIFOENTRIES(iadc) ((iadc) == IADC0 ? IADC0_FIFOENTRIES \
     78                                          : 0UL)
