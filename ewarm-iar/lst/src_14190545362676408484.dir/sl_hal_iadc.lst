    861          /***************************************************************************//**
    862           * Get analog gain calibration value from device info.
    863           ******************************************************************************/
    864          static uint16_t iadc_get_analog_gain_cal_value(unsigned analog_gain)
    865          {
    866            uint16_t calc_ana_gain;
    867          
    868            switch (analog_gain) {
    869          #if defined(_IADC_CFG_ANALOGGAIN_ANAGAIN0P25)
    870              case SL_HAL_IADC_ANALOG_GAIN_0P25:
    871          #endif
    872              case SL_HAL_IADC_ANALOG_GAIN_0P5:
    873              case SL_HAL_IADC_ANALOG_GAIN_1:
    874                calc_ana_gain = (uint16_t)((DEVINFO->IADC0GAIN0 & _DEVINFO_IADC0GAIN0_GAINCANA1_MASK) >> _DEVINFO_IADC0GAIN0_GAINCANA1_SHIFT);
    875                break;
    876              case SL_HAL_IADC_ANALOG_GAIN_2:
    877                calc_ana_gain = (uint16_t)((DEVINFO->IADC0GAIN0 & _DEVINFO_IADC0GAIN0_GAINCANA2_MASK) >> _DEVINFO_IADC0GAIN0_GAINCANA2_SHIFT);
    878                break;
    879              case SL_HAL_IADC_ANALOG_GAIN_3:
    880                calc_ana_gain = (uint16_t)((DEVINFO->IADC0GAIN1 & _DEVINFO_IADC0GAIN1_GAINCANA3_MASK) >> _DEVINFO_IADC0GAIN1_GAINCANA3_SHIFT);
    881                break;
    882              case SL_HAL_IADC_ANALOG_GAIN_4:
    883                calc_ana_gain = (uint16_t)((DEVINFO->IADC0GAIN1 & _DEVINFO_IADC0GAIN1_GAINCANA4_MASK) >> _DEVINFO_IADC0GAIN1_GAINCANA4_SHIFT);
    884                break;
    885              default:
    886                calc_ana_gain = (uint16_t)((DEVINFO->IADC0GAIN0 & _DEVINFO_IADC0GAIN0_GAINCANA1_MASK) >> _DEVINFO_IADC0GAIN0_GAINCANA1_SHIFT);
    887                break;
    888            }
    889          
    890            return calc_ana_gain;
    891          }
    892          
    893          /***************************************************************************//**
    894           * Calculate offset for normal and high-speed modes.
    895           ******************************************************************************/
    896          static float iadc_calculate_offset(unsigned analog_gain,
    897                                             sl_hal_iadc_config_adc_mode_t adc_mode)
    898          {
    899            float offset = 0.0f;
    900          
    901            if (analog_gain == SL_HAL_IADC_ANALOG_GAIN_2) {
    902              if (adc_mode == SL_HAL_IADC_CFG_ADC_MODE_NORMAL) {
    903                offset = (int16_t)(DEVINFO->IADC0NORMALOFFSETCAL0 >> _DEVINFO_IADC0NORMALOFFSETCAL0_OFFSETANA2NORM_SHIFT);
    904              } else {
    905                offset = (int16_t)(DEVINFO->IADC0HISPDOFFSETCAL0 >> _DEVINFO_IADC0HISPDOFFSETCAL0_OFFSETANA2HISPD_SHIFT);
    906              }
    907            } else if (analog_gain == SL_HAL_IADC_ANALOG_GAIN_3) {
    908              if (adc_mode == SL_HAL_IADC_CFG_ADC_MODE_NORMAL) {
    909                offset = (int16_t)(DEVINFO->IADC0NORMALOFFSETCAL0 >> _DEVINFO_IADC0NORMALOFFSETCAL0_OFFSETANA2NORM_SHIFT) * 2;
    910              } else {
    911                offset = (int16_t)(DEVINFO->IADC0HISPDOFFSETCAL0 >> _DEVINFO_IADC0HISPDOFFSETCAL0_OFFSETANA2HISPD_SHIFT) * 2;
    912              }
    913            } else if (analog_gain == SL_HAL_IADC_ANALOG_GAIN_4) {
    914              if (adc_mode == SL_HAL_IADC_CFG_ADC_MODE_NORMAL) {
    915                offset = (int16_t)(DEVINFO->IADC0NORMALOFFSETCAL0 >> _DEVINFO_IADC0NORMALOFFSETCAL0_OFFSETANA2NORM_SHIFT) * 3;
    916              } else {
    917                offset = (int16_t)(DEVINFO->IADC0HISPDOFFSETCAL0 >> _DEVINFO_IADC0HISPDOFFSETCAL0_OFFSETANA2HISPD_SHIFT) * 3;
    918              }
    919            }
    920          
    921            return offset;
    922          }
    923          
    924          /***************************************************************************//**
    925           * Calculate gain and offset for normal and high-speed modes.
    926           ******************************************************************************/
    927          static void iadc_calculate_normal_highspeed_gain_offset(IADC_TypeDef *iadc,
    928                                                                  const sl_hal_iadc_init_t *init,
    929                                                                  sl_hal_iadc_config_adc_mode_t adc_mode,
    930                                                                  uint8_t config)
    931          {
    932            float offset;
    933            uint32_t scale;
    934            int32_t i_offset;
    935            int32_t i_osr;
    936            uint32_t tmp;
    937            unsigned analog_gain;
    938            uint16_t calc_ana_gain;
    939          
    940            // Calculate analog gain.
    941            analog_gain = (iadc->CFG[config].CFG & _IADC_CFG_ANALOGGAIN_MASK) >> _IADC_CFG_ANALOGGAIN_SHIFT;
    942            calc_ana_gain = iadc_get_analog_gain_cal_value(analog_gain);
    943          
    944            // Calculate base offset based on analog gain.
    945            offset = iadc_calculate_offset(analog_gain, adc_mode);
    946          
    947            // Set gain correction bitfields in scale variable.
    948            tmp = (uint32_t)calc_ana_gain & 0x9FFFU;
    949            scale = tmp << _IADC_SCALE_GAIN13LSB_SHIFT;
    950            if ((tmp & 0x8000U) != 0U) {
    951              scale |= IADC_SCALE_GAIN3MSB;
    952            }
    953          
    954            // Adjust offset according to selected OSR.
    955            i_osr = 1U << (((iadc->CFG[config].CFG & _IADC_CFG_OSRHS_MASK) >> _IADC_CFG_OSRHS_SHIFT) + 1U);
    956            if (i_osr == 2) {
    957              if (adc_mode == SL_HAL_IADC_CFG_ADC_MODE_NORMAL) {
    958                offset += (int16_t)(DEVINFO->IADC0NORMALOFFSETCAL0 & _DEVINFO_IADC0NORMALOFFSETCAL0_OFFSETANA1NORM_MASK);
    959              } else {
    960                offset += (int16_t)(DEVINFO->IADC0HISPDOFFSETCAL0 & _DEVINFO_IADC0HISPDOFFSETCAL0_OFFSETANA1HISPD_MASK);
    961              }
    962            } else {
    963              if (adc_mode == SL_HAL_IADC_CFG_ADC_MODE_NORMAL) {
    964                offset = (int16_t)(DEVINFO->IADC0NORMALOFFSETCAL1 & _DEVINFO_IADC0NORMALOFFSETCAL1_OFFSETANA3NORM_MASK) - offset;
    965              } else {
    966                offset += (int16_t)(DEVINFO->IADC0HISPDOFFSETCAL1 & _DEVINFO_IADC0HISPDOFFSETCAL1_OFFSETANA3HISPD_MASK) - offset;
    967              }
    968              offset /= (float)i_osr / 2.0f;
    969              offset += (int16_t)(DEVINFO->IADC0OFFSETCAL0 & _DEVINFO_IADC0OFFSETCAL0_OFFSETANABASE_MASK);
    970            }
    971          
    972            // Compensate offset according to selected reference voltage.
    973            if (init->configs[config].reference == SL_HAL_IADC_REFERENCE_VREFINT_1V2) {
    974              // Internal reference voltage (VBGR) depends on the chip revision.
    975              offset *= 1.25f / ((float)sl_hal_iadc_get_reference_voltage(init->configs[config].reference) / 1000.0f);
    976            } else {
    977              offset *= 1.25f / ((float)(init->configs[config].vref) / 1000.0f);
    978            }
    979          
    980            // Compensate offset for systematic offset.
    981            offset = (offset * 4.0f) + (640.0f * (256.0f / (float)i_osr));
    982          
    983            // Apply gain error correction.
    984            if (scale != 0x80000000U) {
    985              offset = (calc_ana_gain / 32768.0f) * (offset + 524288.0f) - 524288.0f;
    986            }
    987          
    988            i_offset = IADC_ROUND_D2I(-offset);
    989          
    990            // We only have 18 bits available for OFFSET in SCALE register
    991            // OFFSET is a 2nd complement number.
    992            if (i_offset > 131071) {           // Positive overflow at 0x0001FFFF ?
    993              scale |= 0x1FFFFU;
    994            } else if (i_offset < -131072) {   // Negative overflow at 0xFFFE0000 ?
    995              scale |= 0x20000U;
    996            } else {
    997              scale |= (uint32_t)i_offset & 0x3FFFFU;
    998            }
    999          
   1000            iadc->CFG[config].SCALE = scale;
   1001          }
   1002          
   1003          #if defined(_IADC_CFG_ADCMODE_HIGHACCURACY)
   1004          /***************************************************************************//**
   1005           * Calculate gain and offset for high accuracy mode.
   1006           ******************************************************************************/
   1007          static void iadc_calculate_high_accuracy_gain_offset(IADC_TypeDef *iadc,
   1008                                                               const sl_hal_iadc_init_t *init,
   1009                                                               uint8_t config)
   1010          {
   1011            float ana_gain;
   1012            int32_t ana_gain_round;
   1013            float offset_ana;
   1014            float offset_2;
   1015            int32_t offset_long;
   1016            int32_t offset_ana1_high_acc_int;
   1017            uint8_t osr_value;
   1018            float offset_ana_base;
   1019            float gain_sys_high_acc;
   1020            float ref_voltage;
   1021            unsigned analog_gain;
   1022            uint16_t calc_ana_gain;
   1023          
   1024            // Calculate analog gain.
   1025            analog_gain = (iadc->CFG[config].CFG & _IADC_CFG_ANALOGGAIN_MASK) >> _IADC_CFG_ANALOGGAIN_SHIFT;
   1026            calc_ana_gain = iadc_get_analog_gain_cal_value(analog_gain);
   1027          
   1028            // Over sampling ratio for high accuracy conversions.
   1029            const float osr_high_acc[6] = { 16.0, 32.0, 64.0, 92.0, 128.0, 256.0 };
   1030          
   1031            // Get reference voltage in volts.
   1032            if (init->configs[config].reference == SL_HAL_IADC_REFERENCE_VREFINT_1V2) {
   1033              // Internal reference voltage (VBGR) depends on the chip revision.
   1034              ref_voltage = (float)sl_hal_iadc_get_reference_voltage(init->configs[config].reference) / 1000.0f;
   1035            } else {
   1036              ref_voltage = (float)init->configs[config].vref / 1000.0f;
   1037            }
   1038          
   1039            // Get OSR from config register.
   1040            osr_value = (iadc->CFG[config].CFG & _IADC_CFG_OSRHA_MASK) >> _IADC_CFG_OSRHA_SHIFT;
   1041          
   1042            // 1. Calculate gain correction.
   1043            if ((uint32_t)osr_high_acc[osr_value] == 92U) {
   1044              // for OSR = 92, gain_sys_high_acc = 0.957457.
   1045              gain_sys_high_acc = 0.957457f;
   1046            } else {
   1047              // for OSR != 92, gain_sys_high_acc = OSR/(OSR + 1).
   1048              gain_sys_high_acc = osr_high_acc[osr_value] / (osr_high_acc[osr_value] + 1.0f);
   1049            }
   1050          
   1051            ana_gain = (float) calc_ana_gain * gain_sys_high_acc;
   1052            ana_gain_round = IADC_ROUND_D2I(ana_gain);
   1053            iadc->CFG[config].SCALE &= ~_IADC_SCALE_MASK;
   1054          
   1055            // Write GAIN3MSB.
   1056            if ((uint32_t)ana_gain_round & 0x8000) {
   1057              iadc->CFG[config].SCALE |= IADC_SCALE_GAIN3MSB_GAIN100;
   1058            } else {
   1059              iadc->CFG[config].SCALE |= IADC_SCALE_GAIN3MSB_GAIN011;
   1060            }
   1061          
   1062            // Write GAIN13LSB.
   1063            iadc->CFG[config].SCALE |= ((uint32_t)ana_gain_round & 0x1FFF) << _IADC_SCALE_GAIN13LSB_SHIFT;
   1064          
   1065            // Get offset value for high accuracy mode from DEVINFO.
   1066            offset_ana1_high_acc_int = (uint16_t)((DEVINFO->IADC0OFFSETCAL0 & _DEVINFO_IADC0OFFSETCAL0_OFFSETANA1HIACC_MASK)
   1067                                                  >> _DEVINFO_IADC0OFFSETCAL0_OFFSETANA1HIACC_SHIFT);
   1068          
   1069            // 2. OSR adjustment.
   1070            // Get offset from DEVINFO.
   1071            offset_ana_base = (int16_t)((DEVINFO->IADC0OFFSETCAL0 & _DEVINFO_IADC0OFFSETCAL0_OFFSETANABASE_MASK)
   1072                                        >> _DEVINFO_IADC0OFFSETCAL0_OFFSETANABASE_SHIFT);
   1073            // 1 << osr_value is the same as pow(2, osr_value).
   1074            offset_ana = offset_ana_base + (float)offset_ana1_high_acc_int / (float)(1 << osr_value);
   1075          
   1076            // 3. Reference voltage adjustment.
   1077            offset_ana = offset_ana * (1.25f / ref_voltage);
   1078          
   1079            // 4. Calculate final offset.
   1080            offset_2 = 262144.0f / osr_high_acc[osr_value] / (osr_high_acc[osr_value] + 1.0f) + offset_ana * 4.0f + 524288.0f;
   1081            offset_2 = (calc_ana_gain / 32768.0f * (-1.0f)) * offset_2 + 524288.0f;
   1082            offset_long = IADC_ROUND_D2I(offset_2);
   1083          
   1084            // 5. Write offset to scale register.
   1085            iadc->CFG[config].SCALE |= offset_long & _IADC_SCALE_OFFSET_MASK;
   1086          }
   1087          #endif
   1088          
   1089          #endif /* defined(IADC_COUNT) && (IADC_COUNT > 0) */

