     88          /***************************************************************************//**
     89           * @brief
     90           *   Convert raw IADC data to a structured result.
     91           *
     92           * @details
     93           *   This function processes the raw data from the IADC and converts
     94           *   it into a  structured result containing the data and the ID of
     95           *   the scan table entry or single conversion indicator.
     96           *
     97           * @note
     98           *   The alignment mode determines how the raw data is processed.
     99           *   Ensure that the alignment parameter matches the configuration of the IADC.
    100           *
    101           * @param[in] raw_data
    102           *   The raw 32-bit data read from the IADC.
    103           * @param[in] alignment
    104           *   The alignment mode of the IADC data (e.g., right-aligned or left-aligned).
    105           *
    106           * @return
    107           *   A structured result of type `sl_hal_iadc_result_t` containing:
    108           *    - `data`: The converted IADC data.
    109           *    - `id`: The ID of the scan table entry or single conversion indicator.
    110           ******************************************************************************/
    111          static sl_hal_iadc_result_t iadc_convert_raw_data_to_result(uint32_t raw_data,
    112                                                                      sl_hal_iadc_alignment_t alignment);
    113          
    114          /***************************************************************************//**
    115           * @brief
    116           *   Get analog gain calibration value from device info.
    117           *
    118           * @param[in] analog_gain
    119           *   The analog gain setting.
    120           *
    121           * @return
    122           *   The calibration value for the specified analog gain.
    123           ******************************************************************************/
    124          static uint16_t iadc_get_analog_gain_cal_value(unsigned analog_gain);
    125          
    126          /***************************************************************************//**
    127           * @brief
    128           *   Calculate offset for normal and high-speed modes.
    129           *
    130           * @param analog_gain
    131           *   Analog gain.
    132           * @param[in] adc_mode
    133           *   ADC mode (normal or high-speed).
    134           * @return
    135           *   The calculated offset.
    136           ******************************************************************************/
    137          static float iadc_calculate_offset(unsigned analog_gain,
    138                                             sl_hal_iadc_config_adc_mode_t adc_mode);
    139          
    140          /***************************************************************************//**
    141           * @brief
    142           *   Calculate gain and offset for normal and high-speed modes.
    143           *
    144           * @param[in] iadc
    145           *   Pointer to IADC peripheral register block.
    146           * @param[in] init
    147           *   Pointer to IADC initialization structure.
    148           * @param[in] adc_mode
    149           *   ADC mode (normal or high-speed).
    150           * @param[in] config
    151           *   Configuration index.
    152           ******************************************************************************/
    153          static void iadc_calculate_normal_highspeed_gain_offset(IADC_TypeDef *iadc,
    154                                                                  const sl_hal_iadc_init_t *init,
    155                                                                  sl_hal_iadc_config_adc_mode_t adc_mode,
    156                                                                  uint8_t config);
    157          
    158          #if defined(_IADC_CFG_ADCMODE_HIGHACCURACY)
    159          /***************************************************************************//**
