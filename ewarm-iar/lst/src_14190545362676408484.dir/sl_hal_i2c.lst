    394          #else
    395            // Clear pending commands,clear TX Buffer & Shift register.
    396            i2c->CMD = (I2C_CMD_CLEARPC | I2C_CMD_CLEARTX | I2C_CMD_CLEARRX);
    397          #endif //_SILICON_LABS_32B_SERIES_2
    398          
    399            // Wait for synchronization to complete.
    400            sl_hal_i2c_wait_sync(i2c);
