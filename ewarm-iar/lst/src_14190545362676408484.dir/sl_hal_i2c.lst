   \                                 In section .text, align 2, keep-with-next
    378          void sl_hal_i2c_flush_buffers(I2C_TypeDef *i2c)
    379          {
    380            // Abort the current transmission making the bus go idle.
    381            if (i2c->STATE & I2C_STATE_BUSY) {
   \                     sl_hal_i2c_flush_buffers: (+1)
   \        0x0   0x6901             LDR      R1,[R0, #+16]
   \        0x2   0x07CA             LSLS     R2,R1,#+31
