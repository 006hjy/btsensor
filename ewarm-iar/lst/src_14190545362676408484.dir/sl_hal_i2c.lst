   \        0x8   0x60C1             STRMI    R1,[R0, #+12]
    382              i2c->CMD = I2C_CMD_ABORT;
    383          
    384              // Wait for synchronization to complete.
    385              sl_hal_i2c_wait_sync(i2c);
    386            }
    387          
    388          #if defined(_SILICON_LABS_32B_SERIES_2)
    389            // Clear pending commands,clear TX Buffer.
    390            i2c->CMD = (I2C_CMD_CLEARPC | I2C_CMD_CLEARTX);
   \        0xA   0x22C0             MOVS     R2,#+192
   \        0xC   0x60C2             STR      R2,[R0, #+12]
