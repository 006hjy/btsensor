    585                break;
    586          
    587              case SL_HAL_SYSTEM_HFRCOEM23_FREQ_19M0Hz:
    588                calibration_value = DEVINFO->HFRCOEM23CAL[8].HFRCOEM23CAL;
    589                break;
    590          
