    179          void sl_hal_system_init(void)
    180          {
   \                     sl_hal_system_init: (+1)
   \        0x0   0x....             LDR.N    R0,??DataTable19_1
   \        0x2   0x6800             LDR      R0,[R0, #+0]
   \        0x4   0x0200             LSLS     R0,R0,#+8
   \        0x6   0x0E00             LSRS     R0,R0,#+24
