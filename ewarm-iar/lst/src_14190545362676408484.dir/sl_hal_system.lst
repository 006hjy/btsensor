    546            status = sli_se_device_data_read_word(&se_command_ctx, otp_section_id, offset, &calibration_value);
    547            if (status != SL_STATUS_OK) {
    548              return 0;
    549            }
    550          
    551            return calibration_value;
    552          #elif defined(_SILICON_LABS_32B_SERIES_2) && defined(HFRCOEM23_PRESENT)
