   \        0xE   0xB510             PUSH     {R4,LR}
    181          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_1)
    182            sl_hal_system_chip_revision_t chipRev;
    183            sl_hal_system_get_chip_revision(&chipRev);
    184          
    185            if (chipRev.major == 0x01 && (HFXO0->STATUS & HFXO_STATUS_ENS) == 0U) {
    186              // Change HFXO default peak detector settings.
    187              *(volatile uint32_t*)(HFXO0_BASE + 0x34U) =
    188                (*(volatile uint32_t*)(HFXO0_BASE + 0x34U) & 0xFF8000FFU)
    189                | 0x00178500U;
    190              // Change HFXO low power control settings.
    191              *(volatile uint32_t*)(HFXO0_BASE + 0x30U) =
    192                (*(volatile uint32_t*)(HFXO0_BASE + 0x30U) & 0xFFFF0FFFU)
    193                | 0x0000C000U;
    194              // Change default SQBUF bias current.
    195              *(volatile uint32_t*)(HFXO0_BASE + 0x30U) |= 0x700;
    196            }
    197          
    198            if (chipRev.major == 0x01 && chipRev.minor == 0x0) {
    199              // Trigger RAM read for each RAM instance.
    200              volatile uint32_t *dmem = (volatile uint32_t *) DMEM_RAM0_RAM_MEM_BASE;
    201              for (uint32_t i = 0U; i < DMEM_NUM_BANK; i++) {
    202                // Force memory read
    203                *dmem;
    204                dmem += (DMEM_BANK0_SIZE / 4U);
    205              }
    206            }
    207          
    208            // Set TRACE clock to intended reset value.
    209            CMU->TRACECLKCTRL = (CMU->TRACECLKCTRL & ~_CMU_TRACECLKCTRL_CLKSEL_MASK)
    210                                | CMU_TRACECLKCTRL_CLKSEL_HFRCOEM23;
    211          #endif
