    575              case SL_HAL_SYSTEM_HFRCOEM23_FREQ_7M0Hz:
    576                calibration_value = DEVINFO->HFRCOEM23CAL[3].HFRCOEM23CAL;
    577                break;
    578          
    579              case SL_HAL_SYSTEM_HFRCOEM23_FREQ_13M0Hz:
    580                calibration_value = DEVINFO->HFRCOEM23CAL[6].HFRCOEM23CAL;
    581                break;
    582          
