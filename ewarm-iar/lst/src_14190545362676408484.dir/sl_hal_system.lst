    564              case SL_HAL_SYSTEM_HFRCOEM23_FREQ_5M0Hz:
    565                calibration_value = DEVINFO->HFRCOEM23CAL[1].HFRCOEM23CAL;
    566                break;
    567              case SL_HAL_SYSTEM_HFRCOEM23_FREQ_10M0Hz:
    568                calibration_value = DEVINFO->HFRCOEM23CAL[4].HFRCOEM23CAL;
    569                break;
    570              case SL_HAL_SYSTEM_HFRCOEM23_FREQ_20M0Hz:
    571                calibration_value = DEVINFO->HFRCOEM23CAL[9].HFRCOEM23CAL;
    572                break;
    573            #endif
