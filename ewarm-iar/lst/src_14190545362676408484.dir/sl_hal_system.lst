    123          /***************************************************************************//**
    124           * Get the nth ASCII character of a specified number.
    125           *
    126           * @param[in] input_number The number where the digit will be taken.
    127           * @param[in] position The digit position.
    128           *
    129           * @return The ASCII value of the specified digit.
    130           ******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    131          char sli_get_n_digit(uint16_t input_number,
    132                               uint8_t position)
    133          {
   \                     sli_get_n_digit: (+1)
   \        0x0   0xB530             PUSH     {R4,R5,LR}
   \        0x2   0xB085             SUB      SP,SP,#+20
   \        0x4   0x4604             MOV      R4,R0
   \        0x6   0x460D             MOV      R5,R1
    134            uint32_t exp[] = { 10, 100, 1000, 10000, 100000 };
   \        0x8   0xEA4F 0x000D      MOV.W    R0,SP
   \        0xC   0x....             ADR.N    R1,?_1
   \        0xE   0x2214             MOVS     R2,#+20
   \       0x10   0x.... 0x....      BL       __aeabi_memcpy4
    135            uint32_t number = input_number;
    136          
    137            if (position > 4) {
   \       0x14   0x4628             MOV      R0,R5
   \       0x16   0x2805             CMP      R0,#+5
   \       0x18   0xDB05             BLT.N    ??sli_get_n_digit_0
    138              EFM_ASSERT(false);
   \       0x1A   0x218A             MOVS     R1,#+138
   \       0x1C   0x....             LDR.N    R0,??DataTable19
   \       0x1E   0x.... 0x....      BL       assertEFM
    139              return '0';
   \       0x22   0x2030             MOVS     R0,#+48
   \       0x24   0xE00F             B.N      ??sli_get_n_digit_1
    140            }
    141          
    142            number = (number % exp[position]);
   \                     ??sli_get_n_digit_0: (+1)
   \       0x26   0xF85D 0x1020      LDR      R1,[SP, R0, LSL #+2]
   \       0x2A   0xFBB4 0xF2F1      UDIV     R2,R4,R1
   \       0x2E   0xFB01 0x4412      MLS      R4,R1,R2,R4
    143          
    144            if (position != 0) {
   \       0x32   0xB135             CBZ.N    R5,??sli_get_n_digit_2
    145              number = number / (exp[position - 1]);
   \       0x34   0x4669             MOV      R1,SP
   \       0x36   0xEB01 0x0080      ADD      R0,R1,R0, LSL #+2
   \       0x3A   0xF850 0x2C04      LDR      R2,[R0, #-4]
   \       0x3E   0xFBB4 0xF4F2      UDIV     R4,R4,R2
    146            }
    147          
    148            return (char)(number + '0');
   \                     ??sli_get_n_digit_2: (+1)
   \       0x42   0x3430             ADDS     R4,R4,#+48
   \       0x44   0xB2E0             UXTB     R0,R4
   \                     ??sli_get_n_digit_1: (+1)
   \       0x46   0xB005             ADD      SP,SP,#+20
   \       0x48   0xBD30             POP      {R4,R5,PC}
    149          }
    150          #endif
    151          
    152          #if defined(_DEVINFO_PART0_DIECODE0_MASK) && defined(_SILICON_LABS_SECURITY_FEATURE_VAULT)
    153          /***************************************************************************//**
    154           * Convert hexadecimal ASCII character to integer value.
    155           *
    156           * @param[in] character The character to be coverted to a number.
    157           *
    158           * @return The uint8_t value of the character given in parameter.
    159           ******************************************************************************/
    160          uint8_t sli_hex_ascii_to_value(char character)
    161          {
    162            if (character >= '0' && character <= '9') {
    163              return character - '0';
    164            } else if (character >= 'A' && character <= 'F') {
    165              return character - 'A';
    166            }
    167          
    168            return 0U;
    169          }
    170          #endif
