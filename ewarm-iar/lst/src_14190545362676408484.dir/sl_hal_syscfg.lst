    370          /***************************************************************************//**
    371           * DMA read and write existing values (for ECC initialization).
    372           *
    373           * @param[in] start Start address of address range in RAM to read/write.
    374           * @param[in] size Size of address range in RAM to read/write.
    375           * @param[in] channels[2] Array of 2 DMA channels to use.
    376           *
    377           * @details This function uses DMA to read and write the existing data values in
    378           *          the RAM region specified by start and size. The function will use the
    379           *          2 DMA channels specified by the channels[2] array.
    380           ******************************************************************************/
    381          static void sli_hal_syscfg_ecc_read_write_existing_dma(uint32_t start,
    382                                                                 uint32_t size,
    383                                                                 const uint32_t channels[2])
    384          {
    385            // Assert that the 2 DMA channel numbers are different.
    386            EFM_ASSERT(channels[0] != channels[1]);
    387            // Make sure ECC_RAM_SIZE_MAX is a multiple of ECC_DMA_DESC_SIZE in order
    388            // to match the total xfer size of the descriptor chain with the largest
    389            // ECC RAM bank.
    390            EFM_ASSERT((ECC_RAM_SIZE_MAX % ECC_DMA_DESC_SIZE) == 0);
    391          
    392            uint32_t desc_cnt = 0;
    393            volatile uint32_t dma_desc[ECC_DMA_DESCS][4];
    394            uint32_t ch_mask = (1 << channels[0]) | (1 << channels[1]);
    395          
    396            // Initialize LDMA descriptor chain.
    397            do {
    398              dma_desc[desc_cnt][0] = (LDMA_CH_CTRL_STRUCTTYPE_TRANSFER  // DMA desc CTRL word.
    399                                       | LDMA_CH_CTRL_STRUCTREQ
    400                                       | _LDMA_CH_CTRL_XFERCNT_MASK
    401                                       | LDMA_CH_CTRL_BLOCKSIZE_ALL
    402                                       | LDMA_CH_CTRL_REQMODE_ALL
    403                                       | LDMA_CH_CTRL_SRCINC_ONE
    404                                       | LDMA_CH_CTRL_SIZE_WORD
    405                                       | LDMA_CH_CTRL_DSTINC_ONE);
    406          
    407              // source and destination address.
    408              dma_desc[desc_cnt][1] = start;
    409              dma_desc[desc_cnt][2] = start;
    410              // link to next descriptor.
    411              dma_desc[desc_cnt][3] = LDMA_CH_LINK_LINK
    412                                      | (((uint32_t) &dma_desc[desc_cnt + 1][0])
    413                                         & _LDMA_CH_LINK_LINKADDR_MASK);
    414          
    415              start += ECC_DMA_DESC_SIZE;
    416              size  -= ECC_DMA_DESC_SIZE;
    417              desc_cnt++;
    418            } while (size);
    419          
    420            // Make sure desc_cnt is valid to avoid out-of-bounds access when writing to
    421            // dma_desc array.
    422            if ((desc_cnt < 2) || (desc_cnt > ECC_DMA_DESCS)) {
    423              while (true) {
    424                EFM_ASSERT(false);
    425              }
    426            }
    427            // Now, divide the descriptor list in two parts, one for each channel,
    428            // by setting the link bit and address 0 of the descriptor in the middle
    429            // to 0.
    430            dma_desc[(desc_cnt / 2) - 1][3] = 0;
    431          
    432            // Set last descriptor link bit and address to 0.
    433            dma_desc[desc_cnt - 1][3] = 0;
    434            // Round robin scheduling for all channels (0 = no fixed priority channels).
    435            LDMA->CTRL    = 0 << _LDMA_CTRL_NUMFIXED_SHIFT;
    436            LDMA->EN      = LDMA_EN_EN;
    437            LDMA->CHEN    = 0;
    438            LDMA->DBGHALT = 0;
    439            LDMA->REQDIS  = 0;
    440          
    441            // Disable LDMA interrupts, and clear interrupt status.
    442            LDMA->IEN = 0;
    443            LDMA->IF_CLR = ch_mask;
    444          
    445            // Disable looping.
    446            LDMA->CH[channels[0]].LOOP = 0;
    447            LDMA->CH[channels[1]].LOOP = 0;
    448          
    449            // Set descriptor address for first channel.
    450            LDMA->CH[channels[0]].LINK = ((uint32_t)&dma_desc[0][0])
    451                                         & _LDMA_CH_LINK_LINKADDR_MASK;
    452            // Set descriptor address for second channel.
    453            LDMA->CH[channels[1]].LINK = ((uint32_t)&dma_desc[desc_cnt / 2][0])
    454                                         & _LDMA_CH_LINK_LINKADDR_MASK;
    455            // Clear the channel done flags.
    456            sl_hal_bus_reg_clear_mask(&LDMA->CHDONE, ch_mask);
    457          
    458            // Start transfer by loading descriptors.
    459            LDMA->LINKLOAD = ch_mask;
    460            while (!(((LDMA->CHSTATUS & ch_mask) == 0)
    461                     && ((LDMA->CHDONE & ch_mask) == ch_mask))) {
    462              // Wait until finished.
    463            }
    464          }
    465          #endif /* #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2) || defined(_MPAHBRAM_CTRL_MASK) */
    466          
    467          /***************************************************************************//**
    468           * This function initializes ECC for a given memory bank which is specified
    469           * with the sli_hal_syscfg_ecc_bank_t structure input parameter.
    470           *
    471           * @param[in] ecc_bank ECC memory bank device structure.
    472           * @param[in] dma_channels Array of 2 DMA channels that may be used during ECC
    473           *                         initialization.
    474           ******************************************************************************/
    475          static void sli_hal_syscfg_ecc_init_bank(const sli_hal_syscfg_ecc_bank_t *ecc_bank,
    476                                                   const uint32_t dma_channels[2])
    477          {
    478            EFM_ASSERT(ecc_bank != NULL);
    479            EFM_ASSERT(dma_channels[0] != dma_channels[1]);
    480          
    481            CORE_DECLARE_IRQ_STATE;
    482            CORE_ENTER_CRITICAL();
    483          #if defined(_SILICON_LABS_32B_SERIES_2_CONFIG_2)  \
    484            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_7) \
    485            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_9) \
    486            || defined(_SILICON_LABS_32B_SERIES_2_CONFIG_11) \
    487            || defined(_MPAHBRAM_CTRL_MASK)
    488          
    489            (void) dma_channels;
    490          #if !defined(_MPAHBRAM_CTRL_MASK)
    491            // Disable ECC write.
    492            ECC_CTRL_REG &= ~ecc_bank->init_syndrome_enable;
    493          #endif
    494            // Initialize ECC syndromes by using core cpu to load and store the existing
    495            // data values in RAM.
    496            sli_hal_syscfg_ecc_read_write_existing_pio(ecc_bank);
    497          #else
    498            // Enable ECC write.
    499            ECC_CTRL_REG |= ecc_bank->init_syndrome_enable;
    500            // Initialize ECC syndromes by using DMA to read and write the existing
    501            // data values in RAM.
    502            sli_hal_syscfg_ecc_read_write_existing_dma(ecc_bank->base, ecc_bank->size, dma_channels);
    503          #endif
    504          
    505            // Clear any ECC errors that may have been reported before or during
    506            // initialization.
    507          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    508            if (ecc_bank->base == ECC_RAM0_MEM_BASE) {
    509              ECC_IFC0_REG = ECC_IFC_MASK;
    510            } else if (ecc_bank->base == ECC_RAM1_MEM_BASE) {
    511              ECC_IFC1_REG = ECC_IFC_MASK;
    512            }
    513          #else
    514            ECC_IFC_REG = ECC_IFC_MASK;
    515          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
    516          
    517          #if !defined(_MPAHBRAM_CTRL_MASK)
    518            // Enable ECC decoder to detect and report ECC errors.
    519            ECC_CTRL_REG |= ecc_bank->correction_enable;
    520          #endif
    521          
    522            CORE_EXIT_CRITICAL();
    523          }
    524          
    525          /***************************************************************************//**
    526           * Disable ECC for a given memory bank.
    527           *
    528           * @param[in] ecc_bank ECC memory bank device structure.
    529           ******************************************************************************/
    530          static void sli_hal_syscfg_ecc_disable_bank(const sli_hal_syscfg_ecc_bank_t *ecc_bank)
    531          {
    532            EFM_ASSERT(ecc_bank != NULL);
    533          
    534          #if defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    535            // Disable ECC write (encoder) and checking (decoder).
    536            if (ecc_bank->base == ECC_RAM0_MEM_BASE) {
    537              ECC_CTRL0_REG &= ~(ecc_bank->init_syndrome_enable | ecc_bank->correction_enable);
    538            } else if (ecc_bank->base == ECC_RAM1_MEM_BASE) {
    539              ECC_CTRL1_REG &= ~(ecc_bank->init_syndrome_enable | ecc_bank->correction_enable);
    540            }
    541          #else
    542            ECC_CTRL_REG &= ~(ecc_bank->init_syndrome_enable | ecc_bank->correction_enable);
    543          #endif /* defined(DMEM_COUNT) && (DMEM_COUNT == 2) */
    544          }
