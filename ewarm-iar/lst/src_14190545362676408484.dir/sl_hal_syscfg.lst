     60          
     61          /// On Series 2 Config 2, aka EFR32XG22, ECC is supported for the
     62          /// main DMEM RAM banks which is controlled with one ECC encoder/decoder.
     63          #define ECC_RAM0_SYNDROMES_INIT (SYSCFG_DMEM0ECCCTRL_RAMECCEN)
