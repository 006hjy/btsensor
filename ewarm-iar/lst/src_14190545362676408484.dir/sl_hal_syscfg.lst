    572          #if defined(_SYSCFG_DMEM0PORTMAPSEL_MASK)
    573          /***************************************************************************//**
    574           * Set MPAHBRAM port to use to access DMEM.
    575           ******************************************************************************/
    576          void sl_hal_syscfg_set_dmem_port_map(sl_hal_syscfg_dmem_master_t master,
    577                                               uint8_t port)
    578          {
    579            // make sure master is within the mask of port map that can be changed
    580            // and make sure port is a sensible value.
    581            EFM_ASSERT(((1 << master) & _SYSCFG_DMEM0PORTMAPSEL_MASK) != 0x0);
    582          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    583            EFM_ASSERT(port < DMEM_NUM_PORTS);
    584          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    585            EFM_ASSERT(port < DMEM0_NUM_PORTS);
    586          #endif
    587          
    588          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    589            uint32_t bit_field_mask = DMEM_NUM_PORTS - 1;
    590          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    591            uint32_t bit_field_mask = DMEM0_NUM_PORTS - 1;
    592          #endif
    593          
    594            sl_hal_bus_reg_write_mask(&SYSCFG->DMEM0PORTMAPSEL,
    595                                      bit_field_mask << master,
    596                                      (uint32_t)port << master);
    597          }
    598          #endif
    599          
    600          #if defined(_MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK)
    601          /***************************************************************************//**
    602           * Set MPAHBRAM port priority for arbitration when multiple concurrent
    603           * transactions to DMEM.
    604           ******************************************************************************/
    605          void sl_hal_syscfg_set_port_priority(sl_hal_syscfg_port_priority_t port_priority)
    606          {
    607          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    608            EFM_ASSERT(port_priority < ((DMEM_NUM_PORTS + 1) << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT));
    609          
    610            sl_hal_bus_reg_write_mask(&DMEM->CTRL,
    611                                      _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
    612                                      (uint32_t)port_priority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    613          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    614            EFM_ASSERT(port_priority < ((DMEM0_NUM_PORTS + 1) << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT));
    615          
    616            sl_hal_bus_reg_write_mask(&DMEM0->CTRL,
    617                                      _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
    618                                      (uint32_t)port_priority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    619            sl_hal_bus_reg_write_mask(&DMEM1->CTRL,
    620                                      _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK,
    621                                      (uint32_t)port_priority << _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    622          #endif
    623          }
    624          
    625          /***************************************************************************//**
    626           * Get MPAHBRAM port arbitration priority selection.
    627           ******************************************************************************/
    628          sl_hal_syscfg_port_priority_t sl_hal_syscfg_get_port_priority(void)
    629          {
    630            uint32_t port = 0;
    631          
    632          #if defined(DMEM_COUNT) && (DMEM_COUNT == 1)
    633            port = sl_hal_bus_reg_read_mask(&DMEM->CTRL,
    634                                            _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK);
    635          #elif defined(DMEM_COUNT) && (DMEM_COUNT == 2)
    636            port = sl_hal_bus_reg_read_mask(&DMEM0->CTRL,
    637                                            _MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK);
    638          #endif
    639          
    640            return (sl_hal_syscfg_port_priority_t)(port >> _MPAHBRAM_CTRL_AHBPORTPRIORITY_SHIFT);
    641          }
    642          #endif /* if defined(_MPAHBRAM_CTRL_AHBPORTPRIORITY_MASK) */
