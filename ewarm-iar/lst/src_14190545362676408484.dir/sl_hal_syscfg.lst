    320          
    321            // Performs a read and write of all RAM address to initialize
    322            // ECC syndromes. ECC is initialized by reading a RAM address
    323            // while ECC is disabled and write it back while ECC is enabled.
    324            //
    325            // HardFault could occur if we try to read values from RAM while ECC
    326            // is enabled and not initialized. In this case, ECC tries to correct the
    327            // value and ended giving the wrong value which could be sometimes an
    328            // non-existing address.
    329            //
    330            // So for ECC initialization to work properly, this must ensures that while
    331            // ECC is enabled, RAM will be accessed only through writes, no reads shall
    332            // occur. It's hard to have such guarantee with C code, because the C
    333            // compiler with optimization settings, can get in the way
    334            // and do some unwanted reads while ECC is enabled. Assembly allows such
    335            // guarantee and let ECC be initialized without triggering errors.
    336          
    337            __asm__ volatile (
    338              "1:\n\t"                              // Define label 1.
    339              "LDR r1, [%[ram_ptr]]\n\t"            // Load content of ram_ptr into R1, ECC
    340                                                    //   is disabled to get a correct value.
    341              "LDR r0, [%[ctrl_reg]]\n\t"           // Load ctrl_reg content into R0
    342              "ORR r0, r0, %[enable_ecc]\n\t"       // OR R0 and enable_ecc, and store result
    343                                                    //   in R0
    344              "STR r0, [%[ctrl_reg]]\n\t"           // Write R0 into ctrl_reg, ECC is
    345                                                    //   enabled from now on
    346              "STR r1, [%[ram_ptr]]\n\t"            // Write back ram content where it was,
    347                                                    //  syndrome will be written in ECC
    348              "BIC r0, r0, %[enable_ecc]\n\t"       // Bit clear enable_ecc from R0, and store
    349                                                    //   result in R0.
    350              "STR r0, [%[ctrl_reg]]\n\t"           // Write R0 into ctrl_reg, ECC is
    351                                                    //   disabled.
    352              "ADDS %[ram_ptr], %[ram_ptr], #4\n\t" // Increment ram_ptr by 4 (size of
    353                                                    //   a word).
    354              "CMP %[ram_ptr], %[end_ptr]\n\t"      // Compare ram_ptr and end_ptr...
    355              "BCC 1b\n\t"                          //... and jump back to label 1 if Carry.
    356                                                    // Clear (meaning ram_ptr < end_ptr).
    357              "ORR r0, r0, %[enable_ecc]\n\t"       // And re-enable ECC ASAP to be sure no.
    358              "STR r0, [%[ctrl_reg]]\n\t"           // STR occurs with ECC disabled.
    359              :[ram_ptr] "+r" (ram_ptr)
    360              :[end_ptr] "r" (end_ptr),
    361              [ctrl_reg] "r" (ctrl_reg),
    362              [enable_ecc] "r" (enable_ecc)
    363              : "r0", "r1",                         // R0 and R1 used as temporary registers.
    364              "memory"                              // Memory pointed by ram_ptr is modified.
    365              );
