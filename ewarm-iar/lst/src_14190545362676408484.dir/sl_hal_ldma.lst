     88          /***************************************************************************//**
     89           * @brief
     90           *   Get LDMAXBAR by ldma instance
     91           *
     92           * @param[in] ldma
     93           *   This struct contains information about the LDMA register declaration.
     94           *
     95           * @return
     96           *   Struct contains information about the LDMAXBAR register declaration.
     97           ******************************************************************************/
     98          static __INLINE LDMAXBAR_TypeDef *sli_get_ldmaxbar_by_ldma_instance(LDMA_TypeDef *ldma)
     99          {
    100          #if defined(_SILICON_LABS_32B_SERIES_3)
    101            uint32_t ldma_instance_number = LDMA_NUM(ldma);
    102          
    103            LDMAXBAR_TypeDef * ldmaXbar_instance = LDMAXBAR(ldma_instance_number);
    104          
    105            // ldma instance is null of invalid.
    106            EFM_ASSERT((uint32_t)ldmaXbar_instance != 0x0UL);
    107          
    108            return ldmaXbar_instance;
    109          #else
    110            (void)*ldma;
    111            return LDMAXBAR;
    112          #endif
    113          }
