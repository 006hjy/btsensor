    534          #if defined(EUSART_DALICFG_DALIEN)
    535          /***************************************************************************//**
    536           * Transmit one DALI frame.
    537           ******************************************************************************/
    538          void sl_hal_eusart_dali_tx(EUSART_TypeDef *eusart, uint32_t data)
    539          {
    540            uint32_t packet;
    541          
    542            // Make sure the module exists on the selected chip.
    543            EFM_ASSERT(SL_HAL_EUSART_REF_VALID(eusart));
    544          
    545            while (!(eusart->STATUS & EUSART_STATUS_TXFL)) {
    546              // Check that transmit FIFO is not full.
    547            }
    548          
    549            // When DALICFG.DALIEN is set to 1, then all 16 bits [15:0] represent data.
    550            // First write to TXDATA register should contain 16 LSBs of the TX frame.
    551            // Transmission will not start after this first write.
    552            packet = data;
    553            // To ensure compatibility with future devices, always write bits [31:16] to 0.
    554            packet &= 0x0000FFFF;
    555            eusart->TXDATA = packet;
    556          
    557            // Second write to TXDATA register should contain the remaining TX frame bits.
    558            // This second write will result in start of transmission.
    559            if (dali_tx_nb_packets[EUSART_NUM(eusart)] == 2) {
    560              packet = data >> 16;
    561              eusart->TXDATA = packet;
    562            }
    563          }
    564          
    565          /***************************************************************************//**
    566           * Receive one DALI frame.
    567           ******************************************************************************/
    568          uint32_t sl_hal_eusart_dali_rx(EUSART_TypeDef *eusart)
    569          {
    570            uint32_t data = 0;
    571          
    572            // Make sure the module exists on the selected chip.
    573            EFM_ASSERT(SL_HAL_EUSART_REF_VALID(eusart));
    574          
    575            while (!(eusart->STATUS & EUSART_STATUS_RXFL)) {
    576              // Wait for incoming data.
    577            }
    578          
    579            // When DALICFG.DALIEN is set to 1, then all 16 bits [15:0] represent data.
    580            // When receiving a frame that has more than 16 databits,
    581            // RXDATA register needs to be read twice.
    582            // First read will provide 16 LSBs of the received frame.
    583            data |= (eusart->RXDATA & _EUSART_RXDATA_RXDATA_MASK);
    584          
    585            // Second read will provide the remaining RX frame bits.
    586            if (dali_rx_nb_packets[EUSART_NUM(eusart)] == 2) {
    587              data |= ((eusart->RXDATA & _EUSART_RXDATA_RXDATA_MASK) <<  16);
    588            }
    589            return data;
    590          }
    591          #endif /* EUSART_DALICFG_DALIEN */
