    594          /***************************************************************************//**
    595           * Set the number of bytes for the LIN response.
    596           ******************************************************************************/
    597          void sl_hal_eusart_set_lin_response_length(EUSART_TypeDef *eusart, uint8_t length_bytes)
    598          {
    599            EFM_ASSERT(SL_HAL_EUSART_REF_VALID(eusart));
    600          
    601            // The number of bytes for the response must be between 1 and 8.
    602            EFM_ASSERT(length_bytes > 0 && length_bytes <= 8);
    603          
    604            sl_hal_eusart_wait_sync(eusart, _EUSART_SYNCBUSY_DBYTE_MASK);
    605          
    606            eusart->LINCTRL = (eusart->LINCTRL & ~_EUSART_LINCTRL_DBYTE_MASK)
    607                              | ((uint32_t)(length_bytes - 1) << _EUSART_LINCTRL_DBYTE_SHIFT);
    608          }
    609          #endif
