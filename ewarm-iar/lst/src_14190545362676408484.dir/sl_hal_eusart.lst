    189          /***************************************************************************//**
    190           * Initializes the EUSART when used in DALI mode with the high or low
    191           * frequency clock.
    192           ******************************************************************************/
    193          void sl_hal_eusart_init_dali(EUSART_TypeDef *eusart,
    194                                       const sl_hal_eusart_dali_init_t *dali_init)
    195          {
    196            // Make sure the module exists on the selected chip.
    197            EFM_ASSERT(SL_HAL_EUSART_REF_VALID(eusart));
    198            // Init structure must be provided.
    199            EFM_ASSERT(dali_init);
    200          
    201            if (dali_init->eusart_init.loopback_enable) {
    202              // If LOOPBK in CFG0 is set to 1 in order to do loopback testing for DALI,
    203              // then in this case DALIRXENDT should be set to 1 and DALIRXDATABITS should
    204              // be set the same as DALITXDATABITS.
    205              EFM_ASSERT(dali_init->tx_data_bits == dali_init->rx_data_bits);
    206            }
    207          
    208            if (dali_init->dali_low_frequency_enable) {
    209              // Validate the low frequency capability of the EUSART instance.
    210              EFM_ASSERT(EUSART_EM2_CAPABLE(EUSART_NUM(eusart)));
    211              // The oversampling must be disabled when using a low frequency clock.
    212              EFM_ASSERT(dali_init->eusart_init.oversampling == SL_HAL_EUSART_OVS_0);
    213            } else {
    214              EFM_ASSERT(dali_init->eusart_init.oversampling != SL_HAL_EUSART_OVS_0);
    215            }
    216          
    217            // Initialize EUSART with common features to HF and LF.
    218            eusart_async_init_common(eusart, &dali_init->eusart_init);
    219          
    220            // DALI configuration.
    221            if (dali_init->eusart_init.loopback_enable) {
    222              // If LOOPBK in CFG0 is set to 1 in order to do loopback testing for DALI,
    223              // then in this case DALIRXENDT should be set to 1.
    224              eusart->DALICFG_SET = EUSART_DALICFG_DALIRXENDT;
    225            }
    226          
    227            if (SL_HAL_EUSART_REF_VALID(eusart)) {
    228              uint8_t index = EUSART_NUM(eusart);
    229          
    230              // keep track of the number of 16-bits packet to send
    231              if (dali_init->tx_data_bits <= SL_HAL_EUSART_DALI_DATA_BITS_16) {
    232                dali_tx_nb_packets[index] = 1;
    233              } else {
    234                dali_tx_nb_packets[index] = 2;
    235              }
    236          
    237              // keep track of the number of 16-bits packet to receive
    238              if (dali_init->rx_data_bits <= SL_HAL_EUSART_DALI_DATA_BITS_16) {
    239                dali_rx_nb_packets[index] = 1;
    240              } else {
    241                dali_rx_nb_packets[index] = 2;
    242              }
    243            }
    244          
    245            // Configure the numbers of bits per TX and RX frames
    246            eusart->DALICFG = (eusart->DALICFG & ~(_EUSART_DALICFG_DALITXDATABITS_MASK
    247                                                   | _EUSART_DALICFG_DALIRXDATABITS_MASK))
    248                              | (dali_init->tx_data_bits << _EUSART_DALICFG_DALITXDATABITS_SHIFT)
    249                              | (dali_init->rx_data_bits << _EUSART_DALICFG_DALIRXDATABITS_SHIFT);
    250            eusart->DALICFG_SET = EUSART_DALICFG_DALIEN;
    251          }
    252          #endif
