    270          #if defined(_EUSART_CFG0_SCMODE_MASK)
    271          /***************************************************************************//**
    272           * Initializes the EUSART when used in Smart Card mode with the high or low
    273           * frequency clock.
    274           ******************************************************************************/
    275          void sl_hal_eusart_init_smartcard(EUSART_TypeDef *eusart,
    276                                            const sl_hal_eusart_smartcard_init_t *smartcard_init)
    277          {
    278            // Make sure the module exists on the selected chip.
    279            EFM_ASSERT(SL_HAL_EUSART_REF_VALID(eusart));
    280            // Init structure must be provided.
    281            EFM_ASSERT(smartcard_init);
    282          
    283            // Smart Card mode is only available in asynchronous mode (SYNC = 0)
    284            // This is handled by the eusart_async_init_common() function
    285          
    286            if (smartcard_init->eusart_init.oversampling == SL_HAL_EUSART_OVS_0) {
    287              // Validate the low frequency capability of the EUSART instance.
    288              EFM_ASSERT(EUSART_EM2_CAPABLE(EUSART_NUM(eusart)));
    289              // Number of stop bits can only be 1 or 2 in LF.
    290              EFM_ASSERT((smartcard_init->eusart_init.stop_bits == SL_HAL_EUSART_STOP_BITS_1) || (smartcard_init->eusart_init.stop_bits == SL_HAL_EUSART_STOP_BITS_2));
    291            } else {
    292              EFM_ASSERT(smartcard_init->eusart_init.oversampling != SL_HAL_EUSART_OVS_0);
    293            }
    294          
    295            // Initialize EUSART with common features to HF and LF.
    296            eusart_async_init_common(eusart, &smartcard_init->eusart_init);
    297          
    298            // Loopback mode must be enabled in transmit mode.
    299            eusart->CFG0_SET = EUSART_CFG0_LOOPBK_ENABLE;
    300            // Configure Smart Card mode
    301            eusart->CFG0_SET = EUSART_CFG0_SCMODE;
    302          
    303            // Configure Smart Card retransmit if enabled
    304            if (smartcard_init->retransmit_enable == true) {
    305              eusart->CFG0_SET = EUSART_CFG0_SCRETRANS;
    306            }
    307          }
    308          #endif
    309          
    310          #if defined(_EUSART_LINCFG_MASK)
    311          /***************************************************************************//**
    312           * Initializes the EUSART when used in LIN mode with the high or low
    313           * frequency clock.
    314           ******************************************************************************/
    315          void sl_hal_eusart_init_lin(EUSART_TypeDef *eusart,
    316                                      const sl_hal_eusart_lin_init_t *lin_init)
    317          {
    318            // Make sure the module exists on the selected chip.
    319            EFM_ASSERT(SL_HAL_EUSART_REF_VALID(eusart));
    320            // Init structure must be provided.
    321            EFM_ASSERT(lin_init);
    322          
    323            // Initialize EUSART with common features to HF and LF.
    324            eusart_async_init_common(eusart, &lin_init->eusart_init);
    325          
    326            // Loopback mode and auto-baud must be enabled in transmit mode.
    327            eusart->CFG0_SET = EUSART_CFG0_LOOPBK_ENABLE | EUSART_CFG0_AUTOBAUDEN;
    328            // Configure LIN mode.
    329            eusart->LINCFG_SET = EUSART_LINCFG_LINEN;
    330          #if defined(_EUSART_CFG3_BREAKTIMEOUT_MASK)
    331            // Configure CFG3.
    332            eusart->CFG3 = (eusart->CFG3 & ~(_EUSART_CFG3_BREAKTIMEOUT_MASK))
    333                           | ((uint32_t)lin_init->break_timeout << _EUSART_CFG3_BREAKTIMEOUT_SHIFT);
    334          #endif
    335          }
    336          #endif
