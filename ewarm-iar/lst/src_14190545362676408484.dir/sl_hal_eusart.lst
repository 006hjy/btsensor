   1191          /***************************************************************************//**
   1192           *  Map oversampling enum value to ovesampling real value.
   1193           *
   1194           * @param[in] ref_freq Peripheral clock frequency.
   1195           * @param[in] baudrate Transmission speed.
   1196           * @param[in] ovs Oversampling rate.
   1197           *
   1198           * @return Real ovesampling value.
   1199           ******************************************************************************/
   1200          static uint8_t eusart_map_oversampling(uint32_t ref_freq,
   1201                                                 uint32_t baudrate,
   1202                                                 sl_hal_eusart_ovs_t ovs)
   1203          {
   1204            uint8_t oversample = 0;
   1205            // Map oversampling.
   1206            switch (ovs) {
   1207              case SL_HAL_EUSART_OVS_16:
   1208                EFM_ASSERT(baudrate <= (ref_freq / 16));
   1209                oversample = 16;
   1210                break;
   1211          
   1212              case SL_HAL_EUSART_OVS_8:
   1213                EFM_ASSERT(baudrate <= (ref_freq / 8));
   1214                oversample = 8;
   1215                break;
   1216          
   1217              case SL_HAL_EUSART_OVS_6:
   1218                EFM_ASSERT(baudrate <= (ref_freq / 6));
   1219                oversample = 6;
   1220                break;
   1221          
   1222              case SL_HAL_EUSART_OVS_4:
   1223                EFM_ASSERT(baudrate <= (ref_freq / 4));
   1224                oversample = 4;
   1225                break;
   1226          
   1227              case SL_HAL_EUSART_OVS_0:
   1228                EFM_ASSERT(ref_freq >= (3 * baudrate));
   1229                oversample = 1;
   1230                break;
   1231          
   1232              default:
   1233                // Invalid input
   1234                EFM_ASSERT(0);
   1235                break;
   1236            }
   1237          
   1238            return oversample;
   1239          }
   1240          #endif /* defined(EUSART_PRESENT) */

