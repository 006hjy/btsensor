    255          /***************************************************************************//**
    256           * Initializes the EUSART when used in SPI mode.
    257           ******************************************************************************/
    258          void sl_hal_eusart_init_spi(EUSART_TypeDef *eusart,
    259                                      const sl_hal_eusart_spi_init_t *spi_init)
    260          {
    261            // Make sure the module exists on the selected chip.
