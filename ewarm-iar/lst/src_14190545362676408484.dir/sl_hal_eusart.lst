   1157                                                      SL_HAL_PRS_TYPE_ASYNC,
   1158                                                      SL_HAL_PRS_CONSUMER_EUSART1_CLK);
   1159                }
   1160          #endif
   1161          #if defined(EUSART2)
   1162                else if (eusart == EUSART2) {
   1163                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_clock_channel,
   1164                                                      SL_HAL_PRS_TYPE_ASYNC,
