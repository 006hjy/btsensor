    854          /***************************************************************************//**
    855           * Calculate the baudrate from the clkdiv value and the clock branch frequency
    856           ******************************************************************************/
    857          uint32_t sl_hal_eusart_spi_calculate_baudrate(uint32_t div, uint32_t freq)
    858          {
    859            // Prevent dividing by 0.
    860            EFM_ASSERT(freq);
    861          
    862            return freq / (div + 1);
    863          }
