   1025          /***************************************************************************//**
   1026           * Initializes the EUSART with synchronous common settings to high
   1027           * and low frequency clock.
   1028           *
   1029           * @param[in] eusart Pointer to the EUSART peripheral register block.
   1030           * @param[in] init A pointer to the initialization structure.
   1031           ******************************************************************************/
   1032          static void eusart_sync_init_common(EUSART_TypeDef *eusart,
   1033                                              const sl_hal_eusart_spi_init_t *init)
   1034          {
   1035            // Initialize EUSART registers to hardware reset state.
   1036            sl_hal_eusart_reset(eusart);
   1037          
   1038            // Configure global configuration register 2.
   1039            eusart->CFG2 = (eusart->CFG2 & ~(_EUSART_CFG2_MASTER_MASK
   1040                                             | _EUSART_CFG2_CLKPOL_MASK
   1041                                             | _EUSART_CFG2_CLKPHA_MASK
   1042                                             | _EUSART_CFG2_FORCELOAD_MASK))
   1043                           | ((uint32_t)init->master << _EUSART_CFG2_MASTER_SHIFT)
   1044                           | ((uint32_t)init->clock_mode << _EUSART_CFG2_CLKPOL_SHIFT)
   1045                           | EUSART_CFG2_FORCELOAD;   // Force load feature enabled by default.
   1046          
   1047            eusart->CFG0 = (eusart->CFG0 & ~(_EUSART_CFG0_SYNC_MASK
   1048                                             | _EUSART_CFG0_LOOPBK_MASK))
   1049                           | _EUSART_CFG0_SYNC_SYNC
   1050                           | (uint32_t)(init->loopback_enable << _EUSART_CFG0_LOOPBK_SHIFT);
   1051          
   1052            // Configure frame format
   1053            eusart->FRAMECFG = (eusart->FRAMECFG & ~(_EUSART_FRAMECFG_DATABITS_MASK))
   1054                               | (uint32_t)(init->data_bits << _EUSART_FRAMECFG_DATABITS_SHIFT);
   1055          
   1056            // Set clock divider for synchronous operation mode.
   1057            eusart->CFG2 = (eusart->CFG2 & ~(_EUSART_CFG2_SDIV_MASK))
   1058                           | ((init->clock_div << _EUSART_CFG2_SDIV_SHIFT) & _EUSART_CFG2_SDIV_MASK);
   1059          
   1060            if (init->advanced_config) {
   1061              // Configure global configuration register 2.
   1062              eusart->CFG2 = (eusart->CFG2 & ~(_EUSART_CFG2_FORCELOAD_MASK
   1063                                               | _EUSART_CFG2_AUTOCS_MASK
   1064                                               | _EUSART_CFG2_AUTOTX_MASK
   1065                                               | _EUSART_CFG2_CSINV_MASK
   1066                                               | _EUSART_CFG2_CLKPRSEN_MASK))
   1067                             | ((uint32_t)init->advanced_config->force_load << _EUSART_CFG2_FORCELOAD_SHIFT)
   1068                             | ((uint32_t)init->advanced_config->auto_cs_enable << _EUSART_CFG2_AUTOCS_SHIFT)
   1069                             | ((uint32_t)init->advanced_config->auto_tx_enable << _EUSART_CFG2_AUTOTX_SHIFT)
   1070                             | ((uint32_t)init->advanced_config->cs_polarity << _EUSART_CFG2_CSINV_SHIFT)
   1071                             | ((uint32_t)init->advanced_config->prs_clock_enable << _EUSART_CFG2_CLKPRSEN_SHIFT);
   1072          
   1073              // Only applicable to EM2 (low frequency) capable EUSART instances.
   1074              eusart->CFG1 = (eusart->CFG1 & ~(_EUSART_CFG1_RXFIW_MASK
   1075                                               | _EUSART_CFG1_TXFIW_MASK))
   1076                             | ((uint32_t)init->advanced_config->rx_fifo_watermark << _EUSART_CFG1_RXFIW_SHIFT)
   1077                             | ((uint32_t)init->advanced_config->tx_fifo_watermark << _EUSART_CFG1_TXFIW_SHIFT)
   1078          #if defined(_EUSART_CFG1_RXDMAWU_SHIFT)
   1079                             | ((uint32_t)init->advanced_config->dma_wakeup_on_rx << _EUSART_CFG1_RXDMAWU_SHIFT)
   1080          #endif
   1081                             | ((uint32_t)init->advanced_config->prs_rx_enable << _EUSART_CFG1_RXPRSEN_SHIFT);
   1082          
   1083              eusart->CFG0 = (eusart->CFG0 & ~(_EUSART_CFG0_RXINV_MASK
   1084                                               | _EUSART_CFG0_TXINV_MASK))
   1085                             | (uint32_t)(init->advanced_config->invert_io << _EUSART_CFG0_RXINV_SHIFT);
   1086              eusart->CFG0_SET = (uint32_t)init->advanced_config->msb_first << _EUSART_CFG0_MSBF_SHIFT;
   1087          
   1088              // Configure global configuration Timing register.
   1089              eusart->TIMINGCFG = (eusart->TIMINGCFG & ~(_EUSART_TIMINGCFG_CSSETUP_MASK
   1090                                                         | _EUSART_TIMINGCFG_CSHOLD_MASK
   1091                                                         | _EUSART_TIMINGCFG_ICS_MASK
   1092                                                         | _EUSART_TIMINGCFG_SETUPWINDOW_MASK
   1093                                                         | _EUSART_TIMINGCFG_TXDELAY_MASK))
   1094                                  | ((uint32_t)(init->advanced_config->auto_cs_setup_time << _EUSART_TIMINGCFG_CSSETUP_SHIFT)
   1095                                     & _EUSART_TIMINGCFG_CSSETUP_MASK)
   1096                                  | ((uint32_t)(init->advanced_config->auto_cs_hold_time << _EUSART_TIMINGCFG_CSHOLD_SHIFT)
   1097                                     & _EUSART_TIMINGCFG_CSHOLD_MASK)
   1098                                  | ((uint32_t)(init->advanced_config->auto_inter_frame_time << _EUSART_TIMINGCFG_ICS_SHIFT)
   1099                                     & _EUSART_TIMINGCFG_ICS_MASK)
   1100                                  | ((uint32_t)(init->advanced_config->setup_window << _EUSART_TIMINGCFG_SETUPWINDOW_SHIFT)
   1101                                     & _EUSART_TIMINGCFG_SETUPWINDOW_MASK)
   1102                                  | ((uint32_t)(init->advanced_config->auto_tx_delay << _EUSART_TIMINGCFG_TXDELAY_SHIFT)
   1103                                     & _EUSART_TIMINGCFG_TXDELAY_MASK);
   1104          
   1105              eusart->DTXDATCFG = (init->advanced_config->default_tx_data & _EUSART_DTXDATCFG_MASK);
   1106          #if defined(SL_HAL_EUSART_PRS_SUPPORTED)
   1107              if (init->advanced_config->prs_rx_enable) {
   1108                // Configure PRS channel as input data line for EUSART.
   1109                if (eusart == EUSART0) {
   1110                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_rx_channel,
   1111                                                      SL_HAL_PRS_TYPE_ASYNC,
   1112                                                      SL_HAL_PRS_CONSUMER_EUSART0_RX);
   1113                }
   1114          #if defined(EUSART1)
   1115                else if (eusart == EUSART1) {
   1116                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_rx_channel,
   1117                                                      SL_HAL_PRS_TYPE_ASYNC,
   1118                                                      SL_HAL_PRS_CONSUMER_EUSART1_RX);
   1119                }
   1120          #endif
   1121          #if defined(EUSART2)
   1122                else if (eusart == EUSART2) {
   1123                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_rx_channel,
   1124                                                      SL_HAL_PRS_TYPE_ASYNC,
   1125                                                      SL_HAL_PRS_CONSUMER_EUSART2_RX);
   1126                }
   1127          #endif
   1128          #if defined(EUSART3)
   1129                else if (eusart == EUSART3) {
   1130                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_rx_channel,
   1131                                                      SL_HAL_PRS_TYPE_ASYNC,
   1132                                                      SL_HAL_PRS_CONSUMER_EUSART3_RX);
   1133                }
   1134          #endif
   1135          #if defined(EUSART4)
   1136                else if (eusart == EUSART4) {
   1137                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_rx_channel,
   1138                                                      SL_HAL_PRS_TYPE_ASYNC,
   1139                                                      SL_HAL_PRS_CONSUMER_EUSART4_RX);
   1140                }
   1141          #endif
   1142                else {
   1143                  EFM_ASSERT(false);
   1144                }
   1145              }
   1146          
   1147              if (init->advanced_config->prs_clock_enable) {
   1148                // Configure PRS channel as SCLK input for EUSART.
   1149                if (eusart == EUSART0) {
   1150                  sl_hal_prs_connect_channel_consumer(init->advanced_config->prs_clock_channel,
   1151                                                      SL_HAL_PRS_TYPE_ASYNC,
   1152                                                      SL_HAL_PRS_CONSUMER_EUSART0_CLK);
   1153                }
   1154          #if defined(EUSART1)
