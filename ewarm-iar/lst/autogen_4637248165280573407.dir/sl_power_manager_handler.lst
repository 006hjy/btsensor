     24          
     25          /***************************************************************************//**
     26           * Check if the MCU can sleep after an interrupt. This function is called after an
     27           * interrupt occured and was processed. It allows the power manger to know if it must
     28           * go back to sleep or wakeup.
     29           *
     30           * @return  SL_POWER_MANAGER_IGNORE, if the module did not trigger an ISR and it
     31           *          won't to contribute to the decision.
     32           *
     33           *          SL_POWER_MANAGER_SLEEP, The module was the one that caused the system
     34           *          wakeup and the system SHOULD go back to sleep.
     35           *
     36           *          SL_POWER_MANAGER_WAKEUP, The module was the one that caused the system
     37           *          wakeup and the system MUST NOT go back to sleep.
     38           *
     39           * @note  This function must not have any side effects. It is not guaranteed to be
     40           *        called for every ISR. If a prior hook function requires to wakeup, such
     41           *        as a wireless stack, the application hook function won't be called.
     42           ******************************************************************************/
     43           SL_CODE_CLASSIFY(SL_CODE_COMPONENT_POWER_MANAGER, SL_CODE_CLASS_TIME_CRITICAL)

