     25          
     26          /***************************************************************************//**
     27           * Check if the MCU can sleep after an interrupt. This function is called after an
     28           * interrupt occured and was processed. It allows the power manger to know if it must
     29           * go back to sleep or wakeup.
     30           *
     31           * @return  SL_POWER_MANAGER_IGNORE, if the module did not trigger an ISR and it
     32           *          won't to contribute to the decision.
     33           *
     34           *          SL_POWER_MANAGER_SLEEP, The module was the one that caused the system
     35           *          wakeup and the system SHOULD go back to sleep.
     36           *
     37           *          SL_POWER_MANAGER_WAKEUP, The module was the one that caused the system
     38           *          wakeup and the system MUST NOT go back to sleep.
     39           *
     40           * @note  This function must not have any side effects. It is not guaranteed to be
     41           *        called for every ISR. If a prior hook function requires to wakeup, such
     42           *        as a wireless stack, the application hook function won't be called.
     43           ******************************************************************************/
     44           SL_CODE_CLASSIFY(SL_CODE_COMPONENT_POWER_MANAGER, SL_CODE_CLASS_TIME_CRITICAL)

