     42          #include <sys/reent.h>
     43          
     44          // Wrapping a system function with GCC works by using the linker option '--wrap=symbol'.
     45          // Any undefined reference to "symbol" will be resolved to "__wrap_symbol".
     46          // Any undefined reference to "__real_symbol" will be resolved to "symbol".
     47          // In our case, "__real_symbol" is not really required as the retargeted standard
     48          // C memory functions will call the corresponding Memory Manager (MM)
     49          // native function and not the standard functions again. So it should be seen:
     50          // standard _malloc_r()  -> MM sl_malloc()
     51          // standard _free_r()    -> MM sl_free()
     52          // standard _calloc_r()  -> MM sl_calloc()
     53          // standard _realloc_r() -> MM sl_realloc()
     54          #define STD_LIB_WRAPPER_MALLOC  __wrap__malloc_r
     55          #define STD_LIB_WRAPPER_FREE    __wrap__free_r
     56          #define STD_LIB_WRAPPER_CALLOC  __wrap__calloc_r
     57          #define STD_LIB_WRAPPER_REALLOC __wrap__realloc_r
     58          
     59          // The GNU gold linker has an issue with LTO and wrapping, where the symbol is
     60          // stripped even if it is used in the source code, which leads to link-time errors.
     61          // https://sourceware.org/bugzilla/show_bug.cgi?id=24415
     62          // By marking the wrapper as externally_visible, the symbol will not be stripped
     63          // from the final binary, regardless if it is referenced or not in the source code.
     64          #if !defined(__clang__)
     65          #define ATTR_EXT_VIS    __attribute__((externally_visible))
     66          #else
     67          // The 'externally_visible' attribute is not supported by clang, but the 'used'
     68          // attribute has a similar effect in preventing the compiler from stripping symbols.
     69          // However, for this wrapper, we can leave it empty for clang.
     70          #define ATTR_EXT_VIS
     71          #endif
     72          
     73          // Reentrant parameter.
     74          #define RARG            const struct _reent *reent,
     75          #define VOID_RARG       (void) reent
     76          
     77          #elif defined(__IAR_SYSTEMS_ICC__)
     78          // Wrapping a system function works with IAR by patching symbol definitions using $Super$$ and $Sub$$
     79          // The $Super$$ special pattern identifies the original unpatched function used for calling
     80          // the original function directly.
     81          // The $Sub$$ special pattern identifies the new function that is called instead of the
     82          // original function.
     83          // In our case, $Super$$ is not really required as the retargeted standard
     84          // C memory functions will call the corresponding Memory Manager (MM)
     85          // native function and not the standard functions again.
     86          //
     87          // NOTE: IAR supports three separate heap memory handlers: the basic, the advanced, and the no-free
     88          //       heap handlers.
     89          //       - If there are calls to heap memory allocation routines in your application, but no calls
     90          //         to heap deallocation routines, the linker automatically chooses the no-free heap.
     91          //       - If there are calls to heap memory allocation routines in your application, the linker
     92          //         automatically chooses the advanced heap.
     93          //       - If there are calls to heap memory allocation routines in a library for example, the linker
     94          //         automatically chooses the basic heap.
     95          //
     96          //       Depending on the heap handler type, IAR will select a different malloc/free/calloc/realloc
     97          //       implementation provided by the IAR system library. That's why, there are different sets of
     98          //       macros below below to wrap the right IAR standard memory functions with $Sub$$.
     99          //       - Basic heap:    IAR memory functions are prefixed with "basic_"
    100          //       - Advanced heap: IAR memory functions are prefixed with "dl"
    101          //       - No Free heap:  IAR memory functions are prefixed with "no_free"
    102          //
    103          //       For No Free heap, IAR does not provide a free and realloc implementation.
    104          #if (__VER__ == 8050009)
    105          #define STD_LIB_WRAPPER_MALLOC  $Sub$$__iar_dlmalloc
    106          #define STD_LIB_WRAPPER_FREE    $Sub$$__iar_dlfree
    107          #define STD_LIB_WRAPPER_CALLOC  $Sub$$__iar_dlcalloc
    108          #define STD_LIB_WRAPPER_REALLOC $Sub$$__iar_dlrealloc
    109          #elif (__VER__ == 9040001) || (__VER__ == 9060004) || (__VER__ == 9070004)
    110          #define STD_LIB_WRAPPER_MALLOC  $Sub$$__basic_malloc
    111          #define STD_LIB_WRAPPER_FREE    $Sub$$__basic_free
    112          #define STD_LIB_WRAPPER_CALLOC  $Sub$$__basic_calloc
    113          #define STD_LIB_WRAPPER_REALLOC $Sub$$__basic_realloc
    114          
    115          #define STD_LIB_WRAPPER_MALLOC_ADVANCED  $Sub$$__iar_dlmalloc
    116          #define STD_LIB_WRAPPER_FREE_ADVANCED    $Sub$$__iar_dlfree
    117          #define STD_LIB_WRAPPER_CALLOC_ADVANCED  $Sub$$__iar_dlcalloc
    118          #define STD_LIB_WRAPPER_REALLOC_ADVANCED $Sub$$__iar_dlrealloc
    119          
    120          #define STD_LIB_WRAPPER_MALLOC_NO_FREE  $Sub$$__no_free_malloc
    121          #define STD_LIB_WRAPPER_CALLOC_NO_FREE  $Sub$$__no_free_calloc
    122          #else
    123          #error Unsupported IAR compiler version for standard C memory functions retarget
    124          #endif
    125          
    126          // Since IAR does not use LTO, resolve the attribute as nothing.
    127          #define ATTR_EXT_VIS
    128          
    129          // Since IAR does not use reentrant functions, resolve reentrant parameter to nothing.
    130          #define RARG
    131          #define VOID_RARG
    132          
    133          #else
    134          #error Unsupported compiler for standard C memory functions retarget
    135          #endif
    136          
    137          #if defined(TEST_MEMORY_MANAGER_RETARGET_PRESENT)
    138          volatile uint32_t retarget_malloc_counter = 0;
    139          volatile uint32_t retarget_free_counter = 0;
    140          volatile uint32_t retarget_calloc_counter = 0;
    141          volatile uint32_t retarget_realloc_counter = 0;
    142          #endif
