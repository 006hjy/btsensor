    148          /***************************************************************************//**
    149           * malloc() wrapper. Allocates a memory block of at least requested size from
    150           * the heap.
    151           *
    152           * @param[in] size  Size of the block, in bytes.
    153           *
    154           * @return    Pointer to allocated block if successful. Null pointer if
    155           *            allocation failed.
    156           *
    157           * @note Requesting a block of 0 byte will return a null pointer.
    158           *
    159           * @note All allocated blocks using this function will be considered long-term
    160           *       allocations.
    161           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    162          ATTR_EXT_VIS void *STD_LIB_WRAPPER_MALLOC(RARG
    163                                                    size_t size)
    164          {
    165          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    166            void * volatile return_address = sli_memory_profiler_get_return_address();
    167          #endif
    168            VOID_RARG;
    169            void *ptr;
    170          
    171            ptr = sl_malloc(size);
    172          #if defined(TEST_MEMORY_MANAGER_RETARGET_PRESENT)
    173            retarget_malloc_counter++;
    174          #endif
    175          
    176          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    177            sli_memory_profiler_track_ownership(SLI_INVALID_MEMORY_TRACKER_HANDLE,
    178                                                ptr,
    179                                                return_address);
    180          #endif
    181          
    182            return ptr;
   \                     `$Sub$$__basic_malloc`: (+1)
   \        0x0   0x.... 0x....      B.W      sl_malloc
    183          }
    184          
    185          #if defined(__IAR_SYSTEMS_ICC__) && (__VER__ == 9040001)
    186          void *STD_LIB_WRAPPER_MALLOC_ADVANCED(size_t size)
    187          {
    188          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    189            void * volatile return_address = sli_memory_profiler_get_return_address();
    190          #endif
    191            void *ptr;
    192          
    193            ptr = sl_malloc(size);
    194          
    195          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    196            sli_memory_profiler_track_ownership(SLI_INVALID_MEMORY_TRACKER_HANDLE,
    197                                                ptr,
    198                                                return_address);
    199          #endif
    200          
    201            return ptr;
    202          }
    203          
    204          void *STD_LIB_WRAPPER_MALLOC_NO_FREE(size_t size)
    205          {
    206          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    207            void * volatile return_address = sli_memory_profiler_get_return_address();
    208          #endif
