    223          /***************************************************************************//**
    224           * free() wrapper. Frees a previously allocated block back into the heap.
    225           *
    226           * @param[in] ptr   Pointer to memory block to be freed.
    227           *
    228           * @note Passing a null pointer does nothing.
    229           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    230          ATTR_EXT_VIS void STD_LIB_WRAPPER_FREE(RARG
    231                                                 void *ptr)
    232          {
    233            VOID_RARG;
    234            sl_free(ptr);
   \                     `$Sub$$__basic_free`: (+1)
   \        0x0   0x.... 0x....      B.W      sl_free
    235          #if defined(TEST_MEMORY_MANAGER_RETARGET_PRESENT)
    236            retarget_free_counter++;
    237          #endif
    238          }
    239          
    240          #if defined(__IAR_SYSTEMS_ICC__) && (__VER__ == 9040001)
    241          void STD_LIB_WRAPPER_FREE_ADVANCED(void *ptr)
    242          {
    243            sl_free(ptr);
    244          }
    245          #endif
