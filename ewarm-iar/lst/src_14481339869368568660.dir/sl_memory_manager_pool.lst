     46          /*******************************************************************************
     47           *********************************   DEFINES   *********************************
     48           ******************************************************************************/
     49          
     50          #define SLI_MEM_POOL_OUT_OF_MEMORY     UINTPTR_MAX
     51          #define SLI_MEM_POOL_REQUIRED_PADDING(obj_size) (((sizeof(size_t) - ((obj_size) % sizeof(size_t))) % sizeof(size_t)))
     52          
     53          #if (defined(SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE) && (SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE == 1))
     54          /***************************************************************************//**
     55           * Checks if a value looks like a valid free list pointer.
     56           * Used as a quick O(1) pre-check for double-free detection.
     57           *
     58           * A value looks like a free list pointer if it's either:
     59           * - The end-of-list marker (SLI_MEM_POOL_OUT_OF_MEMORY), OR
     60           * - A block-aligned address within the pool's memory range
     61           *
     62           * @param[in] pool_handle  Pointer to the memory pool handle.
     63           * @param[in] value        The value to check.
     64           *
     65           * @return true if value looks like it could be a free list pointer.
     66           ******************************************************************************/
     67          static inline bool sli_looks_like_free_list_ptr(const sl_memory_pool_t *pool_handle,
     68                                                          size_t value)
     69          {
     70            // Check for end-of-list marker.
     71            if (value == SLI_MEM_POOL_OUT_OF_MEMORY) {
     72              return true;
     73            }
     74          
     75            // Check if it points within the pool's block range.
     76            size_t pool_start = (size_t)pool_handle->block_address;
     77            size_t pool_end = pool_start + (pool_handle->block_size * pool_handle->block_count);
     78          
     79            if ((value >= pool_start) && (value < pool_end)) {
     80              // Must be aligned to a block boundary.
     81              size_t offset = value - pool_start;
     82              return (offset % pool_handle->block_size) == 0;
     83            }
     84          
     85            return false;
     86          }
     87          
     88          /***************************************************************************//**
     89           * Checks if a block is in the free list by walking the list.
     90           * Used as O(n) verification when the quick check is suspicious.
     91           *
     92           * @param[in] pool_handle  Pointer to the memory pool handle.
     93           * @param[in] block        The block address to search for.
     94           *
     95           * @return true if block is found in the free list (already freed).
     96           *
     97           * @note Must be called within an atomic section.
     98           ******************************************************************************/
     99          static bool sli_block_is_in_free_list(const sl_memory_pool_t *pool_handle,
    100                                                const void *block)
    101          {
    102            void *current = pool_handle->block_free;
    103          
    104            while ((size_t)current != SLI_MEM_POOL_OUT_OF_MEMORY) {
    105              if (current == block) {
    106                return true;
    107              }
    108              // Follow the free list to the next block.
    109              current = (void *)*(size_t *)current;
    110            }
    111          
    112            return false;
    113          }
    114          #endif // (defined(SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE) && (SL_MEMORY_MANAGER_POOL_DOUBLE_FREE_PROTECTION_ENABLE == 1))
