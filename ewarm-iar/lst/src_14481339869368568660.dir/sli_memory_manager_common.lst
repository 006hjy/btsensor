     85          /***************************************************************************//**
     86           * Gets the index in sli_reservation_handle_ptr_table[] by block address.
     87           *
     88           * @param[in]  addr  Pointer to block reservation.
     89           *
     90           * @return    Corresponding index in sli_reservation_handle_ptr_table.
     91           ******************************************************************************/
     92          static uint32_t get_reservation_ix_by_addr(void *addr)
     93          {
     94            for (uint32_t ix = 0; ix < SLI_MAX_RESERVATION_COUNT; ix++) {
     95              if (sli_reservation_handle_ptr_table[ix] == NULL) {
     96                continue;
     97              }
     98              if (sli_reservation_handle_ptr_table[ix]->block_address == addr) {
     99                return ix;
    100              }
    101            }
    102            return -1;
    103          }
    104          
    105          /***************************************************************************//**
    106           * Gets the index in sli_reservation_handle_ptr_table[]
    107           * by reservation handle pointer.
    108           *
    109           * @param[in]  reservation_handle_ptr  Pointer to reservation handle.
    110           *
    111           * @return    Corresponding index in sli_reservation_handle_ptr_table.
    112           ******************************************************************************/
    113          static uint32_t get_reservation_ix_by_handle(sl_memory_reservation_t *reservation_handle_ptr)
    114          {
    115            for (uint32_t ix = 0; ix < SLI_MAX_RESERVATION_COUNT; ix++) {
    116              if (sli_reservation_handle_ptr_table[ix] == NULL) {
    117                continue;
    118              }
    119              if (sli_reservation_handle_ptr_table[ix] == reservation_handle_ptr) {
    120                return ix;
    121              }
    122            }
    123            return -1;
    124          }
    125          
    126          /***************************************************************************//**
    127           * Get an index of sli_reservation_handle_ptr_table that is free.
    128           *
    129           * @return    Index of an empty entry in sli_reservation_handle_ptr_table.
    130           ******************************************************************************/
    131          uint32_t sli_get_available_reservation_handle_ix(void)
    132          {
    133            for (uint32_t ix = 0; ix < SLI_MAX_RESERVATION_COUNT; ix++) {
    134              if (sli_reservation_handle_ptr_table[ix] == NULL) {
    135                return ix;
    136              }
    137            }
    138            return -1;
    139          }
    140          
    141          /***************************************************************************//**
