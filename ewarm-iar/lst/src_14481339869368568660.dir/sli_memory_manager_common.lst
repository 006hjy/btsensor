    145           *
    146           * @return    Corresponding index in sli_reservation_no_retention_table[].
    147           ******************************************************************************/
    148          static uint32_t get_reservation_no_retention_ix(void *addr)
    149          {
    150            for (uint32_t ix = 0; ix < SLI_MAX_RESERVATION_COUNT; ix++) {
    151              if (sli_reservation_no_retention_table[ix].block_address == NULL) {
