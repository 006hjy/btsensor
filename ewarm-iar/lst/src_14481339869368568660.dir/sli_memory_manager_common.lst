    594          /***************************************************************************//**
    595           * Does a heap integrity check forwards from the general-purpose heap free_lt_list_head
    596           * and return the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    597           * This could go past reservations so there are checks.
    598           *
    599           * @return    Pointer to the corrupted sli_block_metadata_t{}.
    600           ******************************************************************************/
    601          sli_block_metadata_t *sli_memory_check_general_purpose_heap_integrity_forwards(void)
    602          {
    603            return sli_memory_check_heap_integrity_forwards(&sli_general_purpose_heap);
    604          }
    605          
    606          /***************************************************************************//**
    607           * Does a heap integrity check forwards from the general-purpose heap and return
    608           * the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    609           * This could go past reservations so there are checks.
    610           *
    611           * @note: Here are a few typical heap layout patterns that can be checked:
    612           *
    613           * Meta(LT1)|Payload(LT1)|Meta(LT2)|Payload(LT2)|Meta(free1)|Payload(free1)||
    614           * Meta(LT1)|Payload(LT1)|Meta(free1)|Payload(free1)|Meta(ST1)|Payload(ST1)||
    615           * Meta(RH1)|Payload(RH1)|Meta(free1)|Payload(free1)|Payload(R1)||
    616           * Meta(RH1)|Payload(RH1)|Meta(free1)|Payload(free1)|Payload(R1)|Payload(RNR1)||
    617           * Meta(RH1)|Payload(RH1)|Meta(LT1)|Payload(LT1)|Meta(free1)|Payload(free1)|Payload(R1)|Payload(RNR1)||
    618           * Meta(RH1)|Payload(RH1)|Meta(LT1)|Payload(LT1)|Meta(free1)|Payload(free1)|Meta(ST1)|Payload(ST1)|Payload(R1)|Payload(RNR1)||
    619           *
    620           * Legend of heap layouts:
    621           *    LT1 = allocated long-term block, ST1 = allocated short-term block
    622           *    RH1 = reservation handle, R1 = reserved block
    623           *    RNR1 = reserved block with no retention
    624           *    free1 = free block
    625           *    || = real end of heap
    626           ******************************************************************************/
    627          sli_block_metadata_t *sli_memory_check_heap_integrity_forwards(sl_memory_heap_t *heap)
    628          {
    629            uint64_t *heap_end_by_metadata = NULL;
    630            uint32_t is_corrupted = 0;
    631            sli_block_metadata_t *current = (sli_block_metadata_t *)heap->free_lt_list_head;
    632            sl_memory_region_t heap_region = sl_memory_get_heap_region();
    633            uint32_t reservation_size = 0;
    634          
    635            while (current != NULL) {
    636              // Reached last block in heap.
    637              if (sli_block_offset_next_dword_decode(current) == 0) {
    638                heap_end_by_metadata = (uint64_t *)current + sli_block_len_dword_decode(current) + SLI_BLOCK_METADATA_SIZE_DWORD;
    639          
    640                // Check if reservation (one or more).
    641                while ((reservation_size = sli_memory_get_reservation_size_by_addr((void *)heap_end_by_metadata)) != 0) {
    642                  heap_end_by_metadata = (uint64_t *)((uint8_t *)heap_end_by_metadata + reservation_size);
    643                }
    644          
    645                // Check if reservation no retention (one or more) if heap end is at the end of the DMEM.
    646                if ((uint64_t *)heap->base_addr + heap->size == (uint64_t *)heap_region.addr + heap_region.size) {
    647                  while ((reservation_size = sli_memory_get_reservation_no_retention_size((void *)heap_end_by_metadata)) != 0) {
    648                    heap_end_by_metadata = (uint64_t *)((uint8_t *)heap_end_by_metadata + reservation_size);
    649                  }
    650                }
    651          
    652                // Check the computed heap_end_by_metadata against real heap end, after accounting for any reserved blocks
    653                // and reserved blocks no retention.
    654                if (heap_end_by_metadata != (void *)((uintptr_t)heap->base_addr + heap->size)) {
    655                  is_corrupted = 1;
    656                }
    657                break;
    658              }
    659          
    660              // Calculate the address of the next block using offset and length.
    661              sli_block_metadata_t *next_blk_by_offset = (sli_block_metadata_t *)((uint64_t *)current + sli_block_offset_next_dword_decode(current));
    662              sli_block_metadata_t *next_blk_by_len = (sli_block_metadata_t *)((uint64_t *)current + sli_block_len_dword_decode(current) + SLI_BLOCK_METADATA_SIZE_DWORD);
    663          
    664              // Check if reservation (one or more).
    665              while ((reservation_size = sli_memory_get_reservation_size_by_addr((void *)next_blk_by_len)) != 0) {
    666                next_blk_by_len = (sli_block_metadata_t *)((uint8_t *)next_blk_by_len + reservation_size);
    667              }
    668          
    669              // Check the computed next_blk_by_len against the next block, after accounting for any reserved blocks.
    670              if (next_blk_by_offset != next_blk_by_len) {
    671                is_corrupted = 1;
    672                break;
    673              } else {
    674                current = next_blk_by_offset;
    675              }
    676            }
    677          
    678            return is_corrupted ? current : NULL;
    679          }
    680          
    681          /***************************************************************************//**
    682           * Does a heap integrity check backwards from the general-purpose heap free_st_list_head
    683           * and return the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    684           * This should not go past any reservations, hence there are no checks.
    685           ******************************************************************************/
    686          sli_block_metadata_t *sli_memory_check_general_purpose_heap_integrity_backwards(void)
    687          {
    688            return sli_memory_check_heap_integrity_backwards(&sli_general_purpose_heap);
    689          }
    690          
    691          /***************************************************************************//**
    692           * Does a heap integrity check backwards from free_st_list_head and return
    693           * the pointer to the corrupted sli_block_metadata_t{} (if applicable).
    694           * This should not go past any reservations, hence there are no checks.
    695           ******************************************************************************/
    696          sli_block_metadata_t *sli_memory_check_heap_integrity_backwards(sl_memory_heap_t *heap)
    697          {
    698            uint64_t *heap_base_by_metadata = 0;
    699            uint32_t is_corrupted = 0;
    700            uint32_t reservation_size;
    701            sli_block_metadata_t *current = (sli_block_metadata_t *)heap->free_st_list_head;
    702          
    703            while (current != NULL) {
    704              // Reached first block in heap.
    705              if (sli_block_offset_prev_dword_decode(current) == 0) {
    706                heap_base_by_metadata = ((uint64_t *)current);
    707                if (heap_base_by_metadata != (void *)heap->base_addr) {
    708                  is_corrupted = 1;
    709                }
    710                break;
    711              }
    712          
    713              // Calculate the address of the current block using offset and length of the previous block.
    714              sli_block_metadata_t *prev_blk_by_offset = (sli_block_metadata_t *)((uint64_t *)current - sli_block_offset_prev_dword_decode(current));
    715              sli_block_metadata_t *current_by_prev_offset = (sli_block_metadata_t *)((uint64_t *)prev_blk_by_offset + sli_block_offset_next_dword_decode(prev_blk_by_offset));
