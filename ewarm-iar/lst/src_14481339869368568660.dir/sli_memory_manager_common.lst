    504          /***************************************************************************//**
    505           * Gets the pointer to sl_memory_reservation_t{} by block address.
    506           ******************************************************************************/
    507          sl_memory_reservation_t *sli_memory_get_reservation_handle_by_addr(void *addr)
    508          {
    509            uint32_t reservation_ix = get_reservation_ix_by_addr(addr);
    510          
    511            if (reservation_ix != (uint32_t)-1) {
    512              return sli_reservation_handle_ptr_table[reservation_ix];
    513            }
    514          
    515            return NULL;
    516          }
    517          
    518          /***************************************************************************//**
    519           * Gets the size of a reservation by block address.
    520           ******************************************************************************/
    521          uint32_t sli_memory_get_reservation_size_by_addr(void *addr)
    522          {
    523            sl_memory_reservation_t *reservation_handle_ptr = sli_memory_get_reservation_handle_by_addr(addr);
    524          
    525            if (reservation_handle_ptr != NULL) {
    526              return reservation_handle_ptr->block_size;
    527            }
    528            // Not a reservation, return 0 size.
    529            return 0;
    530          }
    531          
    532          /***************************************************************************//**
    533           * Bookkeeps a reservation for profiling purposes.
    534           ******************************************************************************/
    535          sl_status_t sli_memory_save_reservation_handle(sl_memory_reservation_t *reservation_handle_ptr)
    536          {
    537            uint32_t reservation_ix = sli_get_available_reservation_handle_ix();
    538          
    539            if (reservation_ix != (uint32_t)-1) {
    540              sli_reservation_handle_ptr_table[reservation_ix] = reservation_handle_ptr;
    541              return SL_STATUS_OK;
    542            } else {
    543              return SL_STATUS_FULL;
    544            }
    545          }
    546          
    547          /***************************************************************************//**
    548           * Removes a reservation from records.
    549           ******************************************************************************/
    550          sl_status_t sli_memory_remove_reservation_handle(sl_memory_reservation_t *reservation_handle_ptr)
    551          {
    552            uint32_t reservation_ix = get_reservation_ix_by_handle(reservation_handle_ptr);
    553          
    554            if (reservation_ix != (uint32_t)-1) {
    555              sli_reservation_handle_ptr_table[reservation_ix] = NULL;
    556              return SL_STATUS_OK;
    557            } else {
    558              return SL_STATUS_NOT_FOUND;
    559            }
    560          }
    561          
    562          /***************************************************************************//**
    563           * Bookkeeps a reservation (no retention) for profiling purposes.
    564           ******************************************************************************/
    565          sl_status_t sli_memory_save_reservation_no_retention(void *block_address,
    566                                                               uint32_t block_size)
    567          {
    568            uint32_t reservation_ix = get_available_reservation_no_retention_ix();
    569          
    570            if (reservation_ix != (uint32_t)-1) {
    571              sli_reservation_no_retention_table[reservation_ix].block_address = block_address;
    572              sli_reservation_no_retention_table[reservation_ix].block_size = block_size;
    573          
    574              return SL_STATUS_OK;
    575            } else {
    576              return SL_STATUS_FULL;
    577            }
    578          }
    579          
    580          /***************************************************************************//**
    581           * Gets the size of a reservation (no retention) by block address.
    582           ******************************************************************************/
    583          uint32_t sli_memory_get_reservation_no_retention_size(void *addr)
    584          {
    585            uint32_t reservation_ix = get_reservation_no_retention_ix(addr);
    586          
    587            if (reservation_ix != (uint32_t)-1) {
    588              return sli_reservation_no_retention_table[reservation_ix].block_size;
    589            }
    590            // Not a reservation (no retention), return 0 size.
    591            return 0;
