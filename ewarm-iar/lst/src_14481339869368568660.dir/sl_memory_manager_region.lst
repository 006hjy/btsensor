    156          #if defined(__GNUC__)
    157          /***************************************************************************//**
    158           * Extends the process data space.
    159           *
    160           * @param[in]  incr   Number of bytes to increment/decrement
    161           *
    162           * @return Start of the new space allocated if successful. -1 if error.
    163           *
    164           * @note (1) This is a helper function called by the standard C library
    165           *           function malloc(). _sbrk() is used to dynamically change the
    166           *           amount of space allocated for the calling process data segment.
    167           *           The change is made by allocating the appropriate amount of space
    168           *           from the end of heap.
    169           *           _sbrk() adds 'incr' bytes to the end of heap and changes
    170           *           the allocated space accordingly. 'incr' can be negative, in which
    171           *           case the amount of allocated space is decreased.
    172           *
    173           * @note (2) When the Memory Manager (MM) is used, there is no need for
    174           *           _sbrk() as there is no possible extension with the MM controlling
    175           *           the entire heap size.
    176           *           If _sbrk() is called by the standard C library, then the project
    177           *           may have used the standard C malloc() function implementation.
    178           *           In that case, the MM retarget, wrapping the GCC malloc() to the
    179           *           MM sl_malloc(), may have not worked. You may want to double-check
    180           *           your project settings.
    181           ******************************************************************************/
    182          __USED __WEAK void * _sbrk(int incr)
    183          {
    184          #if defined(SL_CATALOG_MEMORY_MANAGER_PRESENT)
    185            (void)incr;
    186          
    187            // This means there is an issue with the setup of C standard library. See Note #2.
    188            while (1) {
    189              // infinite loop
    190            }
    191          #else
    192            static char *heap_end = __HeapBase;
    193            char *prev_heap_end;
    194          
    195            if ((heap_end + incr) > __HeapLimit) {
    196              // Not enough heap
    197              return (void *) -1;
    198            }
    199          
    200            prev_heap_end = heap_end;
    201            heap_end += incr;
    202          
    203            return prev_heap_end;
    204          #endif
    205          }
    206          #endif

