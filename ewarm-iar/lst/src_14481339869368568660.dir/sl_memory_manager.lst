    233            // Create PSRAM heap.
    234            status = sli_memory_create_heap(psram_heap_region.addr,
    235                                            psram_heap_region.size,
    236                                            SL_MEMORY_HEAP_ALLOC_EXTERNAL_RAM,
    237                                            &sli_psram_heap);
    238          
    239            return status;
    240          }
