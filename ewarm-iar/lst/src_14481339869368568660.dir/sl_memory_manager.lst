    224          sl_status_t sl_memory_init_psram(void)
    225          {
    226            sl_status_t status = SL_STATUS_OK;
    227          
    228            sl_memory_region_t psram_heap_region = sl_memory_get_psram_heap_region();
    229          
    230            EFM_ASSERT(psram_heap_region.addr != NULL);
    231            EFM_ASSERT(psram_heap_region.size > 0);
