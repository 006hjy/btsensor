    530          /***************************************************************************//**
    531           * Resizes a previously allocated memory block.
    532           *
    533           * @note (1) If 'ptr' is a null pointer, sl_memory_realloc() is equivalent to
    534           *           sl_memory_malloc() for the specified 'size'.
    535           *           If 'size' is 0 and 'ptr' points to an existing block of memory,
    536           *           sl_memory_realloc() is equivalent to sl_memory_free() and the
    537           *           memory block is deallocated.
    538           *
    539           * @note (2) The content of the reallocated memory block is preserved up to
    540           *           the lesser of the new and old sizes, even if the block is moved
    541           *           to a new location. If the new size is larger, the value of the
    542           *           newly allocated portion is indeterminate.
    543           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    544          sl_status_t sl_memory_realloc(void *ptr,
    545                                        size_t size,
    546                                        void **block)
    547          {
   \                     sl_memory_realloc: (+1)
   \        0x0   0x4613             MOV      R3,R2
    548          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    549            void * volatile return_address = sli_memory_profiler_get_return_address();
    550          #endif
    551            sl_status_t status;
    552          
    553          #if defined(SL_CATALOG_MEMORY_MANAGER_PSRAM_PRESENT) || defined (SL_CATALOG_MEMORY_MANAGER_DTCM_PRESENT)
    554            sl_memory_heap_t *heap;
    555          
    556            // Retrieve the heap where the block was previously allocated.
    557            heap = sli_memory_get_heap_handle(ptr);
    558          
    559            // If heap is NULL, use the general purpose heap.
    560            // This allows realloc to do allocation if ptr is NULL.
    561            heap = (heap == NULL) ? &sli_general_purpose_heap : heap;
    562          
    563            status = sl_memory_heap_realloc(heap, ptr, size, block);
    564          #else
    565            // Assume general_purpose_heap on boards that don't have a PSRAM or a DTCM
    566            status = sl_memory_heap_realloc(&sli_general_purpose_heap, ptr, size, block);
    567          #endif
    568          
    569          #if defined(SL_CATALOG_MEMORY_PROFILER_PRESENT)
    570            // Realloc to 0 bytes is equivalent to free, so only track ownership when size
    571            // is other than 0
    572            if (size != 0) {
    573              sli_memory_profiler_track_ownership(SLI_INVALID_MEMORY_TRACKER_HANDLE, *block, return_address);
    574            }
    575          #endif
    576          
    577            return status;
