   1849          #if defined(SLI_MEMORY_MANAGER_SUPPORT_ALLOCATION_FALLBACK)
   1850          /***************************************************************************//**
   1851           * Manages allocation fallback into different heap types.
   1852           *
   1853           * @param[in]  size                     Size of the block to allocate in bytes.
   1854           * @param[in]  align                    Alignment required, in bytes.
   1855           * @param[in]  type                     Block type and attribute mask.
   1856           * @param[out] block                    Pointer to variable that will receive
   1857           *                                      the start address of the allocated memory.
   1858           *
   1859           * @return     SL_STATUS_OK if success.
   1860           *             SL_STATUS_NO_MORE_RESOURCE if no fallbacks are available.
   1861           *             Allocation error code otherwise.
   1862           *
   1863           * @note (1) This function is used to handle allocation fallbacks when the
   1864           *           requested allocation cannot be satisfied by the current heap.
   1865           *           It tries to allocate from different heaps based on the specified
   1866           *           block attributes.
   1867           *
   1868           * @note (2) The fallback order follows the heaps initialization order which is:
   1869           *             1. General Purpose Heap
   1870           *             2. PSRAM
   1871           *             3. DTCM
   1872           *
   1873           *           This  makes it so that:
   1874           *             Failed allocations from the general purpose heap always goes first to the
   1875           *             PSRAM and then to the DTCM.
   1876           ******************************************************************************/
   1877          static sl_status_t memory_manage_allocation_fallback(size_t size,
   1878                                                               size_t align,
   1879                                                               uint8_t type,
   1880                                                               void **block)
   1881          {
   1882            sl_memory_heap_t *fallback_heap = sli_general_purpose_heap.next_handle;
   1883            sl_memory_block_attrib_t blocks_heap_attribute = (sl_memory_block_attrib_t) (type & SLI_MEMORY_BLOCK_ATTRIBUTE_MASK);
   1884            size_t allocation_size = SLI_ALIGN_ROUND_UP(size, SLI_BLOCK_ALLOC_MIN_ALIGN);
   1885          
   1886            while (fallback_heap != NULL) {
   1887              // If the fallback heap attribute matches one of the blocks heap attributes
   1888              // and there is enough space in heap, try the allocation.
   1889              if (((fallback_heap->attrib & blocks_heap_attribute) == fallback_heap->attrib)
   1890                  && (allocation_size <= (fallback_heap->size - fallback_heap->used_size))) {
   1891                sl_status_t status = sl_memory_heap_alloc_advanced(fallback_heap,
   1892                                                                   size,
   1893                                                                   align,
   1894                                                                   type & ~SLI_MEMORY_BLOCK_ATTRIBUTE_MASK,  // No fallback on this allocation
   1895                                                                   block);
   1896                if (status == SL_STATUS_OK) {
   1897                  return SL_STATUS_OK;
   1898                }
   1899              }
   1900          
   1901              fallback_heap = fallback_heap->next_handle;
   1902            }
   1903          
   1904            return SL_STATUS_NO_MORE_RESOURCE;
   1905          }
   1906          #endif  // SLI_MEMORY_MANAGER_SUPPORT_ALLOCATION_FALLBACK
