   1448          /***************************************************************************//**
   1449           * State machine for write-write operation in blocking I2C transfer.
   1450           *
   1451           * @details
   1452           *   Implements a blocking state machine for I2C write-write operations that
   1453           *   transmits two separate buffers consecutively in a single atomic I2C transaction.
   1454           *   The transaction format is: S+ADDR(W)+DATA1+DATA2+P.
   1455           *   This ensures atomicity and is primarily designed for I2CSPM compatibility.
   1456           *
   1457           * @param[in] i2c_handle  Pointer to the I2C handle structure.
   1458           * @param[in] tx_buffer1  Pointer to the first transmit buffer.
   1459           * @param[in] tx_len1     Number of bytes in the first buffer.
   1460           * @param[in] tx_buffer2  Pointer to the second transmit buffer.
   1461           * @param[in] tx_len2     Number of bytes in the second buffer.
   1462           * @param[in] timeout     Timeout duration in milliseconds (0 = no timeout).
   1463           *
   1464           * @return
   1465           *   SL_STATUS_OK on success, or appropriate error code on failure.
   1466           *
   1467           * @note
   1468           *   This function supports I2CSPM write_write compatibility, enabling seamless
   1469           *   migration from I2CSPM to I2C driver for applications requiring atomic
   1470           *   two-buffer write operations.
   1471           *   @deprecated This function will be removed when I2CSPM is deprecated.
   1472           ******************************************************************************/
   1473          static sl_status_t i2c_leader_mode_write_no_stop_blocking_state_machine(sl_i2c_handle_t *i2c_handle,
   1474                                                                                  const uint8_t *tx_buffer1,
   1475                                                                                  uint32_t tx_len1,
   1476                                                                                  const uint8_t *tx_buffer2,
   1477                                                                                  uint32_t tx_len2,
   1478                                                                                  uint32_t timeout)
   1479          {
   1480            uint32_t pending_irq;
   1481            I2C_TypeDef *i2c_base_addr = sl_device_peripheral_i2c_get_base_addr(i2c_handle->i2c_peripheral);
   1482          
   1483            i2c_handle->state = SL_I2C_STATE_SEND_START_AND_ADDR;
   1484          
   1485            uint16_t actual_follower_addr = (i2c_handle->follower_address << 1);
   1486            uint8_t first_addr_byte;
   1487            first_addr_byte = (actual_follower_addr & SL_I2C_7BIT_FOLLOWER_ADDRESS_MASK);
   1488          
   1489            uint32_t start_time = get_current_time_ms();
   1490          
   1491            // Local variables to track current buffer and state
   1492            const uint8_t *current_tx_buffer = tx_buffer1;
   1493            uint32_t current_tx_len = tx_len1;
   1494            bool is_second_buffer = false;
   1495          
   1496            while (true) {
   1497              if (timeout > 0 && (get_current_time_ms() - start_time >= timeout)) {
   1498                i2c_base_addr->CMD = I2C_CMD_ABORT;
   1499                i2c_handle->event = SL_I2C_EVENT_TIMEOUT;
   1500                return SL_STATUS_TIMEOUT;
   1501              }
   1502          
   1503              pending_irq = sl_hal_i2c_get_enabled_pending_interrupts(i2c_base_addr);
   1504          
   1505              // Handle errors first - fastest path for error conditions
   1506              if (pending_irq & SL_HAL_I2C_IF_ERRORS) {
   1507                sl_hal_i2c_clear_interrupts(i2c_base_addr, _I2C_IF_MASK);
   1508                i2c_base_addr->CMD = I2C_CMD_ABORT;
   1509                i2c_handle->state = SL_I2C_STATE_ERROR;
   1510          
   1511                if (pending_irq & I2C_IF_ARBLOST) {
   1512                  i2c_handle->event = SL_I2C_EVENT_ARBITRATION_LOST;
   1513                  return SL_STATUS_TRANSMIT;
   1514                } else {
   1515                  i2c_handle->event = SL_I2C_EVENT_BUS_ERROR;
   1516                  return SL_STATUS_IO;
   1517                }
   1518              }
   1519          
   1520              switch (i2c_handle->state) {
   1521                case SL_I2C_STATE_SEND_START_AND_ADDR:
   1522                  sl_hal_i2c_start_cmd(i2c_base_addr);
   1523                  sl_hal_i2c_tx(i2c_base_addr, first_addr_byte);
   1524                  i2c_handle->state = SL_I2C_STATE_ADDR_WAIT_FOR_ACK_OR_NACK;
   1525                  i2c_handle->event = SL_I2C_EVENT_IN_PROGRESS;
   1526                  break;
   1527          
   1528                case SL_I2C_STATE_ADDR_WAIT_FOR_ACK_OR_NACK:
   1529                  if (pending_irq & I2C_IF_ACK) {
   1530                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_ACK);
   1531                    i2c_handle->state = SL_I2C_STATE_SEND_DATA;
   1532                  } else if (pending_irq & I2C_IF_NACK) {
   1533                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_NACK);
   1534                    sl_hal_i2c_stop_cmd(i2c_base_addr);
   1535                    i2c_handle->event = SL_I2C_EVENT_ADDR_NACK;
   1536                    i2c_handle->state = SL_I2C_STATE_SEND_STOP;
   1537                  }
   1538                  break;
   1539          
   1540                case SL_I2C_STATE_SEND_DATA:
   1541                  if (i2c_handle->tx_offset < current_tx_len) {
   1542                    sl_hal_i2c_tx(i2c_base_addr, current_tx_buffer[i2c_handle->tx_offset++]);
   1543                    i2c_handle->state = SL_I2C_STATE_DATA_WAIT_FOR_ACK_OR_NACK;
   1544                  } else {
   1545                    // Current buffer complete
   1546                    if (!is_second_buffer) {
   1547                      // First buffer complete - switch to second buffer without STOP
   1548                      current_tx_buffer = tx_buffer2;
   1549                      current_tx_len = tx_len2;
   1550                      i2c_handle->tx_offset = 0;
   1551                      is_second_buffer = true;
   1552                      // Stay in SL_I2C_STATE_SEND_DATA to continue with second buffer
   1553                    } else {
   1554                      // Second buffer complete - send STOP
   1555                      sl_hal_i2c_stop_cmd(i2c_base_addr);
   1556                      i2c_handle->state = SL_I2C_STATE_SEND_STOP;
   1557                    }
   1558                  }
   1559                  break;
   1560          
   1561                case SL_I2C_STATE_DATA_WAIT_FOR_ACK_OR_NACK:
   1562                  if (pending_irq & I2C_IF_ACK) {
   1563                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_ACK);
   1564                    i2c_handle->state = SL_I2C_STATE_SEND_DATA;
   1565                  } else if (pending_irq & I2C_IF_NACK) {
   1566                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_NACK);
   1567          
   1568                    sl_hal_i2c_stop_cmd(i2c_base_addr);
   1569                    i2c_handle->state = SL_I2C_STATE_SEND_STOP;
   1570                    i2c_handle->event = SL_I2C_EVENT_DATA_NACK;
   1571                  }
   1572                  break;
   1573          
   1574                case SL_I2C_STATE_SEND_STOP:
   1575                  if (pending_irq & I2C_IF_MSTOP) {
   1576                    sl_hal_i2c_clear_interrupts(i2c_base_addr, I2C_IF_MSTOP);
   1577                    if (i2c_handle->event == SL_I2C_EVENT_ADDR_NACK) {
   1578                      return SL_STATUS_NOT_FOUND;
   1579                    } else if (i2c_handle->event == SL_I2C_EVENT_DATA_NACK) {
   1580                      return SL_STATUS_ABORT;
   1581                    } else {
   1582                      i2c_handle->event = SL_I2C_EVENT_COMPLETED;
   1583                      return SL_STATUS_OK;
   1584                    }
   1585                  }
   1586                  break;
   1587          
   1588                default:
   1589                  i2c_handle->event = SL_I2C_EVENT_SW_FAULT;
   1590                  i2c_handle->state = SL_I2C_STATE_ERROR;
   1591                  return SL_STATUS_FAIL;
   1592              }
   1593            }
   1594          }
