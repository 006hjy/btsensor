     46          /**
     47           * @brief Number of clock cycles for bus recovery.
     48           *
     49           * @note
     50           *   Set to 10 clock cycles to ensure the bus can be cleared effectively,
     51           *   allowing for proper recovery.
     52           *   This helps resume communication quickly without leaving the bus in a stalled state.
     53           */
     54          #define I2C_RECOVER_NUM_CLOCKS  10
     55          
     56          /**
     57           * @brief SCL hold time in microseconds.
     58           *
     59           * @note
     60           *   Set to 100 microseconds to ensure proper synchronization
     61           *   between leader and follower devices.
     62           *   This provides enough time for data processing on the SDA line
     63           *   and ensures reliable communication, even with slower devices.
     64           */
     65          #ifndef I2C_SCL_HOLD_TIME_US
     66          #define I2C_SCL_HOLD_TIME_US 100
     67          #endif
