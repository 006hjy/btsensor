   1948          /***************************************************************************//**
   1949           * @brief Stop tx DMA transfers
   1950           ******************************************************************************/
   1951          __STATIC_INLINE void AbortTxDmaTransfers(UARTDRV_Handle_t handle)
   1952          {
   1953            UARTDRV_Buffer_t *txBuffer;
   1954          
   1955            // Stop the current transfer
   1956            DMADRV_StopTransfer(handle->txDmaCh);
   1957            handle->txDmaActive = false;
   1958          
   1959            if (handle->txQueue->used > 0) {
   1960              // Update the transfer status of the active transfer
   1961              GetTailBuffer(handle->txQueue, &txBuffer);
   1962              DMADRV_TransferRemainingCount(handle->txDmaCh,
   1963                                            (int*)&txBuffer->itemsRemaining);
   1964              txBuffer->transferStatus = ECODE_EMDRV_UARTDRV_ABORTED;
   1965          
   1966              // Dequeue all transfers and call callback
   1967              while (handle->txQueue->used > 0) {
   1968                DequeueBuffer(handle->txQueue, &txBuffer);
   1969          
   1970                // Call the callback with ABORTED error code
   1971                if (txBuffer->callback != NULL) {
   1972                  txBuffer->callback(handle,
   1973                                     ECODE_EMDRV_UARTDRV_ABORTED,
   1974                                     txBuffer->data,
   1975                                     txBuffer->transferCount - txBuffer->itemsRemaining
   1976                                     #if defined(UARTDRV_USER_SPECIFIED_CALLBACK_ENABLE) \
   1977                                     && (UARTDRV_USER_SPECIFIED_CALLBACK_ENABLE == 1)
   1978                                     , txBuffer->userParam
   1979                                     #endif
   1980                                     );
   1981                }
   1982              }
   1983            }
   1984          
   1985            while (!(UARTDRV_GetPeripheralStatus(handle) & UARTDRV_STATUS_TXIDLE)) {
   1986              // Wait for peripheral to finish cleaning up, to prevent framing errors
   1987              // on subsequent transfers
   1988            }
