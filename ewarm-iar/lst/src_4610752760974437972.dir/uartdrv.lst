   1995          /***************************************************************************//**
   1996           * @brief Stop rx DMA transfers
   1997           ******************************************************************************/
   1998          __STATIC_INLINE void AbortRxDmaTransfers(UARTDRV_Handle_t handle)
   1999          {
   2000            UARTDRV_Buffer_t *rxBuffer;
   2001          
   2002            // Stop the current transfer
   2003            DMADRV_StopTransfer(handle->rxDmaCh);
   2004            handle->rxDmaActive = false;
   2005          
   2006            if (handle->rxQueue->used > 0) {
   2007              // Update the transfer status of the active transfer
   2008              GetTailBuffer(handle->rxQueue, &rxBuffer);
   2009              DMADRV_TransferRemainingCount(handle->rxDmaCh,
   2010                                            (int*)&rxBuffer->itemsRemaining);
   2011              rxBuffer->transferStatus = ECODE_EMDRV_UARTDRV_ABORTED;
   2012              // Dequeue all transfers and call callback
   2013          
   2014              while (handle->rxQueue->used > 0) {
   2015                DequeueBuffer(handle->rxQueue, &rxBuffer);
   2016                // Call the callback with ABORTED error code
   2017          
   2018                if (rxBuffer->callback != NULL) {
   2019                  rxBuffer->callback(handle,
   2020                                     ECODE_EMDRV_UARTDRV_ABORTED,
   2021                                     rxBuffer->data,
   2022                                     rxBuffer->transferCount - rxBuffer->itemsRemaining
   2023                                     #if defined(UARTDRV_USER_SPECIFIED_CALLBACK_ENABLE) \
   2024                                     && (UARTDRV_USER_SPECIFIED_CALLBACK_ENABLE == 1)
   2025                                     , rxBuffer->userParam
   2026                                     #endif
   2027                                     );
   2028                }
   2029              }
   2030            }
   2031          }
