   30                           
   31                               PUBLIC sli_delay_loop
   32                               RSEG CODE:CODE:NOROOT(4)
   33                               THUMB
   34                           
   35                           ;/*
   36                           ; * @brief
   37                           ; *   Hardware delay loop
   38                           ; *
   39                           ; * @detail
   40                           ; *   This is the hardware specific delay
                                 loop. It is designed specifically to
   41                           ; *   execute in 4 or 3 cycles for each
                                 iteration depending on the architecture.
   42                           ; *   Using this information the caller can
                                 use the core clock frequency to
   43                           ; *   calculate the number of loops required
                                 in order to delay a specific time
   44                           ; *   period.
   45                           ; * 
   46                           ; * @param[in] n (r0)
   47                           ; *   n is the number of loops to execute.
                                 Each loop will execute in 4 cycles.
   48                           ; *   Note that we assume that r0 > 0, so this
                                 invariant should be checked by
   49                           ; *   the caller.
   50                           ; */
   51                           sli_delay_loop:
   52    00000000 401E              subs  r0, r0, #1
   53    00000002 00D0              beq   done
   54    00000004 FCE7              b.n   sli_delay_loop
   55                           done:
   56    00000006 7047              bx    lr
   57                           
   58                               END
