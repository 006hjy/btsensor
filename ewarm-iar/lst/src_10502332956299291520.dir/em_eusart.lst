   1232          /***************************************************************************//**
   1233           * Calculate baudrate for a given reference frequency, clock division,
   1234           * and oversampling rate when the module is in UART mode.
   1235           *
   1236           * @param refFreq The EUSART reference clock frequency in Hz that will be used.
   1237           * @param clkdiv Clock division factor to be used.
   1238           * @param ovs Oversampling to be used.
   1239           *
   1240           * @return Computed baudrate from given settings.
   1241           ******************************************************************************/
   1242          __STATIC_INLINE uint32_t EUSART_AsyncBaudrateCalc(uint32_t refFreq,
   1243                                                            uint32_t clkdiv,
   1244                                                            EUSART_OVS_TypeDef ovs)
   1245          {
   1246            uint32_t oversample;
   1247            uint64_t divisor;
   1248            uint64_t factor;
   1249            uint64_t remainder;
   1250            uint64_t quotient;
   1251            uint32_t br;
   1252          
   1253            // Out of bound clkdiv.
   1254            EFM_ASSERT(clkdiv <= _EUSART_CLKDIV_MASK);
   1255          
   1256            // Mask out unused bits
   1257            clkdiv &= _EUSART_CLKDIV_MASK;
   1258          
   1259            /* Use integer division to avoid forcing in float division
   1260             * utils and yet keep rounding effect errors to a minimum.
   1261             *
   1262             * Baudrate in is given by:
   1263             *
   1264             * br = fUARTn/(oversample * (1 + (CLKDIV / 256)))
   1265             * or
   1266             * br = (256 * fUARTn)/(oversample * (256 + CLKDIV))
   1267             *
   1268             * 256 factor of the dividend is reduced with a
   1269             * (part of) oversample part of the divisor.
   1270             */
   1271          
   1272            switch (ovs) {
   1273              case eusartOVS16:
   1274                oversample = 1;
   1275                factor = 256 / 16;
   1276                break;
   1277          
   1278              case eusartOVS8:
   1279                oversample = 1;
   1280                factor = 256 / 8;
   1281                break;
   1282          
   1283              case eusartOVS6:
   1284                oversample = 3;
   1285                factor = 256 / 2;
   1286                break;
   1287          
   1288              case eusartOVS4:
   1289                oversample = 1;
   1290                factor = 256 / 4;
   1291                break;
   1292          
   1293              case eusartOVS0:
   1294                oversample = 1;
   1295                factor = 256;
   1296                break;
   1297          
   1298              default:
   1299                return 0u;
   1300                break;
   1301            }
   1302          
   1303            /*
   1304             * The basic problem with integer division in the above formula is that
   1305             * the dividend (factor * fUARTn) may become larger than a 32 bit
   1306             * integer. Yet we want to evaluate the dividend first before dividing
   1307             * to get as small rounding effects as possible. Too harsh restrictions
   1308             * should not be made on the maximum fUARTn value either.
   1309             *
   1310             * For division a/b,
   1311             *
   1312             * a = qb + r
   1313             *
   1314             * where q is the quotient and r is the remainder, both integers.
   1315             *
   1316             * The original baudrate formula can be rewritten as
   1317             *
   1318             * br = xa / b = x(qb + r)/b = xq + xr/b
   1319             *
   1320             * where x is 'factor', a is 'refFreq' and b is 'divisor', referring to
   1321             * variable names.
   1322             */
   1323          
   1324            /*
   1325             * The divisor will never exceed max 32 bit value since
   1326             * clkdiv <= _EUSART_CLKDIV_MASK (currently 0x7FFFF8)
   1327             * and 'oversample' has been reduced to <= 3.
   1328             */
   1329            divisor = (uint64_t)(oversample * (256 + clkdiv));
   1330          
   1331            quotient = refFreq / divisor;
   1332            remainder = refFreq % divisor;
   1333          
   1334            // The factor <= 128 and since divisor >= 256, the below cannot exceed the maximum
   1335            // 32 bit value. However, factor * remainder can become larger than 32-bit
   1336            // because of the size of _EUSART_CLKDIV_DIV_MASK on some families.
   1337            br = (uint32_t) (factor * quotient);
   1338          
   1339            /*
   1340             * The factor <= 128 and remainder < (oversample*(256 + clkdiv)), which
   1341             * means dividend (factor * remainder) worst case is
   1342             * 128 * (3 * (256 + _EUSART_CLKDIV_MASK)) = 0xC001_7400.
   1343             */
   1344            br += (uint32_t) ((factor * remainder) / divisor);
   1345          
   1346            return br;
   1347          }
