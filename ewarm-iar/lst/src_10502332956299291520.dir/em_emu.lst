   4338          #if defined(_EMU_TEMP_TEMP_MASK)
   4339          /***************************************************************************//**
   4340           * @brief
   4341           *   Get temperature in degrees Celsius
   4342           *
   4343           * @return
   4344           *   Temperature in degrees Celsius
   4345           ******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
   4346          float EMU_TemperatureGet(void)
   4347          {
   4348          #if defined(_EMU_TEMP_TEMPLSB_MASK)
   4349            return ((float) ((EMU->TEMP & (_EMU_TEMP_TEMP_MASK | _EMU_TEMP_TEMPLSB_MASK) )
   4350                             >> _EMU_TEMP_TEMPLSB_SHIFT)
   4351                    ) / 4.0f - EMU_TEMP_ZERO_C_IN_KELVIN;
   \                     EMU_TemperatureGet: (+1)
   \        0x0   0x....             LDR.N    R0,??DataTable18_31
   \        0x2   0x6801             LDR      R1,[R0, #+0]
   \        0x4   0xEDDF 0x....      VLDR.W   S1,??DataTable18
   \        0x8   0xF3C1 0x010A      UBFX     R1,R1,#+0,#+11
   \        0xC   0xEE00 0x1A10      VMOV     S0,R1
   \       0x10   0xEEBB 0x0ACF      VCVT.F32.U32 S0,S0,#+2
   \       0x14   0xEE30 0x0A20      VADD.F32 S0,S0,S1
   \       0x18   0x4770             BX       LR
   4352          #else
   4353            uint32_t val1;
   4354            uint32_t val2;
   4355            float tempCo;
   4356            uint32_t diTemp, diEmu;
   4357          
   4358            // Calculate calibration temp based on DI page values
   4359            diTemp = ((DEVINFO->CAL & _DEVINFO_CAL_TEMP_MASK) >> _DEVINFO_CAL_TEMP_SHIFT);
   4360            diEmu = ((DEVINFO->EMUTEMP & _DEVINFO_EMUTEMP_EMUTEMPROOM_MASK) >> _DEVINFO_EMUTEMP_EMUTEMPROOM_SHIFT);
   4361            tempCo = EMU_TEMPCO_CONST + (diEmu / 100.0f);
   4362          
   4363            // Read temperature twice to ensure a stable value
   4364            do {
   4365              val1 = (EMU->TEMP & _EMU_TEMP_TEMP_MASK)
   4366                     >> _EMU_TEMP_TEMP_SHIFT;
   4367              val2 = (EMU->TEMP & _EMU_TEMP_TEMP_MASK)
   4368                     >> _EMU_TEMP_TEMP_SHIFT;
   4369            } while (val1 != val2);
   4370          
   4371            return diTemp + tempCo * ((int) diEmu - (int) val1);
   4372          #endif
   4373          }
   4374          #endif // defined(_EMU_TEMP_TEMP_MASK)
