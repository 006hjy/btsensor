   2006          /***************************************************************************//**
   2007           * @brief
   2008           *   Configure Backup Power Domain settings.
   2009           *
   2010           * @param[in] bupdInit
   2011           *   Backup power domain initialization structure.
   2012           ******************************************************************************/
   2013          void EMU_BUPDInit(const EMU_BUPDInit_TypeDef *bupdInit)
   2014          {
   2015            uint32_t reg;
   2016          
   2017            /* Set the power connection configuration. */
   2018            reg = EMU->PWRCONF & ~(_EMU_PWRCONF_PWRRES_MASK
   2019                                   | _EMU_PWRCONF_VOUTSTRONG_MASK
   2020                                   | _EMU_PWRCONF_VOUTMED_MASK
   2021                                   | _EMU_PWRCONF_VOUTWEAK_MASK);
   2022          
   2023            reg |= bupdInit->resistor
   2024                   | (bupdInit->voutStrong << _EMU_PWRCONF_VOUTSTRONG_SHIFT)
   2025                   | (bupdInit->voutMed    << _EMU_PWRCONF_VOUTMED_SHIFT)
   2026                   | (bupdInit->voutWeak   << _EMU_PWRCONF_VOUTWEAK_SHIFT);
   2027          
   2028            EMU->PWRCONF = reg;
   2029          
   2030            /* Set the backup domain inactive mode configuration. */
   2031            reg = EMU->BUINACT & ~(_EMU_BUINACT_PWRCON_MASK);
   2032            reg |= (bupdInit->inactivePower);
   2033            EMU->BUINACT = reg;
   2034          
   2035            /* Set the backup domain active mode configuration. */
   2036            reg = EMU->BUACT & ~(_EMU_BUACT_PWRCON_MASK);
   2037            reg |= (bupdInit->activePower);
   2038            EMU->BUACT = reg;
   2039          
   2040            /* Set the power control configuration */
   2041            reg = EMU->BUCTRL & ~(_EMU_BUCTRL_PROBE_MASK
   2042                                  | _EMU_BUCTRL_BODCAL_MASK
   2043                                  | _EMU_BUCTRL_STATEN_MASK
   2044                                  | _EMU_BUCTRL_EN_MASK);
   2045          
   2046            /* Note the use of ->enable to enable BUPD. Use BU_VIN pin input and
   2047               release reset. */
   2048            reg |= bupdInit->probe
   2049                   | (bupdInit->bodCal          << _EMU_BUCTRL_BODCAL_SHIFT)
   2050                   | (bupdInit->statusPinEnable << _EMU_BUCTRL_STATEN_SHIFT)
   2051                   | (bupdInit->enable          << _EMU_BUCTRL_EN_SHIFT);
   2052          
   2053            /* Enable configuration. */
   2054            EMU->BUCTRL = reg;
   2055          
   2056            /* If enable is true, enable BU_VIN input power pin. If not, disable it.  */
   2057            EMU_BUPinEnable(bupdInit->enable);
   2058          
   2059            /* If enable is true, release BU reset. If not, keep reset asserted. */
   2060            BUS_RegBitWrite(&(RMU->CTRL), _RMU_CTRL_BURSTEN_SHIFT, !bupdInit->enable);
   2061          }
   2062          
   2063          /***************************************************************************//**
   2064           * @brief
   2065           *   Configure the Backup Power Domain BOD Threshold value.
   2066           * @note
   2067           *   These values are precalibrated.
   2068           * @param[in] mode Active or Inactive mode
   2069           * @param[in] value
   2070           ******************************************************************************/
   2071          void EMU_BUThresholdSet(EMU_BODMode_TypeDef mode, uint32_t value)
   2072          {
   2073            EFM_ASSERT(value < 8);
   2074            EFM_ASSERT(value <= (_EMU_BUACT_BUEXTHRES_MASK >> _EMU_BUACT_BUEXTHRES_SHIFT));
   2075          
   2076            switch (mode) {
   2077              case emuBODMode_Active:
   2078                EMU->BUACT = (EMU->BUACT & ~_EMU_BUACT_BUEXTHRES_MASK)
   2079                             | (value << _EMU_BUACT_BUEXTHRES_SHIFT);
   2080                break;
   2081              case emuBODMode_Inactive:
   2082                EMU->BUINACT = (EMU->BUINACT & ~_EMU_BUINACT_BUENTHRES_MASK)
   2083                               | (value << _EMU_BUINACT_BUENTHRES_SHIFT);
   2084                break;
   2085            }
   2086          }
   2087          
   2088          /***************************************************************************//**
   2089           * @brief
   2090           *  Configure the Backup Power Domain BOD Threshold Range.
   2091           * @note
   2092           *  These values are precalibrated.
   2093           * @param[in] mode Active or Inactive mode
   2094           * @param[in] value
   2095           ******************************************************************************/
   2096          void EMU_BUThresRangeSet(EMU_BODMode_TypeDef mode, uint32_t value)
   2097          {
   2098            EFM_ASSERT(value < 4);
   2099            EFM_ASSERT(value <= (_EMU_BUACT_BUEXRANGE_MASK >> _EMU_BUACT_BUEXRANGE_SHIFT));
   2100          
   2101            switch (mode) {
   2102              case emuBODMode_Active:
   2103                EMU->BUACT = (EMU->BUACT & ~_EMU_BUACT_BUEXRANGE_MASK)
   2104                             | (value << _EMU_BUACT_BUEXRANGE_SHIFT);
   2105                break;
   2106              case emuBODMode_Inactive:
   2107                EMU->BUINACT = (EMU->BUINACT & ~_EMU_BUINACT_BUENRANGE_MASK)
   2108                               | (value << _EMU_BUINACT_BUENRANGE_SHIFT);
   2109                break;
   2110            }
   2111          }
   2112          #endif
