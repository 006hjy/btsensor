   4293          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   4294          /***************************************************************************//**
   4295           * @brief
   4296           *   Adjust the bias refresh rate.
   4297           *
   4298           * @details
   4299           *   This function is only meant to be used under high-temperature operation on
   4300           *   EFR32xG1 and EFM32xG1 devices. Adjusting the bias mode will
   4301           *   increase the typical current consumption. See application note 1027
   4302           *   and errata documents for more details.
   4303           *
   4304           * @param [in] mode
   4305           *   The new bias refresh rate.
   4306           ******************************************************************************/
   4307          void EMU_SetBiasMode(EMU_BiasMode_TypeDef mode)
   4308          {
   4309            uint32_t freq = 0x2u;
   4310            bool emuTestLocked = false;
   4311          
   4312            if (mode == emuBiasMode_1KHz) {
   4313              freq = 0x0u;
   4314            }
   4315          
   4316            if (EMU_TESTLOCK == 0x1u) {
   4317              emuTestLocked = true;
   4318              EMU_TESTLOCK = 0xADE8u;
   4319            }
   4320          
   4321            if (mode == emuBiasMode_Continuous) {
   4322              EMU_BIASCONF &= ~0x74u;
   4323            } else {
   4324              EMU_BIASCONF |= 0x74u;
   4325            }
   4326          
   4327            EMU_BIASTESTCTRL |= 0x8u;
   4328            CMU_ULFRCOCTRL    = (CMU_ULFRCOCTRL & ~0xC00u)
   4329                                | ((freq & 0x3u) << 10u);
   4330            EMU_BIASTESTCTRL &= ~0x8u;
   4331          
   4332            if (emuTestLocked) {
   4333              EMU_TESTLOCK = 0u;
   4334            }
   4335          }
   4336          #endif
