   2114          #if defined(BU_PRESENT) && defined(_SILICON_LABS_32B_SERIES_1)
   2115          /***************************************************************************//**
   2116           * @brief
   2117           *   Configure Backup Power Domain settings.
   2118           *
   2119           * @param[in] buInit
