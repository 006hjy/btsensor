    346            || defined(ERRATA_FIX_EMU_E110_ENABLE)
    347          SL_RAMFUNC_DECLARATOR static void __attribute__ ((noinline)) ramWFI(void);
    348          SL_RAMFUNC_DEFINITION_BEGIN

   \                                 In section text_application_ram, align 4, keep-with-next
    349          static void __attribute__ ((noinline)) ramWFI(void)
    350          {
   \                     ramWFI: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    351          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_205)
    352            EMU_CallWFI();                      // Enter EM2 or EM3
   \        0x2   0x.... 0x....      BL       EMU_CallWFI
    353            if (CoreDebug->DHCSR & CoreDebug_DHCSR_C_DEBUGEN_Msk) {
   \        0x6   0x4806             LDR.N    R0,??ramWFI_0
   \        0x8   0x6801             LDR      R1,[R0, #+0]
   \        0xA   0x07CA             LSLS     R2,R1,#+31
   \        0xC   0xD507             BPL.N    ??ramWFI_1
    354              for (volatile int i = 0; i < 6; i++) {
   \        0xE   0x2000             MOVS     R0,#+0
   \       0x10   0xE001             B.N      ??ramWFI_2
   \                     ??ramWFI_3: (+1)
   \       0x12   0x9800             LDR      R0,[SP, #+0]
   \       0x14   0x1C40             ADDS     R0,R0,#+1
   \                     ??ramWFI_2: (+1)
   \       0x16   0x9000             STR      R0,[SP, #+0]
   \       0x18   0x9800             LDR      R0,[SP, #+0]
   \       0x1A   0x2806             CMP      R0,#+6
   \       0x1C   0xDBF9             BLT.N    ??ramWFI_3
    355              }                           // Dummy wait loop ...
    356            }
    357          
    358          #else
    359            EMU_CallWFI();                      // Enter EM2 or EM3
    360          #if defined(__GNUC__)
    361          #pragma GCC diagnostic push
    362          #pragma GCC diagnostic ignored "-Warray-bounds"
    363          #endif
    364            *(volatile uint32_t*)4;       // Clear faulty read data after wakeup
    365          #if defined(__GNUC__)
    366          #pragma GCC diagnostic pop
    367          #endif
    368          #endif
    369          }
   \                     ??ramWFI_1: (+1)
   \       0x1E   0xBD01             POP      {R0,PC}
   \                     ??ramWFI_0:
   \       0x20   0xE000'EDF0        DC32     0xe000edf0
    370          SL_RAMFUNC_DEFINITION_END
    371          #endif
    372          
    373          #if defined(ERRATA_FIX_EMU_E220_DECBOD_ENABLE)
    374          SL_RAMFUNC_DECLARATOR static void __attribute__ ((noinline)) ramWFI(void);
    375          SL_RAMFUNC_DEFINITION_BEGIN
    376          static void __attribute__ ((noinline)) ramWFI(void)
    377          {
    378            /* Second part of EMU_E220 DECBOD Errata fix. Calibration needs to be disabled
    379             * quickly when coming out of EM2/EM3. Ram execution is needed to meet timing.
    380             * Calibration is re-enabled after voltage scaling completes. */
    381            uint32_t temp = EMU_PORBOD | EMU_PORBOD_GMC_CALIB_DISABLE;
    382            EMU_CallWFI();
    383            EMU_PORBOD = temp;
    384          }
    385          SL_RAMFUNC_DEFINITION_END
    386          #endif
    387          
    388          #if (_SILICON_LABS_32B_SERIES < 2)
    389          /***************************************************************************//**
    390           * @brief
    391           *   Save/restore/update oscillator, core clock and voltage scaling configuration on
    392           *   EM2 or EM3 entry/exit.
    393           *
    394           * @details
    395           *   Hardware may automatically change the oscillator and the voltage scaling configuration
    396           *   when going into or out of an energy mode. Static data in this function keeps track of
    397           *   such configuration bits and is used to restore state if needed.
    398           *
    399           ******************************************************************************/
    400          typedef enum {
    401            emState_Save,         /* Save EMU and CMU state. */
    402            emState_Restore,      /* Restore and unlock.     */
    403          } emState_TypeDef;
    404          
    405          static void emState(emState_TypeDef action)
    406          {
    407            uint32_t oscEnCmd;
    408            uint32_t cmuLocked;
    409            static uint32_t cmuStatus;
    410            static CMU_Select_TypeDef hfClock;
    411          #if defined(EMU_VSCALE_PRESENT)
    412            static uint8_t vScaleStatus;
    413            static uint32_t hfrcoCtrl;
    414          #endif
    415          
    416            /* Save or update state. */
    417            if (action == emState_Save) {
    418              /* Save configuration. */
    419              cmuStatus = CMU->STATUS;
    420              hfClock = CMU_ClockSelectGet(cmuClock_HF);
    421          #if defined(EMU_VSCALE_PRESENT)
    422              /* Save vscale. */
    423              EMU_VScaleWait();
    424              vScaleStatus = (uint8_t)((EMU->STATUS & _EMU_STATUS_VSCALE_MASK)
    425                                       >> _EMU_STATUS_VSCALE_SHIFT);
    426              hfrcoCtrl = CMU->HFRCOCTRL;
    427          #endif
    428            } else { /* Restore state. */
    429              /* Apply saved configuration. */
    430          #if defined(EMU_VSCALE_PRESENT)
    431          #if defined(_SILICON_LABS_32B_SERIES_1)
    432              if (EMU_LDOStatusGet() == true)
    433              /* Restore voltage scaling level if LDO regulator is on. */
    434          #endif
    435              {
    436                /* Restore EM0 and 1 voltage scaling level.
    437                   @ref EMU_VScaleWait() is called later,
    438                   just before HF clock select is set. */
    439                EMU->CMD = vScaleEM01Cmd((EMU_VScaleEM01_TypeDef)vScaleStatus);
    440              }
    441          #endif
    442              /* CMU registers may be locked. */
    443              cmuLocked = CMU->LOCK & CMU_LOCK_LOCKKEY_LOCKED;
    444              CMU_Unlock();
    445          
    446          #if defined(_CMU_OSCENCMD_MASK)
    447              /* AUXHFRCO are automatically disabled (except if using debugger). */
    448              /* HFRCO, USHFRCO and HFXO are automatically disabled. */
    449              /* LFRCO/LFXO may be disabled by SW in EM3. */
    450              /* Restore according to status prior to entering energy mode. */
    451              oscEnCmd = 0;
    452              oscEnCmd |= (cmuStatus & CMU_STATUS_HFRCOENS) != 0U
    453                          ? CMU_OSCENCMD_HFRCOEN : 0U;
    454              oscEnCmd |= (cmuStatus & CMU_STATUS_AUXHFRCOENS) != 0U
    455                          ? CMU_OSCENCMD_AUXHFRCOEN : 0U;
    456              oscEnCmd |= (cmuStatus & CMU_STATUS_LFRCOENS) != 0U
    457                          ? CMU_OSCENCMD_LFRCOEN : 0U;
    458              oscEnCmd |= (cmuStatus & CMU_STATUS_HFXOENS) != 0U
    459                          ? CMU_OSCENCMD_HFXOEN : 0U;
    460              oscEnCmd |= (cmuStatus & CMU_STATUS_LFXOENS) != 0U
    461                          ? CMU_OSCENCMD_LFXOEN : 0U;
    462          #if defined(_CMU_STATUS_USHFRCOENS_MASK)
    463              oscEnCmd |= (cmuStatus & CMU_STATUS_USHFRCOENS) != 0U
    464                          ? CMU_OSCENCMD_USHFRCOEN : 0U;
    465          #endif
    466              CMU->OSCENCMD = oscEnCmd;
    467          #endif
    468          
    469          #if defined(_EMU_STATUS_VSCALE_MASK)
    470              /* Wait for upscale to complete and then restore selected clock. */
    471              EMU_VScaleWait();
    472              if ((EMU->CTRL & _EMU_CTRL_EM23VSCALEAUTOWSEN_MASK) != 0U) {
    473                /* Restore HFRCO frequency which was automatically adjusted by hardware. */
    474                while ((CMU->SYNCBUSY & CMU_SYNCBUSY_HFRCOBSY) != 0U) {
    475                }
    476                CMU->HFRCOCTRL = hfrcoCtrl;
    477                if (hfClock == cmuSelect_HFRCO) {
    478                  /* Optimize wait state after EM2/EM3 wakeup because hardware has
    479                   * modified them. */
    480                  CMU_UpdateWaitStates(SystemHfrcoFreq, (int)EMU_VScaleGet());
    481                }
    482              }
    483          #endif
    484          
    485              switch (hfClock) {
    486                case cmuSelect_LFXO:
    487                  CMU_CLOCK_SELECT_SET(HF, LFXO);
    488                  break;
    489                case cmuSelect_LFRCO:
    490                  CMU_CLOCK_SELECT_SET(HF, LFRCO);
    491                  break;
    492                case cmuSelect_HFXO:
    493                  CMU_CLOCK_SELECT_SET(HF, HFXO);
    494                  break;
    495          #if defined(CMU_CMD_HFCLKSEL_USHFRCODIV2)
    496                case cmuSelect_USHFRCODIV2:
    497                  CMU_CLOCK_SELECT_SET(HF, USHFRCODIV2);
    498                  break;
    499          #endif
    500          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
    501                case cmuSelect_HFRCODIV2:
    502                  CMU_CLOCK_SELECT_SET(HF, HFRCODIV2);
    503                  break;
    504          #endif
    505          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
    506                case cmuSelect_CLKIN0:
    507                  CMU_CLOCK_SELECT_SET(HF, CLKIN0);
    508                  break;
    509          #endif
    510          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
    511                case cmuSelect_USHFRCO:
    512                  CMU_CLOCK_SELECT_SET(HF, USHFRCO);
    513                  break;
    514          #endif
    515              }
    516          
    517          #if defined(_CMU_OSCENCMD_MASK)
    518              /* If HFRCO was disabled before entering Energy Mode, turn it off again */
    519              /* as it is automatically enabled by wake up */
    520              if ((cmuStatus & CMU_STATUS_HFRCOENS) == 0U) {
    521                CMU->OSCENCMD = CMU_OSCENCMD_HFRCODIS;
    522              }
    523          #endif
    524          
    525              /* Restore CMU register locking */
    526              if (cmuLocked != 0U) {
    527                CMU_Lock();
    528              }
    529            }
    530          }
    531          #endif
    532          
    533          #if defined(ERRATA_FIX_EMU_E107_ENABLE)
    534          /* Get enable conditions for errata EMU_E107 fix. */
    535          __STATIC_INLINE bool getErrataFixEmuE107En(void)
    536          {
    537          #if defined(_EFM32_HAPPY_FAMILY)   \
    538            || defined(_EFM32_TINY_FAMILY)   \
    539            || defined(_EFM32_WONDER_FAMILY) \
    540            || defined(_EFM32_ZERO_FAMILY)
    541            // all revisions have the errata
    542            return true;
    543          #else
    544            /* SYSTEM_ChipRevisionGet() could have been used here, but a faster implementation
    545             * would be needed in this case.
    546             */
    547            uint16_t majorMinorRev;
    548          
    549            /* CHIP MAJOR bit [3:0]. */
    550            majorMinorRev = ((ROMTABLE->PID0 & _ROMTABLE_PID0_REVMAJOR_MASK)
    551                             >> _ROMTABLE_PID0_REVMAJOR_SHIFT)
    552                            << 8;
    553            /* CHIP MINOR bit [7:4]. */
    554            majorMinorRev |= ((ROMTABLE->PID2 & _ROMTABLE_PID2_REVMINORMSB_MASK)
    555                              >> _ROMTABLE_PID2_REVMINORMSB_SHIFT)
    556                             << 4;
    557            /* CHIP MINOR bit [3:0]. */
    558            majorMinorRev |= (ROMTABLE->PID3 & _ROMTABLE_PID3_REVMINORLSB_MASK)
    559                             >> _ROMTABLE_PID3_REVMINORLSB_SHIFT;
    560          
    561          #if defined(_EFM32_GECKO_FAMILY)
    562            // all GECKO revisions except Revision E have the errata
    563            return (majorMinorRev <= 0x0103);
    564          #elif defined(_EFM32_GIANT_FAMILY)
    565            // all LEOPARD GECKO (Major = 0x01 Or 0x02) revisions have the errata
    566            // all GIANT GECKO (Major = 0x01) revisions except Revision E have the errata
    567            return (majorMinorRev <= 0x0103) || (majorMinorRev == 0x0204) || (majorMinorRev == 0x0205);
    568          #else
    569            /* Invalid configuration. */
    570            EFM_ASSERT(false);
    571            /* Return when assertions are disabled. */
    572            return false;
    573          #endif
    574          #endif /* #if defined(_EFM32_ZERO_FAMILY) || defined(_EFM32_HAPPY_FAMILY) #else */
    575          }
    576          #endif /* #if defined(ERRATA_FIX_EMU_E107_ENABLE) */
    577          
    578          #if defined(ERRATA_FIX_EMU_E110_ENABLE)
    579          /* Get enable conditions for errata EMU_E110 fix. */
    580          __STATIC_INLINE bool getErrataFixEmuE110En(void)
    581          {
    582            /* SYSTEM_ChipRevisionGet() could have been used here, but a faster implementation
    583             * would be needed in this case.
    584             */
    585            uint16_t majorMinorRev;
    586          
    587            /* CHIP MAJOR bit [3:0]. */
    588            majorMinorRev = ((ROMTABLE->PID0 & _ROMTABLE_PID0_REVMAJOR_MASK)
    589                             >> _ROMTABLE_PID0_REVMAJOR_SHIFT)
    590                            << 8;
    591            /* CHIP MINOR bit [7:4]. */
    592            majorMinorRev |= ((ROMTABLE->PID2 & _ROMTABLE_PID2_REVMINORMSB_MASK)
    593                              >> _ROMTABLE_PID2_REVMINORMSB_SHIFT)
    594                             << 4;
    595            /* CHIP MINOR bit [3:0]. */
    596            majorMinorRev |= (ROMTABLE->PID3 & _ROMTABLE_PID3_REVMINORLSB_MASK)
    597                             >> _ROMTABLE_PID3_REVMINORLSB_SHIFT;
    598          
    599          #if defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_ZERO_FAMILY)
    600            return (majorMinorRev == 0x0100);
    601          #elif defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_HAPPY_FAMILY)
    602            return ((majorMinorRev == 0x0100 || majorMinorRev == 0x0101));
    603          #elif defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_WONDER_FAMILY)
    604            return (majorMinorRev == 0x0100);
    605          #elif defined(_SILICON_LABS_32B_SERIES_0) && defined(_EFM32_GIANT_FAMILY)
    606            return (majorMinorRev == 0x0204);
    607          #else
    608            /* Invalid configuration. */
    609            EFM_ASSERT(false);
    610            /* Return when assertions are disabled. */
    611            return false;
    612          #endif
    613          }
    614          #endif /* #if defined(ERRATA_FIX_EMU_E110_ENABLE) */
    615          
    616          /* LP prepare / LN restore P/NFET count. */
    617          #if defined(ERRATA_FIX_DCDC_FETCNT_SET_ENABLE)
    618          static void currentLimitersUpdate(void);
    619          static void dcdcFetCntSet(bool lpModeSet)
    620          {
    621            uint32_t tmp;
    622            static uint32_t emuDcdcMiscCtrlReg;
    623          
    624            if (lpModeSet) {
    625              emuDcdcMiscCtrlReg = EMU->DCDCMISCCTRL;
    626              tmp  = EMU->DCDCMISCCTRL
    627                     & ~(_EMU_DCDCMISCCTRL_PFETCNT_MASK | _EMU_DCDCMISCCTRL_NFETCNT_MASK);
    628              tmp |= (DCDC_LP_PFET_CNT << _EMU_DCDCMISCCTRL_PFETCNT_SHIFT)
    629                     | (DCDC_LP_NFET_CNT << _EMU_DCDCMISCCTRL_NFETCNT_SHIFT);
    630              EMU->DCDCMISCCTRL = tmp;
    631              currentLimitersUpdate();
    632            } else {
    633              EMU->DCDCMISCCTRL = emuDcdcMiscCtrlReg;
    634              currentLimitersUpdate();
    635            }
    636          }
    637          #endif
    638          
    639          #if defined(ERRATA_FIX_DCDC_LNHS_BLOCK_ENABLE)
    640          static void dcdcHsFixLnBlock(void)
    641          {
    642            if ((errataFixDcdcHsState == errataFixDcdcHsTrimSet)
    643                || (errataFixDcdcHsState == errataFixDcdcHsBypassLn)) {
    644              /* Wait for LNRUNNING */
    645              if ((EMU->DCDCCTRL & _EMU_DCDCCTRL_DCDCMODE_MASK) == EMU_DCDCCTRL_DCDCMODE_LOWNOISE) {
    646                while (!(EMU_DCDCSTATUS & (0x1 << 16))) {
    647                }
    648              }
    649              errataFixDcdcHsState = errataFixDcdcHsLnWaitDone;
    650            }
    651          }
    652          #endif
    653          
    654          #if defined(_EMU_CTRL_EM23VSCALE_MASK) && defined(EMU_CTRL_EM23VSCALEAUTOWSEN)
    655          /* Configure EMU and CMU for EM2 and 3 voltage downscale. */
    656          static void vScaleDownEM23Setup(void)
    657          {
    658          #if defined(_SILICON_LABS_32B_SERIES_1)
    659            if (EMU_LDOStatusGet() == false) {
    660              /* Skip voltage scaling if the LDO regulator is turned off. */
    661              return;
    662            }
    663          #endif
    664          
    665            /* Wait until previous scaling is done. */
    666            EMU_VScaleWait();
    667          
    668            uint32_t em23vs = (EMU->CTRL & _EMU_CTRL_EM23VSCALE_MASK) >> _EMU_CTRL_EM23VSCALE_SHIFT;
    669            uint32_t em01vs = (EMU->STATUS & _EMU_STATUS_VSCALE_MASK) >> _EMU_STATUS_VSCALE_SHIFT;
    670          
    671            /* Inverse coding. */
    672            if (em23vs > em01vs) {
    673              EMU->CTRL |= EMU_CTRL_EM23VSCALEAUTOWSEN;
    674          #if defined(_MSC_RAMCTRL_RAMWSEN_MASK)
    675              /* Set RAM wait states for safe EM2 wakeup. */
    676              BUS_RegMaskedSet(&MSC->RAMCTRL, (MSC_RAMCTRL_RAMWSEN
    677                                               | MSC_RAMCTRL_RAM1WSEN
    678                                               | MSC_RAMCTRL_RAM2WSEN));
    679          #endif
    680            } else {
    681              EMU->CTRL &= ~EMU_CTRL_EM23VSCALEAUTOWSEN;
    682            }
    683          }
    684          
    685          /* Handle automatic HFRCO adjustment that may have occurred during EM2/EM3. */
    686          static void vScaleAfterWakeup(void)
    687          {
    688            if ((EMU->CTRL & EMU_CTRL_EM23VSCALEAUTOWSEN) != 0U) {
    689              /* The hardware may have updated the HFRCOCTRL register during EM2/EM3
    690               * entry if voltage scaling in EM2/EM3 is enabled. The hardware would
    691               * then update the HFRCO frequency to 19 MHz automatically. */
    692              uint32_t freqRange = (CMU->HFRCOCTRL & _CMU_HFRCOCTRL_FREQRANGE_MASK)
    693                                   >> _CMU_HFRCOCTRL_FREQRANGE_SHIFT;
    694              if (freqRange == 0x08U) {
