   \        0x4   0xB5F8             PUSH     {R3-R7,LR}
   \        0x6   0x....             LDR.N    R3,??DataTable18_4
   \        0x8   0x601A             STR      R2,[R3, #+0]
   3501          #if defined(_DCDC_EN_EN_MASK)
   3502            DCDC->EN_SET = DCDC_EN_EN;
   \        0xA   0x....             LDR.N    R2,??DataTable18_23
   \        0xC   0x2501             MOVS     R5,#+1
   \        0xE   0x6015             STR      R5,[R2, #+0]
   3503          #endif
   3504            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   \       0x10   0x....             LDR.N    R3,??DataTable18_24
   \       0x12   0x6BDD             LDR      R5,[R3, #+60]
   3505            EMU_DCDCUnlock();
   \       0x14   0xF64A 0x36CD      MOVW     R6,#+43981
   \       0x18   0x639E             STR      R6,[R3, #+56]
   \       0x1A   0x2400             MOVS     R4,#+0
   \       0x1C   0x2100             MOVS     R1,#+0
   \       0x1E   0xF005 0x0501      AND      R5,R5,#0x1
   3506          
   3507            if (dcdcMode == emuDcdcMode_Bypass) {
   \       0x22   0x....             LDR.N    R6,??DataTable18_25
   \       0x24   0x....             LDR.N    R7,??DataTable18_26
   \       0x26   0xB990             CBNZ.N   R0,??EMU_DCDCModeSet_0
   3508          #if defined(_DCDC_SYNCBUSY_MASK)
   3509          #if defined(_DCDC_SYNCBUSY_CTRL_MASK)
   3510              EMU_DCDCSync(DCDC_SYNCBUSY_CTRL);
   3511          #else
   3512              EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3513          #endif
   3514          #endif
   3515              currentDcdcMode = (DCDC->CTRL & _DCDC_CTRL_MODE_MASK) >> _DCDC_CTRL_MODE_SHIFT;
   \       0x28   0x6818             LDR      R0,[R3, #+0]
   3516          
   3517              if (currentDcdcMode != emuDcdcMode_Bypass) {
   \       0x2A   0x07C0             LSLS     R0,R0,#+31
   \       0x2C   0xD50B             BPL.N    ??EMU_DCDCModeSet_1
   3518                /* Switch to BYPASS mode if it is not the current mode */
   3519                DCDC->CTRL_CLR = DCDC_CTRL_MODE;
   \       0x2E   0x2201             MOVS     R2,#+1
