   3783            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3784          
   3785            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3786            EMU_DCDCUnlock();
   3787          
   3788          #if defined(_DCDC_SYNCBUSY_MASK)
   3789            /* Wait for synchronization before writing new value */
   3790            EMU_DCDCSync(DCDC_SYNCBUSY_PFMXCTRL);
   3791          #endif
   3792          
   3793            DCDC->PFMXCTRL = ((DCDC->PFMXCTRL & ~_DCDC_PFMXCTRL_IPKTMAXCTRL_MASK)
   3794                              | value << _DCDC_PFMXCTRL_IPKTMAXCTRL_SHIFT);
   3795          
   3796            if (dcdcLocked) {
   3797              EMU_DCDCLock();
   3798            }
   3799          
   3800            if (!dcdcClkWasEnabled) {
   3801              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3802            }
   3803          
   3804            EMU_DCDCUpdatedHook();
   3805          }
   3806          #endif /* _DCDC_PFMXCTRL_IPKTMAXCTRL_MASK */
   3807          #endif /* EMU_SERIES2_DCDC_BUCK_PRESENT */
   3808          
   3809          #if defined(_DCDC_DOCTRL_REGULATIONTYPE_MASK)
   3810          /***************************************************************************//**
   3811           * @brief
   3812           *   Set DCDC dual output regulation type.
   3813           *
   3814           * @param[in] regulationType
   3815           *   Regulation type for dual output DCDC configuration.
   3816           ******************************************************************************/
   3817          void EMU_DCDCSetRegulationType(EMU_DcdcRegulationType_TypeDef regulationType)
   3818          {
   3819            bool dcdcLocked = false;
   3820            bool dcdcClkWasEnabled = false;
   3821          
   3822            dcdcClkWasEnabled = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) != 0);
   3823            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3824          
   3825            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3826            EMU_DCDCUnlock();
   3827          
   3828          #if defined(DCDC_SYNCBUSY_DOCTRL)
   3829            EMU_DCDCSync(DCDC_SYNCBUSY_DOCTRL);
   3830          #endif
   3831          
   3832            DCDC->DOCTRL = ((DCDC->DOCTRL & ~_DCDC_DOCTRL_REGULATIONTYPE_MASK)
   3833                            | ((uint32_t)regulationType << _DCDC_DOCTRL_REGULATIONTYPE_SHIFT));
   3834          
   3835            if (dcdcLocked) {
   3836              EMU_DCDCLock();
   3837            }
   3838          
   3839            if (!dcdcClkWasEnabled) {
   3840              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3841            }
   3842          
   3843            EMU_DCDCUpdatedHook();
   3844          }
   3845          
   3846          /***************************************************************************//**
   3847           * @brief
   3848           *   Get current DCDC regulation type.
   3849           *
   3850           * @return
   3851           *   Current regulation type setting.
   3852           ******************************************************************************/
   3853          EMU_DcdcRegulationType_TypeDef EMU_DCDCGetRegulationType(void)
   3854          {
   3855            bool dcdcClkWasEnabled = false;
   3856            uint32_t regValue;
   3857          
   3858            dcdcClkWasEnabled = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) != 0);
   3859            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3860          
   3861            regValue = (DCDC->DOCTRL & _DCDC_DOCTRL_REGULATIONTYPE_MASK) >> _DCDC_DOCTRL_REGULATIONTYPE_SHIFT;
   3862          
   3863            if (!dcdcClkWasEnabled) {
   3864              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3865            }
   3866          
   3867            return (EMU_DcdcRegulationType_TypeDef)regValue;
   3868          }
   3869          #endif
   3870          
   3871          #if defined(_DCDC_DOCTRL_DUALIPKEN_MASK)
   3872          /***************************************************************************//**
   3873           * @brief
   3874           *   Enable or disable dual IPK DAC mode.
   3875           *
   3876           * @param[in] enable
   3877           *   True to enable separate IPK DAC values for DVDD and DEC outputs.
   3878           ******************************************************************************/
   3879          void EMU_DCDCSetDualIpkEnable(bool enable)
   3880          {
   3881            bool dcdcLocked = false;
   3882            bool dcdcClkWasEnabled = false;
   3883          
   3884            dcdcClkWasEnabled = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) != 0);
   3885            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3886          
   3887            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3888            EMU_DCDCUnlock();
   3889          
   3890          #if defined(DCDC_SYNCBUSY_DOCTRL)
   3891            EMU_DCDCSync(DCDC_SYNCBUSY_DOCTRL);
   3892          #endif
   3893          
   3894            if (enable) {
   3895              DCDC->DOCTRL |= DCDC_DOCTRL_DUALIPKEN;
   3896            } else {
   3897              DCDC->DOCTRL &= ~DCDC_DOCTRL_DUALIPKEN;
   3898            }
   3899          
   3900            if (dcdcLocked) {
   3901              EMU_DCDCLock();
   3902            }
   3903          
   3904            if (!dcdcClkWasEnabled) {
   3905              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3906            }
   3907          
   3908            EMU_DCDCUpdatedHook();
   3909          }
   3910          
   3911          /***************************************************************************//**
   3912           * @brief
   3913           *   Get current dual IPK enable state.
   3914           *
   3915           * @return
   3916           *   True if dual IPK DAC mode is enabled.
   3917           ******************************************************************************/
   3918          bool EMU_DCDCGetDualIpkEnable(void)
   3919          {
   3920            bool dcdcClkWasEnabled = false;
   3921            bool result;
   3922          
   3923            dcdcClkWasEnabled = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) != 0);
   3924            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3925          
   3926            result = ((DCDC->DOCTRL & DCDC_DOCTRL_DUALIPKEN) != 0);
   3927          
   3928            if (!dcdcClkWasEnabled) {
   3929              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3930            }
   3931          
   3932            return result;
   3933          }
   3934          #endif
   3935          
   3936          #if defined(EMU_STATUS_VMONRDY)
   3937          
   3938          /***************************************************************************//**
   3939           * @brief
   3940           *   Get the calibrated threshold value.
   3941           *
   3942           * @details
   3943           *   All VMON channels have two calibration fields in the DI page that
   3944           *   describes the threshold at 1.86 V and 2.98 V. This function will convert
   3945           *   the uncalibrated input voltage threshold in millivolts into a calibrated
   3946           *   threshold.
   3947           *
   3948           * @param[in] channel
   3949           *   A VMON channel.
   3950           *
   3951           * @param[in] threshold
   3952           *   A desired threshold in millivolts.
   3953           *
   3954           * @return
   3955           *   A calibrated threshold value to use. The first digit of the return value is placed
   3956           *   in the "fine" register fields while the next digits are placed in the
   3957           *   "coarse" register fields.
   3958           ******************************************************************************/
   3959          static uint32_t vmonCalibratedThreshold(EMU_VmonChannel_TypeDef channel,
   3960                                                  int threshold)
   3961          {
   3962            uint32_t tDiff = 0;
   3963            uint32_t tLow = 0;
   3964            uint32_t tHigh = 0;
   3965            uint32_t calReg;
   3966          
   3967            /* Get calibration values for 1.86 V and 2.98 V */
   3968            switch (channel) {
   3969              case emuVmonChannel_AVDD:
   3970                calReg = DEVINFO->VMONCAL0;
   3971                tLow = (10U * ((calReg & _DEVINFO_VMONCAL0_AVDD1V86THRESCOARSE_MASK)
   3972                               >> _DEVINFO_VMONCAL0_AVDD1V86THRESCOARSE_SHIFT))
   3973                       + ((calReg & _DEVINFO_VMONCAL0_AVDD1V86THRESFINE_MASK)
   3974                          >> _DEVINFO_VMONCAL0_AVDD1V86THRESFINE_SHIFT);
   3975                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL0_AVDD2V98THRESCOARSE_MASK)
   3976                                >> _DEVINFO_VMONCAL0_AVDD2V98THRESCOARSE_SHIFT))
   3977                        + ((calReg & _DEVINFO_VMONCAL0_AVDD2V98THRESFINE_MASK)
   3978                           >> _DEVINFO_VMONCAL0_AVDD2V98THRESFINE_SHIFT);
   3979                break;
   3980              case emuVmonChannel_ALTAVDD:
   3981                calReg = DEVINFO->VMONCAL0;
   3982                tLow = (10U * ((calReg & _DEVINFO_VMONCAL0_ALTAVDD1V86THRESCOARSE_MASK)
   3983                               >> _DEVINFO_VMONCAL0_ALTAVDD1V86THRESCOARSE_SHIFT))
   3984                       + ((calReg & _DEVINFO_VMONCAL0_ALTAVDD1V86THRESFINE_MASK)
   3985                          >> _DEVINFO_VMONCAL0_ALTAVDD1V86THRESFINE_SHIFT);
   3986                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL0_ALTAVDD2V98THRESCOARSE_MASK)
   3987                                >> _DEVINFO_VMONCAL0_ALTAVDD2V98THRESCOARSE_SHIFT))
   3988                        + ((calReg & _DEVINFO_VMONCAL0_ALTAVDD2V98THRESFINE_MASK)
   3989                           >> _DEVINFO_VMONCAL0_ALTAVDD2V98THRESFINE_SHIFT);
   3990                break;
   3991              case emuVmonChannel_DVDD:
   3992                calReg = DEVINFO->VMONCAL1;
   3993                tLow = (10U * ((calReg & _DEVINFO_VMONCAL1_DVDD1V86THRESCOARSE_MASK)
   3994                               >> _DEVINFO_VMONCAL1_DVDD1V86THRESCOARSE_SHIFT))
   3995                       + ((calReg & _DEVINFO_VMONCAL1_DVDD1V86THRESFINE_MASK)
   3996                          >> _DEVINFO_VMONCAL1_DVDD1V86THRESFINE_SHIFT);
   3997                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL1_DVDD2V98THRESCOARSE_MASK)
   3998                                >> _DEVINFO_VMONCAL1_DVDD2V98THRESCOARSE_SHIFT))
   3999                        + ((calReg & _DEVINFO_VMONCAL1_DVDD2V98THRESFINE_MASK)
   4000                           >> _DEVINFO_VMONCAL1_DVDD2V98THRESFINE_SHIFT);
   4001                break;
   4002              case emuVmonChannel_IOVDD0:
   4003                calReg = DEVINFO->VMONCAL1;
   4004                tLow = (10U * ((calReg & _DEVINFO_VMONCAL1_IO01V86THRESCOARSE_MASK)
   4005                               >> _DEVINFO_VMONCAL1_IO01V86THRESCOARSE_SHIFT))
   4006                       + ((calReg & _DEVINFO_VMONCAL1_IO01V86THRESFINE_MASK)
   4007                          >> _DEVINFO_VMONCAL1_IO01V86THRESFINE_SHIFT);
   4008                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL1_IO02V98THRESCOARSE_MASK)
   4009                                >> _DEVINFO_VMONCAL1_IO02V98THRESCOARSE_SHIFT))
   4010                        + ((calReg & _DEVINFO_VMONCAL1_IO02V98THRESFINE_MASK)
   4011                           >> _DEVINFO_VMONCAL1_IO02V98THRESFINE_SHIFT);
   4012                break;
   4013          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4014              case emuVmonChannel_IOVDD1:
   4015                calReg = DEVINFO->VMONCAL2;
   4016                tLow = (10U * ((calReg & _DEVINFO_VMONCAL2_IO11V86THRESCOARSE_MASK)
   4017                               >> _DEVINFO_VMONCAL2_IO11V86THRESCOARSE_SHIFT))
   4018                       + ((calReg & _DEVINFO_VMONCAL2_IO11V86THRESFINE_MASK)
   4019                          >> _DEVINFO_VMONCAL2_IO11V86THRESFINE_SHIFT);
   4020                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL2_IO12V98THRESCOARSE_MASK)
   4021                                >> _DEVINFO_VMONCAL2_IO12V98THRESCOARSE_SHIFT))
   4022                        + ((calReg & _DEVINFO_VMONCAL2_IO12V98THRESFINE_MASK)
   4023                           >> _DEVINFO_VMONCAL2_IO12V98THRESFINE_SHIFT);
   4024                break;
   4025          #endif
   4026          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4027              case emuVmonChannel_BUVDD:
   4028                calReg = DEVINFO->VMONCAL2;
   4029                tLow = (10U * ((calReg & _DEVINFO_VMONCAL2_BUVDD1V86THRESCOARSE_MASK)
   4030                               >> _DEVINFO_VMONCAL2_BUVDD1V86THRESCOARSE_SHIFT))
   4031                       + ((calReg & _DEVINFO_VMONCAL2_BUVDD1V86THRESFINE_MASK)
   4032                          >> _DEVINFO_VMONCAL2_BUVDD1V86THRESFINE_SHIFT);
   4033                tHigh = (10U * ((calReg & _DEVINFO_VMONCAL2_BUVDD2V98THRESCOARSE_MASK)
   4034                                >> _DEVINFO_VMONCAL2_BUVDD2V98THRESCOARSE_SHIFT))
   4035                        + ((calReg & _DEVINFO_VMONCAL2_BUVDD2V98THRESFINE_MASK)
   4036                           >> _DEVINFO_VMONCAL2_BUVDD2V98THRESFINE_SHIFT);
   4037                break;
   4038          #endif
   4039              default:
   4040                EFM_ASSERT(false);
   4041                break;
   4042            }
   4043          
   4044            tDiff = tHigh - tLow;
   4045            if (tDiff > 0) {
   4046              /* Calculate threshold.
   4047               *
   4048               * Note that volt is used in the reference manual. However, the results
   4049               * should be in millivolts. The precision of Va and Vb are increased in the
   4050               * calculation instead of using floating points.
   4051               */
   4052              uint32_t va = (1120U * 100U) / (tDiff);
   4053              uint32_t vb = (1860U * 100U) - (va * tLow);
   4054              // If (tHigh - tLow) is large, Va could be zero. Caught by CSTAT.
   4055              if (va != 0) {
   4056                /* Round the threshold to the nearest integer value. */
   4057                return (((uint32_t)threshold * 100U) - vb + (va / 2U)) / va;
   4058              }
   4059            }
   4060          
   4061            /* Uncalibrated device guard. */
   4062            return (uint32_t)threshold;
   4063          }
   4064          
   4065          /***************************************************************************//**
   4066           * @brief
   4067           *   Initialize a VMON channel.
   4068           *
   4069           * @details
   4070           *   Initialize a VMON channel without hysteresis. If the channel supports
   4071           *   separate rise and fall triggers, both thresholds will be set to the same
   4072           *   value. The threshold will be converted to a register field value based
   4073           *   on calibration values from the DI page.
   4074           *
   4075           * @param[in] vmonInit
   4076           *   The VMON initialization structure.
   4077           ******************************************************************************/
   4078          void EMU_VmonInit(const EMU_VmonInit_TypeDef *vmonInit)
   4079          {
   4080            uint32_t thresholdCoarse, thresholdFine;
   4081            uint32_t threshold;
   4082          
   4083            EFM_ASSERT((vmonInit->threshold >= 1620) && (vmonInit->threshold <= 3400));
   4084          
   4085            threshold = vmonCalibratedThreshold(vmonInit->channel, vmonInit->threshold);
   4086            thresholdFine = threshold % 10U;
   4087            thresholdCoarse = threshold / 10U;
   4088          
   4089            /* Saturate the threshold to maximum values. */
   4090            if (thresholdCoarse > 0xFU) {
   4091              thresholdCoarse = 0xF;
   4092              thresholdFine = 9;
   4093            }
   4094          
   4095            switch (vmonInit->channel) {
   4096              case emuVmonChannel_AVDD:
   4097                EMU->VMONAVDDCTRL = (thresholdCoarse << _EMU_VMONAVDDCTRL_RISETHRESCOARSE_SHIFT)
   4098                                    | (thresholdFine << _EMU_VMONAVDDCTRL_RISETHRESFINE_SHIFT)
   4099                                    | (thresholdCoarse << _EMU_VMONAVDDCTRL_FALLTHRESCOARSE_SHIFT)
   4100                                    | (thresholdFine << _EMU_VMONAVDDCTRL_FALLTHRESFINE_SHIFT)
   4101                                    | (vmonInit->riseWakeup ? EMU_VMONAVDDCTRL_RISEWU : 0U)
   4102                                    | (vmonInit->fallWakeup ? EMU_VMONAVDDCTRL_FALLWU : 0U)
   4103                                    | (vmonInit->enable     ? EMU_VMONAVDDCTRL_EN     : 0U);
   4104                break;
   4105              case emuVmonChannel_ALTAVDD:
   4106                EMU->VMONALTAVDDCTRL = (thresholdCoarse << _EMU_VMONALTAVDDCTRL_THRESCOARSE_SHIFT)
   4107                                       | (thresholdFine << _EMU_VMONALTAVDDCTRL_THRESFINE_SHIFT)
   4108                                       | (vmonInit->riseWakeup ? EMU_VMONALTAVDDCTRL_RISEWU : 0U)
   4109                                       | (vmonInit->fallWakeup ? EMU_VMONALTAVDDCTRL_FALLWU : 0U)
   4110                                       | (vmonInit->enable     ? EMU_VMONALTAVDDCTRL_EN     : 0U);
   4111                break;
   4112              case emuVmonChannel_DVDD:
   4113                EMU->VMONDVDDCTRL = (thresholdCoarse << _EMU_VMONDVDDCTRL_THRESCOARSE_SHIFT)
   4114                                    | (thresholdFine << _EMU_VMONDVDDCTRL_THRESFINE_SHIFT)
   4115                                    | (vmonInit->riseWakeup ? EMU_VMONDVDDCTRL_RISEWU : 0U)
   4116                                    | (vmonInit->fallWakeup ? EMU_VMONDVDDCTRL_FALLWU : 0U)
   4117                                    | (vmonInit->enable     ? EMU_VMONDVDDCTRL_EN     : 0U);
   4118                break;
   4119              case emuVmonChannel_IOVDD0:
   4120                EMU->VMONIO0CTRL = (thresholdCoarse << _EMU_VMONIO0CTRL_THRESCOARSE_SHIFT)
   4121                                   | (thresholdFine << _EMU_VMONIO0CTRL_THRESFINE_SHIFT)
   4122                                   | (vmonInit->retDisable ? EMU_VMONIO0CTRL_RETDIS : 0U)
   4123                                   | (vmonInit->riseWakeup ? EMU_VMONIO0CTRL_RISEWU : 0U)
   4124                                   | (vmonInit->fallWakeup ? EMU_VMONIO0CTRL_FALLWU : 0U)
   4125                                   | (vmonInit->enable     ? EMU_VMONIO0CTRL_EN     : 0U);
   4126                break;
   4127          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4128              case emuVmonChannel_IOVDD1:
   4129                EMU->VMONIO1CTRL = (thresholdCoarse << _EMU_VMONIO1CTRL_THRESCOARSE_SHIFT)
   4130                                   | (thresholdFine << _EMU_VMONIO1CTRL_THRESFINE_SHIFT)
   4131                                   | (vmonInit->retDisable ? EMU_VMONIO1CTRL_RETDIS : 0U)
   4132                                   | (vmonInit->riseWakeup ? EMU_VMONIO1CTRL_RISEWU : 0U)
   4133                                   | (vmonInit->fallWakeup ? EMU_VMONIO1CTRL_FALLWU : 0U)
   4134                                   | (vmonInit->enable     ? EMU_VMONIO1CTRL_EN     : 0U);
   4135                break;
   4136          #endif
   4137          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4138              case emuVmonChannel_BUVDD:
   4139                EMU->VMONBUVDDCTRL = (thresholdCoarse << _EMU_VMONBUVDDCTRL_THRESCOARSE_SHIFT)
   4140                                     | (thresholdFine << _EMU_VMONBUVDDCTRL_THRESFINE_SHIFT)
   4141                                     | (vmonInit->riseWakeup ? EMU_VMONBUVDDCTRL_RISEWU : 0U)
   4142                                     | (vmonInit->fallWakeup ? EMU_VMONBUVDDCTRL_FALLWU : 0U)
   4143                                     | (vmonInit->enable     ? EMU_VMONBUVDDCTRL_EN     : 0U);
   4144                break;
   4145          #endif
   4146              default:
   4147                EFM_ASSERT(false);
   4148                return;
   4149            }
   4150          }
   4151          
   4152          /***************************************************************************//**
   4153           * @brief
   4154           *   Initialize a VMON channel with hysteresis (separate rise and fall triggers).
   4155           *
   4156           * @details
   4157           *   Initialize a VMON channel which supports hysteresis. The AVDD channel is
   4158           *   the only channel to support separate rise and fall triggers. The rise and
   4159           *   fall thresholds will be converted to a register field value based on the
   4160           *   calibration values from the DI page.
   4161           *
   4162           * @param[in] vmonInit
   4163           *   The VMON hysteresis initialization structure.
   4164           ******************************************************************************/
   4165          void EMU_VmonHystInit(const EMU_VmonHystInit_TypeDef *vmonInit)
   4166          {
   4167            uint32_t riseThreshold;
   4168            uint32_t fallThreshold;
   4169          
   4170            /* VMON supports voltages between 1620 mV and 3400 mV (inclusive). */
   4171            EFM_ASSERT((vmonInit->riseThreshold >= 1620) && (vmonInit->riseThreshold <= 3400));
   4172            EFM_ASSERT((vmonInit->fallThreshold >= 1620) && (vmonInit->fallThreshold <= 3400));
   4173            /* The fall threshold has to be lower than rise threshold. */
   4174            EFM_ASSERT(vmonInit->fallThreshold <= vmonInit->riseThreshold);
   4175          
   4176            riseThreshold = vmonCalibratedThreshold(vmonInit->channel, vmonInit->riseThreshold);
   4177            fallThreshold = vmonCalibratedThreshold(vmonInit->channel, vmonInit->fallThreshold);
   4178          
   4179            switch (vmonInit->channel) {
   4180              case emuVmonChannel_AVDD:
   4181                EMU->VMONAVDDCTRL = ((riseThreshold / 10U) << _EMU_VMONAVDDCTRL_RISETHRESCOARSE_SHIFT)
   4182                                    | ((riseThreshold % 10U) << _EMU_VMONAVDDCTRL_RISETHRESFINE_SHIFT)
   4183                                    | ((fallThreshold / 10U) << _EMU_VMONAVDDCTRL_FALLTHRESCOARSE_SHIFT)
   4184                                    | ((fallThreshold % 10U) << _EMU_VMONAVDDCTRL_FALLTHRESFINE_SHIFT)
   4185                                    | (vmonInit->riseWakeup ? EMU_VMONAVDDCTRL_RISEWU : 0U)
   4186                                    | (vmonInit->fallWakeup ? EMU_VMONAVDDCTRL_FALLWU : 0U)
   4187                                    | (vmonInit->enable     ? EMU_VMONAVDDCTRL_EN     : 0U);
   4188                break;
   4189              default:
   4190                EFM_ASSERT(false);
   4191                return;
   4192            }
   4193          }
   4194          
   4195          /***************************************************************************//**
   4196           * @brief
   4197           *   Enable or disable a VMON channel.
   4198           *
   4199           * @param[in] channel
   4200           *   A VMON channel to enable/disable.
   4201           *
   4202           * @param[in] enable
   4203           *   Indicates whether to enable or disable.
   4204           ******************************************************************************/
   4205          void EMU_VmonEnable(EMU_VmonChannel_TypeDef channel, bool enable)
   4206          {
   4207            uint32_t volatile * reg;
   4208            uint32_t bit;
   4209          
   4210            switch (channel) {
   4211              case emuVmonChannel_AVDD:
   4212                reg = &(EMU->VMONAVDDCTRL);
   4213                bit = _EMU_VMONAVDDCTRL_EN_SHIFT;
   4214                break;
   4215              case emuVmonChannel_ALTAVDD:
   4216                reg = &(EMU->VMONALTAVDDCTRL);
   4217                bit = _EMU_VMONALTAVDDCTRL_EN_SHIFT;
   4218                break;
   4219              case emuVmonChannel_DVDD:
   4220                reg = &(EMU->VMONDVDDCTRL);
   4221                bit = _EMU_VMONDVDDCTRL_EN_SHIFT;
   4222                break;
   4223              case emuVmonChannel_IOVDD0:
   4224                reg = &(EMU->VMONIO0CTRL);
   4225                bit = _EMU_VMONIO0CTRL_EN_SHIFT;
   4226                break;
   4227          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4228              case emuVmonChannel_IOVDD1:
   4229                reg = &(EMU->VMONIO1CTRL);
   4230                bit = _EMU_VMONIO1CTRL_EN_SHIFT;
   4231                break;
   4232          #endif
   4233          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4234              case emuVmonChannel_BUVDD:
   4235                reg = &(EMU->VMONBUVDDCTRL);
