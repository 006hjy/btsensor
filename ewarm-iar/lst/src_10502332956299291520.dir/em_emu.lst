   3483          /***************************************************************************//**
   3484           * @brief
   3485           *   Set DCDC regulator operating mode.
   3486           *
   3487           * @param[in] dcdcMode
   3488           *   DCDC mode.
   3489           * @return
   3490           *   Returns the status of the DCDC mode set operation.
   3491           *   SL_STATUS_OK - Operation completed successfully.
   3492           *   SL_STATUS_TIMEOUT - Operation EMU DCDC set mode timeout.
   3493           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
   3494          sl_status_t EMU_DCDCModeSet(EMU_DcdcMode_TypeDef dcdcMode)
   3495          {
