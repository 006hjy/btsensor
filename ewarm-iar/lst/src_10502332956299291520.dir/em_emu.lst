   2296          /***************************************************************************//**
   2297           * @brief
   2298           *   Load DCDC calibration constants from the DI page. A constant means that calibration
   2299           *   data that does not change depending on other configuration parameters.
   2300           *
   2301           * @return
   2302           *   False if calibration registers are locked.
   2303           ******************************************************************************/
   2304          static bool dcdcConstCalibrationLoad(void)
   2305          {
   2306          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2307            uint32_t val;
   2308            volatile uint32_t *reg;
   2309          
   2310            /* DI calibration data in Flash. */
   2311            volatile uint32_t* const diCal_EMU_DCDCLNFREQCTRL =  (volatile uint32_t *)(0x0FE08038);
   2312            volatile uint32_t* const diCal_EMU_DCDCLNVCTRL =     (volatile uint32_t *)(0x0FE08040);
   2313            volatile uint32_t* const diCal_EMU_DCDCLPCTRL =      (volatile uint32_t *)(0x0FE08048);
   2314            volatile uint32_t* const diCal_EMU_DCDCLPVCTRL =     (volatile uint32_t *)(0x0FE08050);
   2315            volatile uint32_t* const diCal_EMU_DCDCTRIM0 =       (volatile uint32_t *)(0x0FE08058);
   2316            volatile uint32_t* const diCal_EMU_DCDCTRIM1 =       (volatile uint32_t *)(0x0FE08060);
   2317          
   2318            if (DEVINFO->DCDCLPVCTRL0 != UINT_MAX) {
   2319              val = *(diCal_EMU_DCDCLNFREQCTRL + 1);
   2320              reg = (volatile uint32_t *)*diCal_EMU_DCDCLNFREQCTRL;
   2321              *reg = val;
   2322          
   2323              val = *(diCal_EMU_DCDCLNVCTRL + 1);
   2324              reg = (volatile uint32_t *)*diCal_EMU_DCDCLNVCTRL;
   2325              *reg = val;
   2326          
   2327              val = *(diCal_EMU_DCDCLPCTRL + 1);
   2328              reg = (volatile uint32_t *)*diCal_EMU_DCDCLPCTRL;
   2329              *reg = val;
   2330          
   2331              val = *(diCal_EMU_DCDCLPVCTRL + 1);
   2332              reg = (volatile uint32_t *)*diCal_EMU_DCDCLPVCTRL;
   2333              *reg = val;
   2334          
   2335              val = *(diCal_EMU_DCDCTRIM0 + 1);
   2336              reg = (volatile uint32_t *)*diCal_EMU_DCDCTRIM0;
   2337              *reg = val;
   2338          
   2339              val = *(diCal_EMU_DCDCTRIM1 + 1);
   2340              reg = (volatile uint32_t *)*diCal_EMU_DCDCTRIM1;
   2341              *reg = val;
   2342          
   2343              return true;
   2344            }
   2345            EFM_ASSERT(false);
   2346            /* Return when assertions are disabled. */
   2347            return false;
   2348          
   2349          #else
   2350            return true;
   2351          #endif
   2352          }
   2353          
   2354          /***************************************************************************//**
   2355           * @brief
   2356           *   Set recommended and validated current optimization and timing settings.
   2357           *
   2358           ******************************************************************************/
   2359          static void dcdcValidatedConfigSet(void)
   2360          {
   2361            uint32_t lnForceCcm;
   2362          
   2363          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2364            uint32_t dcdcTiming;
   2365            SYSTEM_ChipRevision_TypeDef rev;
   2366          #endif
   2367          
   2368            /* Enable duty cycling of the bias. */
   2369            EMU->DCDCLPCTRL |= EMU_DCDCLPCTRL_LPVREFDUTYEN;
   2370          
   2371            /* Set low-noise RCO for LNFORCECCM configuration.
   2372             * LNFORCECCM is default 1 for EFR32
   2373             * LNFORCECCM is default 0 for EFM32
   2374             */
   2375            lnForceCcm = BUS_RegBitRead(&EMU->DCDCMISCCTRL, _EMU_DCDCMISCCTRL_LNFORCECCM_SHIFT);
   2376            if (lnForceCcm != 0U) {
   2377              /* 7 MHz is recommended for LNFORCECCM = 1. */
   2378              EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_7MHz);
   2379            } else {
   2380              /* 3 MHz is recommended for LNFORCECCM = 0. */
   2381              EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_3MHz);
   2382            }
   2383          
   2384          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2385            EMU->DCDCTIMING &= ~_EMU_DCDCTIMING_DUTYSCALE_MASK;
   2386            EMU->DCDCMISCCTRL |= EMU_DCDCMISCCTRL_LPCMPHYSDIS
   2387                                 | EMU_DCDCMISCCTRL_LPCMPHYSHI;
   2388          
   2389            SYSTEM_ChipRevisionGet(&rev);
   2390            if ((rev.major == 1)
   2391                && (rev.minor < 3)
   2392                && (errataFixDcdcHsState == errataFixDcdcHsInit)) {
   2393              /* LPCMPWAITDIS = 1 */
   2394              EMU_DCDCSMCTRL |= 1;
   2395          
   2396              dcdcTiming = EMU->DCDCTIMING;
   2397              dcdcTiming &= ~(_EMU_DCDCTIMING_LPINITWAIT_MASK
   2398                              | _EMU_DCDCTIMING_LNWAIT_MASK
   2399                              | _EMU_DCDCTIMING_BYPWAIT_MASK);
   2400          
   2401              dcdcTiming |= ((180 << _EMU_DCDCTIMING_LPINITWAIT_SHIFT)
   2402                             | (12 << _EMU_DCDCTIMING_LNWAIT_SHIFT)
   2403                             | (180 << _EMU_DCDCTIMING_BYPWAIT_SHIFT));
   2404              EMU->DCDCTIMING = dcdcTiming;
   2405          
   2406              errataFixDcdcHsState = errataFixDcdcHsTrimSet;
   2407            }
   2408          #endif
   2409          }
   2410          
   2411          /***************************************************************************//**
   2412           * @brief
   2413           *   Compute current limiters:
   2414           *     LNCLIMILIMSEL: LN current limiter threshold
   2415           *     LPCLIMILIMSEL: LP current limiter threshold
   2416           *     DCDCZDETCTRL:  zero detector limiter threshold
   2417           ******************************************************************************/
   2418          static void currentLimitersUpdate(void)
   2419          {
   2420            uint32_t lncLimSel;
   2421            uint32_t zdetLimSel;
   2422            uint32_t pFetCnt;
   2423            uint16_t maxReverseCurrent_mA;
   2424          
   2425            /* 80 mA as recommended peak in Application Note AN0948.
   2426               The peak current is the average current plus 50% of the current ripple.
   2427               Hence, a 14 mA average current is recommended in LP mode. Since LP PFETCNT is also
   2428               a constant, lpcLimImSel = 1. The following calculation is provided
   2429               for documentation only. */
   2430            const uint32_t lpcLim = (((14 + 40) + ((14 + 40) / 2))
   2431                                     / (5 * (DCDC_LP_PFET_CNT + 1)))
   2432                                    - 1;
   2433            const uint32_t lpcLimSel = lpcLim << _EMU_DCDCMISCCTRL_LPCLIMILIMSEL_SHIFT;
   2434          
   2435            /* Get enabled PFETs. */
   2436            pFetCnt = (EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_PFETCNT_MASK)
   2437                      >> _EMU_DCDCMISCCTRL_PFETCNT_SHIFT;
   2438          
   2439            /* Compute the LN current limiter threshold from the nominal user input current and
   2440               LN PFETCNT as described in the register description for
   2441               EMU_DCDCMISCCTRL_LNCLIMILIMSEL. */
   2442            lncLimSel = ((((uint32_t)dcdcMaxCurrent_mA + 40U)
   2443                          + (((uint32_t)dcdcMaxCurrent_mA + 40U) / 2U))
   2444                         / (5U * (pFetCnt + 1U)))
   2445                        - 1U;
   2446          
   2447            /* Saturate the register field value. */
   2448            lncLimSel = SL_MIN(lncLimSel,
   2449                               _EMU_DCDCMISCCTRL_LNCLIMILIMSEL_MASK
   2450                               >> _EMU_DCDCMISCCTRL_LNCLIMILIMSEL_SHIFT);
   2451          
   2452            lncLimSel <<= _EMU_DCDCMISCCTRL_LNCLIMILIMSEL_SHIFT;
   2453          
   2454            /* Check for overflow. */
   2455            EFM_ASSERT((lncLimSel & ~_EMU_DCDCMISCCTRL_LNCLIMILIMSEL_MASK) == 0x0U);
   2456            EFM_ASSERT((lpcLimSel & ~_EMU_DCDCMISCCTRL_LPCLIMILIMSEL_MASK) == 0x0U);
   2457          
   2458            EMU->DCDCMISCCTRL = (EMU->DCDCMISCCTRL & ~(_EMU_DCDCMISCCTRL_LNCLIMILIMSEL_MASK
   2459                                                       | _EMU_DCDCMISCCTRL_LPCLIMILIMSEL_MASK))
   2460                                | (lncLimSel | lpcLimSel);
   2461          
   2462            /* Compute the reverse current limit threshold for the zero detector from the user input
   2463               maximum reverse current and LN PFETCNT as described in the register description
   2464               for EMU_DCDCZDETCTRL_ZDETILIMSEL. */
   2465            if (dcdcReverseCurrentControl >= 0) {
   2466              /* If dcdcReverseCurrentControl < 0, EMU_DCDCZDETCTRL_ZDETILIMSEL is "don't care". */
   2467              maxReverseCurrent_mA = (uint16_t)dcdcReverseCurrentControl;
   2468          
   2469              zdetLimSel = ((((uint32_t)maxReverseCurrent_mA + 40U)
   2470                             + (((uint32_t)maxReverseCurrent_mA + 40U) / 2U))
   2471                            / ((2U * (pFetCnt + 1U)) + ((pFetCnt + 1U) / 2U)));
   2472              /* Saturate the register field value. */
   2473              zdetLimSel = SL_MIN(zdetLimSel,
   2474                                  _EMU_DCDCZDETCTRL_ZDETILIMSEL_MASK
   2475                                  >> _EMU_DCDCZDETCTRL_ZDETILIMSEL_SHIFT);
   2476          
   2477              zdetLimSel <<= _EMU_DCDCZDETCTRL_ZDETILIMSEL_SHIFT;
   2478          
   2479              /* Check for overflow. */
   2480              EFM_ASSERT((zdetLimSel & ~_EMU_DCDCZDETCTRL_ZDETILIMSEL_MASK) == 0x0U);
   2481          
   2482              EMU->DCDCZDETCTRL = (EMU->DCDCZDETCTRL & ~_EMU_DCDCZDETCTRL_ZDETILIMSEL_MASK)
   2483                                  | zdetLimSel;
   2484            }
   2485          }
   2486          
   2487          /***************************************************************************//**
   2488           * @brief
   2489           *   Set static variables that hold the user set maximum peak current
   2490           *   and reverse current. Update limiters.
   2491           *
   2492           * @param[in] maxCurrent_mA
   2493           *   Set the maximum peak current that the DCDC can draw from the power source.
   2494           * @param[in] reverseCurrentControl
   2495           *   Reverse the current control as defined by
   2496           *   @ref EMU_DcdcLnReverseCurrentControl_TypeDef. Positive values have unit mA.
   2497           ******************************************************************************/
   2498          static void userCurrentLimitsSet(uint32_t maxCurrent_mA,
   2499                                           EMU_DcdcLnReverseCurrentControl_TypeDef reverseCurrentControl)
   2500          {
   2501            dcdcMaxCurrent_mA = (uint16_t)maxCurrent_mA;
   2502            dcdcReverseCurrentControl = reverseCurrentControl;
   2503          }
   2504          
   2505          /***************************************************************************//**
   2506           * @brief
   2507           *   Set DCDC low noise compensator control register.
   2508           *
   2509           * @param[in] comp
   2510           *   Low-noise mode compensator trim setpoint.
   2511           ******************************************************************************/
   2512          static void compCtrlSet(EMU_DcdcLnCompCtrl_TypeDef comp)
   2513          {
   2514            switch (comp) {
   2515              case emuDcdcLnCompCtrl_1u0F:
   2516                EMU->DCDCLNCOMPCTRL = 0x57204077UL;
   2517                break;
   2518          
   2519              case emuDcdcLnCompCtrl_4u7F:
   2520                EMU->DCDCLNCOMPCTRL = 0xB7102137UL;
   2521                break;
   2522          
   2523              default:
   2524                EFM_ASSERT(false);
   2525                break;
   2526            }
   2527          }
   2528          
   2529          /***************************************************************************//**
   2530           * @brief
   2531           *   Load EMU_DCDCLPCTRL_LPCMPHYSSEL depending on LP bias, LP feedback
   2532           *   attenuation, and DEVINFOREV.
   2533           *
   2534           * @param[in] lpAttenuation
   2535           *   LP feedback attenuation.
   2536           * @param[in] lpCmpBias
   2537           *   lpCmpBias selection.
   2538           * @param[in] trimMode
   2539           *   DCDC trim mode.
   2540           ******************************************************************************/
   2541          static bool lpCmpHystCalibrationLoad(bool lpAttenuation,
   2542                                               uint8_t lpCmpBias,
   2543                                               dcdcTrimMode_TypeDef trimMode)
   2544          {
   2545            uint32_t lpcmpHystSel;
   2546          #if !defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2547            (void)lpAttenuation;
   2548          #endif
   2549          
   2550            /* Get calibration data revision. */
   2551          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2552            uint8_t devinfoRev = SYSTEM_GetDevinfoRev();
   2553          
   2554            /* Load LPATT indexed calibration data. */
   2555            if (devinfoRev < 4) {
   2556              lpcmpHystSel = DEVINFO->DCDCLPCMPHYSSEL0;
   2557          
   2558              if (lpAttenuation) {
   2559                lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT1_MASK)
   2560                               >> _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT1_SHIFT;
   2561              } else {
   2562                lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT0_MASK)
   2563                               >> _DEVINFO_DCDCLPCMPHYSSEL0_LPCMPHYSSELLPATT0_SHIFT;
   2564              }
   2565            } else
   2566          #endif
   2567            {
   2568              /* devinfoRev >= 4: load LPCMPBIAS indexed calibration data. */
   2569              lpcmpHystSel = DEVINFO->DCDCLPCMPHYSSEL1;
   2570              switch (lpCmpBias) {
   2571                case 0:
   2572                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS0_MASK)
   2573                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS0_SHIFT;
   2574                  break;
   2575          
   2576                case 1:
   2577                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS1_MASK)
   2578                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS1_SHIFT;
   2579                  break;
   2580          
   2581                case 2:
   2582                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS2_MASK)
   2583                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS2_SHIFT;
   2584                  break;
   2585          
   2586                case 3:
   2587                  lpcmpHystSel = (lpcmpHystSel & _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS3_MASK)
   2588                                 >> _DEVINFO_DCDCLPCMPHYSSEL1_LPCMPHYSSELLPCMPBIAS3_SHIFT;
   2589                  break;
   2590          
   2591                default:
   2592                  EFM_ASSERT(false);
   2593                  /* Return when assertions are disabled. */
   2594                  return false;
   2595              }
   2596            }
   2597          
   2598            /* Set trims. */
   2599            if (trimMode == dcdcTrimMode_EM234H_LP) {
   2600              /* Make sure the sel value is within the field range. */
   2601              lpcmpHystSel <<= _GENERIC_DCDCLPCTRL_LPCMPHYSSELEM234H_SHIFT;
   2602              if ((lpcmpHystSel & ~_GENERIC_DCDCLPCTRL_LPCMPHYSSELEM234H_MASK) != 0U) {
   2603                EFM_ASSERT(false);
   2604                /* Return when assertions are disabled. */
   2605                return false;
   2606              }
   2607              EMU->DCDCLPCTRL = (EMU->DCDCLPCTRL & ~_GENERIC_DCDCLPCTRL_LPCMPHYSSELEM234H_MASK) | lpcmpHystSel;
   2608            }
   2609          
   2610          #if defined(_EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_MASK)
   2611            if (trimMode == dcdcTrimMode_EM01_LP) {
   2612              /* Make sure the sel value is within the field range. */
   2613              lpcmpHystSel <<= _EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_SHIFT;
   2614              if ((lpcmpHystSel & ~_EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_MASK) != 0U) {
   2615                EFM_ASSERT(false);
   2616                /* Return when assertions are disabled. */
   2617                return false;
   2618              }
   2619              EMU->DCDCLPEM01CFG = (EMU->DCDCLPEM01CFG & ~_EMU_DCDCLPEM01CFG_LPCMPHYSSELEM01_MASK) | lpcmpHystSel;
   2620            }
   2621          #endif
   2622          
   2623            return true;
   2624          }
   2625          
   2626          /***************************************************************************//**
   2627           * @brief
   2628           *   Load LPVREF low and high from DEVINFO.
   2629           *
   2630           * @param[out] vrefL
   2631           *   LPVREF low from DEVINFO.
   2632           * @param[out] vrefH
   2633           *   LPVREF high from DEVINFO.
   2634           * @param[in] lpAttenuation
   2635           *   LP feedback attenuation.
   2636           * @param[in] lpcmpBias
   2637           *   lpcmpBias to look up in DEVINFO.
   2638           ******************************************************************************/
   2639          static void lpGetDevinfoVrefLowHigh(uint32_t *vrefL,
   2640                                              uint32_t *vrefH,
   2641                                              bool lpAttenuation,
   2642                                              uint8_t lpcmpBias)
   2643          {
   2644            uint32_t vrefLow = 0;
   2645            uint32_t vrefHigh = 0;
   2646          
   2647            /* Find VREF high and low in DEVINFO indexed by LPCMPBIAS (lpcmpBias)
   2648               and LPATT (lpAttenuation) */
   2649            uint32_t switchVal = ((uint32_t)lpcmpBias << 8) | (lpAttenuation ? 1U : 0U);
   2650            switch (switchVal) {
   2651              case ((0 << 8) | 1):
   2652                vrefLow  = DEVINFO->DCDCLPVCTRL2;
   2653                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS0_MASK)
   2654                           >> _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS0_SHIFT;
   2655                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS0_MASK)
   2656                           >> _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS0_SHIFT;
   2657                break;
   2658          
   2659              case ((1 << 8) | 1):
   2660                vrefLow  = DEVINFO->DCDCLPVCTRL2;
   2661                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS1_MASK)
   2662                           >> _DEVINFO_DCDCLPVCTRL2_3V0LPATT1LPCMPBIAS1_SHIFT;
   2663                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS1_MASK)
   2664                           >> _DEVINFO_DCDCLPVCTRL2_1V8LPATT1LPCMPBIAS1_SHIFT;
   2665                break;
   2666          
   2667              case ((2 << 8) | 1):
   2668                vrefLow  = DEVINFO->DCDCLPVCTRL3;
   2669                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS2_MASK)
   2670                           >> _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS2_SHIFT;
   2671                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS2_MASK)
   2672                           >> _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS2_SHIFT;
   2673                break;
   2674          
   2675              case ((3 << 8) | 1):
   2676                vrefLow  = DEVINFO->DCDCLPVCTRL3;
   2677                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS3_MASK)
   2678                           >> _DEVINFO_DCDCLPVCTRL3_3V0LPATT1LPCMPBIAS3_SHIFT;
   2679                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS3_MASK)
   2680                           >> _DEVINFO_DCDCLPVCTRL3_1V8LPATT1LPCMPBIAS3_SHIFT;
   2681                break;
   2682          
   2683              case ((0 << 8) | 0):
   2684                vrefLow  = DEVINFO->DCDCLPVCTRL0;
   2685                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS0_MASK)
   2686                           >> _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS0_SHIFT;
   2687                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS0_MASK)
   2688                           >> _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS0_SHIFT;
   2689                break;
   2690          
   2691              case ((1 << 8) | 0):
   2692                vrefLow  = DEVINFO->DCDCLPVCTRL0;
   2693                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS1_MASK)
   2694                           >> _DEVINFO_DCDCLPVCTRL0_1V8LPATT0LPCMPBIAS1_SHIFT;
   2695                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS1_MASK)
   2696                           >> _DEVINFO_DCDCLPVCTRL0_1V2LPATT0LPCMPBIAS1_SHIFT;
   2697                break;
   2698          
   2699              case ((2 << 8) | 0):
   2700                vrefLow  = DEVINFO->DCDCLPVCTRL1;
   2701                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS2_MASK)
   2702                           >> _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS2_SHIFT;
   2703                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS2_MASK)
   2704                           >> _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS2_SHIFT;
   2705                break;
   2706          
   2707              case ((3 << 8) | 0):
   2708                vrefLow  = DEVINFO->DCDCLPVCTRL1;
   2709                vrefHigh = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS3_MASK)
   2710                           >> _DEVINFO_DCDCLPVCTRL1_1V8LPATT0LPCMPBIAS3_SHIFT;
   2711                vrefLow  = (vrefLow & _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS3_MASK)
   2712                           >> _DEVINFO_DCDCLPVCTRL1_1V2LPATT0LPCMPBIAS3_SHIFT;
   2713                break;
   2714          
   2715              default:
   2716                EFM_ASSERT(false);
   2717                break;
   2718            }
   2719            *vrefL = vrefLow;
   2720            *vrefH = vrefHigh;
   2721          }
   2722          
   2723          /***************************************************************************//**
   2724           * @brief
   2725           *   Configure the DCDC regulator.
   2726           *
   2727           * @note
   2728           * Do not call this function if the power circuit is configured for NODCDC as
   2729           * described in the Power Configurations section of the Reference Manual.
   2730           * Instead, call @ref EMU_DCDCPowerOff().
   2731           *
   2732           * @param[in] dcdcInit
   2733           *  The DCDC initialization structure.
   2734           *
   2735           * @return
   2736           *   True if initialization parameters are valid.
   2737           ******************************************************************************/
   2738          bool EMU_DCDCInit(const EMU_DCDCInit_TypeDef *dcdcInit)
   2739          {
   2740            uint32_t lpCmpBiasSelEM234H;
   2741          
   2742          #if defined(_EMU_PWRCFG_MASK)
   2743            /* Set the external power configuration. This enables writing to the other
   2744               DCDC registers. */
   2745            EMU->PWRCFG = EMU_PWRCFG_PWRCFG_DCDCTODVDD;
   2746          
   2747            /* EMU->PWRCFG is write-once and POR reset only. Check that
   2748               the desired power configuration was set. */
   2749            if ((EMU->PWRCFG & _EMU_PWRCFG_PWRCFG_MASK) != EMU_PWRCFG_PWRCFG_DCDCTODVDD) {
   2750              /* If this assert triggers unexpectedly, power cycle the
   2751                 kit to reset the power configuration. */
   2752              EFM_ASSERT(false);
   2753              /* Return when assertions are disabled. */
   2754              return false;
   2755            }
   2756          #endif
   2757          
   2758            /* Load DCDC calibration data from the DI page. */
   2759            (void)dcdcConstCalibrationLoad();
   2760          
   2761            /* Check current parameters */
   2762            EFM_ASSERT(dcdcInit->maxCurrent_mA <= 200U);
   2763            EFM_ASSERT(dcdcInit->em01LoadCurrent_mA <= dcdcInit->maxCurrent_mA);
   2764            EFM_ASSERT(dcdcInit->reverseCurrentControl <= 200);
   2765          
   2766            if (dcdcInit->dcdcMode == emuDcdcMode_LowNoise) {
   2767              /* DCDC low-noise supports max 200 mA. */
   2768              EFM_ASSERT(dcdcInit->em01LoadCurrent_mA <= 200U);
   2769            }
   2770          #if (_SILICON_LABS_GECKO_INTERNAL_SDID != 80)
   2771            else if (dcdcInit->dcdcMode == emuDcdcMode_LowPower) {
   2772              /* Up to 10 mA is supported for EM01-LP mode. */
   2773              EFM_ASSERT(dcdcInit->em01LoadCurrent_mA <= 10U);
   2774            }
   2775          #endif
   2776            else {
   2777              /* No need to check the EM01 load limit. */
   2778            }
   2779          
   2780            /* EM2/3/4 current above 10 mA is not supported. */
   2781            EFM_ASSERT(dcdcInit->em234LoadCurrent_uA <= 10000U);
   2782          
   2783            if (dcdcInit->em234LoadCurrent_uA < 75U) {
   2784              lpCmpBiasSelEM234H  = 0;
   2785            } else if (dcdcInit->em234LoadCurrent_uA < 500U) {
   2786              lpCmpBiasSelEM234H  = 1U << _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT;
   2787            } else if (dcdcInit->em234LoadCurrent_uA < 2500U) {
   2788              lpCmpBiasSelEM234H  = 2U << _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT;
   2789            } else {
   2790              lpCmpBiasSelEM234H  = 3U << _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT;
   2791            }
   2792          
   2793            /* ==== THESE NEXT STEPS ARE STRONGLY ORDER DEPENDENT ==== */
   2794          
   2795            /* Set DCDC low-power mode comparator bias selection. */
   2796          
   2797            /* 1. Set DCDC low-power mode comparator bias selection and forced CCM.
   2798                  => Updates DCDCMISCCTRL_LNFORCECCM */
   2799            EMU->DCDCMISCCTRL = (EMU->DCDCMISCCTRL & ~(_GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_MASK
   2800                                                       | _EMU_DCDCMISCCTRL_LNFORCECCM_MASK))
   2801                                | ((uint32_t)lpCmpBiasSelEM234H
   2802                                   | (dcdcInit->reverseCurrentControl >= 0
   2803                                      ? EMU_DCDCMISCCTRL_LNFORCECCM : 0U));
   2804          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   2805            /* Only 10 mA EM01-LP current is supported. */
   2806            EMU->DCDCLPEM01CFG = (EMU->DCDCLPEM01CFG & ~_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   2807                                 | EMU_DCDCLPEM01CFG_LPCMPBIASEM01_BIAS3;
   2808          #endif
   2809          
   2810            /* 2. Set recommended and validated current optimization settings.
   2811                  <= Depends on LNFORCECCM
   2812                  => Updates DCDCLNFREQCTRL_RCOBAND */
   2813            dcdcEm01LoadCurrent_mA = dcdcInit->em01LoadCurrent_mA;
   2814            dcdcValidatedConfigSet();
   2815          
   2816            /* 3. Updated static currents and limits user data.
   2817                  Limiters are updated in @ref EMU_DCDCOptimizeSlice(). */
   2818            userCurrentLimitsSet(dcdcInit->maxCurrent_mA,
   2819                                 dcdcInit->reverseCurrentControl);
   2820          
   2821            /* 4. Optimize LN slice based on the given user input load current.
   2822                  <= Depends on DCDCMISCCTRL_LNFORCECCM and DCDCLNFREQCTRL_RCOBAND
   2823                  <= Depends on dcdcInit->maxCurrent_mA and dcdcInit->reverseCurrentControl
   2824                  => Updates DCDCMISCCTRL_P/NFETCNT
   2825                  => Updates DCDCMISCCTRL_LNCLIMILIMSEL and DCDCMISCCTRL_LPCLIMILIMSEL
   2826                  => Updates DCDCZDETCTRL_ZDETILIMSEL */
   2827            EMU_DCDCOptimizeSlice(dcdcInit->em01LoadCurrent_mA);
   2828          
   2829            /* ======================================================= */
   2830          
   2831            /* Set DCDC low noise mode compensator control register. */
   2832            compCtrlSet(dcdcInit->dcdcLnCompCtrl);
   2833          
   2834            /* Set DCDC output voltage. */
   2835            if (!EMU_DCDCOutputVoltageSet(dcdcInit->mVout, true, true)) {
   2836              EFM_ASSERT(false);
   2837              /* Return when assertions are disabled. */
   2838              return false;
   2839            }
   2840          
   2841          #if (_SILICON_LABS_GECKO_INTERNAL_SDID == 80)
   2842            /* Select analog peripheral power supply. This must be done before
   2843               DCDC mode is set for all EFM32xG1 and EFR32xG1 devices. */
   2844            BUS_RegBitWrite(&EMU->PWRCTRL,
   2845                            _EMU_PWRCTRL_ANASW_SHIFT,
   2846                            dcdcInit->anaPeripheralPower ? 1 : 0);
   2847          #endif
   2848          
   2849          #if defined(_EMU_PWRCTRL_REGPWRSEL_MASK)
   2850            /* Select DVDD as input to the digital regulator. The switch to DVDD will take
   2851               effect once the DCDC output is stable. */
   2852            #if defined (EMU_HAS_SET_CLEAR)
   2853            EMU->PWRCTRL_SET = EMU_PWRCTRL_REGPWRSEL_DVDD;
   2854            #else
   2855            EMU->PWRCTRL |= EMU_PWRCTRL_REGPWRSEL_DVDD;
   2856            #endif
   2857          #endif
   2858          
   2859            /* Set EM0 DCDC operating mode. Output voltage set in
   2860               @ref EMU_DCDCOutputVoltageSet() above takes effect if mode
   2861               is changed from bypass/off mode. */
   2862            EMU_DCDCModeSet(dcdcInit->dcdcMode);
   2863          
   2864          #if (_SILICON_LABS_GECKO_INTERNAL_SDID != 80)
   2865            /* Select the analog peripheral power supply. This must be done after
   2866               DCDC mode is set for all devices other than EFM32xG1 and EFR32xG1. */
   2867            BUS_RegBitWrite(&EMU->PWRCTRL,
   2868                            _EMU_PWRCTRL_ANASW_SHIFT,
   2869                            dcdcInit->anaPeripheralPower
   2870                            == emuDcdcAnaPeripheralPower_DCDC ? 1U : 0U);
   2871          #endif
   2872          
   2873            return true;
   2874          }
   2875          
   2876          /***************************************************************************//**
   2877           * @brief
   2878           *   Set DCDC regulator operating mode.
   2879           *
   2880           * @param[in] dcdcMode
   2881           *   DCDC mode.
   2882           ******************************************************************************/
   2883          void EMU_DCDCModeSet(EMU_DcdcMode_TypeDef dcdcMode)
   2884          {
   2885            bool dcdcLocked;
   2886            uint32_t currentDcdcMode;
   2887          
   2888            dcdcLocked = (EMU->PWRLOCK == EMU_PWRLOCK_LOCKKEY_LOCKED);
   2889            EMU_PowerUnlock();
   2890          
   2891            /* Wait for any previous write sync to complete and read DCDC mode. */
   2892            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   2893            }
   2894            currentDcdcMode = (EMU->DCDCCTRL & _EMU_DCDCCTRL_DCDCMODE_MASK);
   2895          
   2896            /* Enable bypass current limiter when not in bypass mode to prevent
   2897               excessive current between VREGVDD and DVDD supplies when reentering bypass mode.  */
   2898            if (currentDcdcMode != EMU_DCDCCTRL_DCDCMODE_BYPASS) {
   2899              BUS_RegBitWrite(&EMU->DCDCCLIMCTRL, _EMU_DCDCCLIMCTRL_BYPLIMEN_SHIFT, 1);
   2900            }
   2901          
   2902            if ((EMU_DcdcMode_TypeDef)currentDcdcMode == dcdcMode) {
   2903              /* Mode already set. If already in bypass, make sure the bypass current limiter
   2904                 is disabled. */
   2905              if (dcdcMode == emuDcdcMode_Bypass) {
   2906                BUS_RegBitWrite(&EMU->DCDCCLIMCTRL, _EMU_DCDCCLIMCTRL_BYPLIMEN_SHIFT, 0);
   2907              }
   2908              return;
   2909            }
   2910          
   2911          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2912          
   2913            /* Fix for errata DCDC_E203. */
   2914            if ((currentDcdcMode == EMU_DCDCCTRL_DCDCMODE_BYPASS)
   2915                && (dcdcMode == emuDcdcMode_LowNoise)) {
   2916              errataFixDcdcHsState = errataFixDcdcHsBypassLn;
   2917            }
   2918          #endif // (_SILICON_LABS_GECKO_INTERNAL_SDID_80)
   2919          
   2920          #if defined(_SILICON_LABS_GECKO_INTERNAL_SDID_84)
   2921          
   2922            /* Fix for errata DCDC_E204. */
   2923            if (((currentDcdcMode == EMU_DCDCCTRL_DCDCMODE_OFF) || (currentDcdcMode == EMU_DCDCCTRL_DCDCMODE_BYPASS))
   2924                && ((dcdcMode == emuDcdcMode_LowPower) || (dcdcMode == emuDcdcMode_LowNoise))) {
   2925              /* Always start in LOWNOISE. Switch to LOWPOWER mode once LOWNOISE startup is complete. */
   2926              EMU_IntClear(EMU_IFC_DCDCLNRUNNING);
   2927              while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   2928              }
   2929              EMU->DCDCCTRL = (EMU->DCDCCTRL & ~_EMU_DCDCCTRL_DCDCMODE_MASK) | EMU_DCDCCTRL_DCDCMODE_LOWNOISE;
   2930              while ((EMU_IntGet() & EMU_IF_DCDCLNRUNNING) == 0U) {
   2931              }
   2932            }
   2933          #endif // (_SILICON_LABS_GECKO_INTERNAL_SDID_84)
   2934          
   2935            /* Set user-requested mode. */
   2936            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0UL) {
   2937            }
   2938            EMU->DCDCCTRL = (EMU->DCDCCTRL & ~_EMU_DCDCCTRL_DCDCMODE_MASK)
   2939                            | (uint32_t)dcdcMode;
   2940          
   2941            /* Disable bypass current limiter after bypass mode is entered.
   2942               Enable the limiter if any other mode is entered. */
   2943            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   2944            }
   2945            BUS_RegBitWrite(&EMU->DCDCCLIMCTRL,
   2946                            _EMU_DCDCCLIMCTRL_BYPLIMEN_SHIFT,
   2947                            dcdcMode == emuDcdcMode_Bypass ? 0U : 1U);
   2948          
   2949            if (dcdcLocked) {
   2950              EMU_PowerLock();
   2951            }
   2952          }
   2953          
   2954          #if defined(EMU_DCDCCTRL_DCDCMODEEM23)
   2955          /***************************************************************************//**
   2956           * @brief
   2957           *   Set DCDC Mode EM23 operating mode.
   2958           *
   2959           * @param[in] dcdcModeEM23
   2960           *   DCDC mode EM23.
   2961           ******************************************************************************/
   2962          void EMU_DCDCModeEM23Set(EMU_DcdcModeEM23_TypeDef dcdcModeEM23)
   2963          {
   2964            bool dcdcLocked;
   2965          
   2966            dcdcLocked = (EMU->PWRLOCK == EMU_PWRLOCK_LOCKKEY_LOCKED);
   2967            EMU_PowerUnlock();
   2968          
   2969            /* Set user-requested mode. */
   2970            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0UL) {
   2971            }
   2972            EMU->DCDCCTRL = (EMU->DCDCCTRL & ~_EMU_DCDCCTRL_DCDCMODEEM23_MASK)
   2973                            | (uint32_t)dcdcModeEM23;
   2974          
   2975            if (dcdcLocked) {
   2976              EMU_PowerLock();
   2977            }
   2978          }
   2979          #endif
   2980          
   2981          /***************************************************************************//**
   2982           * @brief
   2983           *   Power off the DCDC regulator.
   2984           *
   2985           * @details
   2986           *   This function powers off the DCDC controller. This function should only be
   2987           *   used if the external power circuit is wired for no DCDC. If the external power
   2988           *   circuit is wired for DCDC usage, use @ref EMU_DCDCInit() and set the
   2989           *   DCDC in bypass mode to disable DCDC.
   2990           *
   2991           * @return
   2992           *   Return false if the DCDC could not be disabled.
   2993           ******************************************************************************/
   2994          bool EMU_DCDCPowerOff(void)
   2995          {
   2996            bool dcdcModeSet;
   2997          
   2998          #if defined(_EMU_PWRCFG_MASK)
   2999            /* Set DCDCTODVDD only to enable write access to EMU->DCDCCTRL. */
   3000            EMU->PWRCFG = EMU_PWRCFG_PWRCFG_DCDCTODVDD;
   3001          #endif
   3002          
   3003            /* Select DVDD as input to the digital regulator. */
   3004          #if defined(EMU_PWRCTRL_IMMEDIATEPWRSWITCH)
   3005           #if defined (EMU_HAS_SET_CLEAR)
   3006            EMU->PWRCTRL_SET = EMU_PWRCTRL_REGPWRSEL_DVDD | EMU_PWRCTRL_IMMEDIATEPWRSWITCH;
   3007            #else
   3008            EMU->PWRCTRL |= EMU_PWRCTRL_REGPWRSEL_DVDD | EMU_PWRCTRL_IMMEDIATEPWRSWITCH;
   3009            #endif
   3010          #elif defined(EMU_PWRCTRL_REGPWRSEL_DVDD)
   3011            #if defined (EMU_HAS_SET_CLEAR)
   3012            EMU->PWRCTRL_SET = EMU_PWRCTRL_REGPWRSEL_DVDD;
   3013            #else
   3014            EMU->PWRCTRL |= EMU_PWRCTRL_REGPWRSEL_DVDD;
   3015            #endif
   3016          #endif
   3017          
   3018            /* Set DCDC to OFF and disable LP in EM2/3/4. Verify that the required
   3019               mode could be set. */
   3020            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   3021            }
   3022            EMU->DCDCCTRL = EMU_DCDCCTRL_DCDCMODE_OFF;
   3023          
   3024            dcdcModeSet = (EMU->DCDCCTRL == EMU_DCDCCTRL_DCDCMODE_OFF);
   3025            EFM_ASSERT(dcdcModeSet);
   3026          
   3027            return dcdcModeSet;
   3028          }
   3029          
   3030          /***************************************************************************//**
   3031           * @brief
   3032           *   Set DCDC LN regulator conduction mode.
   3033           *
   3034           * @param[in] conductionMode
   3035           *   DCDC LN conduction mode.
   3036           * @param[in] rcoDefaultSet
   3037           *   The default DCDC RCO band for the conductionMode will be used if true.
   3038           *   Otherwise, the current RCO configuration is used.
   3039           ******************************************************************************/
   3040          void EMU_DCDCConductionModeSet(EMU_DcdcConductionMode_TypeDef conductionMode,
   3041                                         bool rcoDefaultSet)
   3042          {
   3043            EMU_DcdcMode_TypeDef currentDcdcMode
   3044              = (EMU_DcdcMode_TypeDef)((uint32_t)
   3045                                       (EMU->DCDCCTRL & _EMU_DCDCCTRL_DCDCMODE_MASK));
   3046            EMU_DcdcLnRcoBand_TypeDef rcoBand
   3047              = (EMU_DcdcLnRcoBand_TypeDef)((uint32_t)
   3048                                            ((EMU->DCDCLNFREQCTRL
   3049                                              & _EMU_DCDCLNFREQCTRL_RCOBAND_MASK)
   3050                                             >> _EMU_DCDCLNFREQCTRL_RCOBAND_SHIFT));
   3051          
   3052            /* Set bypass mode and wait for bypass mode to settle before
   3053               EMU_DCDCMISCCTRL_LNFORCECCM is set. Restore current DCDC mode. */
   3054            EMU_IntClear(EMU_IFC_DCDCINBYPASS);
   3055            EMU_DCDCModeSet(emuDcdcMode_Bypass);
   3056            while ((EMU->DCDCSYNC & EMU_DCDCSYNC_DCDCCTRLBUSY) != 0U) {
   3057            }
   3058            while ((EMU_IntGet() & EMU_IF_DCDCINBYPASS) == 0U) {
   3059            }
   3060            if (conductionMode == emuDcdcConductionMode_DiscontinuousLN) {
   3061              EMU->DCDCMISCCTRL &= ~EMU_DCDCMISCCTRL_LNFORCECCM;
   3062              if (rcoDefaultSet) {
   3063                EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_3MHz);
   3064              } else {
   3065                /* emuDcdcConductionMode_DiscontinuousLN supports up to 4MHz LN RCO. */
   3066                EFM_ASSERT(rcoBand <= emuDcdcLnRcoBand_4MHz);
   3067              }
   3068            } else {
   3069              EMU->DCDCMISCCTRL |= EMU_DCDCMISCCTRL_LNFORCECCM;
   3070              if (rcoDefaultSet) {
   3071                EMU_DCDCLnRcoBandSet(emuDcdcLnRcoBand_7MHz);
   3072              }
   3073            }
   3074            EMU_DCDCModeSet(currentDcdcMode);
   3075            /* Update slice configuration as it depends on conduction mode and RCO band.*/
   3076            EMU_DCDCOptimizeSlice(dcdcEm01LoadCurrent_mA);
   3077          }
   3078          
   3079          /***************************************************************************//**
   3080           * @brief
   3081           *   Set the DCDC output voltage.
   3082           *
   3083           * @note
   3084           *   The DCDC is not characterized for the entire valid output voltage range.
   3085           *   For that reason an upper limit of 3.0V output voltage is enforced.
   3086           *
   3087           * @param[in] mV
   3088           *   Target DCDC output voltage in mV.
   3089           *
   3090           * @param[in] setLpVoltage
   3091           *   Update LP voltage
   3092           *
   3093           * @param[in] setLnVoltage
   3094           *   Update LN voltage
   3095           *
   3096           * @return
   3097           *   True if the mV parameter is valid.
   3098           ******************************************************************************/
   3099          bool EMU_DCDCOutputVoltageSet(uint32_t mV,
   3100                                        bool setLpVoltage,
   3101                                        bool setLnVoltage)
   3102          {
   3103          #if defined(_DEVINFO_DCDCLNVCTRL0_3V0LNATT1_MASK)
   3104          
   3105            bool validOutVoltage;
   3106            bool attenuationSet;
   3107            uint32_t mVlow = 0;
   3108            uint32_t mVhigh = 0;
   3109            uint32_t mVdiff;
   3110            uint32_t vrefVal[DCDC_TRIM_MODES] = { 0 };
   3111            uint32_t vrefLow[DCDC_TRIM_MODES] = { 0 };
   3112            uint32_t vrefHigh[DCDC_TRIM_MODES] = { 0 };
   3113            uint8_t lpcmpBias[DCDC_TRIM_MODES] = { 0 };
   3114          
   3115            /* Check that the set voltage is within valid range.
   3116               Voltages are obtained from the data sheet. */
   3117            validOutVoltage = (mV >= PWRCFG_DCDCTODVDD_VMIN)
   3118                              && (mV <= PWRCFG_DCDCTODVDD_VMAX);
   3119          
   3120            if (!validOutVoltage) {
   3121              EFM_ASSERT(false);
   3122              /* Return when assertions are disabled. */
   3123              return false;
   3124            }
   3125          
   3126            /* Set attenuation to use and low/high range. */
   3127            attenuationSet = mV > 1800U;
   3128            if (attenuationSet) {
   3129              mVlow = 1800;
   3130              mVhigh = 3000;
   3131              mVdiff = mVhigh - mVlow;
   3132            } else {
   3133              mVlow = 1200;
   3134              mVhigh = 1800;
   3135              mVdiff = mVhigh - mVlow;
   3136            }
   3137          
   3138            /* Get 2-point calibration data from DEVINFO. */
   3139          
   3140            /* LN mode */
   3141            if (attenuationSet) {
   3142              vrefLow[dcdcTrimMode_LN]  = DEVINFO->DCDCLNVCTRL0;
   3143              vrefHigh[dcdcTrimMode_LN] = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_3V0LNATT1_MASK)
   3144                                          >> _DEVINFO_DCDCLNVCTRL0_3V0LNATT1_SHIFT;
   3145              vrefLow[dcdcTrimMode_LN]  = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_1V8LNATT1_MASK)
   3146                                          >> _DEVINFO_DCDCLNVCTRL0_1V8LNATT1_SHIFT;
   3147            } else {
   3148              vrefLow[dcdcTrimMode_LN]  = DEVINFO->DCDCLNVCTRL0;
   3149              vrefHigh[dcdcTrimMode_LN] = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_1V8LNATT0_MASK)
   3150                                          >> _DEVINFO_DCDCLNVCTRL0_1V8LNATT0_SHIFT;
   3151              vrefLow[dcdcTrimMode_LN]  = (vrefLow[dcdcTrimMode_LN] & _DEVINFO_DCDCLNVCTRL0_1V2LNATT0_MASK)
   3152                                          >> _DEVINFO_DCDCLNVCTRL0_1V2LNATT0_SHIFT;
   3153            }
   3154          
   3155            /* LP EM234H mode */
   3156            lpcmpBias[dcdcTrimMode_EM234H_LP] = (uint8_t)
   3157                                                ((EMU->DCDCMISCCTRL & _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_MASK)
   3158                                                 >> _GENERIC_DCDCMISCCTRL_LPCMPBIASEM234H_SHIFT);
   3159            lpGetDevinfoVrefLowHigh(&vrefLow[dcdcTrimMode_EM234H_LP],
   3160                                    &vrefHigh[dcdcTrimMode_EM234H_LP],
   3161                                    attenuationSet,
   3162                                    lpcmpBias[dcdcTrimMode_EM234H_LP]);
   3163          
   3164          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3165            /* LP EM01 mode */
   3166            lpcmpBias[dcdcTrimMode_EM01_LP] = (uint8_t)
   3167                                              ((EMU->DCDCLPEM01CFG & _EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3168                                               >> _EMU_DCDCLPEM01CFG_LPCMPBIASEM01_SHIFT);
   3169            lpGetDevinfoVrefLowHigh(&vrefLow[dcdcTrimMode_EM01_LP],
   3170                                    &vrefHigh[dcdcTrimMode_EM01_LP],
   3171                                    attenuationSet,
   3172                                    lpcmpBias[dcdcTrimMode_EM01_LP]);
   3173          #endif
   3174          
   3175            /* Calculate output voltage trims. */
   3176            vrefVal[dcdcTrimMode_LN]         = ((mV - mVlow) * (vrefHigh[dcdcTrimMode_LN] - vrefLow[dcdcTrimMode_LN]))
   3177                                               / mVdiff;
   3178            vrefVal[dcdcTrimMode_LN]        += vrefLow[dcdcTrimMode_LN];
   3179          
   3180            vrefVal[dcdcTrimMode_EM234H_LP]  = ((mV - mVlow) * (vrefHigh[dcdcTrimMode_EM234H_LP] - vrefLow[dcdcTrimMode_EM234H_LP]))
   3181                                               / mVdiff;
   3182            vrefVal[dcdcTrimMode_EM234H_LP] += vrefLow[dcdcTrimMode_EM234H_LP];
   3183          
   3184          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3185            vrefVal[dcdcTrimMode_EM01_LP]    = ((mV - mVlow) * (vrefHigh[dcdcTrimMode_EM01_LP] - vrefLow[dcdcTrimMode_EM01_LP]))
   3186                                               / mVdiff;
   3187            vrefVal[dcdcTrimMode_EM01_LP]   += vrefLow[dcdcTrimMode_EM01_LP];
   3188          #endif
   3189          
   3190            /* Range checks */
   3191            if ((vrefVal[dcdcTrimMode_LN] > vrefHigh[dcdcTrimMode_LN])
   3192                || (vrefVal[dcdcTrimMode_LN] < vrefLow[dcdcTrimMode_LN])
   3193          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3194                || (vrefVal[dcdcTrimMode_EM01_LP] > vrefHigh[dcdcTrimMode_EM01_LP])
   3195                || (vrefVal[dcdcTrimMode_EM01_LP] < vrefLow[dcdcTrimMode_EM01_LP])
   3196          #endif
   3197                || (vrefVal[dcdcTrimMode_EM234H_LP] > vrefHigh[dcdcTrimMode_EM234H_LP])
   3198                || (vrefVal[dcdcTrimMode_EM234H_LP] < vrefLow[dcdcTrimMode_EM234H_LP])) {
   3199              EFM_ASSERT(false);
   3200              /* Return when assertions are disabled. */
   3201              return false;
   3202            }
   3203          
   3204            /* Update output voltage tuning for LN and LP modes. */
   3205            if (setLnVoltage) {
   3206              EMU->DCDCLNVCTRL = (EMU->DCDCLNVCTRL & ~(_EMU_DCDCLNVCTRL_LNVREF_MASK | _EMU_DCDCLNVCTRL_LNATT_MASK))
   3207                                 | (vrefVal[dcdcTrimMode_LN] << _EMU_DCDCLNVCTRL_LNVREF_SHIFT)
   3208                                 | (attenuationSet ? EMU_DCDCLNVCTRL_LNATT : 0U);
   3209            }
   3210          
   3211            if (setLpVoltage) {
   3212              /* Load LP EM234H comparator hysteresis calibration. */
   3213              if (!(lpCmpHystCalibrationLoad(attenuationSet, lpcmpBias[dcdcTrimMode_EM234H_LP], dcdcTrimMode_EM234H_LP))) {
   3214                EFM_ASSERT(false);
   3215                /* Return when assertions are disabled. */
   3216                return false;
   3217              }
   3218          
   3219          #if defined(_EMU_DCDCLPEM01CFG_LPCMPBIASEM01_MASK)
   3220              /* Load LP EM234H comparator hysteresis calibration. */
   3221              if (!(lpCmpHystCalibrationLoad(attenuationSet, lpcmpBias[dcdcTrimMode_EM01_LP], dcdcTrimMode_EM01_LP))) {
   3222                EFM_ASSERT(false);
   3223                /* Return when assertions are disabled. */
   3224                return false;
   3225              }
   3226          
   3227              /* LP VREF is that maximum of trims for EM01 and EM234H. */
   3228              vrefVal[dcdcTrimMode_EM234H_LP] = SL_MAX(vrefVal[dcdcTrimMode_EM234H_LP], vrefVal[dcdcTrimMode_EM01_LP]);
   3229          #endif
   3230          
   3231              /* Don't exceed the maximum available code as specified in the reference manual for EMU_DCDCLPVCTRL. */
   3232              vrefVal[dcdcTrimMode_EM234H_LP] = SL_MIN(vrefVal[dcdcTrimMode_EM234H_LP], 0xE7U);
   3233              EMU->DCDCLPVCTRL = (EMU->DCDCLPVCTRL & ~(_EMU_DCDCLPVCTRL_LPVREF_MASK | _EMU_DCDCLPVCTRL_LPATT_MASK))
   3234                                 | (vrefVal[dcdcTrimMode_EM234H_LP] << _EMU_DCDCLPVCTRL_LPVREF_SHIFT)
   3235                                 | (attenuationSet ? EMU_DCDCLPVCTRL_LPATT : 0U);
   3236            }
   3237          #endif
   3238            return true;
   3239          }
   3240          
   3241          /***************************************************************************//**
   3242           * @brief
   3243           *   Optimize the DCDC slice count based on the estimated average load current
   3244           *   in EM0.
   3245           *
   3246           * @param[in] em0LoadCurrentmA
   3247           *   Estimated average EM0 load current in mA.
   3248           ******************************************************************************/
   3249          void EMU_DCDCOptimizeSlice(uint32_t em0LoadCurrentmA)
   3250          {
   3251            uint32_t sliceCount = 0;
   3252            uint32_t rcoBand = (EMU->DCDCLNFREQCTRL & _EMU_DCDCLNFREQCTRL_RCOBAND_MASK)
   3253                               >> _EMU_DCDCLNFREQCTRL_RCOBAND_SHIFT;
   3254          
   3255            /* Set the recommended slice count. */
   3256            if (((EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_LNFORCECCM_MASK) != 0U)
   3257                && (rcoBand >= (uint32_t)emuDcdcLnRcoBand_5MHz)) {
   3258              if (em0LoadCurrentmA < 20U) {
   3259                sliceCount = 4;
   3260              } else if ((em0LoadCurrentmA >= 20U) && (em0LoadCurrentmA < 40U)) {
   3261                sliceCount = 8;
   3262              } else {
   3263                sliceCount = 16;
   3264              }
   3265            } else if (((EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_LNFORCECCM_MASK) == 0U)
   3266                       && (rcoBand <= (uint32_t)emuDcdcLnRcoBand_4MHz)) {
   3267              if (em0LoadCurrentmA < 10U) {
   3268                sliceCount = 4;
   3269              } else if ((em0LoadCurrentmA >= 10U) && (em0LoadCurrentmA < 20U)) {
   3270                sliceCount = 8;
   3271              } else {
   3272                sliceCount = 16;
   3273              }
   3274            } else if (((EMU->DCDCMISCCTRL & _EMU_DCDCMISCCTRL_LNFORCECCM_MASK) != 0U)
   3275                       && (rcoBand <= (uint32_t)emuDcdcLnRcoBand_4MHz)) {
   3276              if (em0LoadCurrentmA < 40U) {
   3277                sliceCount = 8;
   3278              } else {
   3279                sliceCount = 16;
   3280              }
   3281            } else {
   3282              /* This configuration is not recommended. @ref EMU_DCDCInit() applies a recommended
   3283                 configuration. */
   3284              EFM_ASSERT(false);
   3285            }
   3286          
   3287            /* The selected slices are PSLICESEL + 1. */
   3288            sliceCount--;
   3289          
   3290            /* Apply slice count to both N and P slice. */
   3291            sliceCount = (sliceCount << _EMU_DCDCMISCCTRL_PFETCNT_SHIFT
   3292                          | sliceCount << _EMU_DCDCMISCCTRL_NFETCNT_SHIFT);
   3293            EMU->DCDCMISCCTRL = (EMU->DCDCMISCCTRL & ~(_EMU_DCDCMISCCTRL_PFETCNT_MASK
   3294                                                       | _EMU_DCDCMISCCTRL_NFETCNT_MASK))
   3295                                | sliceCount;
   3296          
   3297            /* Update the current limiters. */
   3298            currentLimitersUpdate();
   3299          }
   3300          
   3301          /***************************************************************************//**
   3302           * @brief
   3303           *   Set DCDC Low-noise RCO band.
   3304           *
   3305           * @param[in] band
   3306           *   RCO band to set.
   3307           ******************************************************************************/
   3308          void EMU_DCDCLnRcoBandSet(EMU_DcdcLnRcoBand_TypeDef band)
   3309          {
   3310            uint32_t forcedCcm;
   3311            forcedCcm = BUS_RegBitRead(&EMU->DCDCMISCCTRL, _EMU_DCDCMISCCTRL_LNFORCECCM_SHIFT);
   3312          
   3313            /* DCM mode supports up to 4 MHz LN RCO. */
   3314            EFM_ASSERT(((forcedCcm == 0U) && band <= emuDcdcLnRcoBand_4MHz)
   3315                       || (forcedCcm != 0U));
   3316          
   3317            EMU->DCDCLNFREQCTRL = (EMU->DCDCLNFREQCTRL & ~_EMU_DCDCLNFREQCTRL_RCOBAND_MASK)
   3318                                  | ((uint32_t)band << _EMU_DCDCLNFREQCTRL_RCOBAND_SHIFT);
   3319          
   3320            /* Update slice configuration as this depends on the RCO band. */
   3321            EMU_DCDCOptimizeSlice(dcdcEm01LoadCurrent_mA);
   3322          }
   3323          #endif /* EMU_SERIES1_DCDC_BUCK_PRESENT */
   3324          
   3325          #if defined(EMU_SERIES2_DCDC_BOOST_PRESENT)
   3326          /***************************************************************************//**
   3327           * @brief
   3328           *   Configure the DCDC Boost regulator.
   3329           *
   3330           * @param[in] dcdcBoostInit
   3331           *  The DCDC initialization structure.
   3332           *
   3333           * @return
   3334           *   True if initialization parameters are valid.
   3335           ******************************************************************************/
   3336          bool EMU_DCDCBoostInit(const EMU_DCDCBoostInit_TypeDef *dcdcBoostInit)
   3337          {
   3338            bool dcdcLocked;
   3339          
   3340            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3341          #if defined(_DCDC_EN_EN_MASK)
   3342            DCDC->EN_SET    = DCDC_EN_EN;
   3343          #endif
   3344            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3345            EMU_DCDCUnlock();
   3346          
   3347          #if defined(_DCDC_SYNCBUSY_MASK)
   3348            EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3349          #endif
   3350          
   3351          #if defined(_DCDC_CTRL_DVDDBSTPRG_MASK)
   3352            BUS_RegMaskedWrite(&DCDC->CTRL,
   3353                               _DCDC_CTRL_DVDDBSTPRG_MASK,
   3354                               ((uint32_t)dcdcBoostInit->outputVoltage << _DCDC_CTRL_DVDDBSTPRG_SHIFT));
   3355          #endif
   3356          
   3357            DCDC->BSTCTRL = (DCDC->BSTCTRL & ~(_DCDC_BSTCTRL_IPKTMAXCTRL_MASK))
   3358                            | ((uint32_t)dcdcBoostInit->tonMax << _DCDC_BSTCTRL_IPKTMAXCTRL_SHIFT);
   3359            DCDC->BSTEM01CTRL = ((uint32_t)dcdcBoostInit->driveSpeedEM01 << _DCDC_BSTEM01CTRL_DRVSPEED_SHIFT)
   3360                                | ((uint32_t)dcdcBoostInit->peakCurrentEM01 << _DCDC_BSTEM01CTRL_IPKVAL_SHIFT);
   3361            DCDC->BSTEM23CTRL = ((uint32_t)dcdcBoostInit->driveSpeedEM23 << _DCDC_BSTEM23CTRL_DRVSPEED_SHIFT)
   3362                                | ((uint32_t)dcdcBoostInit->peakCurrentEM23 << _DCDC_BSTEM23CTRL_IPKVAL_SHIFT);
   3363          
   3364            EMU_BoostExternalShutdownEnable(dcdcBoostInit->externalShutdownEn);
   3365          
   3366            EMU_DCDCModeSet(emuDcdcMode_Regulation);
   3367          
   3368            if (dcdcLocked) {
   3369              EMU_DCDCLock();
   3370            }
   3371          
   3372            EMU_DCDCUpdatedHook();
   3373          
   3374            return true;
   3375          }
   3376          
   3377          /***************************************************************************//**
   3378           * @brief
   3379           *   Set EM01 mode Boost Peak Current setting.
   3380           *
   3381           * @param[in] boostPeakCurrentEM01
   3382           *  Boost Peak load current coefficient in EM01 mode.
   3383           ******************************************************************************/
   3384          void EMU_EM01BoostPeakCurrentSet(const EMU_DcdcBoostEM01PeakCurrent_TypeDef boostPeakCurrentEM01)
   3385          {
   3386            bool dcdcLocked = false;
   3387            bool dcdcClkWasEnabled = false;
   3388          
   3389            dcdcClkWasEnabled = ((CMU->CLKEN0 & CMU_CLKEN0_DCDC) != 0);
   3390            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3391          
   3392            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3393            EMU_DCDCUnlock();
   3394          
   3395            /* Wait for synchronization before writing new value */
   3396          #if defined(_DCDC_SYNCBUSY_MASK)
   3397            EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3398          #endif
   3399          
   3400            BUS_RegMaskedWrite(&DCDC->BSTEM01CTRL,
   3401                               _DCDC_BSTEM01CTRL_IPKVAL_MASK,
   3402                               ((uint32_t)boostPeakCurrentEM01 << _DCDC_BSTEM01CTRL_IPKVAL_SHIFT));
   3403          
   3404            if (dcdcLocked) {
   3405              EMU_DCDCLock();
   3406            }
   3407          
   3408            if (!dcdcClkWasEnabled) {
   3409              CMU->CLKEN0_CLR = CMU_CLKEN0_DCDC;
   3410            }
   3411          
   3412            EMU_DCDCUpdatedHook();
   3413          }
   3414          
   3415          /***************************************************************************//**
   3416           * @brief
   3417           *   Enable/disable Boost External Shutdown Mode.
   3418           *
   3419           * @param[in] enable
   3420           *   The boost DC-DC converter can be activated or deactivated
   3421           *   from a dedicated BOOST_EN pin on the device if enable is true.
   3422           ******************************************************************************/
   3423          void EMU_BoostExternalShutdownEnable(bool enable)
   3424          {
   3425            if (enable) {
   3426              EMU->BOOSTCTRL_CLR = EMU_BOOSTCTRL_BOOSTENCTRL;
   3427            } else {
   3428              EMU->BOOSTCTRL_SET = EMU_BOOSTCTRL_BOOSTENCTRL;
   3429            }
   3430          }
   3431          
   3432          #if defined(_DCDC_CTRL_DVDDBSTPRG_MASK)
   3433          /***************************************************************************//**
   3434           * @brief
   3435           *   Set DCDC Boost output voltage.
   3436           *
   3437           * @param[in] boostOutputVoltage
   3438           *   Boost output voltage.
   3439           ******************************************************************************/
   3440          void EMU_DCDCBoostOutputVoltageSet(const EMU_DcdcBoostOutputVoltage_TypeDef boostOutputVoltage)
   3441          {
   3442            bool dcdcLocked = false;
   3443          
   3444            CMU->CLKEN0_SET = CMU_CLKEN0_DCDC;
   3445          
   3446            dcdcLocked = ((DCDC->LOCKSTATUS & DCDC_LOCKSTATUS_LOCK) != 0);
   3447            EMU_DCDCUnlock();
   3448          
   3449            /* Wait for synchronization before writing new value */
   3450          #if defined(_DCDC_SYNCBUSY_MASK)
   3451            EMU_DCDCSync(_DCDC_SYNCBUSY_MASK);
   3452          #endif
   3453          
   3454            BUS_RegMaskedWrite(&DCDC->CTRL,
   3455                               _DCDC_CTRL_DVDDBSTPRG_MASK,
   3456                               ((uint32_t)boostOutputVoltage << _DCDC_CTRL_DVDDBSTPRG_SHIFT));
   3457          
   3458            if (dcdcLocked) {
   3459              EMU_DCDCLock();
   3460            }
   3461          
   3462            EMU_DCDCUpdatedHook();
   3463          }
   3464          #endif
   3465          #endif /* EMU_SERIES2_DCDC_BOOST_PRESENT */
   3466          
   3467          #if defined(EMU_SERIES2_DCDC_BUCK_PRESENT) \
   3468            || defined(EMU_SERIES2_DCDC_BOOST_PRESENT)
   3469          /***************************************************************************//**
   3470           * @brief
   3471           *   Indicate that the DCDC peripheral bus clock enable has changed allowing
   3472           *   RAIL to react accordingly.
   3473           *
   3474           * @details
   3475           *   This function is called after DCDC has been enabled or disabled.
   3476           *   The function implementation does not perform anything, but it is SL_WEAK
   3477           *   so that it can use the RAIL version if needed.
   3478           ******************************************************************************/

   \                                 In section .text, align 2
   3479          SL_WEAK void EMU_DCDCUpdatedHook(void)
   3480          {
   3481          }
   \                     EMU_DCDCUpdatedHook: (+1)
   \        0x0   0x4770             BX       LR
