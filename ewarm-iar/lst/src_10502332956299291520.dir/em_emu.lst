   4247          /***************************************************************************//**
   4248           * @brief
   4249           *   Get the status of a voltage monitor channel.
   4250           *
   4251           * @param[in] channel
   4252           *   A VMON channel to get the status for.
   4253           *
   4254           * @return
   4255           *   A status of the selected VMON channel. True if the channel is triggered.
   4256           ******************************************************************************/
   4257          bool EMU_VmonChannelStatusGet(EMU_VmonChannel_TypeDef channel)
   4258          {
   4259            uint32_t bit;
   4260            switch (channel) {
   4261              case emuVmonChannel_AVDD:
   4262                bit = _EMU_STATUS_VMONAVDD_SHIFT;
   4263                break;
   4264              case emuVmonChannel_ALTAVDD:
   4265                bit = _EMU_STATUS_VMONALTAVDD_SHIFT;
   4266                break;
   4267              case emuVmonChannel_DVDD:
   4268                bit = _EMU_STATUS_VMONDVDD_SHIFT;
   4269                break;
   4270              case emuVmonChannel_IOVDD0:
   4271                bit = _EMU_STATUS_VMONIO0_SHIFT;
   4272                break;
   4273          #if defined(_EMU_VMONIO1CTRL_EN_MASK)
   4274              case emuVmonChannel_IOVDD1:
   4275                bit = _EMU_STATUS_VMONIO1_SHIFT;
   4276                break;
   4277          #endif
   4278          #if defined(_EMU_VMONBUVDDCTRL_EN_MASK)
   4279              case emuVmonChannel_BUVDD:
   4280                bit = _EMU_STATUS_VMONBUVDD_SHIFT;
   4281                break;
   4282          #endif
   4283              default:
   4284                bit = 0;
   4285                EFM_ASSERT(false);
   4286                break;
   4287            }
   4288          
   4289            return BUS_RegBitRead(&EMU->STATUS, bit) != 0U;
   4290          }
   4291          #endif /* EMU_STATUS_VMONRDY */
