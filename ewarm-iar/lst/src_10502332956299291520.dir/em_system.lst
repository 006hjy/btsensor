     50          #define SYSCFG_CHIPREV_PARTNUMBER1  0xFE0
     51          #define SYSCFG_CHIPREV_PARTNUMBER0  0xF
     52          
     53          /* Bit mask to convert NON-SECURE to SECURE */
     54          #define CONVERT_NS_TO_S (~(1 << 28U))
