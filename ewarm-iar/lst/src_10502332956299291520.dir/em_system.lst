   \        0x2   0x6808             LDR      R0,[R1, #+0]
    217            return (uint64_t)((uint64_t)DEVINFO->EUI64H << 32) | tmp;
   \        0x4   0x6849             LDR      R1,[R1, #+4]
   \        0x6   0x4770             BX       LR
    218          #elif defined(_DEVINFO_UNIQUEH_MASK)
    219            uint32_t tmp = DEVINFO->UNIQUEL;
