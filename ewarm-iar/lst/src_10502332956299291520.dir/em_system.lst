    126          
    127          #if defined(MSC_FLASH_CHIPCONFIG_MEM_BASE)
    128            p   = (SYSTEM_CalAddrVal_TypeDef *)MSC_FLASH_CHIPCONFIG_MEM_BASE;
   \        0x4   0x....             LDR.N    R3,??DataTable10_2
    129            end = (SYSTEM_CalAddrVal_TypeDef *)MSC_FLASH_CHIPCONFIG_MEM_END;
    130          #else
    131            p   = (SYSTEM_CalAddrVal_TypeDef *)(DEVINFO_BASE & 0xFFFFF000U);
    132            end = (SYSTEM_CalAddrVal_TypeDef *)DEVINFO_BASE;
    133          #endif
    134          
    135            for (; p < end; p++) {
    136              if (p->address == 0) {
   \                     ??SYSTEM_GetCalibrationValue_0: (+1)
   \        0x6   0x6819             LDR      R1,[R3, #+0]
   \        0x8   0xB151             CBZ.N    R1,??SYSTEM_GetCalibrationValue_1
    137                /* p->address == 0 marks the end of the table */
    138                return false;
    139              }
    140              if (p->address == s_regAddress) {
   \        0xA   0x4291             CMP      R1,R2
   \        0xC   0xD004             BEQ.N    ??SYSTEM_GetCalibrationValue_2
   \        0xE   0x3308             ADDS     R3,R3,#+8
   \       0x10   0x....             LDR.N    R1,??DataTable10_3
   \       0x12   0x428B             CMP      R3,R1
   \       0x14   0xD3F7             BCC.N    ??SYSTEM_GetCalibrationValue_0
   \       0x16   0xE003             B.N      ??SYSTEM_GetCalibrationValue_1
    141                *regAddress = p->calValue;
   \                     ??SYSTEM_GetCalibrationValue_2: (+1)
   \       0x18   0x685A             LDR      R2,[R3, #+4]
   \       0x1A   0x6002             STR      R2,[R0, #+0]
    142                return true;
   \       0x1C   0x2001             MOVS     R0,#+1
   \       0x1E   0x4770             BX       LR
    143              }
    144            }
