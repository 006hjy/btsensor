   4509          #if ((defined(CMU_SYSCLKCTRL_RHCLKPRESC)) \
   4510            && (_SILICON_LABS_EFR32_RADIO_TYPE != _SILICON_LABS_EFR32_RADIO_NONE))
   4511          /***************************************************************************//**
   4512           * @brief
   4513           *   Set maximum allowed prescaler for radio clock tree (RHCLK).
   4514           ******************************************************************************/
   4515          static void rhclkPrescMax(void)
   4516          {
   4517            // Set largest prescaler (DIV2).
   4518            CMU->SYSCLKCTRL_SET = CMU_SYSCLKCTRL_RHCLKPRESC;
   4519          }
   4520          
   4521          /***************************************************************************//**
   4522           * @brief
   4523           *   Set radio clock tree prescaler to achieve highest possible frequency
   4524           *   and still be within spec.
   4525           ******************************************************************************/
   4526          static void rhclkPrescOptimize(void)
   4527          {
   4528            if (CMU_ClockFreqGet(cmuClock_SYSCLK) <= CMU_MAX_RHCLK_FREQ) {
   4529              // Set smallest prescaler (DIV1).
   4530              CMU->SYSCLKCTRL_CLR = CMU_SYSCLKCTRL_RHCLKPRESC;
   4531            }
   4532          }
   4533          #endif // ((defined(CMU_SYSCLKCTRL_RHCLKPRESC)) && (_SILICON_LABS_EFR32_RADIO_TYPE != _SILICON_LABS_EFR32_RADIO_NONE))
   4534          #endif // #if (_SILICON_LABS_32B_SERIES_2_CONFIG > 1)
   4535          
   4536          #if defined(HFRCOEM23_PRESENT)
   4537          /***************************************************************************//**
   4538           * @brief
   4539           *   Get calibrated HFRCOEM23 tuning value from Device information (DI) page
   4540           *   for a given frequency. Calibration value is not available for all frequency
   4541           *   bands.
   4542           *
   4543           * @param[in] freq
   4544           *   HFRCOEM23 frequency band
   4545           ******************************************************************************/
   4546          static uint32_t HFRCOEM23DevinfoGet(CMU_HFRCOEM23Freq_TypeDef freq)
   4547          {
   4548            uint32_t ret = 0U;
   4549          
   4550            switch (freq) {
   4551              // 1, 2 and 4MHz share the same calibration word
   4552              case cmuHFRCOEM23Freq_1M0Hz:
   4553              case cmuHFRCOEM23Freq_2M0Hz:
   4554              case cmuHFRCOEM23Freq_4M0Hz:
   4555                ret = DEVINFO->HFRCOEM23CAL[0].HFRCOEM23CAL;
   4556                break;
   4557          
   4558              case cmuHFRCOEM23Freq_13M0Hz:
   4559                ret = DEVINFO->HFRCOEM23CAL[6].HFRCOEM23CAL;
   4560                break;
   4561          
   4562              case cmuHFRCOEM23Freq_16M0Hz:
   4563                ret = DEVINFO->HFRCOEM23CAL[7].HFRCOEM23CAL;
   4564                break;
   4565          
   4566              case cmuHFRCOEM23Freq_19M0Hz:
   4567                ret = DEVINFO->HFRCOEM23CAL[8].HFRCOEM23CAL;
   4568                break;
   4569          
   4570              case cmuHFRCOEM23Freq_26M0Hz:
   4571                ret = DEVINFO->HFRCOEM23CAL[10].HFRCOEM23CAL;
   4572                break;
   4573          
   4574              case cmuHFRCOEM23Freq_32M0Hz:
   4575                ret = DEVINFO->HFRCOEM23CAL[11].HFRCOEM23CAL;
   4576                break;
   4577          
   4578              case cmuHFRCOEM23Freq_40M0Hz:
   4579                ret = DEVINFO->HFRCOEM23CAL[12].HFRCOEM23CAL;
   4580                break;
   4581          
   4582          #if !defined(_SILICON_LABS_32B_SERIES_2_CONFIG_1)
   4583              case cmuHFRCOEM23Freq_5M0Hz:
   4584                ret = DEVINFO->HFRCOEM23CAL[1].HFRCOEM23CAL;
   4585                break;
   4586          
   4587              case cmuHFRCOEM23Freq_10M0Hz:
   4588                ret = DEVINFO->HFRCOEM23CAL[4].HFRCOEM23CAL;
   4589                break;
   4590          
   4591              case cmuHFRCOEM23Freq_20M0Hz:
   4592                ret = DEVINFO->HFRCOEM23CAL[9].HFRCOEM23CAL;
   4593                break;
   4594          #endif
   4595          
   4596              case cmuHFRCOEM23Freq_UserDefined:
   4597                break;
   4598          
   4599              default:
   4600                EFM_ASSERT(false);
   4601                break;
   4602            }
   4603            return ret;
   4604          }
   4605          #endif // defined(HFRCOEM23_PRESENT)
