   6039            return ret;
   6040          }
   6041          #endif
   6042          
   6043          #if defined(_CMU_QSPICTRL_MASK)
   6044          /***************************************************************************//**
   6045           * @brief
   6046           *   Get the QSPI n reference clock frequency.
