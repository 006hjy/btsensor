   9882          
   9883          #if defined(USBC_CLOCK_PRESENT)
   9884              case CMU_USBCCLKSEL_REG:
   9885                switch (ref) {
   9886                  case cmuSelect_LFXO:
   9887                    /* Select LFXO as a clock source for USB. It can only be used in sleep mode. */
   9888                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9889                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
   9890          
   9891                    /* Switch the oscillator. */
   9892                    CMU->CMD = CMU_CMD_USBCCLKSEL_LFXO;
   9893          
   9894                    /* Wait until the clock is activated. */
   9895                    while ((CMU->STATUS & CMU_STATUS_USBCLFXOSEL) == 0) {
   9896                    }
