   9849          #if defined(_CMU_DBGCLKSEL_DBG_MASK)
   9850                  case cmuSelect_AUXHFRCO:
   9851                    /* Select AUXHFRCO as a debug clock. */
   9852                    CMU->DBGCLKSEL = CMU_DBGCLKSEL_DBG_AUXHFRCO;
