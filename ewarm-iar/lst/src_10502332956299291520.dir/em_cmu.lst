   6179          
   6180          /***************************************************************************//**
   6181           * @brief
   6182           *   Configure flash access wait states to support the given core clock
   6183           *   frequency.
   6184           *
   6185           * @param[in] coreFreq
   6186           *   The core clock frequency to configure flash wait-states.
   6187           *
   6188           * @param[in] vscale
   6189           *   Voltage Scale level. Supported levels are 0 and 2 where 0 is the default.
   6190           ******************************************************************************/
   6191          static void flashWaitStateControl(uint32_t coreFreq, int vscale)
   6192          {
   6193            uint32_t mode;
   6194          #if defined(MSC_READCTRL_MODE_WS0SCBTP)
   6195            bool scbtpEn;   /* Suppressed Conditional Branch Target Prefetch setting. */
   6196          #endif
   6197            (void) vscale;  /* vscale parameter is only used on some devices. */
   6198          
   6199            /* Get mode and SCBTP enable. */
   6200            mode = MSC_ReadCTRLGet() & _MSC_READCTRL_MODE_MASK;
   6201          
   6202          #if defined(_SILICON_LABS_32B_SERIES_0)
   6203          #if defined(MSC_READCTRL_MODE_WS0SCBTP)
   6204            /* Devices with MODE and SCBTP in the same register field. */
   6205            switch (mode) {
   6206              case MSC_READCTRL_MODE_WS0:
   6207              case MSC_READCTRL_MODE_WS1:
   6208          #if defined(MSC_READCTRL_MODE_WS2)
   6209              case MSC_READCTRL_MODE_WS2:
   6210          #endif
   6211                scbtpEn = false;
   6212                break;
   6213          
   6214              default: /* WSxSCBTP */
   6215                scbtpEn = true;
   6216                break;
   6217            }
   6218          
   6219            /* Set mode based on the core clock frequency and SCBTP enable. */
   6220            if (false) {
   6221            }
   6222          #if defined(MSC_READCTRL_MODE_WS2)
   6223            else if (coreFreq > CMU_MAX_FREQ_1WS) {
   6224              mode = (scbtpEn ? MSC_READCTRL_MODE_WS2SCBTP : MSC_READCTRL_MODE_WS2);
   6225            }
   6226          #endif
   6227            else if ((coreFreq <= CMU_MAX_FREQ_1WS) && (coreFreq > CMU_MAX_FREQ_0WS)) {
   6228              mode = (scbtpEn ? MSC_READCTRL_MODE_WS1SCBTP : MSC_READCTRL_MODE_WS1);
   6229            } else {
   6230              mode = (scbtpEn ? MSC_READCTRL_MODE_WS0SCBTP : MSC_READCTRL_MODE_WS0);
   6231            }
   6232          #else /* defined(MSC_READCTRL_MODE_WS0SCBTP) */
   6233          
   6234            if (coreFreq <= CMU_MAX_FREQ_0WS) {
   6235              mode = 0;
   6236            } else if (coreFreq <= CMU_MAX_FREQ_1WS) {
   6237              mode = 1;
   6238            }
   6239          #endif /* defined(MSC_READCTRL_MODE_WS0SCBTP) */
   6240          // End defined(_SILICON_LABS_32B_SERIES_0)
   6241          
   6242          #elif defined(_SILICON_LABS_32B_SERIES_1)
   6243          #if defined(_EMU_STATUS_VSCALE_MASK)
   6244          
   6245            /* These devices have specific requirements on the supported flash wait state
   6246             * depending on the frequency and voltage scale level. */
   6247            uint32_t i;
   6248            for (i = 0; i < FLASH_WS_TABLE_ENTRIES; i++) {
   6249              if ((flashWsTable[i].vscale == (uint8_t)vscale)
   6250                  && (coreFreq <= flashWsTable[i].maxFreq)) {
   6251                break; // Found a matching entry.
   6252              }
   6253            }
   6254          
   6255            if (i == FLASH_WS_TABLE_ENTRIES) {
   6256              mode = 3; // Worst case flash wait state for unsupported cases.
   6257              EFM_ASSERT(false);
   6258            } else {
   6259              mode = flashWsTable[i].ws;
   6260            }
   6261            mode = mode << _MSC_READCTRL_MODE_SHIFT;
   6262          
   6263          #else
   6264            /* Devices where MODE and SCBTP are in separate fields and where the device
   6265             * either does not support voltage scale or where the voltage scale does
   6266             * not impact the flash wait state configuration. */
   6267            if (coreFreq <= CMU_MAX_FREQ_0WS_1V2) {
   6268              mode = 0;
   6269            } else if (coreFreq <= CMU_MAX_FREQ_1WS_1V2) {
   6270              mode = 1;
   6271            }
   6272          #if defined(MSC_READCTRL_MODE_WS2)
   6273            else if (coreFreq <= CMU_MAX_FREQ_2WS) {
   6274              mode = 2;
   6275            }
   6276          #endif
   6277          #if defined(MSC_READCTRL_MODE_WS3)
   6278            else if (coreFreq <= CMU_MAX_FREQ_3WS) {
   6279              mode = 3;
   6280            }
   6281          #endif
   6282            mode = mode << _MSC_READCTRL_MODE_SHIFT;
   6283          #endif
   6284          // End defined(_SILICON_LABS_32B_SERIES_1)
   6285          
   6286          #else
   6287          #error "Undefined 32B SERIES!"
   6288          #endif
   6289          
   6290            mode = (MSC_ReadCTRLGet() & ~_MSC_READCTRL_MODE_MASK) | mode;
   6291            MSC_ReadCTRLSet(mode);
   6292          }
   6293          
   6294          /***************************************************************************//**
   6295           * @brief
   6296           *   Configure flash access wait states to the most conservative setting for
   6297           *   this target. Retain SCBTP (Suppressed Conditional Branch Target Prefetch)
   6298           *   setting.
   6299           ******************************************************************************/
   6300          static void flashWaitStateMax(void)
   6301          {
   6302            /* Make sure the MSC is unlocked */
   6303            bool mscLocked = MSC_LockGetLocked();
   6304            MSC_LockSetUnlocked();
   6305          
   6306            flashWaitStateControl(SystemMaxCoreClockGet(), 0);
   6307          
   6308            if (mscLocked) {
   6309              MSC_LockSetLocked();
   6310            }
   6311          }
   6312          
   6313          #if defined(_MSC_RAMCTRL_RAMWSEN_MASK)
   6314          /***************************************************************************//**
   6315           * @brief
   6316           *   Configure RAM access wait states to support the given core clock
   6317           *   frequency.
   6318           *
   6319           * @param[in] coreFreq
   6320           *   The core clock frequency to configure RAM wait-states.
   6321           *
   6322           * @param[in] vscale
   6323           *   A voltage scale level. Supported levels are 0 and 2 where 0 is the default.
   6324           ******************************************************************************/
   6325          static void setRamWaitState(uint32_t coreFreq, int vscale)
   6326          {
   6327            uint32_t limit = 38000000;
   6328            if (vscale == 2) {
   6329              limit = 16000000;
   6330            }
   6331          
   6332            if (coreFreq > limit) {
   6333              BUS_RegMaskedSet(&MSC->RAMCTRL, (MSC_RAMCTRL_RAMWSEN
   6334                                               | MSC_RAMCTRL_RAM1WSEN
   6335                                               | MSC_RAMCTRL_RAM2WSEN));
   6336            } else {
   6337              BUS_RegMaskedClear(&MSC->RAMCTRL, (MSC_RAMCTRL_RAMWSEN
   6338                                                 | MSC_RAMCTRL_RAM1WSEN
   6339                                                 | MSC_RAMCTRL_RAM2WSEN));
   6340            }
   6341          }
   6342          #endif
   6343          
   6344          #if defined(_MSC_CTRL_WAITMODE_MASK)
   6345          /***************************************************************************//**
   6346           * @brief
   6347           *   Configure the wait state for peripheral accesses over the bus to support
   6348           *   the given bus clock frequency.
   6349           *
   6350           * @param[in] busFreq
   6351           *   A peripheral bus clock frequency to configure wait-states.
   6352           *
   6353           * @param[in] vscale
   6354           *   The voltage scale to configure wait-states. Expected values are
   6355           *   0 or 2.
   6356           *
   6357           *   @li 0 = 1.2 V (VSCALE2)
   6358           *   @li 2 = 1.0 V (VSCALE0)
   6359           * ******************************************************************************/
   6360          static void setBusWaitState(uint32_t busFreq, int vscale)
   6361          {
   6362            if ((busFreq > 50000000) && (vscale == 0)) {
   6363              BUS_RegMaskedSet(&MSC->CTRL, MSC_CTRL_WAITMODE_WS1);
   6364            } else {
   6365              BUS_RegMaskedClear(&MSC->CTRL, MSC_CTRL_WAITMODE_WS1);
   6366            }
   6367          }
   6368          #endif
   6369          
   6370          #if defined(PLFRCO_PRESENT)
   6371          static bool deviceHasPlfrco(void)
   6372          {
   6373            SYSTEM_ChipRevision_TypeDef rev;
   6374          
   6375            if (_SILICON_LABS_GECKO_INTERNAL_SDID == 89) {
   6376              // check the xG13 rev and check if it's >= Rev A3
   6377              SYSTEM_ChipRevisionGet(&rev);
   6378              return (rev.major > 1) || (rev.minor >= 3);
   6379            } else {
   6380              return false;
   6381            }
   6382          }
   6383          #endif
   6384          
   6385          /***************************************************************************//**
   6386           * @brief
   6387           *   Configure various wait states to switch to a certain frequency
   6388           *   and a certain voltage scale.
   6389           *
   6390           * @details
   6391           *   This function will set up the necessary flash, bus, and RAM wait states.
   6392           *   Updating the wait state configuration must be done before
   6393           *   increasing the clock frequency and it must be done after decreasing the
   6394           *   clock frequency. Updating the wait state configuration must be done before
   6395           *   core voltage is decreased and it must be done after a core voltage is
   6396           *   increased.
   6397           *
   6398           * @param[in] freq
   6399           *   The core clock frequency to configure wait-states.
   6400           *
   6401           * @param[in] vscale
   6402           *   The voltage scale to configure wait-states. Expected values are
   6403           *   0 or 2, higher number is lower voltage.
   6404           *
   6405           *   @li 0 = 1.2 V (VSCALE2)
   6406           *   @li 2 = 1.0 V (VSCALE0)
   6407           *
   6408           ******************************************************************************/
   6409          void CMU_UpdateWaitStates(uint32_t freq, int vscale)
   6410          {
   6411            /* Make sure the MSC is unlocked */
   6412            bool mscLocked = MSC_LockGetLocked();
   6413            MSC_LockSetUnlocked();
   6414          
   6415            flashWaitStateControl(freq, vscale);
   6416          #if defined(_MSC_RAMCTRL_RAMWSEN_MASK)
   6417            setRamWaitState(freq, vscale);
   6418          #endif
   6419          #if defined(_MSC_CTRL_WAITMODE_MASK)
   6420            setBusWaitState(freq, vscale);
   6421          #endif
   6422          
   6423            if (mscLocked) {
   6424              MSC_LockSetLocked();
   6425            }
   6426          }
   6427          
   6428          #if defined(_CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK)
   6429          /***************************************************************************//**
   6430           * @brief
   6431           *   Return the upper value for CMU_HFXOSTEADYSTATECTRL_REGISH.
   6432           ******************************************************************************/
   6433          static uint32_t getRegIshUpperVal(uint32_t steadyStateRegIsh)
   6434          {
   6435            uint32_t regIshUpper;
   6436            const uint32_t upperMax = _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK
   6437                                      >> _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_SHIFT;
   6438            /* Add 3 as specified in the register description for CMU_HFXOSTEADYSTATECTRL_REGISHUPPER. */
   6439            regIshUpper = SL_MIN(steadyStateRegIsh + 3UL, upperMax);
   6440            regIshUpper <<= _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_SHIFT;
   6441            return regIshUpper;
   6442          }
   6443          #endif
   6444          
   6445          #if defined(_CMU_HFXOCTRL_MASK)
   6446          /***************************************************************************//**
   6447           * @brief
   6448           *   Get the HFXO tuning mode.
   6449           *
   6450           * @return
   6451           *   The current HFXO tuning mode from the HFXOCTRL register.
   6452           ******************************************************************************/
   6453          __STATIC_INLINE uint32_t getHfxoTuningMode(void)
   6454          {
   6455          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6456            return (CMU->HFXOCTRL & _CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6457                   >> _CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_SHIFT;
   6458          #else
   6459            return (CMU->HFXOCTRL & _CMU_HFXOCTRL_PEAKDETMODE_MASK)
   6460                   >> _CMU_HFXOCTRL_PEAKDETMODE_SHIFT;
   6461          #endif
   6462          }
   6463          
   6464          /***************************************************************************//**
   6465           * @brief
   6466           *   Set the HFXO tuning mode.
   6467           *
   6468           * @param[in] mode
   6469           *   The new HFXO tuning mode. This can be HFXO_TUNING_MODE_AUTO or
   6470           *   HFXO_TUNING_MODE_CMD.
   6471           ******************************************************************************/
   6472          __STATIC_INLINE void setHfxoTuningMode(uint32_t mode)
   6473          {
   6474          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6475            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
   6476                            | (mode << _CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_SHIFT);
   6477          #else
   6478            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_PEAKDETMODE_MASK)
   6479                            | (mode << _CMU_HFXOCTRL_PEAKDETMODE_SHIFT);
   6480          #endif
   6481          }
   6482          #endif
   6483          
   6484          /***************************************************************************//**
   6485           * @brief
   6486           *   Get the LFnCLK frequency based on the current configuration.
   6487           *
   6488           * @param[in] lfClkBranch
   6489           *   Selected LF branch.
   6490           *
   6491           * @return
   6492           *   The LFnCLK frequency in Hz. If no LFnCLK is selected (disabled), 0 is
   6493           *   returned.
   6494           ******************************************************************************/
   6495          static uint32_t lfClkGet(CMU_Clock_TypeDef lfClkBranch)
   6496          {
   6497            uint32_t sel;
   6498            uint32_t ret = 0;
   6499          
   6500            switch (lfClkBranch) {
   6501              case cmuClock_LFA:
   6502              case cmuClock_LFB:
   6503          #if defined(_CMU_LFCCLKEN0_MASK)
   6504              case cmuClock_LFC:
   6505          #endif
   6506          #if defined(_CMU_LFECLKSEL_MASK)
   6507              case cmuClock_LFE:
   6508          #endif
   6509                break;
   6510          
   6511              default:
   6512                EFM_ASSERT(false);
   6513                break;
   6514            }
   6515          
   6516            sel = (uint32_t)CMU_ClockSelectGet(lfClkBranch);
   6517          
   6518            /* Get clock select field */
   6519            switch (lfClkBranch) {
   6520              case cmuClock_LFA:
   6521          #if defined(_CMU_LFCLKSEL_MASK)
   6522                sel = (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFA_MASK) >> _CMU_LFCLKSEL_LFA_SHIFT;
   6523          #elif defined(_CMU_LFACLKSEL_MASK)
   6524                sel = (CMU->LFACLKSEL & _CMU_LFACLKSEL_LFA_MASK) >> _CMU_LFACLKSEL_LFA_SHIFT;
   6525          #else
   6526                EFM_ASSERT(false);
   6527          #endif
   6528                break;
   6529          
   6530              case cmuClock_LFB:
   6531          #if defined(_CMU_LFCLKSEL_MASK)
   6532                sel = (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFB_MASK) >> _CMU_LFCLKSEL_LFB_SHIFT;
   6533          #elif defined(_CMU_LFBCLKSEL_MASK)
   6534                sel = (CMU->LFBCLKSEL & _CMU_LFBCLKSEL_LFB_MASK) >> _CMU_LFBCLKSEL_LFB_SHIFT;
   6535          #else
   6536                EFM_ASSERT(false);
   6537          #endif
   6538                break;
   6539          
   6540          #if defined(_CMU_LFCCLKEN0_MASK)
   6541              case cmuClock_LFC:
   6542          #if defined(_CMU_LFCLKSEL_LFC_MASK)
   6543                sel = (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFC_MASK) >> _CMU_LFCLKSEL_LFC_SHIFT;
   6544          #elif defined(_CMU_LFCCLKSEL_LFC_MASK)
   6545                sel = (CMU->LFCCLKSEL & _CMU_LFCCLKSEL_LFC_MASK) >> _CMU_LFCCLKSEL_LFC_SHIFT;
   6546          #else
   6547                EFM_ASSERT(false);
   6548          #endif
   6549                break;
   6550          #endif
   6551          
   6552          #if defined(_CMU_LFECLKSEL_MASK)
   6553              case cmuClock_LFE:
   6554                sel = (CMU->LFECLKSEL & _CMU_LFECLKSEL_LFE_MASK) >> _CMU_LFECLKSEL_LFE_SHIFT;
   6555                break;
   6556          #endif
   6557          
   6558              default:
   6559                EFM_ASSERT(false);
   6560                break;
   6561            }
   6562          
   6563            /* Get the clock frequency. */
   6564          #if defined(_CMU_LFCLKSEL_MASK)
   6565            switch (sel) {
   6566              case _CMU_LFCLKSEL_LFA_LFRCO:
   6567                ret = SystemLFRCOClockGet();
   6568                break;
   6569          
   6570              case _CMU_LFCLKSEL_LFA_LFXO:
   6571                ret = SystemLFXOClockGet();
   6572                break;
   6573          
   6574          #if defined(_CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2)
   6575              case _CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2:
   6576          #if defined(CMU_MAX_FREQ_HFLE)
   6577                /* HFLE bit is or'ed by hardware with HFCORECLKLEDIV to reduce the
   6578                 * frequency of CMU_HFCORECLKLEDIV2. */
   6579                ret = SystemCoreClockGet() / (1U << (getHfLeConfig() + 1));
   6580          #else
   6581                ret = SystemCoreClockGet() / 2U;
   6582          #endif
   6583                break;
   6584          #endif
   6585          
   6586              case _CMU_LFCLKSEL_LFA_DISABLED:
   6587                ret = 0;
   6588          #if defined(CMU_LFCLKSEL_LFAE)
   6589                /* Check LF Extended bit setting for LFA or LFB ULFRCO clock. */
   6590                if ((lfClkBranch == cmuClock_LFA) || (lfClkBranch == cmuClock_LFB)) {
   6591                  if (CMU->LFCLKSEL >> (lfClkBranch == cmuClock_LFA
   6592                                        ? _CMU_LFCLKSEL_LFAE_SHIFT
   6593                                        : _CMU_LFCLKSEL_LFBE_SHIFT)) {
   6594                    ret = SystemULFRCOClockGet();
   6595                  }
   6596                }
   6597          #endif
   6598                break;
   6599          
   6600              default:
   6601                ret = 0U;
   6602                EFM_ASSERT(false);
   6603                break;
   6604            }
   6605          #endif /* _CMU_LFCLKSEL_MASK */
   6606          
   6607          #if defined(_CMU_LFACLKSEL_MASK)
   6608            switch (sel) {
   6609              case _CMU_LFACLKSEL_LFA_LFRCO:
   6610                ret = SystemLFRCOClockGet();
   6611                break;
   6612          
   6613              case _CMU_LFACLKSEL_LFA_LFXO:
   6614                ret = SystemLFXOClockGet();
   6615                break;
   6616          
   6617              case _CMU_LFACLKSEL_LFA_ULFRCO:
   6618                ret = SystemULFRCOClockGet();
   6619                break;
   6620          
   6621          #if defined(PLFRCO_PRESENT)
   6622              case _CMU_LFACLKSEL_LFA_PLFRCO:
   6623                ret = SystemLFRCOClockGet();
   6624                break;
   6625          #endif
   6626          
   6627          #if defined(_CMU_LFBCLKSEL_LFB_HFCLKLE)
   6628              case _CMU_LFBCLKSEL_LFB_HFCLKLE:
   6629                ret = SystemHFClockGet()
   6630                      / SL_Log2ToDiv(((CMU->HFPRESC & _CMU_HFPRESC_HFCLKLEPRESC_MASK)
   6631                                      >> _CMU_HFPRESC_HFCLKLEPRESC_SHIFT) + 1UL);
   6632                break;
   6633          #endif
   6634          
   6635              case _CMU_LFACLKSEL_LFA_DISABLED:
   6636                ret = 0;
   6637                break;
   6638          
   6639              default:
   6640                ret = 0U;
   6641                EFM_ASSERT(false);
   6642                break;
   6643            }
   6644          #endif
   6645          
   6646            return ret;
   6647          }
   6648          
   6649          /***************************************************************************//**
   6650           * @brief
   6651           *   Wait for an ongoing sync of register(s) to low-frequency domain to complete.
   6652           *
   6653           * @param[in] mask
   6654           *   A bitmask corresponding to SYNCBUSY register defined bits, indicating
   6655           *   registers that must complete any ongoing synchronization.
   6656           ******************************************************************************/
   6657          __STATIC_INLINE void syncReg(uint32_t mask)
   6658          {
   6659            /* Avoid a deadlock if modifying the same register twice when freeze mode is */
   6660            /* activated. */
   6661            if ((CMU->FREEZE & CMU_FREEZE_REGFREEZE) != 0UL) {
   6662              return;
   6663            }
   6664          
   6665            /* Wait for any pending previous write operation to complete */
   6666            /* in low-frequency domain. */
   6667            while ((CMU->SYNCBUSY & mask) != 0UL) {
   6668            }
   6669          }
   6670          
   6671          #if defined(USBC_CLOCK_PRESENT)
   6672          /***************************************************************************//**
   6673           * @brief
   6674           *   Get the USBC frequency.
   6675           *
   6676           * @return
   6677           *   USBC frequency in Hz.
   6678           ******************************************************************************/
   6679          static uint32_t usbCClkGet(void)
   6680          {
   6681            uint32_t ret;
   6682            CMU_Select_TypeDef clk;
   6683          
   6684            /* Get the selected clock source. */
   6685            clk = CMU_ClockSelectGet(cmuClock_USBC);
   6686          
   6687            switch (clk) {
   6688              case cmuSelect_LFXO:
   6689                ret = SystemLFXOClockGet();
   6690                break;
   6691              case cmuSelect_LFRCO:
   6692                ret = SystemLFRCOClockGet();
   6693                break;
   6694          #if defined (_CMU_USHFRCOCTRL_MASK)
   6695              case cmuSelect_USHFRCO:
   6696                ret = ushfrcoFreq;
   6697                break;
   6698          #endif
   6699              case cmuSelect_HFCLK:
   6700                ret = SystemHFClockGet();
   6701                break;
   6702              default:
   6703                /* Clock is not enabled */
   6704                ret = 0;
   6705                break;
   6706            }
   6707            return ret;
   6708          }
   6709          #endif
   6710          
   6711          /***************************************************************************//**
   6712           * @brief
   6713           *   Set HFPER clock tree prescalers to safe values.
   6714           *
   6715           * @note
   6716           *   This function applies to EFM32GG11B. There are 3 HFPER clock trees with
   6717           *   these frequency limits:
   6718           *     HFPERCLK  (A-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   6719           *     HFPERBCLK (B-tree): 20MHz in VSCALE0 mode, 72MHz in VSCALE2 mode.
   6720           *     HFPERCCLK (C-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   6721           ******************************************************************************/
   6722          static void hfperClkSafePrescaler(void)
   6723          {
   6724          #if defined(_CMU_HFPERPRESC_MASK) && defined(_CMU_HFPERPRESCB_MASK) \
   6725            && defined(_CMU_HFPERPRESCC_MASK)
   6726            // Assuming a maximum HFCLK of 72MHz, set prescalers to DIV4.
   6727            CMU_ClockPrescSet(cmuClock_HFPER, 3U);
   6728            CMU_ClockPrescSet(cmuClock_HFPERB, 3U);
   6729            CMU_ClockPrescSet(cmuClock_HFPERC, 3U);
   6730          #endif
   6731          }
   6732          
   6733          /***************************************************************************//**
   6734           * @brief
   6735           *   Set HFPER clock tree prescalers to give highest possible clock node
   6736           *   frequency while still beeing within spec.
   6737           *
   6738           * @note
   6739           *   This function applies to EFM32GG11B. There are 3 HFPER clock trees with
   6740           *   these frequency limits:
   6741           *     HFPERCLK  (A-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   6742           *     HFPERBCLK (B-tree): 20MHz in VSCALE0 mode, 72MHz in VSCALE2 mode.
   6743           *     HFPERCCLK (C-tree): 20MHz in VSCALE0 mode, 50MHz in VSCALE2 mode.
   6744           ******************************************************************************/
   6745          static void hfperClkOptimizedPrescaler(void)
   6746          {
   6747          #if defined(_CMU_HFPERPRESC_MASK) && defined(_CMU_HFPERPRESCB_MASK) \
   6748            && defined(_CMU_HFPERPRESCC_MASK)
   6749            uint32_t hfClkFreq, divisor;
   6750          
   6751            hfClkFreq = SystemHFClockGet();
   6752          
   6753            if ( EMU_VScaleGet() == emuVScaleEM01_LowPower) {
   6754              divisor = (hfClkFreq + 20000000U - 1U) / 20000000U; // ceil(x)
   6755              if (divisor > 0U) {
   6756                divisor--;                                        // Convert to prescaler
   6757              }
   6758              CMU_ClockPrescSet(cmuClock_HFPER, divisor);
   6759              CMU_ClockPrescSet(cmuClock_HFPERB, divisor);
   6760              CMU_ClockPrescSet(cmuClock_HFPERC, divisor);
   6761            } else {
   6762              divisor = (hfClkFreq + 50000000U - 1U) / 50000000U;
   6763              if (divisor > 0U) {
   6764                divisor--;
   6765              }
   6766              CMU_ClockPrescSet(cmuClock_HFPER, divisor);
   6767              CMU_ClockPrescSet(cmuClock_HFPERC, divisor);
   6768          
   6769              divisor = (hfClkFreq + 72000000U - 1U) / 72000000U;
   6770              if (divisor > 0U) {
   6771                divisor--;
   6772              }
   6773              CMU_ClockPrescSet(cmuClock_HFPERB, divisor);
   6774            }
   6775          #endif
   6776          }
   6777          
   6778          /*******************************************************************************
   6779           **************************   GLOBAL FUNCTIONS   *******************************
   6780           ******************************************************************************/
   6781          
   6782          #if defined(_CMU_AUXHFRCOCTRL_BAND_MASK)
   6783          /***************************************************************************//**
   6784           * @brief
   6785           *   Get the AUXHFRCO band in use.
   6786           *
   6787           * @return
   6788           *   AUXHFRCO band in use.
   6789           ******************************************************************************/
   6790          CMU_AUXHFRCOBand_TypeDef CMU_AUXHFRCOBandGet(void)
   6791          {
   6792            return (CMU_AUXHFRCOBand_TypeDef)((CMU->AUXHFRCOCTRL
   6793                                               & _CMU_AUXHFRCOCTRL_BAND_MASK)
   6794                                              >> _CMU_AUXHFRCOCTRL_BAND_SHIFT);
   6795          }
   6796          #endif /* _CMU_AUXHFRCOCTRL_BAND_MASK */
   6797          
   6798          #if defined(_CMU_AUXHFRCOCTRL_BAND_MASK)
   6799          /***************************************************************************//**
   6800           * @brief
   6801           *   Set the AUXHFRCO band and the tuning value based on the value in the
   6802           *   calibration table made during production.
   6803           *
   6804           * @param[in] band
   6805           *   AUXHFRCO band to activate.
   6806           ******************************************************************************/
   6807          void CMU_AUXHFRCOBandSet(CMU_AUXHFRCOBand_TypeDef band)
   6808          {
   6809            uint32_t tuning;
   6810          
   6811            /* Read a tuning value from the calibration table. */
   6812            switch (band) {
   6813              case cmuAUXHFRCOBand_1MHz:
   6814                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND1_MASK)
   6815                         >> _DEVINFO_AUXHFRCOCAL0_BAND1_SHIFT;
   6816                break;
   6817          
   6818              case cmuAUXHFRCOBand_7MHz:
   6819                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND7_MASK)
   6820                         >> _DEVINFO_AUXHFRCOCAL0_BAND7_SHIFT;
   6821                break;
   6822          
   6823              case cmuAUXHFRCOBand_11MHz:
   6824                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND11_MASK)
   6825                         >> _DEVINFO_AUXHFRCOCAL0_BAND11_SHIFT;
   6826                break;
   6827          
   6828              case cmuAUXHFRCOBand_14MHz:
   6829                tuning = (DEVINFO->AUXHFRCOCAL0 & _DEVINFO_AUXHFRCOCAL0_BAND14_MASK)
   6830                         >> _DEVINFO_AUXHFRCOCAL0_BAND14_SHIFT;
   6831                break;
   6832          
   6833              case cmuAUXHFRCOBand_21MHz:
   6834                tuning = (DEVINFO->AUXHFRCOCAL1 & _DEVINFO_AUXHFRCOCAL1_BAND21_MASK)
   6835                         >> _DEVINFO_AUXHFRCOCAL1_BAND21_SHIFT;
   6836                break;
   6837          
   6838          #if defined(_CMU_AUXHFRCOCTRL_BAND_28MHZ)
   6839              case cmuAUXHFRCOBand_28MHz:
   6840                tuning = (DEVINFO->AUXHFRCOCAL1 & _DEVINFO_AUXHFRCOCAL1_BAND28_MASK)
   6841                         >> _DEVINFO_AUXHFRCOCAL1_BAND28_SHIFT;
   6842                break;
   6843          #endif
   6844          
   6845              default:
   6846                EFM_ASSERT(false);
   6847                return;
   6848            }
   6849          
   6850            /* Set band/tuning. */
   6851            CMU->AUXHFRCOCTRL = (CMU->AUXHFRCOCTRL
   6852                                 & ~(_CMU_AUXHFRCOCTRL_BAND_MASK
   6853                                     | _CMU_AUXHFRCOCTRL_TUNING_MASK))
   6854                                | (band << _CMU_AUXHFRCOCTRL_BAND_SHIFT)
   6855                                | (tuning << _CMU_AUXHFRCOCTRL_TUNING_SHIFT);
   6856          }
   6857          #endif /* _CMU_AUXHFRCOCTRL_BAND_MASK */
   6858          
   6859          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   6860          /**************************************************************************//**
   6861           * @brief
   6862           *   Get the AUXHFRCO frequency calibration word in DEVINFO.
   6863           *
   6864           * @param[in] freq
   6865           *   Frequency in Hz.
   6866           *
   6867           * @return
   6868           *   AUXHFRCO calibration word for a given frequency.
   6869           *****************************************************************************/
   6870          static uint32_t CMU_AUXHFRCODevinfoGet(CMU_AUXHFRCOFreq_TypeDef freq)
   6871          {
   6872            switch (freq) {
   6873              /* 1, 2, and 4 MHz share the same calibration word. */
   6874              case cmuAUXHFRCOFreq_1M0Hz:
   6875              case cmuAUXHFRCOFreq_2M0Hz:
   6876              case cmuAUXHFRCOFreq_4M0Hz:
   6877                return DEVINFO->AUXHFRCOCAL0;
   6878          
   6879              case cmuAUXHFRCOFreq_7M0Hz:
   6880                return DEVINFO->AUXHFRCOCAL3;
   6881          
   6882              case cmuAUXHFRCOFreq_13M0Hz:
   6883                return DEVINFO->AUXHFRCOCAL6;
   6884          
   6885              case cmuAUXHFRCOFreq_16M0Hz:
   6886                return DEVINFO->AUXHFRCOCAL7;
   6887          
   6888              case cmuAUXHFRCOFreq_19M0Hz:
   6889                return DEVINFO->AUXHFRCOCAL8;
   6890          
   6891              case cmuAUXHFRCOFreq_26M0Hz:
   6892                return DEVINFO->AUXHFRCOCAL10;
   6893          
   6894              case cmuAUXHFRCOFreq_32M0Hz:
   6895                return DEVINFO->AUXHFRCOCAL11;
   6896          
   6897              case cmuAUXHFRCOFreq_38M0Hz:
   6898                return DEVINFO->AUXHFRCOCAL12;
   6899          
   6900          #if defined(_DEVINFO_AUXHFRCOCAL13_MASK)
   6901              case cmuAUXHFRCOFreq_48M0Hz:
   6902                return DEVINFO->AUXHFRCOCAL13;
   6903          #endif
   6904          #if defined(_DEVINFO_AUXHFRCOCAL14_MASK)
   6905              case cmuAUXHFRCOFreq_50M0Hz:
   6906                return DEVINFO->AUXHFRCOCAL14;
   6907          #endif
   6908          
   6909              default: /* cmuAUXHFRCOFreq_UserDefined */
   6910                return 0;
   6911            }
   6912          }
   6913          #endif /* _CMU_AUXHFRCOCTRL_FREQRANGE_MASK */
   6914          
   6915          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   6916          /***************************************************************************//**
   6917           * @brief
   6918           *   Get the current AUXHFRCO frequency.
   6919           *
   6920           * @return
   6921           *   AUXHFRCO frequency.
   6922           ******************************************************************************/
   6923          CMU_AUXHFRCOFreq_TypeDef CMU_AUXHFRCOBandGet(void)
   6924          {
   6925            return auxHfrcoFreq;
   6926          }
   6927          #endif /* _CMU_AUXHFRCOCTRL_FREQRANGE_MASK */
   6928          
   6929          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   6930          /***************************************************************************//**
   6931           * @brief
   6932           *   Set AUXHFRCO calibration for the selected target frequency.
   6933           *
   6934           * @param[in] setFreq
   6935           *   AUXHFRCO frequency to set
   6936           ******************************************************************************/
   6937          void CMU_AUXHFRCOBandSet(CMU_AUXHFRCOFreq_TypeDef setFreq)
   6938          {
   6939            uint32_t freqCal;
   6940          
   6941            /* Get DEVINFO index and set global auxHfrcoFreq. */
   6942            freqCal = CMU_AUXHFRCODevinfoGet(setFreq);
   6943            EFM_ASSERT((freqCal != 0UL) && (freqCal != UINT_MAX));
   6944            auxHfrcoFreq = setFreq;
   6945          
   6946            /* Wait for any previous sync to complete, then set calibration data
   6947               for the selected frequency.  */
   6948            while (BUS_RegBitRead(&CMU->SYNCBUSY,
   6949                                  _CMU_SYNCBUSY_AUXHFRCOBSY_SHIFT) != 0UL) {
   6950            }
   6951          
   6952            /* Set a divider in AUXHFRCOCTRL for 1, 2, and 4 MHz. */
   6953            switch (setFreq) {
   6954              case cmuAUXHFRCOFreq_1M0Hz:
   6955                freqCal = (freqCal & ~_CMU_AUXHFRCOCTRL_CLKDIV_MASK)
   6956                          | CMU_AUXHFRCOCTRL_CLKDIV_DIV4;
   6957                break;
   6958          
   6959              case cmuAUXHFRCOFreq_2M0Hz:
   6960                freqCal = (freqCal & ~_CMU_AUXHFRCOCTRL_CLKDIV_MASK)
   6961                          | CMU_AUXHFRCOCTRL_CLKDIV_DIV2;
   6962                break;
   6963          
   6964              case cmuAUXHFRCOFreq_4M0Hz:
   6965                freqCal = (freqCal & ~_CMU_AUXHFRCOCTRL_CLKDIV_MASK)
   6966                          | CMU_AUXHFRCOCTRL_CLKDIV_DIV1;
   6967                break;
   6968          
   6969              default:
   6970                break;
   6971            }
   6972            CMU->AUXHFRCOCTRL = freqCal;
   6973          }
   6974          #endif /* _CMU_AUXHFRCOCTRL_FREQRANGE_MASK */
   6975          
   6976          /***************************************************************************//**
   6977           * @brief
   6978           *   Calibrate the clock.
   6979           *
   6980           * @details
   6981           *   Run a calibration for HFCLK against a selectable reference clock.
   6982           *   See the reference manual, CMU chapter, for more details.
   6983           *
   6984           * @note
   6985           *   This function will not return until the calibration measurement is completed.
   6986           *
   6987           * @param[in] HFCycles
   6988           *   The number of HFCLK cycles to run the calibration. Increasing this number
   6989           *   increases precision but the calibration will take more time.
   6990           *
   6991           * @param[in] reference
   6992           *   The reference clock used to compare HFCLK.
   6993           *
   6994           * @return
   6995           *   The number of ticks the reference clock after HFCycles ticks on the HF
   6996           *   clock.
   6997           ******************************************************************************/
   6998          uint32_t CMU_Calibrate(uint32_t HFCycles, CMU_Osc_TypeDef reference)
   6999          {
   7000            EFM_ASSERT(HFCycles <= (_CMU_CALCNT_CALCNT_MASK >> _CMU_CALCNT_CALCNT_SHIFT));
   7001          
   7002            /* Set the reference clock source. */
   7003            switch (reference) {
   7004              case cmuOsc_LFXO:
   7005                CMU->CALCTRL = CMU_CALCTRL_UPSEL_LFXO;
   7006                break;
   7007          
   7008              case cmuOsc_LFRCO:
   7009                CMU->CALCTRL = CMU_CALCTRL_UPSEL_LFRCO;
   7010                break;
   7011          
   7012          #if defined(PLFRCO_PRESENT)
   7013              case cmuOsc_PLFRCO:
   7014                CMU->CALCTRL = CMU_CALCTRL_UPSEL_PLFRCO;
   7015                break;
   7016          #endif
   7017          
   7018              case cmuOsc_HFXO:
   7019                CMU->CALCTRL = CMU_CALCTRL_UPSEL_HFXO;
   7020                break;
   7021          
   7022              case cmuOsc_HFRCO:
   7023                CMU->CALCTRL = CMU_CALCTRL_UPSEL_HFRCO;
   7024                break;
   7025          
   7026              case cmuOsc_AUXHFRCO:
   7027                CMU->CALCTRL = CMU_CALCTRL_UPSEL_AUXHFRCO;
   7028                break;
   7029          
   7030          #if defined (_CMU_USHFRCOCTRL_MASK)
   7031              case cmuOsc_USHFRCO:
   7032                CMU->CALCTRL = CMU_CALCTRL_UPSEL_USHFRCO;
   7033                break;
   7034          #endif
   7035          
   7036              default:
   7037                EFM_ASSERT(false);
   7038                return 0;
   7039            }
   7040          
   7041            /* Set the top value. */
   7042            CMU->CALCNT = HFCycles;
   7043          
   7044            /* Start the calibration. */
   7045            CMU->CMD = CMU_CMD_CALSTART;
   7046          
   7047          #if defined(CMU_STATUS_CALRDY)
   7048            /* Wait until calibration completes. */
   7049            while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALRDY_SHIFT) == 0UL) {
   7050            }
   7051          #else
   7052            /* Wait until calibration completes. */
   7053            while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALBSY_SHIFT) != 0UL) {
   7054            }
   7055          #endif
   7056          
   7057            return CMU->CALCNT;
   7058          }
   7059          
   7060          #if defined(_CMU_CALCTRL_UPSEL_MASK) && defined(_CMU_CALCTRL_DOWNSEL_MASK)
   7061          /***************************************************************************//**
   7062           * @brief
   7063           *   Configure the clock calibration.
   7064           *
   7065           * @details
   7066           *   Configure a calibration for a selectable clock source against another
   7067           *   selectable reference clock.
   7068           *   See the reference manual, CMU chapter, for more details.
   7069           *
   7070           * @note
   7071           *   After configuration, a call to @ref CMU_CalibrateStart() is required and
   7072           *   the resulting calibration value can be read out with the
   7073           *   @ref CMU_CalibrateCountGet() function call.
   7074           *
   7075           * @param[in] downCycles
   7076           *   The number of downSel clock cycles to run the calibration. Increasing this
   7077           *   number increases precision but the calibration will take more time.
   7078           *
   7079           * @param[in] downSel
   7080           *   The clock, which will be counted down downCycles.
   7081           *
   7082           * @param[in] upSel
   7083           *   The reference clock; the number of cycles generated by this clock will
   7084           *   be counted and added up and the result can be given with the
   7085           *   @ref CMU_CalibrateCountGet() function call.
   7086           ******************************************************************************/
   7087          void CMU_CalibrateConfig(uint32_t downCycles, CMU_Osc_TypeDef downSel,
   7088                                   CMU_Osc_TypeDef upSel)
   7089          {
   7090            /* Keep configuration settings untouched. */
   7091            uint32_t calCtrl = CMU->CALCTRL
   7092                               & ~(_CMU_CALCTRL_UPSEL_MASK | _CMU_CALCTRL_DOWNSEL_MASK);
   7093          
   7094            /* 20 bits of precision to calibration count register. */
   7095            EFM_ASSERT(downCycles <= (_CMU_CALCNT_CALCNT_MASK >> _CMU_CALCNT_CALCNT_SHIFT));
   7096          
   7097            /* Set down counting clock source - down counter. */
   7098            switch (downSel) {
   7099              case cmuOsc_LFXO:
   7100                calCtrl |= CMU_CALCTRL_DOWNSEL_LFXO;
   7101                break;
   7102          
   7103              case cmuOsc_LFRCO:
   7104                calCtrl |= CMU_CALCTRL_DOWNSEL_LFRCO;
   7105                break;
   7106          
   7107          #if defined(PLFRCO_PRESENT)
   7108              case cmuOsc_PLFRCO:
   7109                calCtrl |= CMU_CALCTRL_DOWNSEL_PLFRCO;
   7110                break;
   7111          #endif
   7112          
   7113              case cmuOsc_HFXO:
   7114                calCtrl |= CMU_CALCTRL_DOWNSEL_HFXO;
   7115                break;
   7116          
   7117              case cmuOsc_HFRCO:
   7118                calCtrl |= CMU_CALCTRL_DOWNSEL_HFRCO;
   7119                break;
   7120          
   7121              case cmuOsc_AUXHFRCO:
   7122                calCtrl |= CMU_CALCTRL_DOWNSEL_AUXHFRCO;
   7123                break;
   7124          
   7125          #if defined (_CMU_USHFRCOCTRL_MASK)
   7126              case cmuOsc_USHFRCO:
   7127                calCtrl |= CMU_CALCTRL_DOWNSEL_USHFRCO;
   7128                break;
   7129          #endif
   7130          
   7131              default:
   7132                EFM_ASSERT(false);
   7133                break;
   7134            }
   7135          
   7136            /* Set the top value to be counted down by the downSel clock. */
   7137            CMU->CALCNT = downCycles;
   7138          
   7139            /* Set the reference clock source - up counter. */
   7140            switch (upSel) {
   7141              case cmuOsc_LFXO:
   7142                calCtrl |= CMU_CALCTRL_UPSEL_LFXO;
   7143                break;
   7144          
   7145              case cmuOsc_LFRCO:
   7146                calCtrl |= CMU_CALCTRL_UPSEL_LFRCO;
   7147                break;
   7148          
   7149          #if defined(PLFRCO_PRESENT)
   7150              case cmuOsc_PLFRCO:
   7151                calCtrl |= CMU_CALCTRL_UPSEL_PLFRCO;
   7152                break;
   7153          #endif
   7154          
   7155              case cmuOsc_HFXO:
   7156                calCtrl |= CMU_CALCTRL_UPSEL_HFXO;
   7157                break;
   7158          
   7159              case cmuOsc_HFRCO:
   7160                calCtrl |= CMU_CALCTRL_UPSEL_HFRCO;
   7161                break;
   7162          
   7163              case cmuOsc_AUXHFRCO:
   7164                calCtrl |= CMU_CALCTRL_UPSEL_AUXHFRCO;
   7165                break;
   7166          
   7167          #if defined (_CMU_USHFRCOCTRL_MASK)
   7168              case cmuOsc_USHFRCO:
   7169                calCtrl |= CMU_CALCTRL_UPSEL_USHFRCO;
   7170                break;
   7171          #endif
   7172          
   7173              default:
   7174                EFM_ASSERT(false);
   7175                break;
   7176            }
   7177          
   7178            CMU->CALCTRL = calCtrl;
   7179          }
   7180          #endif
   7181          
   7182          /***************************************************************************//**
   7183           * @brief
   7184           *    Get the calibration count register.
   7185           * @note
   7186           *    If continuous calibration mode is active, calibration busy will almost
   7187           *    always be off and only the value needs to be read. In a normal case,
   7188           *    this function call is triggered by the CALRDY
   7189           *    interrupt flag.
   7190           * @return
   7191           *    The calibration count, the number of UPSEL clocks
   7192           *    in the period of DOWNSEL oscillator clock cycles configured by a previous
   7193           *    write operation to CMU->CALCNT.
   7194           ******************************************************************************/
   7195          uint32_t CMU_CalibrateCountGet(void)
   7196          {
   7197            /* Wait until calibration completes, UNLESS continuous calibration mode is  */
   7198            /* active. */
   7199          #if defined(CMU_CALCTRL_CONT)
   7200            if (BUS_RegBitRead(&CMU->CALCTRL, _CMU_CALCTRL_CONT_SHIFT) == 0UL) {
   7201          #if defined(CMU_STATUS_CALRDY)
   7202              /* Wait until calibration completes */
   7203              while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALRDY_SHIFT) == 0UL) {
   7204              }
   7205          #else
   7206              /* Wait until calibration completes */
   7207              while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALBSY_SHIFT) != 0UL) {
   7208              }
   7209          #endif
   7210            }
   7211          #else
   7212            while (BUS_RegBitRead(&CMU->STATUS, _CMU_STATUS_CALBSY_SHIFT) != 0UL) {
   7213            }
   7214          #endif
   7215            return CMU->CALCNT;
   7216          }
   7217          
   7218          /***************************************************************************//**
   7219           * @brief
   7220           *   Get the clock divisor/prescaler.
   7221           *
   7222           * @param[in] clock
   7223           *   A clock point to get the divisor/prescaler for. Notice that not all clock points
   7224           *   have a divisor/prescaler. See the CMU overview in the reference manual.
   7225           *
   7226           * @return
   7227           *   The current clock point divisor/prescaler. 1 is returned
   7228           *   if @p clock specifies a clock point without a divisor/prescaler.
   7229           ******************************************************************************/
   7230          CMU_ClkDiv_TypeDef CMU_ClockDivGet(CMU_Clock_TypeDef clock)
   7231          {
   7232          #if defined(_SILICON_LABS_32B_SERIES_1)
   7233            return 1UL + (uint32_t)CMU_ClockPrescGet(clock);
   7234          
   7235          #elif defined(_SILICON_LABS_32B_SERIES_0)
   7236            uint32_t           divReg;
   7237            CMU_ClkDiv_TypeDef ret;
   7238          
   7239            /* Get divisor reg ID. */
   7240            divReg = (clock >> CMU_DIV_REG_POS) & CMU_DIV_REG_MASK;
   7241          
   7242            switch (divReg) {
   7243          #if defined(_CMU_CTRL_HFCLKDIV_MASK)
   7244              case CMU_HFCLKDIV_REG:
   7245                ret = 1 + ((CMU->CTRL & _CMU_CTRL_HFCLKDIV_MASK)
   7246                           >> _CMU_CTRL_HFCLKDIV_SHIFT);
   7247                break;
   7248          #endif
   7249          
   7250              case CMU_HFPERCLKDIV_REG:
   7251                ret = (CMU_ClkDiv_TypeDef)((CMU->HFPERCLKDIV
   7252                                            & _CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   7253                                           >> _CMU_HFPERCLKDIV_HFPERCLKDIV_SHIFT);
   7254                ret = SL_Log2ToDiv(ret);
   7255                break;
   7256          
   7257              case CMU_HFCORECLKDIV_REG:
   7258                ret = (CMU_ClkDiv_TypeDef)((CMU->HFCORECLKDIV
   7259                                            & _CMU_HFCORECLKDIV_HFCORECLKDIV_MASK)
   7260                                           >> _CMU_HFCORECLKDIV_HFCORECLKDIV_SHIFT);
   7261                ret = SL_Log2ToDiv(ret);
   7262                break;
   7263          
   7264          #if defined(_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7265              case CMU_HFCORECLKLEDIV_REG:
   7266                ret = (CMU_ClkDiv_TypeDef)((CMU->HFCORECLKDIV
   7267                                            & _CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7268                                           >> _CMU_HFCORECLKDIV_HFCORECLKLEDIV_SHIFT);
   7269                ret = SL_Log2ToDiv(ret + 1U);
   7270                break;
   7271          #endif
   7272          
   7273              case CMU_LFAPRESC0_REG:
   7274                switch (clock) {
   7275                  case cmuClock_RTC:
   7276                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFAPRESC0 & _CMU_LFAPRESC0_RTC_MASK)
   7277                                               >> _CMU_LFAPRESC0_RTC_SHIFT);
   7278                    ret = SL_Log2ToDiv(ret);
   7279                    break;
   7280          
   7281          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   7282                  case cmuClock_LETIMER0:
   7283                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   7284                                               >> _CMU_LFAPRESC0_LETIMER0_SHIFT);
   7285                    ret = SL_Log2ToDiv(ret);
   7286                    break;
   7287          #endif
   7288          
   7289          #if defined(_CMU_LFAPRESC0_LCD_MASK)
   7290                  case cmuClock_LCDpre:
   7291                    ret = (CMU_ClkDiv_TypeDef)(((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   7292                                                >> _CMU_LFAPRESC0_LCD_SHIFT)
   7293                                               + CMU_DivToLog2(cmuClkDiv_16));
   7294                    ret = SL_Log2ToDiv(ret);
   7295                    break;
   7296          #endif
   7297          
   7298          #if defined(_CMU_LFAPRESC0_LESENSE_MASK)
   7299                  case cmuClock_LESENSE:
   7300                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LESENSE_MASK)
   7301                                               >> _CMU_LFAPRESC0_LESENSE_SHIFT);
   7302                    ret = SL_Log2ToDiv(ret);
   7303                    break;
   7304          #endif
   7305          
   7306                  default:
   7307                    ret = cmuClkDiv_1;
   7308                    EFM_ASSERT(false);
   7309                    break;
   7310                }
   7311                break;
   7312          
   7313              case CMU_LFBPRESC0_REG:
   7314                switch (clock) {
   7315          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   7316                  case cmuClock_LEUART0:
   7317                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   7318                                               >> _CMU_LFBPRESC0_LEUART0_SHIFT);
   7319                    ret = SL_Log2ToDiv(ret);
   7320                    break;
   7321          #endif
   7322          
   7323          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   7324                  case cmuClock_LEUART1:
   7325                    ret = (CMU_ClkDiv_TypeDef)((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   7326                                               >> _CMU_LFBPRESC0_LEUART1_SHIFT);
   7327                    ret = SL_Log2ToDiv(ret);
   7328                    break;
   7329          #endif
   7330          
   7331                  default:
   7332                    ret = cmuClkDiv_1;
   7333                    EFM_ASSERT(false);
   7334                    break;
   7335                }
   7336                break;
   7337          
   7338              default:
   7339                ret = cmuClkDiv_1;
   7340                EFM_ASSERT(false);
   7341                break;
   7342            }
   7343          
   7344            return ret;
   7345          #endif
   7346          }
   7347          
   7348          /***************************************************************************//**
   7349           * @brief
   7350           *   Set the clock divisor/prescaler.
   7351           *
   7352           * @note
   7353           *   If setting an LF clock prescaler, synchronization into the low-frequency
   7354           *   domain is required. If the same register is modified before a previous
   7355           *   update has completed, this function will stall until the previous
   7356           *   synchronization has completed. See @ref CMU_FreezeEnable() for
   7357           *   a suggestion on how to reduce the stalling time in some use cases.
   7358           *
   7359           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   7360           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   7361           *
   7362           * @param[in] clock
   7363           *   Clock point to set divisor/prescaler for. Notice that not all clock points
   7364           *   have a divisor/prescaler. See the CMU overview in the reference
   7365           *   manual.
   7366           *
   7367           * @param[in] div
   7368           *   The clock divisor to use (<= cmuClkDiv_512).
   7369           ******************************************************************************/
   7370          void CMU_ClockDivSet(CMU_Clock_TypeDef clock, CMU_ClkDiv_TypeDef div)
   7371          {
   7372          #if defined(_SILICON_LABS_32B_SERIES_1)
   7373            CMU_ClockPrescSet(clock, (CMU_ClkPresc_TypeDef)(div - 1U));
   7374          
   7375          #elif defined(_SILICON_LABS_32B_SERIES_0)
   7376            uint32_t freq;
   7377            uint32_t divReg;
   7378          
   7379            /* Get the divisor reg ID. */
   7380            divReg = (clock >> CMU_DIV_REG_POS) & CMU_DIV_REG_MASK;
   7381          
   7382            switch (divReg) {
   7383          #if defined(_CMU_CTRL_HFCLKDIV_MASK)
   7384              case CMU_HFCLKDIV_REG:
   7385                EFM_ASSERT((div >= cmuClkDiv_1) && (div <= cmuClkDiv_8));
   7386          
   7387                /* Configure worst case wait states for flash access before setting divisor. */
   7388                flashWaitStateMax();
   7389          
   7390                /* Set the divider. */
   7391                CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFCLKDIV_MASK)
   7392                            | ((div - 1) << _CMU_CTRL_HFCLKDIV_SHIFT);
   7393          
   7394                /* Update the CMSIS core clock variable. */
   7395                /* (The function will update the global variable). */
   7396                freq = SystemCoreClockGet();
   7397          
   7398                /* Optimize flash access wait state setting for the current core clk. */
   7399                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   7400                break;
   7401          #endif
   7402          
   7403              case CMU_HFPERCLKDIV_REG:
   7404                EFM_ASSERT((div >= cmuClkDiv_1) && (div <= cmuClkDiv_512));
   7405                /* Convert to the correct scale. */
   7406                div = CMU_DivToLog2(div);
   7407                CMU->HFPERCLKDIV = (CMU->HFPERCLKDIV & ~_CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   7408                                   | (div << _CMU_HFPERCLKDIV_HFPERCLKDIV_SHIFT);
   7409                break;
   7410          
   7411          #if defined(_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7412              case CMU_HFCORECLKLEDIV_REG:
   7413                /*
   7414                   This divisor is usually set when changing HF clock to keep HFLE clock
   7415                   within safe bounds. This code path ignore these constraints.
   7416                 */
   7417                /* Convert to the correct scale. */
   7418                div = CMU_DivToLog2(div) - 1U;
   7419                CMU->HFCORECLKDIV = (CMU->HFCORECLKDIV
   7420                                     & ~_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7421                                    | (div << _CMU_HFCORECLKDIV_HFCORECLKLEDIV_SHIFT);
   7422                break;
   7423          #endif
   7424          
   7425              case CMU_HFCORECLKDIV_REG:
   7426                EFM_ASSERT((div >= cmuClkDiv_1) && (div <= cmuClkDiv_512));
   7427          
   7428                /* Configure worst case wait states for flash access before setting the divisor. */
   7429                flashWaitStateMax();
   7430          
   7431          #if defined(CMU_MAX_FREQ_HFLE)
   7432                setHfLeConfig(SystemCoreClockGet() / div);
   7433          #endif
   7434          
   7435                /* Convert to the correct scale. */
   7436                div = CMU_DivToLog2(div);
   7437          
   7438                CMU->HFCORECLKDIV = (CMU->HFCORECLKDIV
   7439                                     & ~_CMU_HFCORECLKDIV_HFCORECLKDIV_MASK)
   7440                                    | (div << _CMU_HFCORECLKDIV_HFCORECLKDIV_SHIFT);
   7441          
   7442                /* Update the CMSIS core clock variable. */
   7443                /* (The function will update the global variable). */
   7444                freq = SystemCoreClockGet();
   7445          
   7446                /* Optimize wait state setting for the current core clk. */
   7447                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   7448          #if defined(CMU_MAX_FREQ_HFLE)
   7449                setHfLeConfig(freq);
   7450          #endif
   7451                break;
   7452          
   7453              case CMU_LFAPRESC0_REG:
   7454                switch (clock) {
   7455                  case cmuClock_RTC:
   7456                    EFM_ASSERT(div <= cmuClkDiv_32768);
   7457          
   7458                    /* LF register about to be modified requires sync. busy check. */
   7459                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7460          
   7461                    /* Convert to the correct scale. */
   7462                    div = CMU_DivToLog2(div);
   7463          
   7464                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_RTC_MASK)
   7465                                     | (div << _CMU_LFAPRESC0_RTC_SHIFT);
   7466                    break;
   7467          
   7468          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   7469                  case cmuClock_LETIMER0:
   7470                    EFM_ASSERT(div <= cmuClkDiv_32768);
   7471          
   7472                    /* LF register about to be modified requires sync. busy check. */
   7473                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7474          
   7475                    /* Convert to the correct scale. */
   7476                    div = CMU_DivToLog2(div);
   7477          
   7478                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LETIMER0_MASK)
   7479                                     | (div << _CMU_LFAPRESC0_LETIMER0_SHIFT);
   7480                    break;
   7481          #endif
   7482          
   7483          #if defined(LCD_PRESENT)
   7484                  case cmuClock_LCDpre:
   7485                    EFM_ASSERT((div >= cmuClkDiv_16) && (div <= cmuClkDiv_128));
   7486          
   7487                    /* LF register about to be modified requires sync. busy check. */
   7488                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7489          
   7490                    /* Convert to the correct scale. */
   7491                    div = CMU_DivToLog2(div);
   7492          
   7493                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LCD_MASK)
   7494                                     | ((div - CMU_DivToLog2(cmuClkDiv_16))
   7495                                        << _CMU_LFAPRESC0_LCD_SHIFT);
   7496                    break;
   7497          #endif /* defined(LCD_PRESENT) */
   7498          
   7499          #if defined(LESENSE_PRESENT)
   7500                  case cmuClock_LESENSE:
   7501                    EFM_ASSERT(div <= cmuClkDiv_8);
   7502          
   7503                    /* LF register about to be modified requires sync. busy check. */
   7504                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   7505          
   7506                    /* Convert to the correct scale. */
   7507                    div = CMU_DivToLog2(div);
   7508          
   7509                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LESENSE_MASK)
   7510                                     | (div << _CMU_LFAPRESC0_LESENSE_SHIFT);
   7511                    break;
   7512          #endif /* defined(LESENSE_PRESENT) */
   7513          
   7514                  default:
   7515                    EFM_ASSERT(false);
   7516                    break;
   7517                }
   7518                break;
   7519          
   7520              case CMU_LFBPRESC0_REG:
   7521                switch (clock) {
   7522          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   7523                  case cmuClock_LEUART0:
   7524                    EFM_ASSERT(div <= cmuClkDiv_8);
   7525          
   7526                    /* LF register about to be modified requires sync. busy check. */
   7527                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   7528          
   7529                    /* Convert to the correct scale. */
   7530                    div = CMU_DivToLog2(div);
   7531          
   7532                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART0_MASK)
   7533                                     | (((uint32_t)div) << _CMU_LFBPRESC0_LEUART0_SHIFT);
   7534                    break;
   7535          #endif
   7536          
   7537          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   7538                  case cmuClock_LEUART1:
   7539                    EFM_ASSERT(div <= cmuClkDiv_8);
   7540          
   7541                    /* LF register about to be modified requires sync. busy check. */
   7542                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   7543          
   7544                    /* Convert to the correct scale. */
   7545                    div = CMU_DivToLog2(div);
   7546          
   7547                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART1_MASK)
   7548                                     | (((uint32_t)div) << _CMU_LFBPRESC0_LEUART1_SHIFT);
   7549                    break;
   7550          #endif
   7551          
   7552                  default:
   7553                    EFM_ASSERT(false);
   7554                    break;
   7555                }
   7556                break;
   7557          
   7558              default:
   7559                EFM_ASSERT(false);
   7560                break;
   7561            }
   7562          #endif
   7563          }
   7564          
   7565          /***************************************************************************//**
   7566           * @brief
   7567           *   Enable/disable a clock.
   7568           *
   7569           * @details
   7570           *   In general, module clocking is disabled after a reset. If a module
   7571           *   clock is disabled, the registers of that module are not accessible and
   7572           *   reading from such registers may return undefined values. Writing to
   7573           *   registers of clock-disabled modules has no effect.
   7574           *   Avoid accessing module registers of a module with a disabled clock.
   7575           *
   7576           * @note
   7577           *   If enabling/disabling an LF clock, synchronization into the low-frequency
   7578           *   domain is required. If the same register is modified before a previous
   7579           *   update has completed, this function will stall until the previous
   7580           *   synchronization has completed. See @ref CMU_FreezeEnable() for
   7581           *   a suggestion on how to reduce the stalling time in some use cases.
   7582           *
   7583           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   7584           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   7585           *
   7586           * @param[in] clock
   7587           *   The clock to enable/disable. Notice that not all defined clock
   7588           *   points have separate enable/disable control. See the CMU overview
   7589           *   in the reference manual.
   7590           *
   7591           * @param[in] enable
   7592           *   @li true - enable specified clock.
   7593           *   @li false - disable specified clock.
   7594           ******************************************************************************/
   7595          void CMU_ClockEnable(CMU_Clock_TypeDef clock, bool enable)
   7596          {
   7597            volatile uint32_t *reg;
   7598            uint32_t          bit;
   7599            uint32_t          sync = 0;
   7600          
   7601            /* Identify enable register */
   7602            switch (((unsigned)clock >> CMU_EN_REG_POS) & CMU_EN_REG_MASK) {
   7603          #if defined(_CMU_CTRL_HFPERCLKEN_MASK)
   7604              case CMU_CTRL_EN_REG:
   7605                reg = &CMU->CTRL;
   7606                break;
   7607          #endif
   7608          
   7609          #if defined(_CMU_HFCORECLKEN0_MASK)
   7610              case CMU_HFCORECLKEN0_EN_REG:
   7611                reg = &CMU->HFCORECLKEN0;
   7612          #if defined(CMU_MAX_FREQ_HFLE)
   7613                setHfLeConfig(SystemCoreClockGet());
   7614          #endif
   7615                break;
   7616          #endif
   7617          
   7618          #if defined(_CMU_HFBUSCLKEN0_MASK)
   7619              case CMU_HFBUSCLKEN0_EN_REG:
   7620                reg = &CMU->HFBUSCLKEN0;
   7621                break;
   7622          #endif
   7623          
   7624          #if defined(_CMU_HFPERCLKDIV_MASK)
   7625              case CMU_HFPERCLKDIV_EN_REG:
   7626                reg = &CMU->HFPERCLKDIV;
   7627                break;
   7628          #endif
   7629          
   7630              case CMU_HFPERCLKEN0_EN_REG:
   7631                reg = &CMU->HFPERCLKEN0;
   7632                break;
   7633          
   7634          #if defined(_CMU_HFPERCLKEN1_MASK)
   7635              case CMU_HFPERCLKEN1_EN_REG:
   7636                reg = &CMU->HFPERCLKEN1;
   7637                break;
   7638          #endif
   7639          
   7640              case CMU_LFACLKEN0_EN_REG:
   7641                reg  = &CMU->LFACLKEN0;
   7642                sync = CMU_SYNCBUSY_LFACLKEN0;
   7643                break;
   7644          
   7645              case CMU_LFBCLKEN0_EN_REG:
   7646                reg  = &CMU->LFBCLKEN0;
   7647                sync = CMU_SYNCBUSY_LFBCLKEN0;
   7648                break;
   7649          
   7650          #if defined(_CMU_LFCCLKEN0_MASK)
   7651              case CMU_LFCCLKEN0_EN_REG:
   7652                reg = &CMU->LFCCLKEN0;
   7653                sync = CMU_SYNCBUSY_LFCCLKEN0;
   7654                break;
   7655          #endif
   7656          
   7657          #if defined(_CMU_LFECLKEN0_MASK)
   7658              case CMU_LFECLKEN0_EN_REG:
   7659                reg  = &CMU->LFECLKEN0;
   7660                sync = CMU_SYNCBUSY_LFECLKEN0;
   7661                break;
   7662          #endif
   7663          
   7664          #if defined(_CMU_SDIOCTRL_MASK)
   7665              case CMU_SDIOREF_EN_REG:
   7666                reg = &CMU->SDIOCTRL;
   7667                enable = !enable;
   7668                break;
   7669          #endif
   7670          
   7671          #if defined(_CMU_QSPICTRL_MASK)
   7672              case CMU_QSPI0REF_EN_REG:
   7673                reg = &CMU->QSPICTRL;
   7674                enable = !enable;
   7675                break;
   7676          #endif
   7677          #if defined(_CMU_USBCTRL_MASK)
   7678              case CMU_USBRCLK_EN_REG:
   7679                reg = &CMU->USBCTRL;
   7680                break;
   7681          #endif
   7682          #if defined(_CMU_PDMCTRL_MASK)
   7683              case CMU_PDMREF_EN_REG:
   7684                reg = &CMU->PDMCTRL;
   7685                break;
   7686          #endif
   7687          
   7688              case CMU_PCNT_EN_REG:
   7689                reg = &CMU->PCNTCTRL;
   7690                break;
   7691          
   7692              default: /* Cannot enable/disable a clock point. */
   7693                EFM_ASSERT(false);
   7694                return;
   7695            }
   7696          
   7697            /* Get the bit position used to enable/disable. */
   7698            bit = ((unsigned)clock >> CMU_EN_BIT_POS) & CMU_EN_BIT_MASK;
   7699          
   7700            /* LF synchronization required. */
   7701            if (sync > 0UL) {
   7702              syncReg(sync);
   7703            }
   7704          
   7705            /* Set/clear bit as requested. */
   7706            BUS_RegBitWrite(reg, bit, (uint32_t)enable);
   7707          }
   7708          
   7709          /***************************************************************************//**
   7710           * @brief
   7711           *   Get the clock frequency for a clock point.
   7712           *
   7713           * @param[in] clock
   7714           *   A clock point to fetch the frequency for.
   7715           *
   7716           * @return
   7717           *   The current frequency in Hz.
   7718           ******************************************************************************/
   7719          uint32_t CMU_ClockFreqGet(CMU_Clock_TypeDef clock)
   7720          {
   7721            uint32_t ret;
   7722          
   7723            switch ((unsigned)clock & (CMU_CLK_BRANCH_MASK << CMU_CLK_BRANCH_POS)) {
   7724              case (CMU_HF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7725                ret = SystemHFClockGet();
   7726                break;
   7727          
   7728              case (CMU_HFPER_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7729                ret = SystemHFClockGet();
   7730                /* Calculate frequency after HFPER divider. */
   7731          #if defined(_CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   7732                ret >>= (CMU->HFPERCLKDIV & _CMU_HFPERCLKDIV_HFPERCLKDIV_MASK)
   7733                        >> _CMU_HFPERCLKDIV_HFPERCLKDIV_SHIFT;
   7734          #endif
   7735          #if defined(_CMU_HFPERPRESC_PRESC_MASK)
   7736                ret /= 1U + ((CMU->HFPERPRESC & _CMU_HFPERPRESC_PRESC_MASK)
   7737                             >> _CMU_HFPERPRESC_PRESC_SHIFT);
   7738          #endif
   7739                break;
   7740          
   7741          #if defined(_CMU_HFPERPRESCB_MASK)
   7742              case (CMU_HFPERB_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7743                ret = SystemHFClockGet();
   7744                /* Calculate frequency after HFPERB prescaler. */
   7745                ret /= 1U + ((CMU->HFPERPRESCB & _CMU_HFPERPRESCB_PRESC_MASK)
   7746                             >> _CMU_HFPERPRESCB_PRESC_SHIFT);
   7747                break;
   7748          #endif
   7749          
   7750          #if defined(_CMU_HFPERPRESCC_MASK)
   7751              case (CMU_HFPERC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7752                ret = SystemHFClockGet();
   7753                /* Calculate frequency after HFPERC prescaler. */
   7754                ret /= 1U + ((CMU->HFPERPRESCC & _CMU_HFPERPRESCC_PRESC_MASK)
   7755                             >> _CMU_HFPERPRESCC_PRESC_SHIFT);
   7756                break;
   7757          #endif
   7758          
   7759          #if defined(_SILICON_LABS_32B_SERIES_1)
   7760          #if defined(CRYPTO_PRESENT)     \
   7761                || defined(LDMA_PRESENT)  \
   7762                || defined(GPCRC_PRESENT) \
   7763                || defined(PRS_PRESENT)   \
   7764                || defined(GPIO_PRESENT)
   7765              case (CMU_HFBUS_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7766                ret = SystemHFClockGet();
   7767          #if defined(_CMU_HFBUSPRESC_MASK)
   7768                ret /= 1U + ((CMU->HFBUSPRESC & _CMU_HFBUSPRESC_MASK)
   7769                             >> _CMU_HFBUSPRESC_PRESC_SHIFT);
   7770          #endif
   7771                break;
   7772          #endif
   7773          
   7774              case (CMU_HFCORE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7775                ret = SystemHFClockGet();
   7776                ret /= 1U + ((CMU->HFCOREPRESC & _CMU_HFCOREPRESC_PRESC_MASK)
   7777                             >> _CMU_HFCOREPRESC_PRESC_SHIFT);
   7778                break;
   7779          
   7780              case (CMU_HFEXP_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7781                ret = SystemHFClockGet();
   7782                ret /= 1U + ((CMU->HFEXPPRESC & _CMU_HFEXPPRESC_PRESC_MASK)
   7783                             >> _CMU_HFEXPPRESC_PRESC_SHIFT);
   7784                break;
   7785          #endif
   7786          
   7787          #if defined(_SILICON_LABS_32B_SERIES_0)
   7788          #if defined(AES_PRESENT)      \
   7789                || defined(DMA_PRESENT) \
   7790                || defined(EBI_PRESENT) \
   7791                || defined(USB_PRESENT)
   7792              case (CMU_HFCORE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7793              {
   7794                ret = SystemCoreClockGet();
   7795              } break;
   7796          #endif
   7797          #endif
   7798          
   7799              case (CMU_LFA_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7800                ret = lfClkGet(cmuClock_LFA);
   7801                break;
   7802          
   7803          #if defined(_CMU_LFACLKEN0_RTC_MASK)
   7804              case (CMU_RTC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7805                ret = lfClkGet(cmuClock_LFA);
   7806                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_RTC_MASK)
   7807                        >> _CMU_LFAPRESC0_RTC_SHIFT;
   7808                break;
   7809          #endif
   7810          
   7811          #if defined(_CMU_LFECLKEN0_RTCC_MASK)
   7812              case (CMU_RTCC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7813                ret = lfClkGet(cmuClock_LFE);
   7814                ret >>= (CMU->LFEPRESC0 & _CMU_LFEPRESC0_RTCC_MASK)
   7815                        >> _CMU_LFEPRESC0_RTCC_SHIFT;
   7816                break;
   7817          #endif
   7818          
   7819          #if defined(_CMU_LFACLKEN0_LETIMER0_MASK)
   7820              case (CMU_LETIMER0_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7821                ret = lfClkGet(cmuClock_LFA);
   7822          #if defined(_SILICON_LABS_32B_SERIES_0)
   7823                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   7824                        >> _CMU_LFAPRESC0_LETIMER0_SHIFT;
   7825          #else
   7826                ret /= SL_Log2ToDiv((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   7827                                    >> _CMU_LFAPRESC0_LETIMER0_SHIFT);
   7828          #endif
   7829                break;
   7830          #endif
   7831          
   7832          #if defined(_CMU_LFACLKEN0_LETIMER1_MASK)
   7833              case (CMU_LETIMER1_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7834                ret = lfClkGet(cmuClock_LFA);
   7835          #if defined(_SILICON_LABS_32B_SERIES_0)
   7836                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER1_MASK)
   7837                        >> _CMU_LFAPRESC0_LETIMER1_SHIFT;
   7838          #else
   7839                ret /= SL_Log2ToDiv((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER1_MASK)
   7840                                    >> _CMU_LFAPRESC0_LETIMER1_SHIFT);
   7841          #endif
   7842                break;
   7843          #endif
   7844          
   7845          #if defined(_CMU_LFACLKEN0_LCD_MASK)
   7846              case (CMU_LCDPRE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7847                ret = lfClkGet(cmuClock_LFA);
   7848          #if defined(_SILICON_LABS_32B_SERIES_0)
   7849                ret >>= ((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   7850                         >> _CMU_LFAPRESC0_LCD_SHIFT)
   7851                        + CMU_DivToLog2(cmuClkDiv_16);
   7852          #else
   7853                ret /= SL_Log2ToDiv((CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   7854                                    >> _CMU_LFAPRESC0_LCD_SHIFT);
   7855          #endif
   7856                break;
   7857          
   7858          #if defined(_CMU_LCDCTRL_MASK)
   7859              case (CMU_LCD_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7860                ret = lfClkGet(cmuClock_LFA);
   7861                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   7862                        >> _CMU_LFAPRESC0_LCD_SHIFT;
   7863                ret /= 1U + ((CMU->LCDCTRL & _CMU_LCDCTRL_FDIV_MASK)
   7864                             >> _CMU_LCDCTRL_FDIV_SHIFT);
   7865                break;
   7866          #endif
   7867          #endif
   7868          
   7869          #if defined(_CMU_LFACLKEN0_LESENSE_MASK)
   7870              case (CMU_LESENSE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7871                ret = lfClkGet(cmuClock_LFA);
   7872                ret >>= (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LESENSE_MASK)
   7873                        >> _CMU_LFAPRESC0_LESENSE_SHIFT;
   7874                break;
   7875          #endif
   7876          
   7877              case (CMU_LFB_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7878                ret = lfClkGet(cmuClock_LFB);
   7879                break;
   7880          
   7881          #if defined(_CMU_LFBCLKEN0_LEUART0_MASK)
   7882              case (CMU_LEUART0_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7883                ret = lfClkGet(cmuClock_LFB);
   7884          #if defined(_SILICON_LABS_32B_SERIES_0)
   7885                ret >>= (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   7886                        >> _CMU_LFBPRESC0_LEUART0_SHIFT;
   7887          #else
   7888                ret /= SL_Log2ToDiv((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   7889                                    >> _CMU_LFBPRESC0_LEUART0_SHIFT);
   7890          #endif
   7891                break;
   7892          #endif
   7893          
   7894          #if defined(_CMU_LFBCLKEN0_LEUART1_MASK)
   7895              case (CMU_LEUART1_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7896                ret = lfClkGet(cmuClock_LFB);
   7897          #if defined(_SILICON_LABS_32B_SERIES_0)
   7898                ret >>= (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   7899                        >> _CMU_LFBPRESC0_LEUART1_SHIFT;
   7900          #else
   7901                ret /= SL_Log2ToDiv((CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   7902                                    >> _CMU_LFBPRESC0_LEUART1_SHIFT);
   7903          #endif
   7904                break;
   7905          #endif
   7906          
   7907          #if defined(_CMU_LFBCLKEN0_CSEN_MASK)
   7908              case (CMU_CSEN_LF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7909                ret = lfClkGet(cmuClock_LFB);
   7910                ret /= SL_Log2ToDiv(((CMU->LFBPRESC0 & _CMU_LFBPRESC0_CSEN_MASK)
   7911                                     >> _CMU_LFBPRESC0_CSEN_SHIFT) + 4UL);
   7912                break;
   7913          #endif
   7914          
   7915          #if defined(CMU_LFCCLKEN0_USB)
   7916              case (CMU_USBLE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7917                ret = lfClkGet(cmuClock_LFC);
   7918                break;
   7919          #endif
   7920          
   7921          #if defined(_SILICON_LABS_32B_SERIES_1)
   7922              case (CMU_LFE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7923                ret = lfClkGet(cmuClock_LFE);
   7924                break;
   7925          #endif
   7926          
   7927              case (CMU_DBG_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7928                ret = dbgClkGet();
   7929                break;
   7930          
   7931              case (CMU_AUX_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7932                ret = auxClkGet();
   7933                break;
   7934          
   7935          #if defined(USBC_CLOCK_PRESENT)
   7936              case (CMU_USBC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7937                ret = usbCClkGet();
   7938                break;
   7939          #endif
   7940          
   7941          #if defined(_CMU_ADCCTRL_ADC0CLKSEL_MASK)
   7942              case (CMU_ADC0ASYNC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7943                ret = adcAsyncClkGet(0);
   7944          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   7945                ret /= 1U + ((CMU->ADCCTRL & _CMU_ADCCTRL_ADC0CLKDIV_MASK)
   7946                             >> _CMU_ADCCTRL_ADC0CLKDIV_SHIFT);
   7947          #endif
   7948                break;
   7949          #endif
   7950          
   7951          #if defined(_CMU_ADCCTRL_ADC1CLKSEL_MASK)
   7952              case (CMU_ADC1ASYNC_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7953                ret = adcAsyncClkGet(1);
   7954          #if defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   7955                ret /= 1U + ((CMU->ADCCTRL & _CMU_ADCCTRL_ADC1CLKDIV_MASK)
   7956                             >> _CMU_ADCCTRL_ADC1CLKDIV_SHIFT);
   7957          #endif
   7958                break;
   7959          #endif
   7960          
   7961          #if defined(_CMU_SDIOCTRL_SDIOCLKSEL_MASK)
   7962              case (CMU_SDIOREF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7963                ret = sdioRefClkGet();
   7964                break;
   7965          #endif
   7966          
   7967          #if defined(_CMU_QSPICTRL_QSPI0CLKSEL_MASK)
   7968              case (CMU_QSPI0REF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7969                ret = qspiRefClkGet(0);
   7970                break;
   7971          #endif
   7972          
   7973          #if defined(USBR_CLOCK_PRESENT)
   7974              case (CMU_USBR_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7975                ret = usbRateClkGet();
   7976                break;
   7977          #endif
   7978          
   7979          #if defined(_CMU_PDMCTRL_PDMCLKSEL_MASK)
   7980              case (CMU_PDMREF_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7981                ret = pdmRefClkGet();
   7982                break;
   7983          #endif
   7984          
   7985              case (CMU_HFLE_CLK_BRANCH << CMU_CLK_BRANCH_POS):
   7986          #if defined(_CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK)
   7987                ret = SystemCoreClockGet() / CMU_ClockDivGet(clock);
   7988          #elif defined(_CMU_HFPRESC_HFCLKLEPRESC_MASK)
   7989                ret = SystemHFClockGet() / CMU_ClockDivGet(clock);
   7990          #else
   7991                ret = SystemCoreClockGet() / 2;
   7992          #endif
   7993                break;
   7994          
   7995              default:
   7996                ret = 0;
   7997                EFM_ASSERT(false);
   7998                break;
   7999            }
   8000          
   8001            return ret;
   8002          }
   8003          
   8004          #if defined(_SILICON_LABS_32B_SERIES_1)
   8005          /***************************************************************************//**
   8006           * @brief
   8007           *   Get the clock prescaler.
   8008           *
   8009           * @param[in] clock
   8010           *   A clock point to get the prescaler for. Notice that not all clock points
   8011           *   have a prescaler. See the CMU overview in the reference manual.
   8012           *
   8013           * @return
   8014           *   The prescaler value of the current clock point. 0 is returned
   8015           *   if @p clock specifies a clock point without a prescaler.
   8016           ******************************************************************************/
   8017          uint32_t CMU_ClockPrescGet(CMU_Clock_TypeDef clock)
   8018          {
   8019            uint32_t  prescReg;
   8020            uint32_t  ret;
   8021          
   8022            /* Get the prescaler register ID. */
   8023            prescReg = ((unsigned)clock >> CMU_PRESC_REG_POS) & CMU_PRESC_REG_MASK;
   8024          
   8025            switch (prescReg) {
   8026              case CMU_HFPRESC_REG:
   8027                ret = (CMU->HFPRESC & _CMU_HFPRESC_PRESC_MASK)
   8028                      >> _CMU_HFPRESC_PRESC_SHIFT;
   8029                break;
   8030          
   8031              case CMU_HFEXPPRESC_REG:
   8032                ret = (CMU->HFEXPPRESC & _CMU_HFEXPPRESC_PRESC_MASK)
   8033                      >> _CMU_HFEXPPRESC_PRESC_SHIFT;
   8034                break;
   8035          
   8036              case CMU_HFCLKLEPRESC_REG:
   8037                ret = (CMU->HFPRESC & _CMU_HFPRESC_HFCLKLEPRESC_MASK)
   8038                      >> _CMU_HFPRESC_HFCLKLEPRESC_SHIFT;
   8039                ret = SL_Log2ToDiv(ret + 1U) - 1U;
   8040                break;
   8041          
   8042              case CMU_HFPERPRESC_REG:
   8043                ret = (CMU->HFPERPRESC & _CMU_HFPERPRESC_PRESC_MASK)
   8044                      >> _CMU_HFPERPRESC_PRESC_SHIFT;
   8045                break;
   8046          
   8047          #if defined(_CMU_HFPERPRESCB_MASK)
   8048              case CMU_HFPERPRESCB_REG:
   8049                ret = (CMU->HFPERPRESCB & _CMU_HFPERPRESCB_PRESC_MASK)
   8050                      >> _CMU_HFPERPRESCB_PRESC_SHIFT;
   8051                break;
   8052          #endif
   8053          
   8054          #if defined(_CMU_HFPERPRESCC_MASK)
   8055              case CMU_HFPERPRESCC_REG:
   8056                ret = (CMU->HFPERPRESCC & _CMU_HFPERPRESCC_PRESC_MASK)
   8057                      >> _CMU_HFPERPRESCC_PRESC_SHIFT;
   8058                break;
   8059          #endif
   8060          
   8061              case CMU_HFCOREPRESC_REG:
   8062                ret = (CMU->HFCOREPRESC & _CMU_HFCOREPRESC_PRESC_MASK)
   8063                      >> _CMU_HFCOREPRESC_PRESC_SHIFT;
   8064                break;
   8065          
   8066              case CMU_LFAPRESC0_REG:
   8067                switch (clock) {
   8068          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   8069                  case cmuClock_LETIMER0:
   8070                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER0_MASK)
   8071                          >> _CMU_LFAPRESC0_LETIMER0_SHIFT;
   8072                    /* Convert the exponent to a prescaler value. */
   8073                    ret = SL_Log2ToDiv(ret) - 1U;
   8074                    break;
   8075          #endif
   8076          
   8077          #if defined(_CMU_LFAPRESC0_LESENSE_MASK)
   8078                  case cmuClock_LESENSE:
   8079                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LESENSE_MASK)
   8080                          >> _CMU_LFAPRESC0_LESENSE_SHIFT;
   8081                    /* Convert the exponent to a prescaler value. */
   8082                    ret = SL_Log2ToDiv(ret) - 1U;
   8083                    break;
   8084          #endif
   8085          
   8086          #if defined(_CMU_LFAPRESC0_LETIMER1_MASK)
   8087                  case cmuClock_LETIMER1:
   8088                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LETIMER1_MASK)
   8089                          >> _CMU_LFAPRESC0_LETIMER1_SHIFT;
   8090                    ret = SL_Log2ToDiv(ret) - 1U;
   8091                    break;
   8092          #endif
   8093          
   8094          #if defined(_CMU_LFAPRESC0_LCD_MASK)
   8095                  case cmuClock_LCD:
   8096                  case cmuClock_LCDpre:
   8097                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_LCD_MASK)
   8098                          >> _CMU_LFAPRESC0_LCD_SHIFT;
   8099                    ret = SL_Log2ToDiv(ret) - 1U;
   8100                    break;
   8101          #endif
   8102          
   8103          #if defined(_CMU_LFAPRESC0_RTC_MASK)
   8104                  case cmuClock_RTC:
   8105                    ret = (CMU->LFAPRESC0 & _CMU_LFAPRESC0_RTC_MASK)
   8106                          >> _CMU_LFAPRESC0_RTC_SHIFT;
   8107                    ret = SL_Log2ToDiv(ret) - 1U;
   8108                    break;
   8109          #endif
   8110          
   8111                  default:
   8112                    ret = 0U;
   8113                    EFM_ASSERT(false);
   8114                    break;
   8115                }
   8116                break;
   8117          
   8118              case CMU_LFBPRESC0_REG:
   8119                switch (clock) {
   8120          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   8121                  case cmuClock_LEUART0:
   8122                    ret = (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART0_MASK)
   8123                          >> _CMU_LFBPRESC0_LEUART0_SHIFT;
   8124                    /* Convert the exponent to a prescaler value. */
   8125                    ret = SL_Log2ToDiv(ret) - 1U;
   8126                    break;
   8127          #endif
   8128          
   8129          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   8130                  case cmuClock_LEUART1:
   8131                    ret = (CMU->LFBPRESC0 & _CMU_LFBPRESC0_LEUART1_MASK)
   8132                          >> _CMU_LFBPRESC0_LEUART1_SHIFT;
   8133                    /* Convert the exponent to a prescaler value. */
   8134                    ret = SL_Log2ToDiv(ret) - 1U;
   8135                    break;
   8136          #endif
   8137          
   8138          #if defined(_CMU_LFBPRESC0_CSEN_MASK)
   8139                  case cmuClock_CSEN_LF:
   8140                    ret = (CMU->LFBPRESC0 & _CMU_LFBPRESC0_CSEN_MASK)
   8141                          >> _CMU_LFBPRESC0_CSEN_SHIFT;
   8142                    /* Convert the exponent to a prescaler value. */
   8143                    ret = SL_Log2ToDiv(ret + 4U) - 1U;
   8144                    break;
   8145          #endif
   8146          
   8147                  default:
   8148                    ret = 0U;
   8149                    EFM_ASSERT(false);
   8150                    break;
   8151                }
   8152                break;
   8153          
   8154              case CMU_LFEPRESC0_REG:
   8155                switch (clock) {
   8156          #if defined(RTCC_PRESENT)
   8157                  case cmuClock_RTCC:
   8158                    ret = (CMU->LFEPRESC0 & _CMU_LFEPRESC0_RTCC_MASK)
   8159                          >> _CMU_LFEPRESC0_RTCC_SHIFT;
   8160                    break;
   8161          
   8162                  default:
   8163                    ret = 0U;
   8164                    EFM_ASSERT(false);
   8165                    break;
   8166          #endif
   8167                }
   8168                break;
   8169          
   8170          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK) \
   8171                || defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8172              case CMU_ADCASYNCDIV_REG:
   8173                switch (clock) {
   8174          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8175                  case cmuClock_ADC0ASYNC:
   8176                    ret = (CMU->ADCCTRL & _CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8177                          >> _CMU_ADCCTRL_ADC0CLKDIV_SHIFT;
   8178                    break;
   8179          #endif
   8180          #if defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8181                  case cmuClock_ADC1ASYNC:
   8182                    ret = (CMU->ADCCTRL & _CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8183                          >> _CMU_ADCCTRL_ADC1CLKDIV_SHIFT;
   8184                    break;
   8185          #endif
   8186                  default:
   8187                    ret = 0U;
   8188                    EFM_ASSERT(false);
   8189                    break;
   8190                }
   8191                break;
   8192          #endif
   8193          #if defined(_CMU_HFBUSPRESC_MASK)
   8194              case CMU_HFBUSPRESC_REG:
   8195                ret = (CMU->HFBUSPRESC & _CMU_HFBUSPRESC_MASK)
   8196                      >> _CMU_HFBUSPRESC_PRESC_SHIFT;
   8197                break;
   8198          #endif
   8199              default:
   8200                ret = 0U;
   8201                EFM_ASSERT(false);
   8202                break;
   8203            }
   8204          
   8205            return ret;
   8206          }
   8207          #endif
   8208          
   8209          #if defined(_SILICON_LABS_32B_SERIES_1)
   8210          /***************************************************************************//**
   8211           * @brief
   8212           *   Set the clock prescaler.
   8213           *
   8214           * @note
   8215           *   If setting an LF clock prescaler, synchronization into the low-frequency
   8216           *   domain is required. If the same register is modified before a previous
   8217           *   update has completed, this function will stall until the previous
   8218           *   synchronization has completed. See @ref CMU_FreezeEnable() for
   8219           *   a suggestion on how to reduce the stalling time in some use cases.
   8220           *
   8221           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   8222           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   8223           *
   8224           * @param[in] clock
   8225           *   A clock point to set the prescaler for. Notice that not all clock points
   8226           *   have a prescaler. See the CMU overview in the reference manual.
   8227           *
   8228           * @param[in] presc
   8229           *   The clock prescaler. The prescaler value is linked to the clock divider by:
   8230           *   divider = 'presc' + 1.
   8231           ******************************************************************************/
   8232          void CMU_ClockPrescSet(CMU_Clock_TypeDef clock, CMU_ClkPresc_TypeDef presc)
   8233          {
   8234            uint32_t freq;
   8235            uint32_t prescReg;
   8236          
   8237            /* Get the divisor reg ID. */
   8238            prescReg = ((unsigned)clock >> CMU_PRESC_REG_POS) & CMU_PRESC_REG_MASK;
   8239          
   8240            switch (prescReg) {
   8241              case CMU_HFPRESC_REG:
   8242                EFM_ASSERT(presc < 32U);
   8243          
   8244                /* Configure worst case wait-states for flash and HFLE, set safe HFPER
   8245                   clock-tree prescalers. */
   8246                flashWaitStateMax();
   8247                setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   8248                hfperClkSafePrescaler();
   8249          
   8250                CMU->HFPRESC = (CMU->HFPRESC & ~_CMU_HFPRESC_PRESC_MASK)
   8251                               | (presc << _CMU_HFPRESC_PRESC_SHIFT);
   8252          
   8253                /* Update the CMSIS core clock variable (this function updates the global
   8254                   variable). */
   8255                freq = SystemCoreClockGet();
   8256                /* Optimize flash and HFLE wait states and set optimized HFPER clock-tree
   8257                   prescalers. */
   8258                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   8259                setHfLeConfig(SystemHFClockGet());
   8260                hfperClkOptimizedPrescaler();
   8261                break;
   8262          
   8263              case CMU_HFEXPPRESC_REG:
   8264                EFM_ASSERT(presc < 32U);
   8265          
   8266                CMU->HFEXPPRESC = (CMU->HFEXPPRESC & ~_CMU_HFEXPPRESC_PRESC_MASK)
   8267                                  | (presc << _CMU_HFEXPPRESC_PRESC_SHIFT);
   8268                break;
   8269          
   8270              case CMU_HFCLKLEPRESC_REG:
   8271                presc = CMU_DivToLog2(presc);
   8272                CMU->HFPRESC = (CMU->HFPRESC & ~_CMU_HFPRESC_HFCLKLEPRESC_MASK)
   8273                               | (presc << _CMU_HFPRESC_HFCLKLEPRESC_SHIFT);
   8274                break;
   8275          
   8276              case CMU_HFPERPRESC_REG:
   8277                EFM_ASSERT(presc < 512U);
   8278                CMU->HFPERPRESC = (CMU->HFPERPRESC & ~_CMU_HFPERPRESC_PRESC_MASK)
   8279                                  | (presc << _CMU_HFPERPRESC_PRESC_SHIFT);
   8280                break;
   8281          
   8282          #if defined(_CMU_HFPERPRESCB_MASK)
   8283              case CMU_HFPERPRESCB_REG:
   8284                EFM_ASSERT(presc < 512U);
   8285                CMU->HFPERPRESCB = (CMU->HFPERPRESCB & ~_CMU_HFPERPRESCB_PRESC_MASK)
   8286                                   | (presc << _CMU_HFPERPRESCB_PRESC_SHIFT);
   8287                break;
   8288          #endif
   8289          
   8290          #if defined(_CMU_HFPERPRESCC_MASK)
   8291              case CMU_HFPERPRESCC_REG:
   8292                EFM_ASSERT(presc < 512U);
   8293                CMU->HFPERPRESCC = (CMU->HFPERPRESCC & ~_CMU_HFPERPRESCC_PRESC_MASK)
   8294                                   | (presc << _CMU_HFPERPRESCC_PRESC_SHIFT);
   8295                break;
   8296          #endif
   8297          
   8298              case CMU_HFCOREPRESC_REG:
   8299                EFM_ASSERT(presc < 512U);
   8300          
   8301                /* Configure worst case wait-states for flash. */
   8302                flashWaitStateMax();
   8303          
   8304                CMU->HFCOREPRESC = (CMU->HFCOREPRESC & ~_CMU_HFCOREPRESC_PRESC_MASK)
   8305                                   | (presc << _CMU_HFCOREPRESC_PRESC_SHIFT);
   8306          
   8307                /* Update the CMSIS core clock variable (this function updates the global variable).
   8308                   Optimize flash and HFLE wait states. */
   8309                freq = SystemCoreClockGet();
   8310                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   8311                break;
   8312          
   8313              case CMU_LFAPRESC0_REG:
   8314                switch (clock) {
   8315          #if defined(RTC_PRESENT)
   8316                  case cmuClock_RTC:
   8317                    EFM_ASSERT(presc <= 32768U);
   8318          
   8319                    /* Convert the prescaler value to a DIV exponent scale. */
   8320                    presc = CMU_PrescToLog2(presc);
   8321          
   8322                    /* LF register about to be modified requires sync. Busy check. */
   8323                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8324          
   8325                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_RTC_MASK)
   8326                                     | (presc << _CMU_LFAPRESC0_RTC_SHIFT);
   8327                    break;
   8328          #endif
   8329          
   8330          #if defined(RTCC_PRESENT)
   8331                  case cmuClock_RTCC:
   8332          #if defined(_CMU_LFEPRESC0_RTCC_MASK)
   8333          #if defined(_CMU_LFEPRESC0_RTCC_DIV4)
   8334                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV4);
   8335          #elif defined(_CMU_LFEPRESC0_RTCC_DIV2)
   8336                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV2);
   8337          #else
   8338                    EFM_ASSERT(presc <= 0U);
   8339          #endif
   8340          
   8341                    /* LF register about to be modified requires sync. Busy check. */
   8342                    syncReg(CMU_SYNCBUSY_LFEPRESC0);
   8343          
   8344                    CMU->LFEPRESC0 = (CMU->LFEPRESC0 & ~_CMU_LFEPRESC0_RTCC_MASK)
   8345                                     | (presc << _CMU_LFEPRESC0_RTCC_SHIFT);
   8346          #else
   8347                    EFM_ASSERT(presc <= 32768U);
   8348          
   8349                    /* Convert the prescaler value to a DIV exponent scale. */
   8350                    presc = CMU_PrescToLog2(presc);
   8351          
   8352                    /* LF register about to be modified requires sync. Busy check. */
   8353                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8354          
   8355                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_RTCC_MASK)
   8356                                     | (presc << _CMU_LFAPRESC0_RTCC_SHIFT);
   8357          #endif
   8358                    break;
   8359          #endif
   8360          
   8361          #if defined(_CMU_LFAPRESC0_LETIMER0_MASK)
   8362                  case cmuClock_LETIMER0:
   8363                    EFM_ASSERT(presc <= 32768U);
   8364          
   8365                    /* Convert the prescaler value to a DIV exponent scale. */
   8366                    presc = CMU_PrescToLog2(presc);
   8367          
   8368                    /* LF register about to be modified requires sync. Busy check. */
   8369                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8370          
   8371                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LETIMER0_MASK)
   8372                                     | (presc << _CMU_LFAPRESC0_LETIMER0_SHIFT);
   8373                    break;
   8374          #endif
   8375          
   8376          #if defined(_CMU_LFAPRESC0_LETIMER1_MASK)
   8377                  case cmuClock_LETIMER1:
   8378                    EFM_ASSERT(presc <= 32768U);
   8379          
   8380                    /* Convert the prescaler value to a DIV exponent scale. */
   8381                    presc = CMU_PrescToLog2(presc);
   8382          
   8383                    /* LF register about to be modified requires sync. Busy check. */
   8384                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8385          
   8386                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LETIMER1_MASK)
   8387                                     | (presc << _CMU_LFAPRESC0_LETIMER1_SHIFT);
   8388                    break;
   8389          #endif
   8390          
   8391          #if defined(_CMU_LFAPRESC0_LESENSE_MASK)
   8392                  case cmuClock_LESENSE:
   8393                    EFM_ASSERT(presc <= 8U);
   8394          
   8395                    /* Convert the prescaler value to a DIV exponent scale. */
   8396                    presc = CMU_PrescToLog2(presc);
   8397          
   8398                    /* LF register about to be modified requires sync. Busy check. */
   8399                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8400          
   8401                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LESENSE_MASK)
   8402                                     | (presc << _CMU_LFAPRESC0_LESENSE_SHIFT);
   8403                    break;
   8404          #endif
   8405          
   8406          #if defined(_CMU_LFAPRESC0_LCD_MASK)
   8407                  case cmuClock_LCDpre:
   8408                  case cmuClock_LCD:
   8409                    EFM_ASSERT(presc <= 32768U);
   8410          
   8411                    /* Convert the prescaler value to a DIV exponent scale. */
   8412                    presc = CMU_PrescToLog2(presc);
   8413          
   8414                    /* LF register about to be modified requires sync. Busy check. */
   8415                    syncReg(CMU_SYNCBUSY_LFAPRESC0);
   8416          
   8417                    CMU->LFAPRESC0 = (CMU->LFAPRESC0 & ~_CMU_LFAPRESC0_LCD_MASK)
   8418                                     | (presc << _CMU_LFAPRESC0_LCD_SHIFT);
   8419                    break;
   8420          #endif
   8421          
   8422                  default:
   8423                    EFM_ASSERT(false);
   8424                    break;
   8425                }
   8426                break;
   8427          
   8428              case CMU_LFBPRESC0_REG:
   8429                switch (clock) {
   8430          #if defined(_CMU_LFBPRESC0_LEUART0_MASK)
   8431                  case cmuClock_LEUART0:
   8432                    EFM_ASSERT(presc <= 8U);
   8433          
   8434                    /* Convert the prescaler value to a DIV exponent scale. */
   8435                    presc = CMU_PrescToLog2(presc);
   8436          
   8437                    /* LF register about to be modified requires sync. Busy check. */
   8438                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   8439          
   8440                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART0_MASK)
   8441                                     | (presc << _CMU_LFBPRESC0_LEUART0_SHIFT);
   8442                    break;
   8443          #endif
   8444          
   8445          #if defined(_CMU_LFBPRESC0_LEUART1_MASK)
   8446                  case cmuClock_LEUART1:
   8447                    EFM_ASSERT(presc <= 8U);
   8448          
   8449                    /* Convert the prescaler value to a DIV exponent scale. */
   8450                    presc = CMU_PrescToLog2(presc);
   8451          
   8452                    /* LF register about to be modified requires sync. Busy check. */
   8453                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   8454          
   8455                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_LEUART1_MASK)
   8456                                     | (presc << _CMU_LFBPRESC0_LEUART1_SHIFT);
   8457                    break;
   8458          #endif
   8459          
   8460          #if defined(_CMU_LFBPRESC0_CSEN_MASK)
   8461                  case cmuClock_CSEN_LF:
   8462                    EFM_ASSERT((presc <= 127U) && (presc >= 15U));
   8463          
   8464                    /* Convert the prescaler value to a DIV exponent scale.
   8465                     * DIV16 is the lowest supported prescaler. */
   8466                    presc = CMU_PrescToLog2(presc) - 4U;
   8467          
   8468                    /* LF register about to be modified requires sync. Busy check. */
   8469                    syncReg(CMU_SYNCBUSY_LFBPRESC0);
   8470          
   8471                    CMU->LFBPRESC0 = (CMU->LFBPRESC0 & ~_CMU_LFBPRESC0_CSEN_MASK)
   8472                                     | (presc << _CMU_LFBPRESC0_CSEN_SHIFT);
   8473                    break;
   8474          #endif
   8475          
   8476                  default:
   8477                    EFM_ASSERT(false);
   8478                    break;
   8479                }
   8480                break;
   8481          
   8482              case CMU_LFEPRESC0_REG:
   8483                switch (clock) {
   8484          #if defined(_CMU_LFEPRESC0_RTCC_MASK)
   8485                  case cmuClock_RTCC:
   8486          #if defined(_CMU_LFEPRESC0_RTCC_DIV4)
   8487                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV4);
   8488          #elif defined(_CMU_LFEPRESC0_RTCC_DIV2)
   8489                    EFM_ASSERT(presc <= _CMU_LFEPRESC0_RTCC_DIV2);
   8490          #else
   8491                    EFM_ASSERT(presc <= 0U);
   8492          #endif
   8493          
   8494                    /* LF register about to be modified requires sync. Busy check. */
   8495                    syncReg(CMU_SYNCBUSY_LFEPRESC0);
   8496          
   8497                    CMU->LFEPRESC0 = (CMU->LFEPRESC0 & ~_CMU_LFEPRESC0_RTCC_MASK)
   8498                                     | (presc << _CMU_LFEPRESC0_RTCC_SHIFT);
   8499                    break;
   8500          #endif
   8501          
   8502                  default:
   8503                    EFM_ASSERT(false);
   8504                    break;
   8505                }
   8506                break;
   8507          
   8508          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK) \
   8509                ||  defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8510              case CMU_ADCASYNCDIV_REG:
   8511                switch (clock) {
   8512          #if defined(_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8513                  case cmuClock_ADC0ASYNC:
   8514                    EFM_ASSERT(presc <= 3);
   8515                    CMU->ADCCTRL = (CMU->ADCCTRL & ~_CMU_ADCCTRL_ADC0CLKDIV_MASK)
   8516                                   | (presc << _CMU_ADCCTRL_ADC0CLKDIV_SHIFT);
   8517                    break;
   8518          #endif
   8519          
   8520          #if defined(_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8521                  case cmuClock_ADC1ASYNC:
   8522                    EFM_ASSERT(presc <= 3);
   8523                    CMU->ADCCTRL = (CMU->ADCCTRL & ~_CMU_ADCCTRL_ADC1CLKDIV_MASK)
   8524                                   | (presc << _CMU_ADCCTRL_ADC1CLKDIV_SHIFT);
   8525                    break;
   8526          #endif
   8527                  default:
   8528                    EFM_ASSERT(false);
   8529                    break;
   8530                }
   8531                break;
   8532          #endif
   8533          
   8534          #if defined(_CMU_HFBUSPRESC_MASK)
   8535              case CMU_HFBUSPRESC_REG:
   8536                EFM_ASSERT(presc <= _CMU_HFBUSPRESC_MASK >> _CMU_HFBUSPRESC_PRESC_SHIFT);
   8537                CMU->HFBUSPRESC = (CMU->HFBUSPRESC & ~_CMU_HFBUSPRESC_MASK)
   8538                                  | (presc << _CMU_HFBUSPRESC_PRESC_SHIFT);
   8539                break;
   8540          #endif
   8541          
   8542              default:
   8543                EFM_ASSERT(false);
   8544                break;
   8545            }
   8546          }
   8547          #endif
   8548          
   8549          /***************************************************************************//**
   8550           * @brief
   8551           *   Get the currently selected reference clock used for a clock branch.
   8552           *
   8553           * @param[in] clock
   8554           *   Clock branch to fetch selected ref. clock for. One of:
   8555           *   @li #cmuClock_HF
   8556           *   @li #cmuClock_LFA
   8557           *   @li #cmuClock_LFB @if _CMU_LFCLKSEL_LFAE_ULFRCO
   8558           *   @li #cmuClock_LFC
   8559           *   @endif            @if _SILICON_LABS_32B_SERIES_1
   8560           *   @li #cmuClock_LFE
   8561           *   @endif
   8562           *   @li #cmuClock_DBG @if DOXYDOC_USB_PRESENT
   8563           *   @li #cmuClock_USBC
   8564           *   @endif
   8565           *
   8566           * @return
   8567           *   The reference clock used for clocking the selected branch, #cmuSelect_Error if
   8568           *   invalid @p clock provided.
   8569           ******************************************************************************/
   8570          CMU_Select_TypeDef CMU_ClockSelectGet(CMU_Clock_TypeDef clock)
   8571          {
   8572            CMU_Select_TypeDef ret = cmuSelect_Disabled;
   8573            uint32_t selReg;
   8574          
   8575            selReg = ((unsigned)clock >> CMU_SEL_REG_POS) & CMU_SEL_REG_MASK;
   8576          
   8577            switch (selReg) {
   8578              case CMU_HFCLKSEL_REG:
   8579          #if defined(_CMU_HFCLKSTATUS_MASK)
   8580                switch (CMU->HFCLKSTATUS & _CMU_HFCLKSTATUS_SELECTED_MASK) {
   8581                  case CMU_HFCLKSTATUS_SELECTED_LFXO:
   8582                    ret = cmuSelect_LFXO;
   8583                    break;
   8584          
   8585                  case CMU_HFCLKSTATUS_SELECTED_LFRCO:
   8586                    ret = cmuSelect_LFRCO;
   8587                    break;
   8588          
   8589                  case CMU_HFCLKSTATUS_SELECTED_HFXO:
   8590                    ret = cmuSelect_HFXO;
   8591                    break;
   8592          
   8593          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
   8594                  case CMU_HFCLKSTATUS_SELECTED_HFRCODIV2:
   8595                    ret = cmuSelect_HFRCODIV2;
   8596                    break;
   8597          #endif
   8598          
   8599          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
   8600                  case CMU_HFCLKSTATUS_SELECTED_CLKIN0:
   8601                    ret = cmuSelect_CLKIN0;
   8602                    break;
   8603          #endif
   8604          
   8605          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
   8606                  case CMU_HFCLKSTATUS_SELECTED_USHFRCO:
   8607                    ret = cmuSelect_USHFRCO;
   8608                    break;
   8609          #endif
   8610          
   8611                  default:
   8612                    ret = cmuSelect_HFRCO;
   8613                    break;
   8614                }
   8615          #else
   8616                switch (CMU->STATUS
   8617                        & (CMU_STATUS_HFRCOSEL
   8618                           | CMU_STATUS_HFXOSEL
   8619                           | CMU_STATUS_LFRCOSEL
   8620          #if defined(CMU_STATUS_USHFRCODIV2SEL)
   8621                           | CMU_STATUS_USHFRCODIV2SEL
   8622          #endif
   8623                           | CMU_STATUS_LFXOSEL)) {
   8624                  case CMU_STATUS_LFXOSEL:
   8625                    ret = cmuSelect_LFXO;
   8626                    break;
   8627          
   8628                  case CMU_STATUS_LFRCOSEL:
   8629                    ret = cmuSelect_LFRCO;
   8630                    break;
   8631          
   8632                  case CMU_STATUS_HFXOSEL:
   8633                    ret = cmuSelect_HFXO;
   8634                    break;
   8635          
   8636          #if defined(CMU_STATUS_USHFRCODIV2SEL)
   8637                  case CMU_STATUS_USHFRCODIV2SEL:
   8638                    ret = cmuSelect_USHFRCODIV2;
   8639                    break;
   8640          #endif
   8641          
   8642                  default:
   8643                    ret = cmuSelect_HFRCO;
   8644                    break;
   8645                }
   8646          #endif
   8647                break;
   8648          
   8649          #if defined(_CMU_LFCLKSEL_MASK) || defined(_CMU_LFACLKSEL_MASK)
   8650              case CMU_LFACLKSEL_REG:
   8651          #if defined(_CMU_LFCLKSEL_MASK)
   8652                switch (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFA_MASK) {
   8653                  case CMU_LFCLKSEL_LFA_LFRCO:
   8654                    ret = cmuSelect_LFRCO;
   8655                    break;
   8656          
   8657                  case CMU_LFCLKSEL_LFA_LFXO:
   8658                    ret = cmuSelect_LFXO;
   8659                    break;
   8660          
   8661          #if defined(CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2)
   8662                  case CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2:
   8663                    ret = cmuSelect_HFCLKLE;
   8664                    break;
   8665          #endif
   8666          
   8667                  default:
   8668          #if defined(CMU_LFCLKSEL_LFAE)
   8669                    if (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFAE_MASK) {
   8670                      ret = cmuSelect_ULFRCO;
   8671                      break;
   8672                    }
   8673          #else
   8674                    ret = cmuSelect_Disabled;
   8675          #endif
   8676                    break;
   8677                }
   8678          
   8679          #elif defined(_CMU_LFACLKSEL_MASK)
   8680                switch (CMU->LFACLKSEL & _CMU_LFACLKSEL_LFA_MASK) {
   8681                  case CMU_LFACLKSEL_LFA_LFRCO:
   8682                    ret = cmuSelect_LFRCO;
   8683                    break;
   8684          
   8685                  case CMU_LFACLKSEL_LFA_LFXO:
   8686                    ret = cmuSelect_LFXO;
   8687                    break;
   8688          
   8689                  case CMU_LFACLKSEL_LFA_ULFRCO:
   8690                    ret = cmuSelect_ULFRCO;
   8691                    break;
   8692          
   8693          #if defined(PLFRCO_PRESENT)
   8694                  case CMU_LFACLKSEL_LFA_PLFRCO:
   8695                    ret = cmuSelect_PLFRCO;
   8696                    break;
   8697          #endif
   8698          
   8699                  default:
   8700                    ret = cmuSelect_Disabled;
   8701                    break;
   8702                }
   8703          #endif
   8704                break;
   8705          #endif /* _CMU_LFCLKSEL_MASK || _CMU_LFACLKSEL_MASK */
   8706          
   8707          #if defined(_CMU_LFCLKSEL_MASK) || defined(_CMU_LFBCLKSEL_MASK)
   8708              case CMU_LFBCLKSEL_REG:
   8709          #if defined(_CMU_LFCLKSEL_MASK)
   8710                switch (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFB_MASK) {
   8711                  case CMU_LFCLKSEL_LFB_LFRCO:
   8712                    ret = cmuSelect_LFRCO;
   8713                    break;
   8714          
   8715                  case CMU_LFCLKSEL_LFB_LFXO:
   8716                    ret = cmuSelect_LFXO;
   8717                    break;
   8718          
   8719          #if defined(CMU_LFCLKSEL_LFB_HFCORECLKLEDIV2)
   8720                  case CMU_LFCLKSEL_LFB_HFCORECLKLEDIV2:
   8721                    ret = cmuSelect_HFCLKLE;
   8722                    break;
   8723          #endif
   8724          
   8725          #if defined(CMU_LFCLKSEL_LFB_HFCLKLE)
   8726                  case CMU_LFCLKSEL_LFB_HFCLKLE:
   8727                    ret = cmuSelect_HFCLKLE;
   8728                    break;
   8729          #endif
   8730          
   8731                  default:
   8732          #if defined(CMU_LFCLKSEL_LFBE)
   8733                    if (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFBE_MASK) {
   8734                      ret = cmuSelect_ULFRCO;
   8735                      break;
   8736                    }
   8737          #else
   8738                    ret = cmuSelect_Disabled;
   8739          #endif
   8740                    break;
   8741                }
   8742          
   8743          #elif defined(_CMU_LFBCLKSEL_MASK)
   8744                switch (CMU->LFBCLKSEL & _CMU_LFBCLKSEL_LFB_MASK) {
   8745                  case CMU_LFBCLKSEL_LFB_LFRCO:
   8746                    ret = cmuSelect_LFRCO;
   8747                    break;
   8748          
   8749                  case CMU_LFBCLKSEL_LFB_LFXO:
   8750                    ret = cmuSelect_LFXO;
   8751                    break;
   8752          
   8753                  case CMU_LFBCLKSEL_LFB_ULFRCO:
   8754                    ret = cmuSelect_ULFRCO;
   8755                    break;
   8756          
   8757                  case CMU_LFBCLKSEL_LFB_HFCLKLE:
   8758                    ret = cmuSelect_HFCLKLE;
   8759                    break;
   8760          
   8761          #if defined(PLFRCO_PRESENT)
   8762                  case CMU_LFBCLKSEL_LFB_PLFRCO:
   8763                    ret = cmuSelect_PLFRCO;
   8764                    break;
   8765          #endif
   8766          
   8767                  default:
   8768                    ret = cmuSelect_Disabled;
   8769                    break;
   8770                }
   8771          #endif
   8772                break;
   8773          #endif /* _CMU_LFCLKSEL_MASK || _CMU_LFBCLKSEL_MASK */
   8774          
   8775          #if defined(_CMU_LFCLKSEL_LFC_MASK)
   8776              case CMU_LFCCLKSEL_REG:
   8777                switch (CMU->LFCLKSEL & _CMU_LFCLKSEL_LFC_MASK) {
   8778                  case CMU_LFCLKSEL_LFC_LFRCO:
   8779                    ret = cmuSelect_LFRCO;
   8780                    break;
   8781          
   8782                  case CMU_LFCLKSEL_LFC_LFXO:
   8783                    ret = cmuSelect_LFXO;
   8784                    break;
   8785          
   8786                  default:
   8787                    ret = cmuSelect_Disabled;
   8788                    break;
   8789                }
   8790                break;
   8791          #endif
   8792          
   8793          #if defined(_CMU_LFECLKSEL_LFE_MASK)
   8794              case CMU_LFECLKSEL_REG:
   8795                switch (CMU->LFECLKSEL & _CMU_LFECLKSEL_LFE_MASK) {
   8796                  case CMU_LFECLKSEL_LFE_LFRCO:
   8797                    ret = cmuSelect_LFRCO;
   8798                    break;
   8799          
   8800                  case CMU_LFECLKSEL_LFE_LFXO:
   8801                    ret = cmuSelect_LFXO;
   8802                    break;
   8803          
   8804                  case CMU_LFECLKSEL_LFE_ULFRCO:
   8805                    ret = cmuSelect_ULFRCO;
   8806                    break;
   8807          
   8808          #if defined(PLFRCO_PRESENT)
   8809                  case CMU_LFECLKSEL_LFE_PLFRCO:
   8810                    ret = cmuSelect_PLFRCO;
   8811                    break;
   8812          #endif
   8813          
   8814                  default:
   8815                    ret = cmuSelect_Disabled;
   8816                    break;
   8817                }
   8818                break;
   8819          #endif /* CMU_LFECLKSEL_REG */
   8820          
   8821          #if defined(_CMU_LFCCLKSEL_LFC_MASK)
   8822              case CMU_LFCCLKSEL_REG:
   8823                switch (CMU->LFCCLKSEL & _CMU_LFCCLKSEL_LFC_MASK) {
   8824                  case CMU_LFCCLKSEL_LFC_LFRCO:
   8825                    ret = cmuSelect_LFRCO;
   8826                    break;
   8827          
   8828                  case CMU_LFCCLKSEL_LFC_LFXO:
   8829                    ret = cmuSelect_LFXO;
   8830                    break;
   8831          
   8832                  case CMU_LFCCLKSEL_LFC_ULFRCO:
   8833                    ret = cmuSelect_ULFRCO;
   8834                    break;
   8835          
   8836                  default:
   8837                    ret = cmuSelect_Disabled;
   8838                    break;
   8839                }
   8840                break;
   8841          #endif /* CMU_LFCCLKSEL_REG */
   8842          
   8843              case CMU_DBGCLKSEL_REG:
   8844          #if defined(_CMU_DBGCLKSEL_DBG_MASK)
   8845                switch (CMU->DBGCLKSEL & _CMU_DBGCLKSEL_DBG_MASK) {
   8846                  case CMU_DBGCLKSEL_DBG_HFCLK:
   8847                    ret = cmuSelect_HFCLK;
   8848                    break;
   8849          
   8850                  case CMU_DBGCLKSEL_DBG_AUXHFRCO:
   8851                    ret = cmuSelect_AUXHFRCO;
   8852                    break;
   8853          
   8854                  default:
   8855                    ret = cmuSelect_Disabled;
   8856                    break;
   8857                }
   8858          
   8859          #elif defined(_CMU_CTRL_DBGCLK_MASK)
   8860                switch (CMU->CTRL & _CMU_CTRL_DBGCLK_MASK) {
   8861                  case CMU_CTRL_DBGCLK_AUXHFRCO:
   8862                    ret = cmuSelect_AUXHFRCO;
   8863                    break;
   8864          
   8865                  case CMU_CTRL_DBGCLK_HFCLK:
   8866                    ret = cmuSelect_HFCLK;
   8867                    break;
   8868                }
   8869          #else
   8870                ret = cmuSelect_AUXHFRCO;
   8871          #endif
   8872                break;
   8873          
   8874          #if defined(USBC_CLOCK_PRESENT)
   8875              case CMU_USBCCLKSEL_REG:
   8876                switch (CMU->STATUS
   8877                        & (CMU_STATUS_USBCLFXOSEL
   8878          #if defined(_CMU_STATUS_USBCHFCLKSEL_MASK)
   8879                           | CMU_STATUS_USBCHFCLKSEL
   8880          #endif
   8881          #if defined(_CMU_STATUS_USBCUSHFRCOSEL_MASK)
   8882                           | CMU_STATUS_USBCUSHFRCOSEL
   8883          #endif
   8884                           | CMU_STATUS_USBCLFRCOSEL)) {
   8885          #if defined(_CMU_STATUS_USBCHFCLKSEL_MASK)
   8886                  case CMU_STATUS_USBCHFCLKSEL:
   8887                    ret = cmuSelect_HFCLK;
   8888                    break;
   8889          #endif
   8890          
   8891          #if defined(_CMU_STATUS_USBCUSHFRCOSEL_MASK)
   8892                  case CMU_STATUS_USBCUSHFRCOSEL:
   8893                    ret = cmuSelect_USHFRCO;
   8894                    break;
   8895          #endif
   8896          
   8897                  case CMU_STATUS_USBCLFXOSEL:
   8898                    ret = cmuSelect_LFXO;
   8899                    break;
   8900          
   8901                  case CMU_STATUS_USBCLFRCOSEL:
   8902                    ret = cmuSelect_LFRCO;
   8903                    break;
   8904          
   8905                  default:
   8906                    ret = cmuSelect_Disabled;
   8907                    break;
   8908                }
   8909                break;
   8910          #endif
   8911          
   8912          #if defined(_CMU_ADCCTRL_ADC0CLKSEL_MASK)
   8913              case CMU_ADC0ASYNCSEL_REG:
   8914                switch (CMU->ADCCTRL & _CMU_ADCCTRL_ADC0CLKSEL_MASK) {
   8915                  case CMU_ADCCTRL_ADC0CLKSEL_DISABLED:
   8916                    ret = cmuSelect_Disabled;
   8917                    break;
   8918          
   8919                  case CMU_ADCCTRL_ADC0CLKSEL_AUXHFRCO:
   8920                    ret = cmuSelect_AUXHFRCO;
   8921                    break;
   8922          
   8923                  case CMU_ADCCTRL_ADC0CLKSEL_HFXO:
   8924                    ret = cmuSelect_HFXO;
   8925                    break;
   8926          
   8927                  case CMU_ADCCTRL_ADC0CLKSEL_HFSRCCLK:
   8928                    ret = cmuSelect_HFSRCCLK;
   8929                    break;
   8930          
   8931                  default:
   8932                    ret = cmuSelect_Disabled;
   8933                    break;
   8934                }
   8935                break;
   8936          #endif
   8937          
   8938          #if defined(_CMU_ADCCTRL_ADC1CLKSEL_MASK)
   8939              case CMU_ADC1ASYNCSEL_REG:
   8940                switch (CMU->ADCCTRL & _CMU_ADCCTRL_ADC1CLKSEL_MASK) {
   8941                  case CMU_ADCCTRL_ADC1CLKSEL_DISABLED:
   8942                    ret = cmuSelect_Disabled;
   8943                    break;
   8944          
   8945                  case CMU_ADCCTRL_ADC1CLKSEL_AUXHFRCO:
   8946                    ret = cmuSelect_AUXHFRCO;
   8947                    break;
   8948          
   8949                  case CMU_ADCCTRL_ADC1CLKSEL_HFXO:
   8950                    ret = cmuSelect_HFXO;
   8951                    break;
   8952          
   8953                  case CMU_ADCCTRL_ADC1CLKSEL_HFSRCCLK:
   8954                    ret = cmuSelect_HFSRCCLK;
   8955                    break;
   8956                }
   8957                break;
   8958          #endif
   8959          
   8960          #if defined(_CMU_SDIOCTRL_SDIOCLKSEL_MASK)
   8961              case CMU_SDIOREFSEL_REG:
   8962                switch (CMU->SDIOCTRL & _CMU_SDIOCTRL_SDIOCLKSEL_MASK) {
   8963                  case CMU_SDIOCTRL_SDIOCLKSEL_HFRCO:
   8964                    ret = cmuSelect_HFRCO;
   8965                    break;
   8966          
   8967                  case CMU_SDIOCTRL_SDIOCLKSEL_HFXO:
   8968                    ret = cmuSelect_HFXO;
   8969                    break;
   8970          
   8971                  case CMU_SDIOCTRL_SDIOCLKSEL_AUXHFRCO:
   8972                    ret = cmuSelect_AUXHFRCO;
   8973                    break;
   8974          
   8975                  case CMU_SDIOCTRL_SDIOCLKSEL_USHFRCO:
   8976                    ret = cmuSelect_USHFRCO;
   8977                    break;
   8978                }
   8979                break;
   8980          #endif
   8981          
   8982          #if defined(_CMU_QSPICTRL_QSPI0CLKSEL_MASK)
   8983              case CMU_QSPI0REFSEL_REG:
   8984                switch (CMU->QSPICTRL & _CMU_QSPICTRL_QSPI0CLKSEL_MASK) {
   8985                  case CMU_QSPICTRL_QSPI0CLKSEL_HFRCO:
   8986                    ret = cmuSelect_HFRCO;
   8987                    break;
   8988          
   8989                  case CMU_QSPICTRL_QSPI0CLKSEL_HFXO:
   8990                    ret = cmuSelect_HFXO;
   8991                    break;
   8992          
   8993                  case CMU_QSPICTRL_QSPI0CLKSEL_AUXHFRCO:
   8994                    ret = cmuSelect_AUXHFRCO;
   8995                    break;
   8996          
   8997                  case CMU_QSPICTRL_QSPI0CLKSEL_USHFRCO:
   8998                    ret = cmuSelect_USHFRCO;
   8999                    break;
   9000                }
   9001                break;
   9002          #endif
   9003          
   9004          #if defined(_CMU_USBCTRL_USBCLKSEL_MASK)
   9005              case CMU_USBRCLKSEL_REG:
   9006                switch (CMU->USBCTRL & _CMU_USBCTRL_USBCLKSEL_MASK) {
   9007                  case CMU_USBCTRL_USBCLKSEL_USHFRCO:
   9008                    ret = cmuSelect_USHFRCO;
   9009                    break;
   9010          
   9011                  case CMU_USBCTRL_USBCLKSEL_HFXO:
   9012                    ret = cmuSelect_HFXO;
   9013                    break;
   9014          
   9015                  case CMU_USBCTRL_USBCLKSEL_HFXOX2:
   9016                    ret = cmuSelect_HFXOX2;
   9017                    break;
   9018          
   9019                  case CMU_USBCTRL_USBCLKSEL_HFRCO:
   9020                    ret = cmuSelect_HFRCO;
   9021                    break;
   9022          
   9023                  case CMU_USBCTRL_USBCLKSEL_LFXO:
   9024                    ret = cmuSelect_LFXO;
   9025                    break;
   9026          
   9027                  case CMU_USBCTRL_USBCLKSEL_LFRCO:
   9028                    ret = cmuSelect_LFRCO;
   9029                    break;
   9030                }
   9031                break;
   9032          #endif
   9033          
   9034          #if defined(_CMU_PDMCTRL_PDMCLKSEL_MASK)
   9035              case CMU_PDMREFSEL_REG:
   9036                switch (CMU->PDMCTRL & _CMU_PDMCTRL_PDMCLKSEL_MASK) {
   9037                  case CMU_PDMCTRL_PDMCLKSEL_USHFRCO:
   9038                    ret = cmuSelect_USHFRCO;
   9039                    break;
   9040          
   9041                  case CMU_PDMCTRL_PDMCLKSEL_HFXO:
   9042                    ret = cmuSelect_HFXO;
   9043                    break;
   9044          
   9045                  case CMU_PDMCTRL_PDMCLKSEL_HFRCO:
   9046                    ret = cmuSelect_HFRCO;
   9047                    break;
   9048                }
   9049                break;
   9050          #endif
   9051          
   9052              default:
   9053                ret = cmuSelect_Error;
   9054                EFM_ASSERT(false);
   9055                break;
   9056            }
   9057          
   9058            return ret;
   9059          }
   9060          
   9061          /***************************************************************************//**
   9062           * @brief This function configures the HFLE wait-states and divider suitable
   9063           *        for the System Core Clock.
   9064           *
   9065           * @note FOR INTERNAL USE ONLY.
   9066           *
   9067           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9068           *       the clock source is HFCLKLE.
   9069           ******************************************************************************/
   9070          void sli_em_cmu_SetHFLEConfigSystemCoreClock(void)
   9071          {
   9072          #if defined(CMU_MAX_FREQ_HFLE)
   9073            setHfLeConfig(SystemCoreClockGet());
   9074          #endif
   9075          }
   9076          
   9077          /***************************************************************************//**
   9078           * @brief This function configures the HFLE wait-states and divider suitable
   9079           *        for the HF Clock.
   9080           *
   9081           * @note FOR INTERNAL USE ONLY.
   9082           *
   9083           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9084           *       the clock source is HFCLKLE.
   9085           ******************************************************************************/
   9086          void sli_em_cmu_SetHFLEConfigHFClock(void)
   9087          {
   9088          #if defined(CMU_MAX_FREQ_HFLE)
   9089            setHfLeConfig(SystemHFClockGet());
   9090          #endif
   9091          }
   9092          
   9093          /***************************************************************************//**
   9094           * @brief This function is used to initialize the HF clock and selecting
   9095           *        an LF clock source.
   9096           *
   9097           * @note FOR INTERNAL USE ONLY.
   9098           *
   9099           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9100           *       the clock is HF and LFXO or LFRCO is selected as the clock source.
   9101           ******************************************************************************/
   9102          void sli_em_cmu_HFClockSelectLFOsc(uint8_t osc)
   9103          {
   9104            if (osc == (uint8_t)cmuOsc_LFXO) {
   9105              // Enable LFXO oscillator
   9106              CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
   9107            } else if (osc == (uint8_t)cmuOsc_LFRCO) {
   9108              // Enable LFRCO oscillator
   9109              CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
   9110            } else {
   9111              EFM_ASSERT(false);
   9112            }
   9113          
   9114            // Configure worst case wait-states for flash and set safe HFPER
   9115            // clock-tree prescalers.
   9116            flashWaitStateMax();
   9117            hfperClkSafePrescaler();
   9118          
   9119          #if defined(_SILICON_LABS_32B_SERIES_1)
   9120            // Select HF clock source.
   9121            if (osc == (uint8_t)cmuOsc_LFXO) {
   9122              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_LFXO;
   9123            } else if (osc == (uint8_t)cmuOsc_LFRCO) {
   9124              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_LFRCO;
   9125            }
   9126          #if defined(CMU_MAX_FREQ_HFLE)
   9127            // Set HFLE clock.
   9128            setHfLeConfig(SystemHFClockGet());
   9129          #endif
   9130          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9131            // Select HF clock source.
   9132            if (osc == (uint8_t)cmuOsc_LFXO) {
   9133              CMU->CMD = CMU_CMD_HFCLKSEL_LFXO;
   9134            } else if (osc == (uint8_t)cmuOsc_LFRCO) {
   9135              CMU->CMD = CMU_CMD_HFCLKSEL_LFRCO;
   9136            }
   9137          #if defined(CMU_MAX_FREQ_HFLE)
   9138            // Set HFLE clock.
   9139            setHfLeConfig(SystemCoreClockGet());
   9140          #endif
   9141          #endif
   9142          
   9143            // Optimize flash access wait state setting for the currently selected core clk.
   9144            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9145            // Set optimized HFPER clock-tree prescalers.
   9146            hfperClkOptimizedPrescaler();
   9147          }
   9148          
   9149          /***************************************************************************//**
   9150           * @brief This function is used to initialize the HF clock and selecting
   9151           *        HFXO as the clock source.
   9152           *
   9153           * @note FOR INTERNAL USE ONLY.
   9154           *
   9155           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9156           *       the clock is HF and HFXO is selected as the clock source.
   9157           ******************************************************************************/
   9158          void sli_em_cmu_HFClockSelectHFXO(void)
   9159          {
   9160          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9161            uint32_t vScaleFrequency = SystemHFXOClockGet();
   9162            EMU_VScaleEM01ByClock(vScaleFrequency, false);
   9163          #endif
   9164          
   9165          #if defined(CMU_MAX_FREQ_HFLE)
   9166            // Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9167            // This is known after 'select' is written below.
   9168            setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9169          #endif
   9170          #if defined(CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ)
   9171            // Adjust HFXO buffer current for frequencies above 32 MHz.
   9172            if (SystemHFXOClockGet() > 32000000) {
   9173              CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9174                          | CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ;
   9175            } else {
   9176              CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9177                          | CMU_CTRL_HFXOBUFCUR_BOOSTUPTO32MHZ;
   9178            }
   9179          #endif
   9180          
   9181            // Enable HFXO oscillator
   9182            CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
   9183          
   9184            // Configure worst case wait-states for flash and set safe HFPER
   9185            // clock-tree prescalers.
   9186            flashWaitStateMax();
   9187            hfperClkSafePrescaler();
   9188          
   9189          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9190            // Wait for voltage upscaling to complete before the clock is set.
   9191            if (vScaleFrequency != 0UL) {
   9192              EMU_VScaleWait();
   9193            }
   9194          #endif
   9195          
   9196          #if defined(CMU_HFCLKSEL_HF_HFXO)
   9197            // Select HF clock source.
   9198            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFXO;
   9199          #if defined(CMU_MAX_FREQ_HFLE)
   9200            // Set HFLE clock.
   9201            setHfLeConfig(SystemHFClockGet());
   9202          #endif
   9203          #elif defined(CMU_CMD_HFCLKSEL_HFXO)
   9204            // Select HF clock source.
   9205            CMU->CMD = CMU_CMD_HFCLKSEL_HFXO;
   9206          #if defined(CMU_MAX_FREQ_HFLE)
   9207            // Set HFLE clock.
   9208            setHfLeConfig(SystemCoreClockGet());
   9209          #endif
   9210          #endif
   9211          
   9212            // Optimize flash access wait state setting for the currently selected core clk.
   9213            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9214          
   9215          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9216            // Keep EMU module informed on the source HF clock frequency. This will apply voltage
   9217            // downscaling after clock is set if downscaling is configured.
   9218            if (vScaleFrequency == 0UL) {
   9219              EMU_VScaleEM01ByClock(0, true);
   9220            }
   9221          #endif
   9222          
   9223            // Set optimized HFPER clock-tree prescalers.
   9224            hfperClkOptimizedPrescaler();
   9225          }
   9226          
   9227          /***************************************************************************//**
   9228           * @brief This function is used to initialize the HF clock and selecting
   9229           *        HFRCO as the clock source.
   9230           *
   9231           * @note FOR INTERNAL USE ONLY.
   9232           *
   9233           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9234           *       the clock is HF and HFRCO is selected as the clock source.
   9235           ******************************************************************************/
   9236          void sli_em_cmu_HFClockSelectHFRCO(void)
   9237          {
   9238          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9239            uint32_t vScaleFrequency = 0;    /* Use default. */
   9240            if (((uint32_t)CMU_HFRCOBandGet() > CMU_VSCALEEM01_LOWPOWER_VOLTAGE_CLOCK_MAX)) {
   9241              vScaleFrequency = (uint32_t)CMU_HFRCOBandGet();
   9242            }
   9243            if (vScaleFrequency != 0UL) {
   9244              EMU_VScaleEM01ByClock(vScaleFrequency, false);
   9245            }
   9246          #endif
   9247          
   9248          #if defined(CMU_MAX_FREQ_HFLE)
   9249            // Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9250            // This is known after 'select' is written below.
   9251            setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9252          #endif
   9253          
   9254            // Enable HFRCO oscillator
   9255            CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
   9256          
   9257            // Configure worst case wait-states for flash and set safe HFPER
   9258            // clock-tree prescalers.
   9259            flashWaitStateMax();
   9260            hfperClkSafePrescaler();
   9261          
   9262          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9263            // Wait for voltage upscaling to complete before the clock is set.
   9264            if (vScaleFrequency != 0UL) {
   9265              EMU_VScaleWait();
   9266            }
   9267          #endif
   9268          
   9269          #if defined(_SILICON_LABS_32B_SERIES_1)
   9270            // Select HF clock source.
   9271            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCO;
   9272          #if defined(CMU_MAX_FREQ_HFLE)
   9273            // Set HFLE clock.
   9274            setHfLeConfig(SystemHFClockGet());
   9275          #endif
   9276          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9277            // Select HF clock source.
   9278            CMU->CMD = CMU_CMD_HFCLKSEL_HFRCO;
   9279          #if defined(CMU_MAX_FREQ_HFLE)
   9280            // Set HFLE clock.
   9281            setHfLeConfig(SystemCoreClockGet());
   9282          #endif
   9283          #endif
   9284          
   9285            // Optimize flash access wait state setting for the currently selected core clk.
   9286            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9287          
   9288          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9289            // Keep EMU module informed on the source HF clock frequency. This will apply voltage
   9290            // downscaling after clock is set if downscaling is configured.
   9291            if (vScaleFrequency == 0UL) {
   9292              EMU_VScaleEM01ByClock(0, true);
   9293            }
   9294          #endif
   9295          
   9296            // Set optimized HFPER clock-tree prescalers.
   9297            hfperClkOptimizedPrescaler();
   9298          }
   9299          
   9300          #if defined(CMU_CMD_HFCLKSEL_USHFRCODIV2)
   9301          /***************************************************************************//**
   9302           * @brief This function is used to initialize the HF clock and selecting
   9303           *        USHFRCODIV2 as the clock source.
   9304           *
   9305           * @note FOR INTERNAL USE ONLY.
   9306           *
   9307           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9308           *       the clock is HF and USHFRCODIV2 is selected as the clock source.
   9309           ******************************************************************************/
   9310          void sli_em_cmu_HFClockSelectUSHFRCODIV2(void)
   9311          {
   9312            // Enable USHFRCO oscillator
   9313            CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
   9314            // Configure worst case wait-states for flash and set safe HFPER
   9315            // clock-tree prescalers.
   9316            flashWaitStateMax();
   9317            hfperClkSafePrescaler();
   9318          
   9319            // Select HF clock source.
   9320            CMU->CMD = CMU_CMD_HFCLKSEL_USHFRCODIV2;
   9321          #if defined(CMU_MAX_FREQ_HFLE)
   9322            setHfLeConfig(SystemCoreClockGet());
   9323          #endif
   9324          
   9325            // Optimize flash access wait state setting for the currently selected core clk.
   9326            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9327            // Set optimized HFPER clock-tree prescalers.
   9328            hfperClkOptimizedPrescaler();
   9329          }
   9330          #endif
   9331          
   9332          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
   9333          /***************************************************************************//**
   9334           * @brief This function is used to initialize the HF clock and selecting
   9335           *        HFRCODIV2 as the clock source.
   9336           *
   9337           * @note FOR INTERNAL USE ONLY.
   9338           *
   9339           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9340           *       the clock is HF and HFRCODIV2 is selected as the clock source.
   9341           ******************************************************************************/
   9342          void sli_em_cmu_HFClockSelectHFRCODIV2(void)
   9343          {
   9344            // Enable HFRCO oscillator
   9345            CMU_OscillatorEnable(cmuOsc_HFRCO, true, true);
   9346            // Configure worst case wait-states for flash and set safe HFPER
   9347            // clock-tree prescalers.
   9348            flashWaitStateMax();
   9349            hfperClkSafePrescaler();
   9350          
   9351            // Select HF clock source.
   9352            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCODIV2;
   9353          #if defined(CMU_MAX_FREQ_HFLE)
   9354            setHfLeConfig(SystemHFClockGet());
   9355          #endif
   9356          
   9357            // Optimize flash access wait state setting for the currently selected core clk.
   9358            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9359            // Set optimized HFPER clock-tree prescalers.
   9360            hfperClkOptimizedPrescaler();
   9361          }
   9362          #endif
   9363          
   9364          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
   9365          /***************************************************************************//**
   9366           * @brief This function is used to initialize the HF clock and selecting
   9367           *        CLKIN0 as the clock source.
   9368           *
   9369           * @note FOR INTERNAL USE ONLY.
   9370           *
   9371           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9372           *       the clock is HF and CLKIN0 is selected as the clock source.
   9373           ******************************************************************************/
   9374          void sli_em_cmu_HFClockSelectCLKIN0(void)
   9375          {
   9376            // Configure worst case wait-states for flash and set safe HFPER
   9377            // clock-tree prescalers.
   9378            flashWaitStateMax();
   9379            hfperClkSafePrescaler();
   9380          
   9381            // Select HF clock source.
   9382            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_CLKIN0;
   9383          #if defined(CMU_MAX_FREQ_HFLE)
   9384            setHfLeConfig(SystemHFClockGet());
   9385          #endif
   9386          
   9387            // Optimize flash access wait state setting for the currently selected core clk.
   9388            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9389            // Set optimized HFPER clock-tree prescalers.
   9390            hfperClkOptimizedPrescaler();
   9391          }
   9392          #endif
   9393          
   9394          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
   9395          /***************************************************************************//**
   9396           * @brief This function is used to initialize the HF clock and selecting
   9397           *        USHFRCO as the clock source.
   9398           *
   9399           * @note FOR INTERNAL USE ONLY.
   9400           *
   9401           * @note This function is needed for macro expansion of CMU_CLOCK_SELECT_SET when
   9402           *       the clock is HF and USHFRCO is selected as the clock source.
   9403           ******************************************************************************/
   9404          void sli_em_cmu_HFClockSelectUSHFRCO(void)
   9405          {
   9406            // Enable USHFRCO oscillator
   9407            CMU_OscillatorEnable(cmuOsc_USHFRCO, true, true);
   9408            // Configure worst case wait-states for flash and set safe HFPER
   9409            // clock-tree prescalers.
   9410            flashWaitStateMax();
   9411            hfperClkSafePrescaler();
   9412          
   9413            // Select HF clock source.
   9414            CMU->HFCLKSEL = CMU_HFCLKSEL_HF_USHFRCO;
   9415          #if defined(CMU_MAX_FREQ_HFLE)
   9416            setHfLeConfig(SystemHFClockGet());
   9417          #endif
   9418          
   9419            // Optimize flash access wait state setting for the currently selected core clk.
   9420            CMU_UpdateWaitStates(SystemCoreClockGet(), VSCALE_DEFAULT);
   9421            // Set optimized HFPER clock-tree prescalers.
   9422            hfperClkOptimizedPrescaler();
   9423          }
   9424          #endif
   9425          
   9426          /***************************************************************************//**
   9427           * @brief
   9428           *   Select the reference clock/oscillator used for a clock branch.
   9429           *
   9430           * @details
   9431           *   Notice that if a selected reference is not enabled prior to selecting its
   9432           *   use, it will be enabled and this function will wait for the selected
   9433           *   oscillator to be stable. It will however NOT be disabled if another
   9434           *   reference clock is selected later.
   9435           *
   9436           *   This feature is particularly important if selecting a new reference
   9437           *   clock for the clock branch clocking the core. Otherwise, the system
   9438           *   may halt.
   9439           *
   9440           * @note
   9441           *   HFCLKLE prescaler is automatically modified when peripherals with clock
   9442           *   domain HFBUSCLK is chosen based on the maximum HFLE frequency allowed.
   9443           *
   9444           * @param[in] clock
   9445           *   A clock branch to select reference clock for. One of:
   9446           *   @li #cmuClock_HF
   9447           *   @li #cmuClock_LFA
   9448           *   @li #cmuClock_LFB
   9449           *   @if _CMU_LFCCLKEN0_MASK
   9450           *   @li #cmuClock_LFC
   9451           *   @endif
   9452           *   @if _CMU_LFECLKEN0_MASK
   9453           *   @li #cmuClock_LFE
   9454           *   @endif
   9455           *   @li #cmuClock_DBG
   9456           *   @if _CMU_CMD_USBCLKSEL_MASK
   9457           *   @li #cmuClock_USBC
   9458           *   @endif
   9459           *   @if _CMU_USBCTRL_MASK
   9460           *   @li #cmuClock_USBR
   9461           *   @endif
   9462           *
   9463           * @param[in] ref
   9464           *   A reference selected for clocking. See the reference manual
   9465           *   for details about references available for a specific clock branch.
   9466           *   @li #cmuSelect_HFRCO
   9467           *   @li #cmuSelect_LFRCO
   9468           *   @li #cmuSelect_HFXO
   9469           *   @if _CMU_HFXOCTRL_HFXOX2EN_MASK
   9470           *   @li #cmuSelect_HFXOX2
   9471           *   @endif
   9472           *   @li #cmuSelect_LFXO
   9473           *   @li #cmuSelect_HFCLKLE
   9474           *   @li #cmuSelect_AUXHFRCO
   9475           *   @if _CMU_USHFRCOCTRL_MASK
   9476           *   @li #cmuSelect_USHFRCO
   9477           *   @endif
   9478           *   @li #cmuSelect_HFCLK
   9479           *   @ifnot DOXYDOC_EFM32_GECKO_FAMILY
   9480           *   @li #cmuSelect_ULFRCO
   9481           *   @endif
   9482           *   @if CMU_OSCENCMD_PLFRCOEN
   9483           *   @li #cmuSelect_PLFRCO
   9484           *   @endif
   9485           ******************************************************************************/
   9486          void CMU_ClockSelectSet(CMU_Clock_TypeDef clock, CMU_Select_TypeDef ref)
   9487          {
   9488            uint32_t              select = (uint32_t)cmuOsc_HFRCO;
   9489            CMU_Osc_TypeDef       osc    = cmuOsc_HFRCO;
   9490            uint32_t              freq;
   9491            uint32_t              tmp;
   9492            uint32_t              selRegId;
   9493          #if defined(_SILICON_LABS_32B_SERIES_1)
   9494            volatile uint32_t     *selReg = NULL;
   9495          #endif
   9496          #if defined(CMU_LFCLKSEL_LFAE_ULFRCO)
   9497            uint32_t              lfExtended = 0;
   9498          #endif
   9499          
   9500          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9501            uint32_t              vScaleFrequency = 0; /* Use default. */
   9502          
   9503            /* Start voltage upscaling before the clock is set. */
   9504            if (clock == cmuClock_HF) {
   9505              if (ref == cmuSelect_HFXO) {
   9506                vScaleFrequency = SystemHFXOClockGet();
   9507              } else if ((ref == cmuSelect_HFRCO)
   9508                         && ((uint32_t)CMU_HFRCOBandGet()
   9509                             > CMU_VSCALEEM01_LOWPOWER_VOLTAGE_CLOCK_MAX)) {
   9510                vScaleFrequency = (uint32_t)CMU_HFRCOBandGet();
   9511              } else {
   9512                /* Use the default frequency. */
   9513              }
   9514              if (vScaleFrequency != 0UL) {
   9515                EMU_VScaleEM01ByClock(vScaleFrequency, false);
   9516              }
   9517            }
   9518          #endif
   9519          
   9520            selRegId = ((unsigned)clock >> CMU_SEL_REG_POS) & CMU_SEL_REG_MASK;
   9521          
   9522            switch (selRegId) {
   9523              case CMU_HFCLKSEL_REG:
   9524                switch (ref) {
   9525                  case cmuSelect_LFXO:
   9526          #if defined(_SILICON_LABS_32B_SERIES_1)
   9527                    select = CMU_HFCLKSEL_HF_LFXO;
   9528          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9529                    select = CMU_CMD_HFCLKSEL_LFXO;
   9530          #endif
   9531                    osc = cmuOsc_LFXO;
   9532                    break;
   9533          
   9534                  case cmuSelect_LFRCO:
   9535          #if defined(_SILICON_LABS_32B_SERIES_1)
   9536                    select = CMU_HFCLKSEL_HF_LFRCO;
   9537          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9538                    select = CMU_CMD_HFCLKSEL_LFRCO;
   9539          #endif
   9540                    osc = cmuOsc_LFRCO;
   9541                    break;
   9542          
   9543                  case cmuSelect_HFXO:
   9544          #if defined(CMU_HFCLKSEL_HF_HFXO)
   9545                    select = CMU_HFCLKSEL_HF_HFXO;
   9546          #elif defined(CMU_CMD_HFCLKSEL_HFXO)
   9547                    select = CMU_CMD_HFCLKSEL_HFXO;
   9548          #endif
   9549                    osc = cmuOsc_HFXO;
   9550          #if defined(CMU_MAX_FREQ_HFLE)
   9551                    /* Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9552                       This is known after 'select' is written below. */
   9553                    setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9554          #endif
   9555          #if defined(CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ)
   9556                    /* Adjust HFXO buffer current for frequencies above 32 MHz. */
   9557                    if (SystemHFXOClockGet() > 32000000) {
   9558                      CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9559                                  | CMU_CTRL_HFXOBUFCUR_BOOSTABOVE32MHZ;
   9560                    } else {
   9561                      CMU->CTRL = (CMU->CTRL & ~_CMU_CTRL_HFXOBUFCUR_MASK)
   9562                                  | CMU_CTRL_HFXOBUFCUR_BOOSTUPTO32MHZ;
   9563                    }
   9564          #endif
   9565                    break;
   9566          
   9567                  case cmuSelect_HFRCO:
   9568          #if defined(_SILICON_LABS_32B_SERIES_1)
   9569                    select = CMU_HFCLKSEL_HF_HFRCO;
   9570          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9571                    select = CMU_CMD_HFCLKSEL_HFRCO;
   9572          #endif
   9573                    osc = cmuOsc_HFRCO;
   9574          #if defined(CMU_MAX_FREQ_HFLE)
   9575                    /* Set 1 HFLE wait-state until the new HFCLKLE frequency is known.
   9576                       This is known after 'select' is written below. */
   9577                    setHfLeConfig(CMU_MAX_FREQ_HFLE + 1UL);
   9578          #endif
   9579                    break;
   9580          
   9581          #if defined(CMU_CMD_HFCLKSEL_USHFRCODIV2)
   9582                  case cmuSelect_USHFRCODIV2:
   9583                    select = CMU_CMD_HFCLKSEL_USHFRCODIV2;
   9584                    osc = cmuOsc_USHFRCO;
   9585                    break;
   9586          #endif
   9587          
   9588          #if defined(CMU_HFCLKSTATUS_SELECTED_HFRCODIV2)
   9589                  case cmuSelect_HFRCODIV2:
   9590                    select = CMU_HFCLKSEL_HF_HFRCODIV2;
   9591                    osc = cmuOsc_HFRCO;
   9592                    break;
   9593          #endif
   9594          
   9595          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
   9596                  case cmuSelect_CLKIN0:
   9597                    select = CMU_HFCLKSEL_HF_CLKIN0;
   9598                    osc = cmuOsc_CLKIN0;
   9599                    break;
   9600          #endif
   9601          
   9602          #if defined(CMU_HFCLKSTATUS_SELECTED_USHFRCO)
   9603                  case cmuSelect_USHFRCO:
   9604                    select = CMU_HFCLKSEL_HF_USHFRCO;
   9605                    osc = cmuOsc_USHFRCO;
   9606                    break;
   9607          #endif
   9608          
   9609          #if defined(CMU_LFCLKSEL_LFAE_ULFRCO) || defined(CMU_LFACLKSEL_LFA_ULFRCO)
   9610                  case cmuSelect_ULFRCO:
   9611                    /* ULFRCO cannot be used as HFCLK.  */
   9612                    EFM_ASSERT(false);
   9613                    return;
   9614          #endif
   9615          
   9616                  default:
   9617                    EFM_ASSERT(false);
   9618                    return;
   9619                }
   9620          
   9621                /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9622          #if defined(CMU_HFCLKSTATUS_SELECTED_CLKIN0)
   9623                if (osc != cmuOsc_CLKIN0) {
   9624                  CMU_OscillatorEnable(osc, true, true);
   9625                }
   9626          #else
   9627                CMU_OscillatorEnable(osc, true, true);
   9628          #endif
   9629          
   9630                /* Configure worst case wait-states for flash and set safe HFPER
   9631                   clock-tree prescalers. */
   9632                flashWaitStateMax();
   9633                hfperClkSafePrescaler();
   9634          
   9635          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9636                /* Wait for voltage upscaling to complete before the clock is set. */
   9637                if (vScaleFrequency != 0UL) {
   9638                  EMU_VScaleWait();
   9639                }
   9640          #endif
   9641          
   9642                /* Switch to the selected oscillator. */
   9643          #if defined(_CMU_HFCLKSEL_MASK)
   9644                CMU->HFCLKSEL = select;
   9645          #else
   9646                CMU->CMD = select;
   9647          #endif
   9648                /* Update the CMSIS core clock variable. */
   9649                /* (The function will update the global variable). */
   9650                freq = SystemCoreClockGet();
   9651          
   9652          #if defined(CMU_MAX_FREQ_HFLE)
   9653                /* Update the HFLE configuration after 'select' is set.
   9654                   Note that the HFCLKLE clock is connected differently on platforms 1 and 2. */
   9655          #if defined(_SILICON_LABS_32B_SERIES_0)
   9656                setHfLeConfig(freq);
   9657          #else
   9658                setHfLeConfig(SystemHFClockGet());
   9659          #endif
   9660          #endif
   9661          
   9662                /* Optimize flash access wait state setting for the currently selected core clk. */
   9663                CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
   9664          
   9665          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
   9666                /* Keep EMU module informed on the source HF clock frequency. This will apply voltage
   9667                   downscaling after clock is set if downscaling is configured. */
   9668                if (vScaleFrequency == 0UL) {
   9669                  EMU_VScaleEM01ByClock(0, true);
   9670                }
   9671          #endif
   9672                /* Set optimized HFPER clock-tree prescalers. */
   9673                hfperClkOptimizedPrescaler();
   9674                break;
   9675          
   9676          #if defined(_SILICON_LABS_32B_SERIES_1)
   9677              case CMU_LFACLKSEL_REG:
   9678                selReg = &CMU->LFACLKSEL;
   9679                /* HFCLKCLE can't be used as LFACLK. */
   9680                EFM_ASSERT(ref != cmuSelect_HFCLKLE);
   9681                SL_FALLTHROUGH
   9682                /* Fall through and select the clock source. */
   9683          
   9684          #if defined(_CMU_LFCCLKSEL_MASK)
   9685              case CMU_LFCCLKSEL_REG:
   9686                selReg = (selReg == NULL) ? &CMU->LFCCLKSEL : selReg;
   9687                /* HFCLKCLE can't be used as LFCCLK. */
   9688                EFM_ASSERT(ref != cmuSelect_HFCLKLE);
   9689                SL_FALLTHROUGH
   9690          #endif
   9691              /* Fall through and select the clock source. */
   9692          
   9693              case CMU_LFECLKSEL_REG:
   9694                selReg = (selReg == NULL) ? &CMU->LFECLKSEL : selReg;
   9695                /* HFCLKCLE can't be used as LFECLK. */
   9696                EFM_ASSERT(ref != cmuSelect_HFCLKLE);
   9697                SL_FALLTHROUGH
   9698              /* Fall through and select the clock source. */
   9699          
   9700              case CMU_LFBCLKSEL_REG:
   9701                selReg = (selReg == NULL) ? &CMU->LFBCLKSEL : selReg;
   9702                switch (ref) {
   9703                  case cmuSelect_Disabled:
   9704                    tmp = _CMU_LFACLKSEL_LFA_DISABLED;
   9705                    break;
   9706          
   9707                  case cmuSelect_LFXO:
   9708                    /* Ensure that thes elected oscillator is enabled, waiting for it to stabilize. */
   9709                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
   9710                    tmp = _CMU_LFACLKSEL_LFA_LFXO;
   9711                    break;
   9712          
   9713                  case cmuSelect_LFRCO:
   9714                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9715                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
   9716                    tmp = _CMU_LFACLKSEL_LFA_LFRCO;
   9717                    break;
   9718          
   9719                  case cmuSelect_HFCLKLE:
   9720                    /* Ensure the correct HFLE wait-states and enable HFCLK to LE.*/
   9721                    setHfLeConfig(SystemHFClockGet());
   9722                    BUS_RegBitWrite(&CMU->HFBUSCLKEN0, _CMU_HFBUSCLKEN0_LE_SHIFT, 1);
   9723                    tmp = _CMU_LFBCLKSEL_LFB_HFCLKLE;
   9724                    break;
   9725          
   9726                  case cmuSelect_ULFRCO:
   9727                    /* ULFRCO is always on, there is no need to enable it. */
   9728                    tmp = _CMU_LFACLKSEL_LFA_ULFRCO;
   9729                    break;
   9730          
   9731          #if defined(PLFRCO_PRESENT)
   9732                  case cmuSelect_PLFRCO:
   9733                    CMU_OscillatorEnable(cmuOsc_PLFRCO, true, true);
   9734                    tmp = _CMU_LFACLKSEL_LFA_PLFRCO;
   9735                    break;
   9736          #endif
   9737          
   9738                  default:
   9739                    EFM_ASSERT(false);
   9740                    return;
   9741                }
   9742                *selReg = tmp;
   9743                break;
   9744          
   9745          #elif defined(_SILICON_LABS_32B_SERIES_0)
   9746              case CMU_LFACLKSEL_REG:
   9747              case CMU_LFBCLKSEL_REG:
   9748                switch (ref) {
   9749                  case cmuSelect_Disabled:
   9750                    tmp = _CMU_LFCLKSEL_LFA_DISABLED;
   9751                    break;
   9752          
   9753                  case cmuSelect_LFXO:
   9754                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9755                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
   9756                    tmp = _CMU_LFCLKSEL_LFA_LFXO;
   9757                    break;
   9758          
   9759                  case cmuSelect_LFRCO:
   9760                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9761                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
   9762                    tmp = _CMU_LFCLKSEL_LFA_LFRCO;
   9763                    break;
   9764          
   9765                  case cmuSelect_HFCLKLE:
   9766          #if defined(CMU_MAX_FREQ_HFLE)
   9767                    /* Set the HFLE wait-state and divider. */
   9768                    freq = SystemCoreClockGet();
   9769                    setHfLeConfig(freq);
   9770          #endif
   9771                    /* Ensure HFCORE to LE clocking is enabled. */
   9772                    BUS_RegBitWrite(&CMU->HFCORECLKEN0, _CMU_HFCORECLKEN0_LE_SHIFT, 1);
   9773                    tmp = _CMU_LFCLKSEL_LFA_HFCORECLKLEDIV2;
   9774                    break;
   9775          
   9776          #if defined(CMU_LFCLKSEL_LFAE_ULFRCO)
   9777                  case cmuSelect_ULFRCO:
   9778                    /* ULFRCO is always enabled. */
   9779                    tmp = _CMU_LFCLKSEL_LFA_DISABLED;
   9780                    lfExtended = 1;
   9781                    break;
   9782          #endif
   9783          
   9784                  default:
   9785                    /* An illegal clock source for LFA/LFB selected. */
   9786                    EFM_ASSERT(false);
   9787                    return;
   9788                }
   9789          
   9790                /* Apply select. */
   9791                if (selRegId == CMU_LFACLKSEL_REG) {
   9792          #if defined(_CMU_LFCLKSEL_LFAE_MASK)
   9793                  CMU->LFCLKSEL = (CMU->LFCLKSEL
   9794                                   & ~(_CMU_LFCLKSEL_LFA_MASK | _CMU_LFCLKSEL_LFAE_MASK))
   9795                                  | (tmp << _CMU_LFCLKSEL_LFA_SHIFT)
   9796                                  | (lfExtended << _CMU_LFCLKSEL_LFAE_SHIFT);
   9797          #else
   9798                  CMU->LFCLKSEL = (CMU->LFCLKSEL & ~_CMU_LFCLKSEL_LFA_MASK)
   9799                                  | (tmp << _CMU_LFCLKSEL_LFA_SHIFT);
   9800          #endif
   9801                } else {
   9802          #if defined(_CMU_LFCLKSEL_LFBE_MASK)
   9803                  CMU->LFCLKSEL = (CMU->LFCLKSEL
   9804                                   & ~(_CMU_LFCLKSEL_LFB_MASK | _CMU_LFCLKSEL_LFBE_MASK))
   9805                                  | (tmp << _CMU_LFCLKSEL_LFB_SHIFT)
   9806                                  | (lfExtended << _CMU_LFCLKSEL_LFBE_SHIFT);
   9807          #else
   9808                  CMU->LFCLKSEL = (CMU->LFCLKSEL & ~_CMU_LFCLKSEL_LFB_MASK)
   9809                                  | (tmp << _CMU_LFCLKSEL_LFB_SHIFT);
   9810          #endif
   9811                }
   9812                break;
   9813          
   9814          #if defined(_CMU_LFCLKSEL_LFC_MASK)
   9815              case CMU_LFCCLKSEL_REG:
   9816                switch (ref) {
   9817                  case cmuSelect_Disabled:
   9818                    tmp = _CMU_LFCLKSEL_LFA_DISABLED;
   9819                    break;
   9820          
   9821                  case cmuSelect_LFXO:
   9822                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9823                    CMU_OscillatorEnable(cmuOsc_LFXO, true, true);
   9824                    tmp = _CMU_LFCLKSEL_LFC_LFXO;
   9825                    break;
   9826          
   9827                  case cmuSelect_LFRCO:
   9828                    /* Ensure that the selected oscillator is enabled, waiting for it to stabilize. */
   9829                    CMU_OscillatorEnable(cmuOsc_LFRCO, true, true);
   9830                    tmp = _CMU_LFCLKSEL_LFC_LFRCO;
   9831                    break;
   9832          
   9833                  default:
   9834                    /* An illegal clock source for LFC selected. */
   9835                    EFM_ASSERT(false);
   9836                    return;
   9837                }
   9838          
   9839                /* Apply select. */
   9840                CMU->LFCLKSEL = (CMU->LFCLKSEL & ~_CMU_LFCLKSEL_LFC_MASK)
   9841                                | (tmp << _CMU_LFCLKSEL_LFC_SHIFT);
   9842                break;
