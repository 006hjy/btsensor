   9857                    CMU->DBGCLKSEL = CMU_DBGCLKSEL_DBG_HFCLK;
   9858                    break;
   9859          #endif
   9860          
   9861          #if defined(CMU_CTRL_DBGCLK)
   9862                  case cmuSelect_AUXHFRCO:
