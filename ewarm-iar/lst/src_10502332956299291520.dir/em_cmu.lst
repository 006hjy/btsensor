   5424          #if defined(USB_PRESENT)
   5425          /***************************************************************************//**
   5426           * @brief
   5427           *   Get selected oscillator and frequency for @ref cmuClock_USB clock tree.
   5428           *
   5429           * @param[out] freq
   5430           *   The frequency.
   5431           *
   5432           * @param[out] sel
   5433           *   The selected oscillator.
   5434           ******************************************************************************/
   5435          static void usbClkGet(uint32_t *freq, CMU_Select_TypeDef *sel)
   5436          {
   5437            uint32_t f = 0U;
   5438            CMU_Select_TypeDef s;
   5439          
   5440            switch (CMU->USB0CLKCTRL & _CMU_USB0CLKCTRL_CLKSEL_MASK) {
   5441              case CMU_USB0CLKCTRL_CLKSEL_USBPLL0:
   5442                f = PLL0_USB_OUTPUT_FREQ;
   5443                s = cmuSelect_USBPLL0;
   5444                break;
   5445          
   5446              case CMU_USB0CLKCTRL_CLKSEL_LFXO:
   5447                f = SystemLFXOClockGet();
   5448                s = cmuSelect_LFXO;
   5449                break;
   5450          
   5451              case CMU_USB0CLKCTRL_CLKSEL_LFRCO:
   5452                f = SystemLFRCOClockGet();
   5453                s = cmuSelect_LFRCO;
   5454                break;
   5455          
   5456              default:
   5457                s = cmuSelect_Error;
   5458                EFM_ASSERT(false);
   5459                break;
   5460            }
   5461          
   5462            if (freq != NULL) {
   5463              *freq = f;
   5464            }
   5465            if (sel != NULL) {
   5466              *sel = s;
   5467            }
   5468          }
   5469          #endif
