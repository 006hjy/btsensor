  10148                               | (tmp << _CMU_USBCTRL_USBCLKSEL_SHIFT);
  10149                break;
  10150          #endif
  10151          
  10152          #if defined(_CMU_PDMCTRL_PDMCLKSEL_MASK)
  10153              case CMU_PDMREFSEL_REG:
