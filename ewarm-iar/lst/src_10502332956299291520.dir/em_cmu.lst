   3178          /**************************************************************************//**
   3179           * @brief
   3180           *   Initialize HFXO Bufout (Crystal sharing) leader control registers.
   3181           *   Configure the bufout request input GPIO as a clock request signal
   3182           *   to add the crystal sharing follower chip as a source of clock request.
   3183           *
   3184           * @warning
   3185           *   If EM2 capabilities are needed, a GPIO that fully retains its
   3186           *   capabilities while in EM2 must be selected.
   3187           *
   3188           * @param[in] bufoutInit
   3189           *   Bufout setup parameters.
   3190           *
   3191           * @param[in] port
   3192           *   Bufout request GPIO port.
   3193           *
   3194           * @param[in] pin
   3195           *   Bufout request GPIO pin.
   3196           *****************************************************************************/
   3197          void CMU_HFXOStartCrystalSharingLeader(const CMU_BUFOUTLeaderInit_TypeDef *bufoutInit,
   3198                                                 GPIO_Port_TypeDef                   port,
   3199                                                 unsigned int                        pin)
   3200          {
   3201            EFM_ASSERT(GPIO_PORT_PIN_VALID(port, pin));
   3202          
   3203            // Configure Bufout request GPIO.
   3204            GPIO_PinModeSet(port, pin, gpioModeInput, 0U);
   3205            GPIO->SYXOROUTE[0].BUFOUTREQINASYNCROUTE = pin    << _GPIO_SYXO_BUFOUTREQINASYNCROUTE_PIN_SHIFT
   3206                                                       | port << _GPIO_SYXO_BUFOUTREQINASYNCROUTE_PORT_SHIFT;
   3207          
   3208            bool wasLocked = HFXO0->STATUS & HFXO_STATUS_LOCK_LOCKED ? true : false;
   3209          
   3210            // Unlock register interface.
   3211            HFXO0->LOCK = HFXO_LOCK_LOCKKEY_UNLOCK;
   3212          
   3213            HFXO0->CTRL_CLR = _HFXO_CTRL_BUFOUTFREEZE_MASK | _HFXO_CTRL_DISONDEMANDBUFOUT_MASK;
   3214          
   3215            BUS_RegMaskedWrite(&HFXO0->BUFOUTCTRL,
   3216                               _HFXO_BUFOUTCTRL_MINIMUMSTARTUPDELAY_MASK
   3217                               | _HFXO_BUFOUTCTRL_TIMEOUTSTARTUP_MASK,
   3218                               bufoutInit->minimalStartupDelay  << _HFXO_BUFOUTCTRL_MINIMUMSTARTUPDELAY_SHIFT
   3219                               | bufoutInit->timeoutStartup       << _HFXO_BUFOUTCTRL_TIMEOUTSTARTUP_SHIFT);
   3220          
   3221            if (wasLocked) {
   3222              HFXO0->LOCK = ~HFXO_LOCK_LOCKKEY_UNLOCK;
   3223            }
   3224          }
   3225          #endif
   3226          
   3227          #if defined(_HFXO_CTRL_PRSSTATUSSEL0_MASK)
   3228          /**************************************************************************//**
   3229           * @brief
   3230           *   Initialize HFXO Bufout (Crystal sharing) follower control registers.
   3231           *   Configure the clock request signal to a specified GPIO to automatically
   3232           *   request the high frequency crystal oscillator sine wave clock.
   3233           *   This function must be used in conjunction with CMU_HFXOInit() configured
   3234           *   with EXTERNAL_SINE or EXTERNAL_SINEPKDET mode.
   3235           *
   3236           * @warning
   3237           *   If EM2 capabilities are needed, a GPIO that fully retains its
   3238           *   capabilities while in EM2 must be selected.
   3239           *
   3240           * @note
   3241           *   This function can be emulated on XG21/XG22 chips by controlling the clock
   3242           *   request GPIO to ask the crystal sharing leader clock when needed.
   3243           *
   3244           * @param[in] prsStatusSelectOutput
   3245           *    Selected HFXO PRS signal output.
   3246           *
   3247           * @param[in] prsAsyncCh
   3248           *    PRS producer asynchronous signal channel.
   3249           *
   3250           * @param[in] port
   3251           *    Bufout request GPIO port.
   3252           *
   3253           * @param[in] pin
   3254           *    Bufout request GPIO pin.
   3255           *****************************************************************************/
   3256          void CMU_HFXOCrystalSharingFollowerInit(CMU_PRS_Status_Output_Select_TypeDef prsStatusSelectOutput,
   3257                                                  unsigned int                         prsAsyncCh,
   3258                                                  GPIO_Port_TypeDef                    port,
   3259                                                  unsigned int                         pin)
   3260          {
   3261            EFM_ASSERT(prsAsyncCh < PRS_ASYNC_CH_NUM);
   3262            EFM_ASSERT(GPIO_PORT_PIN_VALID(port, pin));
   3263          
   3264            uint32_t mask = 0U, prsSignal = 0U, value = 0U;
   3265          
   3266            switch (prsStatusSelectOutput) {
   3267              case PRS_Status_select_0:
   3268                mask      = _HFXO_CTRL_PRSSTATUSSEL0_MASK;
   3269                value     = _HFXO_CTRL_PRSSTATUSSEL0_ENS << _HFXO_CTRL_PRSSTATUSSEL0_SHIFT;
   3270                prsSignal = _PRS_ASYNC_CH_CTRL_SIGSEL_HFXO0LSTATUS;
   3271                break;
   3272          
   3273              case PRS_Status_select_1:
   3274          #if defined(SL_CATALOG_POWER_MANAGER_PRESENT)
   3275                // Power Manager module requires the HFXO PRS Producer output 1 for its usage.
   3276                EFM_ASSERT(false);
   3277          #else
   3278                mask      = _HFXO_CTRL_PRSSTATUSSEL1_MASK;
   3279                value     = _HFXO_CTRL_PRSSTATUSSEL1_ENS << _HFXO_CTRL_PRSSTATUSSEL1_SHIFT;
   3280                prsSignal = _PRS_ASYNC_CH_CTRL_SIGSEL_HFXO0LSTATUS1;
   3281          #endif
   3282                break;
   3283          
   3284              default:
   3285                EFM_ASSERT(false);
   3286                break;
   3287            }
   3288          
   3289            bool wasLocked = HFXO0->STATUS & HFXO_STATUS_LOCK_LOCKED ? true : false;
   3290          
   3291            // Unlock register interface.
   3292            HFXO0->LOCK = HFXO_LOCK_LOCKKEY_UNLOCK;
   3293          
   3294            BUS_RegMaskedWrite(&HFXO0->CTRL, mask, value);
   3295          
   3296            if (wasLocked) {
   3297              HFXO0->LOCK = ~HFXO_LOCK_LOCKKEY_UNLOCK;
   3298            }
   3299          
   3300            value = _PRS_ASYNC_CH_CTRL_AUXSEL_DEFAULT     << _PRS_ASYNC_CH_CTRL_AUXSEL_SHIFT
   3301                    | _PRS_ASYNC_CH_CTRL_FNSEL_A          << _PRS_ASYNC_CH_CTRL_FNSEL_SHIFT
   3302                    | _PRS_ASYNC_CH_CTRL_SOURCESEL_HFXO0L << _PRS_ASYNC_CH_CTRL_SOURCESEL_SHIFT
   3303                    | prsSignal                           << _PRS_ASYNC_CH_CTRL_SIGSEL_SHIFT;
   3304          
   3305            mask = _PRS_ASYNC_CH_CTRL_AUXSEL_MASK
   3306                   | _PRS_ASYNC_CH_CTRL_FNSEL_MASK
   3307                   | _PRS_ASYNC_CH_CTRL_SOURCESEL_MASK
   3308                   | _PRS_ASYNC_CH_CTRL_SIGSEL_MASK;
   3309          
   3310            BUS_RegMaskedWrite(&(PRS->ASYNC_CH[prsAsyncCh].CTRL), mask, value);
   3311          
   3312            GPIO_PinModeSet(port, pin, gpioModeWiredOrPullDown, 0U);
   3313          
   3314            (&(GPIO->PRSROUTE[0].ASYNCH0ROUTE))[prsAsyncCh] = pin    << _GPIO_PRS_ASYNCH0ROUTE_PIN_SHIFT
   3315                                                              | port << _GPIO_PRS_ASYNCH0ROUTE_PORT_SHIFT;
   3316            GPIO->PRSROUTE[0].ROUTEEN = 1U << (_GPIO_PRS_ROUTEEN_ASYNCH0PEN_SHIFT + prsAsyncCh);
   3317          }
   3318          #endif
