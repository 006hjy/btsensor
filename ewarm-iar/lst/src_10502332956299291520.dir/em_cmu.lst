   3972          /***************************************************************************//**
   3973           * @brief
   3974           *   Set HFRCOEM23 band and the tuning value based on the value in the
   3975           *   calibration table made during production.
   3976           *
   3977           * @param[in] freq
   3978           *   HFRCOEM23 frequency band to activate.
   3979           ******************************************************************************/
   3980          void CMU_HFRCOEM23BandSet(CMU_HFRCOEM23Freq_TypeDef freq)
   3981          {
   3982            uint32_t freqCal;
   3983          
   3984            // Get calibration data from DEVINFO
   3985            freqCal = HFRCOEM23DevinfoGet(freq);
   3986            EFM_ASSERT((freqCal != 0UL) && (freqCal != UINT_MAX));
   3987          #if defined(CMU_CLKEN0_HFRCOEM23)
   3988            CMU->CLKEN0_SET = CMU_CLKEN0_HFRCOEM23;
   3989          #endif
   3990          
   3991            // Set divider for 1, 2 and 4MHz bands
   3992            freqCal &= ~_HFRCO_CAL_CLKDIV_MASK;
   3993            switch (freq) {
   3994              case cmuHFRCOEM23Freq_1M0Hz:
   3995                freqCal |= HFRCO_CAL_CLKDIV_DIV4;
   3996                break;
   3997          
   3998              case cmuHFRCOEM23Freq_2M0Hz:
   3999                freqCal |= HFRCO_CAL_CLKDIV_DIV2;
   4000                break;
   4001          
   4002              default:
   4003                break;
   4004            }
   4005          
   4006            // Activate new band selection
   4007            HFRCOEM23->CAL = freqCal;
   4008          }
   4009          #endif // defined(HFRCOEM23_PRESENT)
