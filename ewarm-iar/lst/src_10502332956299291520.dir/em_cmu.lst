    277          /***************************************************************************//**
    278           * @brief
    279           *   Calibrate an oscillator.
    280           *
    281           * @details
    282           *   Run a calibration of a selectable reference clock againt HCLK. Please
    283           *   refer to the reference manual, CMU chapter, for further details.
    284           *
    285           * @note
    286           *   This function will not return until calibration measurement is completed.
    287           *
    288           * @param[in] cycles
    289           *   The number of HCLK cycles to run calibration. Increasing this number
    290           *   increases precision, but the calibration will take more time.
    291           *
    292           * @param[in] ref
    293           *   The reference clock used to compare against HCLK.
    294           *
    295           * @return
    296           *   The number of ticks the selected reference clock ticked while running
    297           *   cycles ticks of the HCLK clock.
    298           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    299          uint32_t CMU_Calibrate(uint32_t cycles, CMU_Select_TypeDef ref)
    300          {
   \                     CMU_Calibrate: (+1)
   \        0x0   0xB538             PUSH     {R3-R5,LR}
   \        0x2   0x4604             MOV      R4,R0
   \        0x4   0x460D             MOV      R5,R1
    301            // Check for cycle count overflow
    302          #if defined(_CMU_CALCTRL_CALTOP_MASK)
    303            EFM_ASSERT(cycles <= (_CMU_CALCTRL_CALTOP_MASK
    304                                  >> _CMU_CALCTRL_CALTOP_SHIFT));
   \        0x6   0xF5B4 0x1F80      CMP      R4,#+1048576
   \        0xA   0xD303             BCC.N    ??CrossCallReturnLabel_43
   \        0xC   0xF44F 0x7198      MOV      R1,#+304
   \       0x10   0x.... 0x....      BL       ?Subroutine5
    305          #elif defined(_CMU_CALTOP_CALTOP_MASK)
    306            EFM_ASSERT(cycles <= (_CMU_CALTOP_CALTOP_MASK
    307                                  >> _CMU_CALTOP_CALTOP_SHIFT));
    308          #endif
    309          
    310            CMU_CalibrateConfig(cycles, cmuSelect_HCLK, ref);
   \                     ??CrossCallReturnLabel_43: (+1)
   \       0x14   0x462A             MOV      R2,R5
   \       0x16   0x210C             MOVS     R1,#+12
   \       0x18   0x4620             MOV      R0,R4
   \       0x1A   0x.... 0x....      BL       CMU_CalibrateConfig
    311            CMU_CalibrateStart();
   \       0x1E   0x2001             MOVS     R0,#+1
   \       0x20   0x.... 0x....      LDR.W    R1,??DataTable16_2
   \       0x24   0x6008             STR      R0,[R1, #+0]
    312            return CMU_CalibrateCountGet();
   \       0x26   0xE8BD 0x4031      POP      {R0,R4,R5,LR}
   \       0x2A   0x....             B.N      CMU_CalibrateCountGet
    313          }

   \                                 In section .text, align 2, keep-with-next
   \                     ?Subroutine5: (+1)
   \        0x0   0x....             LDR.N    R0,??DataTable18
   \        0x2   0x.... 0x....      B.W      assertEFM
    314          
    315          /***************************************************************************//**
    316           * @brief
    317           *   Configure clock calibration.
    318           *
    319           * @details
    320           *   Configure a calibration for a selectable clock source against another
    321           *   selectable reference clock.
    322           *   Refer to the reference manual, CMU chapter, for further details.
    323           *
    324           * @note
    325           *   After configuration, a call to @ref CMU_CalibrateStart() is required, and
    326           *   the resulting calibration value can be read with the
    327           *   @ref CMU_CalibrateCountGet() function call.
    328           *
    329           * @param[in] downCycles
    330           *   The number of downSel clock cycles to run calibration. Increasing this
    331           *   number increases precision, but the calibration will take more time.
    332           *
    333           * @param[in] downSel
    334           *   The clock which will be counted down downCycles cycles.
    335           *
    336           * @param[in] upSel
    337           *   The reference clock, the number of cycles generated by this clock will
    338           *   be counted and added up, the result can be given with the
    339           *   @ref CMU_CalibrateCountGet() function call.
    340           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    341          void CMU_CalibrateConfig(uint32_t downCycles, CMU_Select_TypeDef downSel,
    342                                   CMU_Select_TypeDef upSel)
    343          {
   \                     CMU_CalibrateConfig: (+1)
   \        0x0   0xE92D 0x43F8      PUSH     {R3-R9,LR}
    344            // Keep untouched configuration settings
    345            uint32_t calCtrl = CMU->CALCTRL
    346                               & ~(_CMU_CALCTRL_UPSEL_MASK
