   2907          #if defined(RFFPLL_PRESENT)
   2908          /***************************************************************************//**
   2909           * @brief
   2910           *   Initialize the RFFPLL control registers.
   2911           *
   2912           * @param[in] pllInit
   2913           *   RFF PLL parameters
   2914           ******************************************************************************/
   2915          void CMU_RFFPLLInit(const CMU_RFFPLL_Init_TypeDef *pllInit)
   2916          {
   2917            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_SYSCLK) != cmuSelect_RFFPLLSYS);
   2918            EFM_ASSERT(pllInit->dividerY >= 8 && pllInit->dividerY <= 31);
   2919            EFM_ASSERT(pllInit->dividerX >= 4 && pllInit->dividerX <= 15);
   2920            EFM_ASSERT(pllInit->dividerN >= 32 && pllInit->dividerN <= 127);
   2921          
   2922            CMU->CLKEN1_SET = CMU_CLKEN1_RFFPLL0;
   2923          
   2924            RFFPLL0->LOCK = RFFPLL_LOCK_LOCKKEY_UNLOCK;
   2925          
   2926            RFFPLL0->CTRL = (RFFPLL0->CTRL & ~(_RFFPLL_CTRL_DISONDEMAND_MASK | _RFFPLL_CTRL_FORCEEN_MASK))
   2927                            | (pllInit->disOnDemand << _RFFPLL_CTRL_DISONDEMAND_SHIFT)
   2928                            | (pllInit->forceEn     << _RFFPLL_CTRL_FORCEEN_SHIFT);
   2929          
   2930            RFFPLL0->RFFPLLCTRL1 = (RFFPLL0->RFFPLLCTRL1 & ~(_RFFPLL_RFFPLLCTRL1_DIVY_MASK | _RFFPLL_RFFPLLCTRL1_DIVX_MASK | _RFFPLL_RFFPLLCTRL1_DIVN_MASK))
   2931                                   | (pllInit->dividerY << _RFFPLL_RFFPLLCTRL1_DIVY_SHIFT)
   2932                                   | (pllInit->dividerX << _RFFPLL_RFFPLLCTRL1_DIVX_SHIFT)
   2933                                   | (pllInit->dividerN << _RFFPLL_RFFPLLCTRL1_DIVN_SHIFT);
   2934          
   2935            // Update CMSIS RFFPLL frequency.
   2936            SystemRFFPLLClockSet(pllInit->frequency);
   2937          
   2938            if (pllInit->forceEn) {
   2939              CMU_WaitRFFPLLLock();
   2940            }
   2941          
   2942            if (pllInit->regLock) {
   2943              RFFPLL0->LOCK = ~USBPLL_LOCK_LOCKKEY_UNLOCK;
   2944            }
   2945          }
   2946          #endif
