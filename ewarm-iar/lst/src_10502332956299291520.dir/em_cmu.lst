   2851          #if defined(USBPLL_PRESENT)
   2852          /***************************************************************************//**
   2853           * @brief
   2854           *   Initialize the USB PLL control registers.
   2855           *
   2856           * @note
   2857           *  The HFXO reference frequency must be updated if crystal value is
   2858           *  different from default value.
   2859           *
   2860           * @param[in] pllInit
   2861           *   USB PLL parameters
   2862           ******************************************************************************/
   2863          void CMU_USBPLLInit(const CMU_USBPLL_Init_TypeDef *pllInit)
   2864          {
   2865            CMU->CLKEN1_SET = CMU_CLKEN1_USB;
   2866          
   2867            USBPLL0->LOCK = USBPLL_LOCK_LOCKKEY_UNLOCK;
   2868          
   2869            // Stop the PLL for configuration purposes
   2870            USBPLL0->CTRL_SET = USBPLL_CTRL_DISONDEMAND;
   2871            USBPLL0->CTRL_CLR = USBPLL_CTRL_FORCEEN;
   2872          
   2873            while (USBPLL0->STATUS & USBPLL_STATUS_PLLLOCK) ;
   2874          
   2875            if (pllInit->hfxoRefFreq == cmuHFXORefFreq_39M0Hz) {
   2876              // Set DCO in low frequency mode for 39 MHz crystal.
   2877              USBPLL0->DCOCTRL_SET = _USBPLL_DCOCTRL_DCOBIASHALF_MASK;
   2878            } else {
   2879              USBPLL0->DCOCTRL_CLR = _USBPLL_DCOCTRL_DCOBIASHALF_MASK;
   2880            }
   2881          
   2882            while (USBPLL0->STATUS & USBPLL_STATUS_SYNCBUSY) ;
   2883          
   2884            USBPLL0->CTRL = (USBPLL0->CTRL & ~(_USBPLL_CTRL_SHUNTREGLPEN_MASK
   2885                                               | _USBPLL_CTRL_DIVR_MASK
   2886                                               | _USBPLL_CTRL_DIVX_MASK
   2887                                               | _USBPLL_CTRL_DIVN_MASK
   2888                                               | _USBPLL_CTRL_DISONDEMAND_MASK
   2889                                               | _USBPLL_CTRL_FORCEEN_MASK))
   2890                            | pllInit->hfxoRefFreq
   2891                            | pllInit->shuntRegEn  << _USBPLL_CTRL_SHUNTREGLPEN_SHIFT
   2892                            | pllInit->disOnDemand << _USBPLL_CTRL_DISONDEMAND_SHIFT
   2893                            | pllInit->forceEn     << _USBPLL_CTRL_FORCEEN_SHIFT;
   2894          
   2895            while (USBPLL0->STATUS & USBPLL_STATUS_SYNCBUSY) ;
   2896          
   2897            if (pllInit->forceEn) {
   2898              CMU_WaitUSBPLLLock();
   2899            }
   2900          
   2901            if (pllInit->regLock) {
   2902              USBPLL0->LOCK = ~USBPLL_LOCK_LOCKKEY_UNLOCK;
   2903            }
   2904          }
   2905          #endif
