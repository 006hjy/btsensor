  10870          
  10871          #if defined(_CMU_HFXOCTRL_AUTOSTARTEM0EM1_MASK)
  10872          /***************************************************************************//**
  10873           * @brief
  10874           *   Enable or disable HFXO autostart.
  10875           *
  10876           * @param[in] userSel
  10877           *   Additional user specified enable bit.
  10878           *
  10879           * @param[in] enEM0EM1Start
  10880           *   If true, HFXO is automatically started upon entering EM0/EM1 entry from
  10881           *   EM2/EM3. HFXO selection has to be handled by the user.
  10882           *   If false, HFXO is not started automatically when entering EM0/EM1.
  10883           *
  10884           * @param[in] enEM0EM1StartSel
  10885           *   If true, HFXO is automatically started and immediately selected upon
  10886           *   entering EM0/EM1 entry from EM2/EM3. Note that this option stalls the use of
  10887           *   HFSRCCLK until HFXO becomes ready. HFCLKLE prescaler is also automatically
  10888           *   modified if userSel is specified.
  10889           *   If false, HFXO is not started or selected automatically when entering
  10890           *   EM0/EM1.
  10891           ******************************************************************************/
  10892          void CMU_HFXOAutostartEnable(uint32_t userSel,
  10893                                       bool enEM0EM1Start,
  10894                                       bool enEM0EM1StartSel)
  10895          {
  10896            uint32_t hfxoFreq;
  10897            uint32_t hfxoCtrl;
  10898          
  10899          #if defined(_EMU_CTRL_EM23VSCALE_MASK)
  10900            if (enEM0EM1StartSel) {
  10901              /* Voltage scaling is not compatible with HFXO auto start and select. */
  10902              EFM_ASSERT((EMU->CTRL & _EMU_CTRL_EM23VSCALE_MASK) == EMU_CTRL_EM23VSCALE_VSCALE2);
  10903            }
  10904          #endif
  10905          
  10906            /* Mask supported enable bits. */
  10907          #if defined(_CMU_HFXOCTRL_AUTOSTARTRDYSELRAC_MASK)
  10908            userSel &= _CMU_HFXOCTRL_AUTOSTARTRDYSELRAC_MASK;
  10909          #else
  10910            userSel = 0;
  10911          #endif
  10912          
  10913            hfxoFreq = SystemHFXOClockGet();
  10914          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10915            // Update voltage scaling.
  10916            EMU_VScaleEM01ByClock(hfxoFreq, true);
  10917          #endif
  10918            /* Set wait-states for HFXO if automatic start and select is configured. */
  10919            if ((userSel > 0UL) || enEM0EM1StartSel) {
  10920              CMU_UpdateWaitStates(hfxoFreq, VSCALE_DEFAULT);
  10921              setHfLeConfig(hfxoFreq / CMU_ClockDivGet(cmuClock_HF));
  10922            }
  10923          
  10924            if (enEM0EM1Start || enEM0EM1StartSel) {
  10925              /* Enable the HFXO once in order to finish first time calibrations. */
  10926              CMU_OscillatorEnable(cmuOsc_HFXO, true, true);
  10927            }
  10928          
  10929            /* Since call to CMU_OscillatorEnable() can change the CMU->HFXOCTRL register,
  10930             * it's important to read the CMU->HFXOCTRL register after the call to CMU_OscillatorEnable(). */
  10931            hfxoCtrl = CMU->HFXOCTRL & ~(userSel
  10932                                         | _CMU_HFXOCTRL_AUTOSTARTEM0EM1_MASK
  10933                                         | _CMU_HFXOCTRL_AUTOSTARTSELEM0EM1_MASK);
  10934          
  10935            hfxoCtrl |= userSel
  10936                        | (enEM0EM1Start ? CMU_HFXOCTRL_AUTOSTARTEM0EM1 : 0UL)
  10937                        | (enEM0EM1StartSel ? CMU_HFXOCTRL_AUTOSTARTSELEM0EM1 : 0UL);
  10938          
  10939            /* Update HFXOCTRL after wait-states are updated as HF may automatically switch
  10940               to HFXO when automatic select is enabled . */
  10941            CMU->HFXOCTRL = hfxoCtrl;
  10942          }
  10943          #endif
  10944          
  10945          /**************************************************************************//**
  10946           * @brief
  10947           *   Set HFXO control registers.
  10948           *
  10949           * @note
  10950           *   HFXO configuration should be obtained from a configuration tool,
  10951           *   app note, or crystal data sheet. This function disables the HFXO to
  10952           *   ensure a valid state before update.
  10953           *
  10954           * @param[in] hfxoInit
  10955           *    HFXO setup parameters.
  10956           *****************************************************************************/
  10957          void CMU_HFXOInit(const CMU_HFXOInit_TypeDef *hfxoInit)
  10958          {
  10959            /* Do not disable HFXO if it is currently selected as the HF/Core clock. */
  10960            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_HF) != cmuSelect_HFXO);
  10961          
  10962            /* HFXO must be disabled before reconfiguration. */
  10963            CMU_OscillatorEnable(cmuOsc_HFXO, false, true);
  10964          
  10965          #if defined(_SILICON_LABS_32B_SERIES_1) \
  10966            && (_SILICON_LABS_GECKO_INTERNAL_SDID >= 100)
  10967            uint32_t tmp = CMU_HFXOCTRL_MODE_XTAL;
  10968          
  10969            switch (hfxoInit->mode) {
  10970              case cmuOscMode_Crystal:
  10971                tmp = CMU_HFXOCTRL_MODE_XTAL;
  10972                break;
  10973              case cmuOscMode_External:
  10974                tmp = CMU_HFXOCTRL_MODE_DIGEXTCLK;
  10975                break;
  10976              case cmuOscMode_AcCoupled:
  10977                tmp = CMU_HFXOCTRL_MODE_ACBUFEXTCLK;
  10978                break;
  10979              default:
  10980                EFM_ASSERT(false); /* Unsupported configuration */
  10981                break;
  10982            }
  10983            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_MODE_MASK) | tmp;
  10984          
  10985          #if defined(CMU_HFXOCTRL_HFXOX2EN)
  10986            /* HFXO Doubler can only be enabled on crystals up to max 25 MHz. */
  10987            tmp = 0;
  10988            if (SystemHFXOClockGet() <= 25000000) {
  10989              tmp |= CMU_HFXOCTRL_HFXOX2EN;
  10990            }
  10991          
  10992            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_HFXOX2EN_MASK) | tmp;
  10993          #endif
  10994          
  10995            /* Set tuning for startup and steady state. */
  10996            CMU->HFXOSTARTUPCTRL = (hfxoInit->ctuneStartup
  10997                                    << _CMU_HFXOSTARTUPCTRL_CTUNE_SHIFT)
  10998                                   | (hfxoInit->xoCoreBiasTrimStartup
  10999                                      << _CMU_HFXOSTARTUPCTRL_IBTRIMXOCORE_SHIFT);
  11000          
  11001            CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  11002                                        & ~(_CMU_HFXOSTEADYSTATECTRL_CTUNE_MASK
  11003                                            | _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK))
  11004                                       | (hfxoInit->ctuneSteadyState
  11005                                          << _CMU_HFXOSTEADYSTATECTRL_CTUNE_SHIFT)
  11006                                       | (hfxoInit->xoCoreBiasTrimSteadyState
  11007                                          << _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_SHIFT);
  11008          
  11009            /* Set timeouts */
  11010            CMU->HFXOTIMEOUTCTRL = (hfxoInit->timeoutPeakDetect
  11011                                    << _CMU_HFXOTIMEOUTCTRL_PEAKDETTIMEOUT_SHIFT)
  11012                                   | (hfxoInit->timeoutSteady
  11013                                      << _CMU_HFXOTIMEOUTCTRL_STEADYTIMEOUT_SHIFT)
  11014                                   | (hfxoInit->timeoutStartup
  11015                                      << _CMU_HFXOTIMEOUTCTRL_STARTUPTIMEOUT_SHIFT);
  11016          
  11017          #elif defined(_CMU_HFXOCTRL_MASK)
  11018            uint32_t tmp = CMU_HFXOCTRL_MODE_XTAL;
  11019          
  11020            /* AC coupled external clock not supported. */
  11021            EFM_ASSERT(hfxoInit->mode != cmuOscMode_AcCoupled);
  11022            if (hfxoInit->mode == cmuOscMode_External) {
  11023              tmp = CMU_HFXOCTRL_MODE_DIGEXTCLK;
  11024            }
  11025          
  11026            /* Apply control settings. */
  11027            CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_MODE_MASK)
  11028                            | tmp;
  11029            BUS_RegBitWrite(&CMU->HFXOCTRL,
  11030                            _CMU_HFXOCTRL_LOWPOWER_SHIFT,
  11031                            (unsigned)hfxoInit->lowPowerMode);
  11032          
  11033            /* Set XTAL tuning parameters. */
  11034          
  11035          #if defined(_CMU_HFXOCTRL1_PEAKDETTHR_MASK)
  11036            /* Set peak detection threshold. */
  11037            CMU->HFXOCTRL1 = (CMU->HFXOCTRL1 & ~_CMU_HFXOCTRL1_PEAKDETTHR_MASK)
  11038                             | (hfxoInit->thresholdPeakDetect
  11039                                << _CMU_HFXOCTRL1_PEAKDETTHR_SHIFT);
  11040          #endif
  11041            /* Set tuning for startup and steady state. */
  11042            CMU->HFXOSTARTUPCTRL = ((uint32_t)hfxoInit->ctuneStartup
  11043                                    << _CMU_HFXOSTARTUPCTRL_CTUNE_SHIFT)
  11044                                   | ((uint32_t)hfxoInit->xoCoreBiasTrimStartup
  11045                                      << _CMU_HFXOSTARTUPCTRL_IBTRIMXOCORE_SHIFT);
  11046          
  11047            CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  11048                                        & ~(_CMU_HFXOSTEADYSTATECTRL_CTUNE_MASK
  11049                                            | _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK
  11050                                            | _CMU_HFXOSTEADYSTATECTRL_REGISH_MASK
  11051                                            | _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK))
  11052                                       | ((uint32_t)hfxoInit->ctuneSteadyState
  11053                                          << _CMU_HFXOSTEADYSTATECTRL_CTUNE_SHIFT)
  11054                                       | ((uint32_t)hfxoInit->xoCoreBiasTrimSteadyState
  11055                                          << _CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_SHIFT)
  11056                                       | ((uint32_t)hfxoInit->regIshSteadyState
  11057                                          << _CMU_HFXOSTEADYSTATECTRL_REGISH_SHIFT)
  11058                                       | getRegIshUpperVal(hfxoInit->regIshSteadyState);
  11059          
  11060            /* Set timeouts. */
  11061            CMU->HFXOTIMEOUTCTRL = ((uint32_t)hfxoInit->timeoutPeakDetect
  11062                                    << _CMU_HFXOTIMEOUTCTRL_PEAKDETTIMEOUT_SHIFT)
  11063                                   | ((uint32_t)hfxoInit->timeoutSteady
  11064                                      << _CMU_HFXOTIMEOUTCTRL_STEADYTIMEOUT_SHIFT)
  11065                                   | ((uint32_t)hfxoInit->timeoutStartup
  11066                                      << _CMU_HFXOTIMEOUTCTRL_STARTUPTIMEOUT_SHIFT)
  11067                                   | ((uint32_t)hfxoInit->timeoutShuntOptimization
  11068                                      << _CMU_HFXOTIMEOUTCTRL_SHUNTOPTTIMEOUT_SHIFT);
  11069          
  11070          #else
  11071            CMU->CTRL = (CMU->CTRL & ~(_CMU_CTRL_HFXOTIMEOUT_MASK
  11072                                       | _CMU_CTRL_HFXOBOOST_MASK
  11073                                       | _CMU_CTRL_HFXOMODE_MASK
  11074                                       | _CMU_CTRL_HFXOGLITCHDETEN_MASK))
  11075                        | (hfxoInit->timeout << _CMU_CTRL_HFXOTIMEOUT_SHIFT)
  11076                        | (hfxoInit->boost << _CMU_CTRL_HFXOBOOST_SHIFT)
  11077                        | (hfxoInit->mode << _CMU_CTRL_HFXOMODE_SHIFT)
  11078                        | (hfxoInit->glitchDetector ? CMU_CTRL_HFXOGLITCHDETEN : 0);
  11079          #endif
  11080          }
  11081          
  11082          /***************************************************************************//**
  11083           * @brief
  11084           *   Get the LCD framerate divisor (FDIV) setting.
  11085           *
  11086           * @return
  11087           *   The LCD framerate divisor.
  11088           ******************************************************************************/
  11089          uint32_t CMU_LCDClkFDIVGet(void)
  11090          {
  11091          #if defined(LCD_PRESENT) && defined(_CMU_LCDCTRL_MASK)
  11092            return (CMU->LCDCTRL & _CMU_LCDCTRL_FDIV_MASK) >> _CMU_LCDCTRL_FDIV_SHIFT;
  11093          #else
  11094            return 0;
  11095          #endif /* defined(LCD_PRESENT) */
  11096          }
  11097          
  11098          /***************************************************************************//**
  11099           * @brief
  11100           *   Set the LCD framerate divisor (FDIV) setting.
  11101           *
  11102           * @note
  11103           *   The FDIV field (CMU LCDCTRL register) should only be modified while the
  11104           *   LCD module is clock disabled (CMU LFACLKEN0.LCD bit is 0). This function
  11105           *   will NOT modify FDIV if the LCD module clock is enabled. See
  11106           *   @ref CMU_ClockEnable() for disabling/enabling LCD clock.
  11107           *
  11108           * @param[in] div
  11109           *   The FDIV setting to use.
  11110           ******************************************************************************/
  11111          void CMU_LCDClkFDIVSet(uint32_t div)
  11112          {
  11113          #if defined(LCD_PRESENT) && defined(_CMU_LCDCTRL_MASK)
  11114            EFM_ASSERT(div <= cmuClkDiv_128);
  11115          
  11116            /* Do not allow modification if LCD clock enabled. */
  11117            if (CMU->LFACLKEN0 & CMU_LFACLKEN0_LCD) {
  11118              return;
  11119            }
  11120          
  11121            div        <<= _CMU_LCDCTRL_FDIV_SHIFT;
  11122            div         &= _CMU_LCDCTRL_FDIV_MASK;
  11123            CMU->LCDCTRL = (CMU->LCDCTRL & ~_CMU_LCDCTRL_FDIV_MASK) | div;
  11124          #else
  11125            (void)div; /* Unused parameter. */
  11126          #endif /* defined(LCD_PRESENT) */
  11127          }
  11128          
  11129          /**************************************************************************//**
  11130           * @brief
  11131           *   Set LFXO control registers.
  11132           *
  11133           * @note
  11134           *   LFXO configuration should be obtained from a configuration tool,
  11135           *   app note, or crystal data sheet. This function disables the LFXO when
  11136           *   necessary to ensure a valid state before update.
  11137           *
  11138           * @param[in] lfxoInit
  11139           *    LFXO setup parameters.
  11140           *****************************************************************************/
  11141          void CMU_LFXOInit(const CMU_LFXOInit_TypeDef *lfxoInit)
  11142          {
  11143            /* Do not disable LFXO if it is currently selected as the HF/Core clock. */
  11144            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_HF) != cmuSelect_LFXO);
  11145          
  11146          #if defined(_SILICON_LABS_32B_SERIES_1)
  11147            uint32_t reg = (CMU->LFXOCTRL & ~(_CMU_LFXOCTRL_TUNING_MASK
  11148                                              | _CMU_LFXOCTRL_GAIN_MASK
  11149                                              | _CMU_LFXOCTRL_TIMEOUT_MASK
  11150                                              | _CMU_LFXOCTRL_MODE_MASK))
  11151                           | ((uint32_t)lfxoInit->ctune << _CMU_LFXOCTRL_TUNING_SHIFT)
  11152                           | ((uint32_t)lfxoInit->gain << _CMU_LFXOCTRL_GAIN_SHIFT)
  11153                           | ((uint32_t)lfxoInit->timeout << _CMU_LFXOCTRL_TIMEOUT_SHIFT)
  11154                           | ((uint32_t)lfxoInit->mode << _CMU_LFXOCTRL_MODE_SHIFT);
  11155          
  11156            /* If LFXO already contains the correct configuration then there is no need
  11157             * to stop the oscillator and apply new settings. The LFXO can be running out
  11158             * of reset, in which case there is no need to disable it unless necessary. */
  11159            if (reg != CMU->LFXOCTRL) {
  11160              CMU_OscillatorEnable(cmuOsc_LFXO, false, true);
  11161              CMU->LFXOCTRL = reg;
  11162            }
  11163          #elif defined(_SILICON_LABS_32B_SERIES_0)
  11164            /* LFXO must be disabled before reconfiguration. */
  11165            CMU_OscillatorEnable(cmuOsc_LFXO, false, true);
  11166          
  11167            bool cmuBoost  = (lfxoInit->boost & 0x2);
  11168            BUS_RegMaskedWrite(&CMU->CTRL,
  11169                               _CMU_CTRL_LFXOTIMEOUT_MASK
  11170                               | _CMU_CTRL_LFXOBOOST_MASK
  11171                               | _CMU_CTRL_LFXOMODE_MASK,
  11172                               ((uint32_t)lfxoInit->timeout
  11173                                << _CMU_CTRL_LFXOTIMEOUT_SHIFT)
  11174                               | ((cmuBoost ? 1 : 0) << _CMU_CTRL_LFXOBOOST_SHIFT)
  11175                               | ((uint32_t)lfxoInit->mode << _CMU_CTRL_LFXOMODE_SHIFT));
  11176          #if defined(_EMU_AUXCTRL_REDLFXOBOOST_MASK)
  11177            /* EFM32GG has a "reduce startup boost" field in the EMU */
  11178            bool emuReduce = (lfxoInit->boost & 0x1);
  11179            BUS_RegBitWrite(&EMU->AUXCTRL, _EMU_AUXCTRL_REDLFXOBOOST_SHIFT, emuReduce ? 1 : 0);
  11180          #endif
  11181          #endif
  11182          }
  11183          
  11184          /**************************************************************************//**
  11185           * @brief
  11186           *   Sets LFXO's crystal precision, in PPM.
  11187           *
  11188           * @note
  11189           *   LFXO precision should be obtained from a crystal datasheet.
  11190           *
  11191           * @details
  11192           *   This function does not affect the hardware, it only stores the precision
  11193           *   in a variable that can be retrieved later using CMU_LFXOPrecisionGet().
  11194           *   This is used by certain wireless stacks to optimize wakeup time for scheduled
  11195           *   events (such as Bluetooth advertising).
  11196           *
  11197           * @param[in] precision
  11198           *    LFXO's crystal precision, in PPM.
  11199           *****************************************************************************/
  11200          void CMU_LFXOPrecisionSet(uint16_t precision)
  11201          {
  11202            lfxo_precision = precision;
  11203          }
  11204          
  11205          /**************************************************************************//**
  11206           * @brief
  11207           *   Gets LFXO's crystal precision, in PPM.
  11208           *
  11209           * @param[in] precision
  11210           *    LFXO's crystal precision, in PPM.
  11211           *****************************************************************************/
  11212          uint16_t CMU_LFXOPrecisionGet(void)
  11213          {
  11214            return lfxo_precision;
  11215          }
  11216          
  11217          /**************************************************************************//**
  11218           * @brief
  11219           *   Sets HFXO's crystal precision, in PPM.
  11220           *
  11221           * @note
  11222           *   HFXO precision should be obtained from a crystal datasheet.
  11223           *
  11224           * @details
  11225           *   This function does not affect the hardware, it only stores the precision
  11226           *   in a variable that can be retrieved later using CMU_HFXOPrecisionGet().
  11227           *
  11228           * @param[in] precision
  11229           *    HFXO's crystal precision, in PPM.
  11230           *****************************************************************************/
  11231          void CMU_HFXOPrecisionSet(uint16_t precision)
  11232          {
  11233            hfxo_precision = precision;
  11234          }
  11235          
  11236          /**************************************************************************//**
  11237           * @brief
  11238           *   Gets HFXO's crystal precision, in PPM.
  11239           *
  11240           * @param[in] precision
  11241           *    HFXO's crystal precision, in PPM.
  11242           *****************************************************************************/
  11243          uint16_t CMU_HFXOPrecisionGet(void)
  11244          {
  11245            return hfxo_precision;
  11246          }
  11247          
  11248          /***************************************************************************//**
  11249           * @brief
  11250           *   Enable/disable oscillator.
  11251           *
  11252           * @note
  11253           *   WARNING: When this function is called to disable either cmuOsc_LFXO or
  11254           *   cmuOsc_HFXO, the LFXOMODE or HFXOMODE fields of the CMU_CTRL register
  11255           *   are reset to the reset value. In other words, if external clock sources are selected
  11256           *   in either LFXOMODE or HFXOMODE fields, the configuration will be cleared
  11257           *   and needs to be reconfigured if needed later.
  11258           *
  11259           * @param[in] osc
  11260           *   The oscillator to enable/disable.
  11261           *
  11262           * @param[in] enable
  11263           *   @li true - enable specified oscillator.
  11264           *   @li false - disable specified oscillator.
  11265           *
  11266           * @param[in] wait
  11267           *   Only used if @p enable is true.
  11268           *   @li true - wait for oscillator start-up time to timeout before returning.
  11269           *   @li false - do not wait for oscillator start-up time to timeout before
  11270           *     returning.
  11271           ******************************************************************************/
  11272          void CMU_OscillatorEnable(CMU_Osc_TypeDef osc, bool enable, bool wait)
  11273          {
  11274            uint32_t rdyBitPos;
  11275          #if defined(_SILICON_LABS_32B_SERIES_1)
  11276            uint32_t ensBitPos;
  11277          #endif
  11278          #if defined(_CMU_STATUS_HFXOPEAKDETRDY_MASK)
  11279            uint32_t hfxoTrimStatus;
  11280          #endif
  11281          
  11282            uint32_t enBit;
  11283            uint32_t disBit;
  11284          
  11285            switch (osc) {
  11286              case cmuOsc_HFRCO:
  11287                enBit  = CMU_OSCENCMD_HFRCOEN;
  11288                disBit = CMU_OSCENCMD_HFRCODIS;
  11289                rdyBitPos = _CMU_STATUS_HFRCORDY_SHIFT;
  11290          #if defined(_SILICON_LABS_32B_SERIES_1)
  11291                ensBitPos = _CMU_STATUS_HFRCOENS_SHIFT;
  11292          #endif
  11293                break;
  11294          
  11295              case cmuOsc_HFXO:
  11296                enBit  = CMU_OSCENCMD_HFXOEN;
  11297                disBit = CMU_OSCENCMD_HFXODIS;
  11298                rdyBitPos = _CMU_STATUS_HFXORDY_SHIFT;
  11299          #if defined(_SILICON_LABS_32B_SERIES_1)
  11300                ensBitPos = _CMU_STATUS_HFXOENS_SHIFT;
  11301          #endif
  11302                break;
  11303          
  11304              case cmuOsc_AUXHFRCO:
  11305                enBit  = CMU_OSCENCMD_AUXHFRCOEN;
  11306                disBit = CMU_OSCENCMD_AUXHFRCODIS;
  11307                rdyBitPos = _CMU_STATUS_AUXHFRCORDY_SHIFT;
  11308          #if defined(_SILICON_LABS_32B_SERIES_1)
  11309                ensBitPos = _CMU_STATUS_AUXHFRCOENS_SHIFT;
  11310          #endif
  11311                break;
  11312          
  11313              case cmuOsc_LFRCO:
  11314                enBit  = CMU_OSCENCMD_LFRCOEN;
  11315                disBit = CMU_OSCENCMD_LFRCODIS;
  11316                rdyBitPos = _CMU_STATUS_LFRCORDY_SHIFT;
  11317          #if defined(_SILICON_LABS_32B_SERIES_1)
  11318                ensBitPos = _CMU_STATUS_LFRCOENS_SHIFT;
  11319          #endif
  11320                break;
  11321          
  11322              case cmuOsc_LFXO:
  11323                enBit  = CMU_OSCENCMD_LFXOEN;
  11324                disBit = CMU_OSCENCMD_LFXODIS;
  11325                rdyBitPos = _CMU_STATUS_LFXORDY_SHIFT;
  11326          #if defined(_SILICON_LABS_32B_SERIES_1)
  11327                ensBitPos = _CMU_STATUS_LFXOENS_SHIFT;
  11328          #endif
  11329                break;
  11330          
  11331          #if defined(_CMU_STATUS_USHFRCOENS_MASK)
  11332              case cmuOsc_USHFRCO:
  11333                enBit  = CMU_OSCENCMD_USHFRCOEN;
  11334                disBit = CMU_OSCENCMD_USHFRCODIS;
  11335                rdyBitPos = _CMU_STATUS_USHFRCORDY_SHIFT;
  11336          #if defined(_SILICON_LABS_32B_SERIES_1)
  11337                ensBitPos = _CMU_STATUS_USHFRCOENS_SHIFT;
  11338          #endif
  11339                break;
  11340          #endif
  11341          
  11342          #if defined(PLFRCO_PRESENT)
  11343              case cmuOsc_PLFRCO:
  11344                if (!deviceHasPlfrco()) {
  11345                  while (true) { // PLFRCO is not available
  11346                    EFM_ASSERT(false);
  11347                  }
  11348                }
  11349                enBit = CMU_OSCENCMD_PLFRCOEN;
  11350                disBit = CMU_OSCENCMD_PLFRCODIS;
  11351                rdyBitPos = _CMU_STATUS_PLFRCORDY_SHIFT;
  11352                ensBitPos = _CMU_STATUS_PLFRCOENS_SHIFT;
  11353                break;
  11354          #endif
  11355          
  11356              default:
  11357                /* Undefined clock source, cmuOsc_CLKIN0 or cmuOsc_ULFRCO. ULFRCO is always enabled
  11358                   and cannot be disabled. In other words,the definition of cmuOsc_ULFRCO is primarily
  11359                   intended for information: the ULFRCO is always on.  */
  11360                EFM_ASSERT(false);
  11361                return;
  11362            }
  11363          
  11364            if (enable) {
  11365           #if defined(_CMU_HFXOCTRL_MASK)
  11366              bool firstHfxoEnable = false;
  11367          
  11368              /* Enabling the HFXO for the first time requires special handling.
  11369               * PEAKDETSHUTOPTMODE field of the HFXOCTRL register is used to see if this is the
  11370               * first time the HFXO is enabled. */
  11371              if (osc == cmuOsc_HFXO) {
  11372                if (getHfxoTuningMode() == HFXO_TUNING_MODE_AUTO) {
  11373                  /* REGPWRSEL must be set to DVDD before the HFXO can be enabled. */
  11374          #if defined(_EMU_PWRCTRL_REGPWRSEL_MASK)
  11375                  EFM_ASSERT((EMU->PWRCTRL & EMU_PWRCTRL_REGPWRSEL_DVDD) != 0UL);
  11376          #endif
  11377          
  11378                  firstHfxoEnable = true;
  11379                  /* The first time that an external clock is enabled, switch to CMD mode to make sure that
  11380                   * only SCO and not PDA tuning is performed. */
  11381                  if ((CMU->HFXOCTRL & (_CMU_HFXOCTRL_MODE_MASK)) == CMU_HFXOCTRL_MODE_DIGEXTCLK) {
  11382                    setHfxoTuningMode(HFXO_TUNING_MODE_CMD);
  11383                  }
  11384                }
  11385              }
  11386          #endif
  11387              CMU->OSCENCMD = enBit;
  11388          
  11389          #if defined(_SILICON_LABS_32B_SERIES_1)
  11390              /* Always wait for ENS to go high. */
  11391              while (BUS_RegBitRead(&CMU->STATUS, ensBitPos) == 0UL) {
  11392              }
  11393          #endif
  11394          
  11395              /* Wait for the clock to become ready after enable. */
  11396              if (wait) {
  11397                while (BUS_RegBitRead(&CMU->STATUS, rdyBitPos) == 0UL) {
  11398                }
  11399          #if defined(_SILICON_LABS_32B_SERIES_1)
  11400                if ((osc == cmuOsc_HFXO) && firstHfxoEnable) {
  11401                  if ((CMU->HFXOCTRL & _CMU_HFXOCTRL_MODE_MASK)
  11402                      == CMU_HFXOCTRL_MODE_DIGEXTCLK) {
  11403          #if defined(CMU_CMD_HFXOSHUNTOPTSTART)
  11404                    /* External clock mode should only do shunt current optimization. */
  11405                    (void)CMU_OscillatorTuningOptimize(cmuOsc_HFXO,
  11406                                                       cmuHFXOTuningMode_ShuntCommand,
  11407                                                       true);
  11408          #endif
  11409                  } else {
  11410                    /* Wait for the peak detection and shunt current optimization
  11411                       to complete. */
  11412                    (void)CMU_OscillatorTuningWait(cmuOsc_HFXO, cmuHFXOTuningMode_Auto);
  11413                  }
  11414          
  11415                  /* Disable the HFXO again to apply the trims. Apply trim from
  11416                     HFXOTRIMSTATUS when disabled. */
  11417                  hfxoTrimStatus = CMU_OscillatorTuningGet(cmuOsc_HFXO);
  11418                  CMU_OscillatorEnable(cmuOsc_HFXO, false, true);
  11419                  CMU_OscillatorTuningSet(cmuOsc_HFXO, hfxoTrimStatus);
  11420          
  11421                  /* Restart in CMD mode. */
  11422                  CMU->OSCENCMD = enBit;
  11423                  while (BUS_RegBitRead(&CMU->STATUS, rdyBitPos) == 0UL) {
  11424                  }
  11425                }
  11426          #endif
  11427              }
  11428            } else {
  11429              CMU->OSCENCMD = disBit;
  11430          
  11431          #if defined(_SILICON_LABS_32B_SERIES_1)
  11432              /* Always wait for ENS to go low. */
  11433              while ((CMU->STATUS & (0x1 << ensBitPos)) != 0U) {
  11434              }
  11435          
  11436              if (wait) {
  11437                /* Wait for RDY to go low as well. */
  11438                while ((CMU->STATUS & (0x1 << rdyBitPos)) != 0U) {
  11439                }
  11440              }
  11441          #endif
  11442            }
  11443          }
  11444          
  11445          /***************************************************************************//**
  11446           * @brief
  11447           *   Get the oscillator frequency tuning setting.
  11448           *
  11449           * @param[in] osc
  11450           *   An oscillator to get tuning value for, one of the following:
  11451           *   @li #cmuOsc_LFRCO
  11452           *   @li #cmuOsc_HFRCO @if _CMU_USHFRCOCTRL_TUNING_MASK
  11453           *   @li #cmuOsc_USHFRCO
  11454           *   @endif
  11455           *   @li #cmuOsc_AUXHFRCO
  11456           *   @li #cmuOsc_HFXO if CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE is defined
  11457           *
  11458           * @return
  11459           *   The oscillator frequency tuning setting in use.
  11460           ******************************************************************************/
  11461          uint32_t CMU_OscillatorTuningGet(CMU_Osc_TypeDef osc)
  11462          {
  11463            uint32_t ret;
  11464          
  11465            switch (osc) {
  11466              case cmuOsc_LFRCO:
  11467                ret = (CMU->LFRCOCTRL & _CMU_LFRCOCTRL_TUNING_MASK)
  11468                      >> _CMU_LFRCOCTRL_TUNING_SHIFT;
  11469                break;
  11470          
  11471              case cmuOsc_HFRCO:
  11472                ret = (CMU->HFRCOCTRL & _CMU_HFRCOCTRL_TUNING_MASK)
  11473                      >> _CMU_HFRCOCTRL_TUNING_SHIFT;
  11474                break;
  11475          
  11476          #if defined (_CMU_USHFRCOCTRL_TUNING_MASK)
  11477              case cmuOsc_USHFRCO:
  11478                ret = (CMU->USHFRCOCTRL & _CMU_USHFRCOCTRL_TUNING_MASK)
  11479                      >> _CMU_USHFRCOCTRL_TUNING_SHIFT;
  11480                break;
  11481          #endif
  11482          
  11483              case cmuOsc_AUXHFRCO:
  11484                ret = (CMU->AUXHFRCOCTRL & _CMU_AUXHFRCOCTRL_TUNING_MASK)
  11485                      >> _CMU_AUXHFRCOCTRL_TUNING_SHIFT;
  11486                break;
  11487          
  11488          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
  11489              case cmuOsc_HFXO:
  11490                ret = CMU->HFXOTRIMSTATUS & (_CMU_HFXOTRIMSTATUS_IBTRIMXOCORE_MASK
  11491          #if defined(_CMU_HFXOTRIMSTATUS_REGISH_MASK)
  11492                                             | _CMU_HFXOTRIMSTATUS_REGISH_MASK
  11493          #endif
  11494                                             );
  11495                break;
  11496          #endif
  11497          
  11498          #if defined(_SILICON_LABS_32B_SERIES_1) && !defined(_EFR32_ZEN_FAMILY)
  11499              case cmuOsc_LFXO:
  11500                ret = (CMU->LFXOCTRL & _CMU_LFXOCTRL_TUNING_MASK) >> _CMU_LFXOCTRL_TUNING_SHIFT;
  11501                break;
  11502          #endif
  11503          
  11504              default:
  11505                ret = 0;
  11506                EFM_ASSERT(false);
  11507                break;
  11508            }
  11509          
  11510            return ret;
  11511          }
  11512          
  11513          /***************************************************************************//**
  11514           * @brief
  11515           *   Set the oscillator frequency tuning control.
  11516           *
  11517           * @note
  11518           *   Oscillator tuning is done during production and the tuning value is
  11519           *   automatically loaded after reset. Changing the tuning value from the
  11520           *   calibrated value is for more advanced use. Certain oscillators also have
  11521           *   build-in tuning optimization.
  11522           *
  11523           * @param[in] osc
  11524           *   An oscillator to set tuning value for, one of the following:
  11525           *   @li #cmuOsc_LFRCO
  11526           *   @li #cmuOsc_HFRCO @if _CMU_USHFRCOCTRL_TUNING_MASK
  11527           *   @li #cmuOsc_USHFRCO
  11528           *   @endif
  11529           *   @li #cmuOsc_AUXHFRCO
  11530           *   @li #cmuOsc_HFXO if PEAKDETSHUNTOPTMODE is available. Note that CMD mode is set.
  11531           *
  11532           * @param[in] val
  11533           *   The oscillator frequency tuning setting to use.
  11534           ******************************************************************************/
  11535          void CMU_OscillatorTuningSet(CMU_Osc_TypeDef osc, uint32_t val)
  11536          {
  11537          #if defined(_SILICON_LABS_32B_SERIES_1) && !defined(_EFR32_ZEN_FAMILY)
  11538            uint8_t ctune = 0;
  11539          #endif
  11540          
  11541          #if defined(_CMU_HFXOSTEADYSTATECTRL_REGISH_MASK)
  11542            uint32_t regIshUpper;
  11543          #endif
  11544          
  11545            switch (osc) {
  11546              case cmuOsc_LFRCO:
  11547                EFM_ASSERT(val <= (_CMU_LFRCOCTRL_TUNING_MASK
  11548                                   >> _CMU_LFRCOCTRL_TUNING_SHIFT));
  11549                val &= (_CMU_LFRCOCTRL_TUNING_MASK >> _CMU_LFRCOCTRL_TUNING_SHIFT);
  11550          #if defined(_SILICON_LABS_32B_SERIES_1)
  11551                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  11552                                      _CMU_SYNCBUSY_LFRCOBSY_SHIFT) != 0UL) {
  11553                }
  11554          #endif
  11555                CMU->LFRCOCTRL = (CMU->LFRCOCTRL & ~(_CMU_LFRCOCTRL_TUNING_MASK))
  11556                                 | (val << _CMU_LFRCOCTRL_TUNING_SHIFT);
  11557                break;
  11558          
  11559              case cmuOsc_HFRCO:
  11560                EFM_ASSERT(val <= (_CMU_HFRCOCTRL_TUNING_MASK
  11561                                   >> _CMU_HFRCOCTRL_TUNING_SHIFT));
  11562                val &= (_CMU_HFRCOCTRL_TUNING_MASK >> _CMU_HFRCOCTRL_TUNING_SHIFT);
  11563          #if defined(_SILICON_LABS_32B_SERIES_1)
  11564                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  11565                                      _CMU_SYNCBUSY_HFRCOBSY_SHIFT) != 0UL) {
  11566                }
  11567          #endif
  11568                CMU->HFRCOCTRL = (CMU->HFRCOCTRL & ~(_CMU_HFRCOCTRL_TUNING_MASK))
  11569                                 | (val << _CMU_HFRCOCTRL_TUNING_SHIFT);
  11570                break;
  11571          
  11572          #if defined (_CMU_USHFRCOCTRL_TUNING_MASK)
  11573              case cmuOsc_USHFRCO:
  11574                EFM_ASSERT(val <= (_CMU_USHFRCOCTRL_TUNING_MASK
  11575                                   >> _CMU_USHFRCOCTRL_TUNING_SHIFT));
  11576                val &= (_CMU_USHFRCOCTRL_TUNING_MASK >> _CMU_USHFRCOCTRL_TUNING_SHIFT);
  11577          #if defined(_SILICON_LABS_32B_SERIES_1)
  11578                while (BUS_RegBitRead(&CMU->SYNCBUSY, _CMU_SYNCBUSY_USHFRCOBSY_SHIFT)) {
  11579                }
  11580          #endif
  11581                CMU->USHFRCOCTRL = (CMU->USHFRCOCTRL & ~(_CMU_USHFRCOCTRL_TUNING_MASK))
  11582                                   | (val << _CMU_USHFRCOCTRL_TUNING_SHIFT);
  11583                break;
  11584          #endif
  11585          
  11586              case cmuOsc_AUXHFRCO:
  11587                EFM_ASSERT(val <= (_CMU_AUXHFRCOCTRL_TUNING_MASK
  11588                                   >> _CMU_AUXHFRCOCTRL_TUNING_SHIFT));
  11589                val &= (_CMU_AUXHFRCOCTRL_TUNING_MASK >> _CMU_AUXHFRCOCTRL_TUNING_SHIFT);
  11590          #if defined(_SILICON_LABS_32B_SERIES_1)
  11591                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  11592                                      _CMU_SYNCBUSY_AUXHFRCOBSY_SHIFT) != 0UL) {
  11593                }
  11594          #endif
  11595                CMU->AUXHFRCOCTRL = (CMU->AUXHFRCOCTRL & ~(_CMU_AUXHFRCOCTRL_TUNING_MASK))
  11596                                    | (val << _CMU_AUXHFRCOCTRL_TUNING_SHIFT);
  11597                break;
  11598          
  11599          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
  11600              case cmuOsc_HFXO:
  11601          
  11602                /* Do set PEAKDETSHUNTOPTMODE or HFXOSTEADYSTATECTRL if HFXO is enabled. */
  11603                EFM_ASSERT((CMU->STATUS & CMU_STATUS_HFXOENS) == 0UL);
  11604          
  11605                /* Switch to command mode. Automatic SCO and PDA calibration is not done
  11606                   at the next enable. Set user REGISH, REGISHUPPER, and IBTRIMXOCORE. */
  11607                CMU->HFXOCTRL = (CMU->HFXOCTRL & ~_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK)
  11608                                | CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_CMD;
  11609          
  11610          #if defined(_CMU_HFXOSTEADYSTATECTRL_REGISH_MASK)
  11611                regIshUpper = getRegIshUpperVal((val & _CMU_HFXOSTEADYSTATECTRL_REGISH_MASK)
  11612                                                >> _CMU_HFXOSTEADYSTATECTRL_REGISH_SHIFT);
  11613                CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  11614                                            & ~(_CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK
  11615                                                | _CMU_HFXOSTEADYSTATECTRL_REGISH_MASK
  11616                                                | _CMU_HFXOSTEADYSTATECTRL_REGISHUPPER_MASK))
  11617                                           | val
  11618                                           | regIshUpper;
  11619          #else
  11620                CMU->HFXOSTEADYSTATECTRL = (CMU->HFXOSTEADYSTATECTRL
  11621                                            & ~_CMU_HFXOSTEADYSTATECTRL_IBTRIMXOCORE_MASK)
  11622                                           | val;
  11623          #endif
  11624          
  11625                break;
  11626          #endif
  11627          
  11628          #if defined(_SILICON_LABS_32B_SERIES_1) && !defined(_EFR32_ZEN_FAMILY)
  11629              case cmuOsc_LFXO:
  11630                EFM_ASSERT(val <= (_CMU_LFXOCTRL_TUNING_MASK >> _CMU_LFXOCTRL_TUNING_SHIFT));
  11631                // Max internal capacitance tuning value is 0x4F (20 pF)
  11632                ctune = (uint8_t) SL_MIN(0x4FU, val);
  11633          
  11634                // Wait for the CMU_LFXOCTRL is ready for update
  11635                while (BUS_RegBitRead(&CMU->SYNCBUSY,
  11636                                      _CMU_SYNCBUSY_LFXOBSY_SHIFT) != 0UL) {
  11637                }
  11638                CMU->LFXOCTRL = (CMU->LFXOCTRL & ~(_CMU_LFXOCTRL_TUNING_MASK))
  11639                                | ((uint32_t)ctune << _CMU_LFXOCTRL_TUNING_SHIFT);
  11640                break;
  11641          #endif
  11642          
  11643              default:
  11644                EFM_ASSERT(false);
  11645                break;
  11646            }
  11647          }
  11648          
  11649          #if defined(_CMU_HFXOCTRL_PEAKDETSHUNTOPTMODE_MASK) || defined(_CMU_HFXOCTRL_PEAKDETMODE_MASK)
  11650          /***************************************************************************//**
  11651           * @brief
  11652           *   Wait for the oscillator tuning optimization.
  11653           *
  11654           * @param[in] osc
  11655           *   An oscillator to set tuning value for, one of the following:
  11656           *   @li #cmuOsc_HFXO
  11657           *
  11658           * @param[in] mode
  11659           *   Tuning optimization mode.
  11660           *
  11661           * @return
  11662           *   Returns false on invalid parameters or oscillator error status.
  11663           ******************************************************************************/
  11664          bool CMU_OscillatorTuningWait(CMU_Osc_TypeDef osc,
  11665                                        CMU_HFXOTuningMode_TypeDef mode)
  11666          {
  11667            uint32_t waitFlags;
  11668            EFM_ASSERT(osc == cmuOsc_HFXO);
  11669          
  11670            /* Currently implemented for HFXO with PEAKDETSHUNTOPTMODE only. */
  11671            (void)osc;
  11672          
  11673            if (getHfxoTuningMode() == HFXO_TUNING_MODE_AUTO) {
  11674              waitFlags = HFXO_TUNING_READY_FLAGS;
  11675            } else {
  11676              /* Set wait flags for each command and wait. */
  11677              switch (mode) {
  11678          #if defined(_CMU_STATUS_HFXOSHUNTOPTRDY_MASK)
  11679                case cmuHFXOTuningMode_ShuntCommand:
  11680                  waitFlags = CMU_STATUS_HFXOSHUNTOPTRDY;
  11681                  break;
  11682          #endif
  11683                case cmuHFXOTuningMode_Auto:
  11684                  waitFlags = HFXO_TUNING_READY_FLAGS;
  11685                  break;
  11686          
  11687          #if defined(CMU_CMD_HFXOSHUNTOPTSTART)
  11688                case cmuHFXOTuningMode_PeakShuntCommand:
  11689                  waitFlags = HFXO_TUNING_READY_FLAGS;
  11690                  break;
  11691          #endif
  11692          
  11693                default:
  11694                  waitFlags = _CMU_STATUS_MASK;
  11695                  EFM_ASSERT(false);
  11696                  break;
  11697              }
  11698            }
  11699            while ((CMU->STATUS & waitFlags) != waitFlags) {
  11700            }
  11701          
  11702          #if defined(CMU_IF_HFXOPEAKDETERR)
  11703            /* Check error flags. */
  11704            if ((waitFlags & CMU_STATUS_HFXOPEAKDETRDY) != 0UL) {
  11705              return (CMU->IF & CMU_IF_HFXOPEAKDETERR) != 0UL ? true : false;
  11706            }
  11707          #endif
  11708            return true;
  11709          }
  11710          
  11711          /***************************************************************************//**
  11712           * @brief
  11713           *   Start and optionally wait for the oscillator tuning optimization.
  11714           *
  11715           * @param[in] osc
  11716           *   An oscillator to set tuning value for, one of the following:
  11717           *   @li #cmuOsc_HFXO
  11718           *
  11719           * @param[in] mode
  11720           *   Tuning optimization mode.
  11721           *
  11722           * @param[in] wait
  11723           *   Wait for tuning optimization to complete.
  11724           *   true - wait for tuning optimization to complete.
  11725           *   false - return without waiting.
  11726           *
  11727           * @return
  11728           *   Returns false on invalid parameters or oscillator error status.
  11729           ******************************************************************************/
  11730          bool CMU_OscillatorTuningOptimize(CMU_Osc_TypeDef osc,
  11731                                            CMU_HFXOTuningMode_TypeDef mode,
  11732                                            bool wait)
  11733          {
  11734            switch (osc) {
  11735              case cmuOsc_HFXO:
  11736                if ((unsigned)mode != 0U) {
  11737          #if defined(CMU_IF_HFXOPEAKDETERR)
  11738                  /* Clear the error flag before command write. */
  11739                  CMU->IFC = CMU_IFC_HFXOPEAKDETERR;
  11740          #endif
  11741                  CMU->CMD = (uint32_t)mode;
  11742                }
  11743                if (wait) {
  11744                  return CMU_OscillatorTuningWait(osc, mode);
  11745                }
  11746                break;
  11747          
  11748              default:
  11749                EFM_ASSERT(false);
  11750                break;
  11751            }
  11752            return true;
  11753          }
  11754          #endif
  11755          
  11756          /**************************************************************************//**
  11757           * @brief
  11758           *   Determine if the currently selected PCNTn clock used is external or LFBCLK.
  11759           *
  11760           * @param[in] instance
  11761           *   PCNT instance number to get currently selected clock source for.
  11762           *
  11763           * @return
  11764           *   @li true - selected clock is external clock.
  11765           *   @li false - selected clock is LFBCLK.
  11766           *****************************************************************************/
  11767          bool CMU_PCNTClockExternalGet(unsigned int instance)
  11768          {
  11769            uint32_t setting;
  11770          
  11771            switch (instance) {
  11772          #if defined(_CMU_PCNTCTRL_PCNT0CLKEN_MASK)
  11773              case 0:
  11774                setting = CMU->PCNTCTRL & CMU_PCNTCTRL_PCNT0CLKSEL_PCNT0S0;
  11775                break;
  11776          
  11777          #if defined(_CMU_PCNTCTRL_PCNT1CLKEN_MASK)
  11778              case 1:
  11779                setting = CMU->PCNTCTRL & CMU_PCNTCTRL_PCNT1CLKSEL_PCNT1S0;
  11780                break;
  11781          
  11782          #if defined(_CMU_PCNTCTRL_PCNT2CLKEN_MASK)
  11783              case 2:
  11784                setting = CMU->PCNTCTRL & CMU_PCNTCTRL_PCNT2CLKSEL_PCNT2S0;
  11785                break;
  11786          #endif
  11787          #endif
  11788          #endif
  11789          
  11790              default:
  11791                setting = 0;
  11792                break;
  11793            }
  11794            return setting > 0UL ? true : false;
  11795          }
  11796          
  11797          /**************************************************************************//**
  11798           * @brief
  11799           *   Select the PCNTn clock.
  11800           *
  11801           * @param[in] instance
  11802           *   PCNT instance number to set selected clock source for.
  11803           *
  11804           * @param[in] external
  11805           *   Set to true to select the external clock, false to select LFBCLK.
  11806           *****************************************************************************/
  11807          void CMU_PCNTClockExternalSet(unsigned int instance, bool external)
  11808          {
  11809          #if defined(PCNT_PRESENT)
  11810            uint32_t setting = 0;
  11811          
  11812            EFM_ASSERT(instance < (unsigned)PCNT_COUNT);
  11813          
  11814            if (external) {
  11815              setting = 1;
  11816            }
  11817          
  11818            BUS_RegBitWrite(&(CMU->PCNTCTRL), (instance * 2U) + 1U, setting);
  11819          
  11820          #else
  11821            (void)instance; /* An unused parameter */
  11822            (void)external; /* An unused parameter */
  11823          #endif
  11824          }
  11825          
  11826          #if defined(_CMU_USHFRCOCONF_BAND_MASK)
  11827          /***************************************************************************//**
  11828           * @brief
  11829           *   Get USHFRCO band in use.
  11830           *
  11831           * @return
  11832           *   USHFRCO band in use.
  11833           ******************************************************************************/
  11834          CMU_USHFRCOBand_TypeDef CMU_USHFRCOBandGet(void)
  11835          {
  11836            return (CMU_USHFRCOBand_TypeDef)((CMU->USHFRCOCONF
  11837                                              & _CMU_USHFRCOCONF_BAND_MASK)
  11838                                             >> _CMU_USHFRCOCONF_BAND_SHIFT);
  11839          }
  11840          
  11841          /***************************************************************************//**
  11842           * @brief
  11843           *   Get USHFRCO frequency.
  11844           *
  11845           * @return
  11846           *   USHFRCO frequency.
  11847           ******************************************************************************/
  11848          uint32_t CMU_USHFRCOFreqGet(void)
  11849          {
  11850            return ushfrcoFreq;
  11851          }
  11852          #endif
  11853          
  11854          #if defined(_CMU_USHFRCOCONF_BAND_MASK)
  11855          /***************************************************************************//**
  11856           * @brief
  11857           *   Set the USHFRCO band to use.
  11858           *
  11859           * @param[in] band
  11860           *   USHFRCO band to activate.
  11861           ******************************************************************************/
  11862          void CMU_USHFRCOBandSet(CMU_USHFRCOBand_TypeDef band)
  11863          {
  11864            uint32_t           tuning;
  11865            uint32_t           fineTuning;
  11866          
  11867            /* Cannot switch band if USHFRCO is already selected as HF clock. */
  11868            EFM_ASSERT(CMU_ClockSelectGet(cmuClock_HF) != cmuSelect_USHFRCODIV2);
  11869          
  11870            /* Read tuning value from calibration table. */
  11871            switch (band) {
  11872              case cmuUSHFRCOBand_24MHz:
  11873                tuning = (DEVINFO->USHFRCOCAL0 & _DEVINFO_USHFRCOCAL0_BAND24_TUNING_MASK)
  11874                         >> _DEVINFO_USHFRCOCAL0_BAND24_TUNING_SHIFT;
  11875                fineTuning = (DEVINFO->USHFRCOCAL0
  11876                              & _DEVINFO_USHFRCOCAL0_BAND24_FINETUNING_MASK)
  11877                             >> _DEVINFO_USHFRCOCAL0_BAND24_FINETUNING_SHIFT;
  11878                ushfrcoFreq = 24000000UL;
  11879                break;
  11880          
  11881              case cmuUSHFRCOBand_48MHz:
  11882                tuning = (DEVINFO->USHFRCOCAL0 & _DEVINFO_USHFRCOCAL0_BAND48_TUNING_MASK)
  11883                         >> _DEVINFO_USHFRCOCAL0_BAND48_TUNING_SHIFT;
  11884                fineTuning = (DEVINFO->USHFRCOCAL0
  11885                              & _DEVINFO_USHFRCOCAL0_BAND48_FINETUNING_MASK)
  11886                             >> _DEVINFO_USHFRCOCAL0_BAND48_FINETUNING_SHIFT;
  11887                /* Enable the clock divider before switching the band from 24 to 48 MHz */
  11888                BUS_RegBitWrite(&CMU->USHFRCOCONF, _CMU_USHFRCOCONF_USHFRCODIV2DIS_SHIFT, 0);
  11889                ushfrcoFreq = 48000000UL;
  11890                break;
  11891          
  11892              default:
  11893                EFM_ASSERT(false);
  11894                return;
  11895            }
  11896          
  11897            /* Set band and tuning. */
  11898            CMU->USHFRCOCONF = (CMU->USHFRCOCONF & ~_CMU_USHFRCOCONF_BAND_MASK)
  11899                               | (band << _CMU_USHFRCOCONF_BAND_SHIFT);
  11900            CMU->USHFRCOCTRL = (CMU->USHFRCOCTRL & ~_CMU_USHFRCOCTRL_TUNING_MASK)
  11901                               | (tuning << _CMU_USHFRCOCTRL_TUNING_SHIFT);
  11902            CMU->USHFRCOTUNE = (CMU->USHFRCOTUNE & ~_CMU_USHFRCOTUNE_FINETUNING_MASK)
  11903                               | (fineTuning << _CMU_USHFRCOTUNE_FINETUNING_SHIFT);
  11904          
  11905            /* Disable the clock divider after switching the band from 48 to 24 MHz. */
  11906            if (band == cmuUSHFRCOBand_24MHz) {
  11907              BUS_RegBitWrite(&CMU->USHFRCOCONF, _CMU_USHFRCOCONF_USHFRCODIV2DIS_SHIFT, 1);
  11908            }
  11909          }
  11910          #endif
  11911          
  11912          #endif // defined(_SILICON_LABS_32B_SERIES_2)
  11913          /** @} (end addtogroup cmu) */
