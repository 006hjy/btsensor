   5710          /*******************************************************************************
   5711           **************************   LOCAL FUNCTIONS   ********************************
   5712           ******************************************************************************/
   5713          
   5714          #if defined(_SILICON_LABS_32B_SERIES_0) \
   5715            && (defined(_EFM32_GIANT_FAMILY)      \
   5716            || defined(_EZR32_LEOPARD_FAMILY))
   5717          /***************************************************************************//**
   5718           * @brief
   5719           *   Return maximum allowed frequency for low energy peripherals.
   5720           ******************************************************************************/
   5721          static uint32_t maxFreqHfle(void)
   5722          {
   5723            uint16_t majorMinorRev;
   5724          
   5725            switch (SYSTEM_GetFamily()) {
   5726              case systemPartFamilyEfm32Leopard:
   5727              case systemPartFamilyEzr32Leopard:
   5728                /* CHIP MAJOR bit [5:0] */
   5729                majorMinorRev = (((ROMTABLE->PID0 & _ROMTABLE_PID0_REVMAJOR_MASK)
   5730                                  >> _ROMTABLE_PID0_REVMAJOR_SHIFT) << 8);
   5731                /* CHIP MINOR bit [7:4] */
   5732                majorMinorRev |= (((ROMTABLE->PID2 & _ROMTABLE_PID2_REVMINORMSB_MASK)
   5733                                   >> _ROMTABLE_PID2_REVMINORMSB_SHIFT) << 4);
   5734                /* CHIP MINOR bit [3:0] */
   5735                majorMinorRev |=  ((ROMTABLE->PID3 & _ROMTABLE_PID3_REVMINORLSB_MASK)
   5736                                   >> _ROMTABLE_PID3_REVMINORLSB_SHIFT);
   5737          
   5738                if (majorMinorRev >= 0x0204) {
   5739                  return 24000000;
   5740                } else {
   5741                  return 32000000;
   5742                }
   5743          
   5744              case systemPartFamilyEfm32Giant:
   5745                return 32000000;
   5746          
   5747              default:
   5748                /* Invalid device family. */
   5749                EFM_ASSERT(false);
   5750                return 0;
   5751            }
   5752          }
   5753          #endif
   5754          
   5755          #if defined(CMU_MAX_FREQ_HFLE)
   5756          
   5757          /** @cond DO_NOT_INCLUDE_WITH_DOXYGEN */
   5758          /* Unified definitions for the HFLE wait-state and prescaler fields. */
   5759          #if defined(CMU_CTRL_HFLE)
   5760          #define _GENERIC_HFLE_WS_MASK           _CMU_CTRL_HFLE_MASK
   5761          #define _GENERIC_HFLE_WS_SHIFT          _CMU_CTRL_HFLE_SHIFT
   5762          #define GENERIC_HFLE_PRESC_REG          CMU->HFCORECLKDIV
   5763          #define _GENERIC_HFLE_PRESC_MASK        _CMU_HFCORECLKDIV_HFCORECLKLEDIV_MASK
   5764          #define _GENERIC_HFLE_PRESC_SHIFT       _CMU_HFCORECLKDIV_HFCORECLKLEDIV_SHIFT
   5765          #elif defined(CMU_CTRL_WSHFLE)
   5766          #define _GENERIC_HFLE_WS_MASK           _CMU_CTRL_WSHFLE_MASK
   5767          #define _GENERIC_HFLE_WS_SHIFT          _CMU_CTRL_WSHFLE_SHIFT
   5768          #define GENERIC_HFLE_PRESC_REG          CMU->HFPRESC
   5769          #define _GENERIC_HFLE_PRESC_MASK        _CMU_HFPRESC_HFCLKLEPRESC_MASK
   5770          #define _GENERIC_HFLE_PRESC_SHIFT       _CMU_HFPRESC_HFCLKLEPRESC_SHIFT
   5771          #endif
   5772          /** @endcond */
   5773          
   5774          /***************************************************************************//**
   5775           * @brief
   5776           *   Set HFLE wait-states and HFCLKLE prescaler according to wanted HF clock.
   5777           *
   5778           * @param[in] hfFreq
   5779           *   The HF clock frequency to use.
   5780           *   This is:
   5781           *     CORE clock on Series0 devices.
   5782           *     HF clock on on Series1 devices.
   5783           ******************************************************************************/
   5784          static void setHfLeConfig(uint32_t hfFreq)
   5785          {
   5786            unsigned int hfleWs;
   5787            uint32_t hflePresc;
   5788          
   5789            /* Check for 1 bit fields. @ref BUS_RegBitWrite() below are going to fail if the
   5790               fields are changed to more than 1 bit. */
   5791            EFM_ASSERT((_GENERIC_HFLE_WS_MASK >> _GENERIC_HFLE_WS_SHIFT) == 0x1U);
   5792          
   5793            /* - Enable HFLE wait-state to allow access to LE peripherals when HFBUSCLK is
   5794                 above maxLeFreq.
   5795               - Set HFLE prescaler. Allowed HFLE clock frequency is maxLeFreq. */
   5796          
   5797            hfleWs = 1;
   5798            if (hfFreq <= CMU_MAX_FREQ_HFLE) {
   5799              hfleWs = 0;
   5800              hflePresc = 0;
   5801            } else if (hfFreq <= (2UL * CMU_MAX_FREQ_HFLE)) {
   5802              hflePresc = 1;
   5803            } else {
   5804              hflePresc = 2;
   5805            }
   5806            BUS_RegBitWrite(&CMU->CTRL, _GENERIC_HFLE_WS_SHIFT, hfleWs);
   5807            GENERIC_HFLE_PRESC_REG = (GENERIC_HFLE_PRESC_REG & ~_GENERIC_HFLE_PRESC_MASK)
   5808                                     | (hflePresc << _GENERIC_HFLE_PRESC_SHIFT);
   5809          }
   5810          
   5811          #if defined(_CMU_CTRL_HFLE_MASK)
   5812          /***************************************************************************//**
   5813           * @brief
   5814           *   Get HFLE wait-state configuration.
   5815           *
   5816           * @return
   5817           *   The current wait-state configuration.
   5818           ******************************************************************************/
   5819          static uint32_t getHfLeConfig(void)
   5820          {
   5821            uint32_t ws = BUS_RegBitRead(&CMU->CTRL, _GENERIC_HFLE_WS_SHIFT);
   5822            return ws;
   5823          }
   5824          #endif
   5825          #endif
   5826          
   5827          /***************************************************************************//**
   5828           * @brief
   5829           *   Get the AUX clock frequency. Used by MSC flash programming and LESENSE,
   5830           *   by default also as a debug clock.
   5831           *
   5832           * @return
   5833           *   AUX Frequency in Hz.
   5834           ******************************************************************************/
   5835          static uint32_t auxClkGet(void)
   5836          {
   5837            uint32_t ret;
   5838          
   5839          #if defined(_CMU_AUXHFRCOCTRL_FREQRANGE_MASK)
   5840            ret = (uint32_t)auxHfrcoFreq;
   5841          
   5842          #elif defined(_CMU_AUXHFRCOCTRL_BAND_MASK)
   5843            /* All series 0 families except EFM32G */
   5844            switch (CMU->AUXHFRCOCTRL & _CMU_AUXHFRCOCTRL_BAND_MASK) {
   5845              case CMU_AUXHFRCOCTRL_BAND_1MHZ:
   5846                if ( SYSTEM_GetProdRev() >= 19 ) {
   5847                  ret = 1200000;
   5848                } else {
   5849                  ret = 1000000;
   5850                }
   5851                break;
   5852          
   5853              case CMU_AUXHFRCOCTRL_BAND_7MHZ:
   5854                if ( SYSTEM_GetProdRev() >= 19 ) {
   5855                  ret = 6600000;
   5856                } else {
   5857                  ret = 7000000;
   5858                }
   5859                break;
   5860          
   5861              case CMU_AUXHFRCOCTRL_BAND_11MHZ:
   5862                ret = 11000000;
   5863                break;
   5864          
   5865              case CMU_AUXHFRCOCTRL_BAND_14MHZ:
   5866                ret = 14000000;
   5867                break;
   5868          
   5869              case CMU_AUXHFRCOCTRL_BAND_21MHZ:
   5870                ret = 21000000;
   5871                break;
   5872          
   5873          #if defined(_CMU_AUXHFRCOCTRL_BAND_28MHZ)
   5874              case CMU_AUXHFRCOCTRL_BAND_28MHZ:
   5875                ret = 28000000;
   5876                break;
   5877          #endif
   5878          
   5879              default:
   5880                ret = 0;
   5881                EFM_ASSERT(false);
   5882                break;
   5883            }
   5884          
   5885          #else
   5886            /* Gecko has a fixed 14 MHz AUXHFRCO clock. */
   5887            ret = 14000000;
   5888          
   5889          #endif
   5890          
   5891            return ret;
   5892          }
   5893          
   5894          #if defined (_CMU_ADCCTRL_ADC0CLKSEL_HFSRCCLK) \
   5895            || defined (_CMU_ADCCTRL_ADC1CLKSEL_HFSRCCLK)
   5896          /***************************************************************************//**
   5897           * @brief
   5898           *   Get the HFSRCCLK frequency.
   5899           *
   5900           * @return
   5901           *   HFSRCCLK Frequency in Hz.
   5902           ******************************************************************************/
   5903          static uint32_t hfSrcClkGet(void)
   5904          {
   5905            uint32_t ret;
   5906          
   5907            ret = SystemHFClockGet();
   5908            return ret * (1U + ((CMU->HFPRESC & _CMU_HFPRESC_PRESC_MASK)
   5909                                >> _CMU_HFPRESC_PRESC_SHIFT));
   5910          }
   5911          #endif
   5912          
   5913          /***************************************************************************//**
   5914           * @brief
   5915           *   Get the Debug Trace clock frequency.
   5916           *
   5917           * @return
   5918           *   Debug Trace frequency in Hz.
   5919           ******************************************************************************/
   5920          static uint32_t dbgClkGet(void)
   5921          {
   5922            uint32_t ret;
   5923            CMU_Select_TypeDef clk;
   5924          
   5925            /* Get selected clock source */
   5926            clk = CMU_ClockSelectGet(cmuClock_DBG);
   5927          
   5928            switch (clk) {
   5929              case cmuSelect_HFCLK:
   5930                ret = SystemHFClockGet();
   5931                break;
   5932          
   5933              case cmuSelect_AUXHFRCO:
   5934                ret = auxClkGet();
   5935                break;
   5936          
   5937              default:
   5938                ret = 0;
   5939                EFM_ASSERT(false);
   5940                break;
   5941            }
   5942            return ret;
   5943          }
   5944          
   5945          #if defined(_CMU_ADCCTRL_ADC0CLKSEL_MASK)
   5946          /***************************************************************************//**
   5947           * @brief
   5948           *   Get the ADC n asynchronous clock frequency.
   5949           *
   5950           * @return
   5951           *   ADC n asynchronous frequency in Hz.
   5952           ******************************************************************************/
   5953          static uint32_t adcAsyncClkGet(uint32_t adc)
   5954          {
   5955            uint32_t ret;
   5956            CMU_Select_TypeDef clk;
   5957          
   5958            /* Get the selected clock source. */
   5959            switch (adc) {
   5960              case 0:
   5961                clk = CMU_ClockSelectGet(cmuClock_ADC0ASYNC);
   5962                break;
   5963          
   5964          #if defined(_CMU_ADCCTRL_ADC1CLKSEL_MASK)
   5965              case 1:
   5966                clk = CMU_ClockSelectGet(cmuClock_ADC1ASYNC);
   5967                break;
   5968          #endif
   5969          
   5970              default:
   5971                EFM_ASSERT(false);
   5972                return 0;
   5973            }
   5974          
   5975            switch (clk) {
   5976              case cmuSelect_Disabled:
   5977                ret = 0;
   5978                break;
   5979          
   5980              case cmuSelect_AUXHFRCO:
   5981                ret = auxClkGet();
   5982                break;
   5983          
   5984              case cmuSelect_HFXO:
   5985                ret = SystemHFXOClockGet();
   5986                break;
   5987          
   5988              case cmuSelect_HFSRCCLK:
   5989                ret = hfSrcClkGet();
   5990                break;
   5991          
   5992              default:
   5993                ret = 0;
   5994                EFM_ASSERT(false);
   5995                break;
   5996            }
   5997            return ret;
   5998          }
   5999          #endif
   6000          
