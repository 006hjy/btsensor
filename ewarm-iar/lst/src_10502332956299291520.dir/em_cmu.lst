  10846          
  10847          /***************************************************************************//**
  10848           * @brief
  10849           *   Set the USHFRCO calibration for the selected target frequency.
  10850           *
  10851           * @param[in] setFreq
  10852           *   USHFRCO frequency to set.
  10853           ******************************************************************************/
  10854          void CMU_USHFRCOBandSet(CMU_USHFRCOFreq_TypeDef setFreq)
  10855          {
  10856            uint32_t freqCal;
  10857          
  10858            /* Get DEVINFO calibration values. */
  10859            freqCal = CMU_USHFRCODevinfoGet(setFreq);
  10860            EFM_ASSERT((freqCal != 0) && (freqCal != UINT_MAX));
  10861            ushfrcoFreq = (uint32_t)setFreq;
  10862          
  10863            /* Wait for any previous sync to complete and set calibration data
  10864               for the selected frequency.  */
  10865            while (BUS_RegBitRead(&CMU->SYNCBUSY, _CMU_SYNCBUSY_USHFRCOBSY_SHIFT)) ;
  10866          
  10867            CMU->USHFRCOCTRL = freqCal;
  10868          }
