  10191          /***************************************************************************//**
  10192           * @brief
  10193           *   Gets the precision (in PPM) of the specified low frequency clock branch.
  10194           *
  10195           * @param[in] clock
  10196           *   Clock branch.
  10197           *
  10198           * @return
  10199           *   Precision, in PPM, of the specified clock branch.
  10200           *
  10201           * @note
  10202           *   This function is only for internal usage.
  10203           *
  10204           * @note
  10205           *   The current implementation of this function is used to determine if the
  10206           *   clock has a precision <= 500 ppm or not (which is the minimum required
  10207           *   for BLE). Future version of this function should provide more accurate
  10208           *   precision numbers to allow for further optimizations from the stacks.
  10209           ******************************************************************************/
  10210          uint16_t CMU_LF_ClockPrecisionGet(CMU_Clock_TypeDef clock)
  10211          {
  10212            CMU_Select_TypeDef src = CMU_ClockSelectGet(clock);
  10213            uint16_t precision;
  10214          
  10215            switch (src) {
  10216              case cmuSelect_LFXO:
  10217                precision = lfxo_precision;
  10218                break;
  10219          
  10220          #if defined(_SILICON_LABS_32B_SERIES_1) && defined(PLFRCO_PRESENT)
  10221              case cmuSelect_PLFRCO:
  10222                precision = 500;
  10223                break;
  10224          #endif
  10225          
  10226              default:
  10227                precision = 0xFFFF;
  10228                break;
  10229            }
  10230          
  10231            return precision;
  10232          }
  10233          
  10234          /***************************************************************************//**
  10235           * @brief
  10236           *   Gets the precision (in PPM) of the specified high frequency clock branch.
  10237           *
  10238           * @param[in] clock
  10239           *   Clock branch.
  10240           *
  10241           * @return
  10242           *   Precision, in PPM, of the specified clock branch.
  10243           *
  10244           * @note
  10245           *   This function is only for internal usage.
  10246           *
  10247           * @note
  10248           *   The current implementation of this function is used to determine if the
  10249           *   clock has a precision <= 500 ppm or not (which is the minimum required
  10250           *   for BLE). Future version of this function should provide more accurate
  10251           *   precision numbers to allow for further optimizations from the stacks.
  10252           ******************************************************************************/
  10253          uint16_t CMU_HF_ClockPrecisionGet(CMU_Clock_TypeDef clock)
  10254          {
  10255            CMU_Select_TypeDef src = CMU_ClockSelectGet(clock);
  10256            uint16_t precision;
  10257          
  10258            switch (src) {
  10259              case cmuSelect_HFXO:
  10260                precision = hfxo_precision;
  10261                break;
  10262          
  10263              case cmuSelect_HFRCO:
  10264                precision = 0xFFFF;
  10265                break;
  10266          
  10267              default:
  10268                precision = 0xFFFF;
  10269                break;
  10270            }
  10271          
  10272            return precision;
  10273          }
  10274          
  10275          #if defined(CMU_OSCENCMD_DPLLEN)
  10276          /**************************************************************************//**
  10277           * @brief
  10278           *   Lock the DPLL to a given frequency.
  10279           *
  10280           *   The frequency is given by: Fout = Fref * (N+1) / (M+1).
  10281           *
  10282           * @note
  10283           *   This function does not check if the given N & M values will actually
  10284           *   produce the desired target frequency. @n
  10285           *   N & M limitations: @n
  10286           *     300 < N <= 4095 @n
  10287           *     0 <= M <= 4095 @n
  10288           *   Any peripheral running off HFRCO should be switched to HFRCODIV2 prior to
  10289           *   calling this function to avoid over-clocking.
  10290           *
  10291           *   HFCLKLE prescaler is automatically modified before updating HFRCO
  10292           *   based on the maximum HFLE frequency allowed.
  10293           *
  10294           * @param[in] init
  10295           *    DPLL setup parameters.
  10296           *
  10297           * @return
  10298           *   Returns false on invalid target frequency or DPLL locking error.
  10299           *****************************************************************************/
  10300          bool CMU_DPLLLock(const CMU_DPLLInit_TypeDef *init)
  10301          {
  10302            int index = 0;
  10303            unsigned int i;
  10304            bool hfrcoDiv2override = false;
  10305            uint32_t hfrcoCtrlVal, lockStatus, sysFreq;
  10306          
  10307            EFM_ASSERT(init->frequency >= hfrcoCtrlTable[0].minFreq);
  10308            EFM_ASSERT(init->frequency
  10309                       <= hfrcoCtrlTable[HFRCOCTRLTABLE_ENTRIES - 1U].maxFreq);
  10310            EFM_ASSERT(init->n > 300U);
  10311            EFM_ASSERT(init->n <= (_CMU_DPLLCTRL1_N_MASK >> _CMU_DPLLCTRL1_N_SHIFT));
  10312            EFM_ASSERT(init->m <= (_CMU_DPLLCTRL1_M_MASK >> _CMU_DPLLCTRL1_M_SHIFT));
  10313            EFM_ASSERT(init->ssInterval  <= (_CMU_HFRCOSS_SSINV_MASK
  10314                                             >> _CMU_HFRCOSS_SSINV_SHIFT));
  10315            EFM_ASSERT(init->ssAmplitude <= (_CMU_HFRCOSS_SSAMP_MASK
  10316                                             >> _CMU_HFRCOSS_SSAMP_SHIFT));
  10317          
  10318          #if defined(_EMU_STATUS_VSCALE_MASK)
  10319            if ((EMU_VScaleGet() == emuVScaleEM01_LowPower)
  10320                && (init->frequency > CMU_VSCALEEM01_LOWPOWER_VOLTAGE_CLOCK_MAX)) {
  10321              EFM_ASSERT(false);
  10322              return false;
  10323            }
  10324          #endif
  10325          
  10326            // Find the correct HFRCO band and retrieve a HFRCOCTRL value.
  10327            for (i = 0; i < HFRCOCTRLTABLE_ENTRIES; i++) {
  10328              if ((init->frequency    >= hfrcoCtrlTable[i].minFreq)
  10329                  && (init->frequency <= hfrcoCtrlTable[i].maxFreq)) {
  10330                index = (int)i;                       // Correct band found
  10331                break;
  10332              }
  10333            }
  10334            if ((uint32_t)index == HFRCOCTRLTABLE_ENTRIES) {
  10335              EFM_ASSERT(false);
  10336              return false;                           // Target frequency out of spec.
  10337            }
  10338            hfrcoCtrlVal = hfrcoCtrlTable[index].value;
  10339          
  10340            // Check if a calibrated HFRCOCTRL.TUNING value is in device DI page.
  10341            if (hfrcoCtrlTable[index].band != (CMU_HFRCOFreq_TypeDef)0) {
  10342              uint32_t tuning;
  10343          
  10344              tuning = (CMU_HFRCODevinfoGet(hfrcoCtrlTable[index].band)
  10345                        & _CMU_HFRCOCTRL_TUNING_MASK)
  10346                       >> _CMU_HFRCOCTRL_TUNING_SHIFT;
  10347          
  10348              // When HFRCOCTRL.FINETUNINGEN is enabled, the center frequency
  10349              // of the band shifts down by 5.8%. 9 is subtracted to compensate.
  10350              if (tuning > 9UL) {
  10351                tuning -= 9UL;
  10352              } else {
  10353                tuning = 0UL;
  10354              }
  10355          
  10356              hfrcoCtrlVal |= tuning << _CMU_HFRCOCTRL_TUNING_SHIFT;
  10357            }
  10358          
  10359            // Update the CMSIS frequency SystemHfrcoFreq value.
  10360            SystemHfrcoFreq = init->frequency;
  10361          
  10362            // Set maximum wait-states while changing the core clock.
  10363            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10364              flashWaitStateMax();
  10365            }
  10366          
  10367            // Update the HFLE configuration before updating HFRCO, use new DPLL frequency.
  10368            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10369              setHfLeConfig(init->frequency);
  10370          
  10371              // Switch to HFRCO/2 before setting DPLL to avoid over-clocking.
  10372              hfrcoDiv2override = true;
  10373              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCODIV2;
  10374            }
  10375          
  10376            CMU->OSCENCMD  = CMU_OSCENCMD_DPLLDIS;
  10377            while ((CMU->STATUS & (CMU_STATUS_DPLLENS | CMU_STATUS_DPLLRDY)) != 0UL) {
  10378            }
  10379            CMU->IFC       = CMU_IFC_DPLLRDY | CMU_IFC_DPLLLOCKFAILLOW
  10380                             | CMU_IFC_DPLLLOCKFAILHIGH;
  10381            CMU->DPLLCTRL1 = ((uint32_t)init->n   << _CMU_DPLLCTRL1_N_SHIFT)
  10382                             | ((uint32_t)init->m << _CMU_DPLLCTRL1_M_SHIFT);
  10383            CMU->HFRCOCTRL = hfrcoCtrlVal;
  10384            CMU->DPLLCTRL  = ((uint32_t)init->refClk << _CMU_DPLLCTRL_REFSEL_SHIFT)
  10385                             | ((init->autoRecover ? 1UL : 0UL)
  10386                                << _CMU_DPLLCTRL_AUTORECOVER_SHIFT)
  10387                             | ((uint32_t)init->edgeSel << _CMU_DPLLCTRL_EDGESEL_SHIFT)
  10388                             | ((uint32_t)init->lockMode << _CMU_DPLLCTRL_MODE_SHIFT);
  10389            CMU->OSCENCMD  = CMU_OSCENCMD_DPLLEN;
  10390            while ((lockStatus = (CMU->IF & (CMU_IF_DPLLRDY
  10391                                             | CMU_IF_DPLLLOCKFAILLOW
  10392                                             | CMU_IF_DPLLLOCKFAILHIGH))) == 0UL) {
  10393            }
  10394          
  10395            // Restore to HFRCO
  10396            if ((CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCODIV2)
  10397                && (hfrcoDiv2override == true)) {
  10398              CMU->HFCLKSEL = CMU_HFCLKSEL_HF_HFRCO;
  10399            }
  10400          
  10401            // If HFRCO is selected as an HF clock, optimize the flash access wait-state
  10402            // configuration for this frequency and update the CMSIS core clock variable.
  10403            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10404              // Call @ref SystemCoreClockGet() to update the CMSIS core clock variable.
  10405              sysFreq = SystemCoreClockGet();
  10406              EFM_ASSERT(sysFreq <= init->frequency);
  10407              EFM_ASSERT(sysFreq <= SystemHfrcoFreq);
  10408              EFM_ASSERT(init->frequency == SystemHfrcoFreq);
  10409              CMU_UpdateWaitStates(sysFreq, VSCALE_DEFAULT);
  10410            }
  10411          
  10412            // Reduce HFLE frequency if possible.
  10413            setHfLeConfig(SystemHFClockGet());
  10414          
  10415          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10416            // Update voltage scaling.
  10417            EMU_VScaleEM01ByClock(0, true);
  10418          #endif
  10419          
  10420            if (lockStatus == CMU_IF_DPLLRDY) {
  10421              return true;
  10422            }
  10423            return false;
  10424          }
  10425          #endif // CMU_OSCENCMD_DPLLEN
  10426          
  10427          /**************************************************************************//**
  10428           * @brief
  10429           *   CMU low frequency register synchronization freeze control.
  10430           *
  10431           * @details
  10432           *   Some CMU registers require synchronization into the low-frequency (LF)
  10433           *   domain. The freeze feature allows for several such registers to be
  10434           *   modified before passing them to the LF domain simultaneously (which
  10435           *   takes place when the freeze mode is disabled).
  10436           *
  10437           *   Another use case for this feature is using an API (such
  10438           *   as the CMU API) for modifying several bit fields consecutively in the
  10439           *   same register. If freeze mode is enabled during this sequence, stalling
  10440           *   can be avoided.
  10441           *
  10442           * @note
  10443           *   When enabling freeze mode, this function will wait for all current
  10444           *   ongoing CMU synchronization to LF domain to complete (normally
  10445           *   synchronization will not be in progress.) However, for this reason, when
  10446           *   using freeze mode, modifications of registers requiring LF synchronization
  10447           *   should be done within one freeze enable/disable block to avoid unnecessary
  10448           *   stalling.
  10449           *
  10450           * @param[in] enable
  10451           *   @li true - enable freeze, modified registers are not propagated to the
  10452           *       LF domain
  10453           *   @li false - disable freeze, modified registers are propagated to the LF
  10454           *       domain
  10455           *****************************************************************************/
  10456          void CMU_FreezeEnable(bool enable)
  10457          {
  10458            if (enable) {
  10459              /* Wait for any ongoing LF synchronizations to complete. This */
  10460              /* protects against the rare case when a user                            */
  10461              /* - modifies a register requiring LF sync                              */
  10462              /* - then enables freeze before LF sync completed                       */
  10463              /* - then modifies the same register again                              */
  10464              /* since modifying a register while it is in sync progress should be    */
  10465              /* avoided.                                                             */
  10466              while (CMU->SYNCBUSY != 0UL) {
  10467              }
  10468          
  10469              CMU->FREEZE = CMU_FREEZE_REGFREEZE;
  10470            } else {
  10471              CMU->FREEZE = 0;
  10472            }
  10473          }
  10474          
  10475          #if defined(_CMU_HFRCOCTRL_BAND_MASK)
  10476          /***************************************************************************//**
  10477           * @brief
  10478           *   Get HFRCO band in use.
  10479           *
  10480           * @return
  10481           *   HFRCO band in use.
  10482           ******************************************************************************/
  10483          CMU_HFRCOBand_TypeDef CMU_HFRCOBandGet(void)
  10484          {
  10485            return (CMU_HFRCOBand_TypeDef)((CMU->HFRCOCTRL & _CMU_HFRCOCTRL_BAND_MASK)
  10486                                           >> _CMU_HFRCOCTRL_BAND_SHIFT);
  10487          }
  10488          #endif /* _CMU_HFRCOCTRL_BAND_MASK */
  10489          
  10490          #if defined(_CMU_HFRCOCTRL_BAND_MASK)
  10491          /***************************************************************************//**
  10492           * @brief
  10493           *   Set HFRCO band and the tuning value based on the value in the calibration
  10494           *   table made during production.
  10495           *
  10496           * @note
  10497           *   HFCLKLE prescaler is automatically modified based on the maximum
  10498           *   HFLE frequency allowed.
  10499           *
  10500           * @param[in] band
  10501           *   HFRCO band to activate.
  10502           ******************************************************************************/
  10503          void CMU_HFRCOBandSet(CMU_HFRCOBand_TypeDef band)
  10504          {
  10505            uint32_t           tuning;
  10506            uint32_t           freq;
  10507            CMU_Select_TypeDef osc;
  10508          
  10509            /* Read the tuning value from the calibration table. */
  10510            switch (band) {
  10511              case cmuHFRCOBand_1MHz:
  10512                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND1_MASK)
  10513                         >> _DEVINFO_HFRCOCAL0_BAND1_SHIFT;
  10514                break;
  10515          
  10516              case cmuHFRCOBand_7MHz:
  10517                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND7_MASK)
  10518                         >> _DEVINFO_HFRCOCAL0_BAND7_SHIFT;
  10519                break;
  10520          
  10521              case cmuHFRCOBand_11MHz:
  10522                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND11_MASK)
  10523                         >> _DEVINFO_HFRCOCAL0_BAND11_SHIFT;
  10524                break;
  10525          
  10526              case cmuHFRCOBand_14MHz:
  10527                tuning = (DEVINFO->HFRCOCAL0 & _DEVINFO_HFRCOCAL0_BAND14_MASK)
  10528                         >> _DEVINFO_HFRCOCAL0_BAND14_SHIFT;
  10529                break;
  10530          
  10531              case cmuHFRCOBand_21MHz:
  10532                tuning = (DEVINFO->HFRCOCAL1 & _DEVINFO_HFRCOCAL1_BAND21_MASK)
  10533                         >> _DEVINFO_HFRCOCAL1_BAND21_SHIFT;
  10534                break;
  10535          
  10536          #if defined(_CMU_HFRCOCTRL_BAND_28MHZ)
  10537              case cmuHFRCOBand_28MHz:
  10538                tuning = (DEVINFO->HFRCOCAL1 & _DEVINFO_HFRCOCAL1_BAND28_MASK)
  10539                         >> _DEVINFO_HFRCOCAL1_BAND28_SHIFT;
  10540                break;
  10541          #endif
  10542          
  10543              default:
  10544                EFM_ASSERT(false);
  10545                return;
  10546            }
  10547          
  10548            /* If HFRCO is used for the core clock, flash access WS has to be considered. */
  10549            osc = CMU_ClockSelectGet(cmuClock_HF);
  10550            if (osc == cmuSelect_HFRCO) {
  10551              /* Configure worst case wait states for flash access before setting the divider. */
  10552              flashWaitStateMax();
  10553            }
  10554          
  10555            /* Set band/tuning. */
  10556            CMU->HFRCOCTRL = (CMU->HFRCOCTRL
  10557                              & ~(_CMU_HFRCOCTRL_BAND_MASK | _CMU_HFRCOCTRL_TUNING_MASK))
  10558                             | (band << _CMU_HFRCOCTRL_BAND_SHIFT)
  10559                             | (tuning << _CMU_HFRCOCTRL_TUNING_SHIFT);
  10560          
  10561            /* If HFRCO is used for the core clock, optimize flash WS. */
  10562            if (osc == cmuSelect_HFRCO) {
  10563              /* Call @ref SystemCoreClockGet() to update the CMSIS core clock variable. */
  10564              freq = SystemCoreClockGet();
  10565              CMU_UpdateWaitStates(freq, VSCALE_DEFAULT);
  10566            }
  10567          
  10568          #if defined(CMU_MAX_FREQ_HFLE)
  10569            /* Reduce HFLE frequency if possible. */
  10570            setHfLeConfig(SystemCoreClockGet());
  10571          #endif
  10572          }
  10573          #endif /* _CMU_HFRCOCTRL_BAND_MASK */
  10574          
  10575          #if defined(_CMU_HFRCOCTRL_FREQRANGE_MASK)
  10576          /**************************************************************************//**
  10577           * @brief
  10578           *   Get the HFRCO frequency calibration word in DEVINFO.
  10579           *
  10580           * @param[in] freq
  10581           *   Frequency in Hz.
  10582           *
  10583           * @return
  10584           *   HFRCO calibration word for a given frequency.
  10585           *****************************************************************************/
  10586          static uint32_t CMU_HFRCODevinfoGet(CMU_HFRCOFreq_TypeDef freq)
  10587          {
  10588            switch (freq) {
  10589              /* 1, 2, and 4 MHz share the same calibration word. */
  10590              case cmuHFRCOFreq_1M0Hz:
  10591              case cmuHFRCOFreq_2M0Hz:
  10592              case cmuHFRCOFreq_4M0Hz:
  10593                return DEVINFO->HFRCOCAL0;
  10594          
  10595              case cmuHFRCOFreq_7M0Hz:
  10596                return DEVINFO->HFRCOCAL3;
  10597          
  10598              case cmuHFRCOFreq_13M0Hz:
  10599                return DEVINFO->HFRCOCAL6;
  10600          
  10601              case cmuHFRCOFreq_16M0Hz:
  10602                return DEVINFO->HFRCOCAL7;
  10603          
  10604              case cmuHFRCOFreq_19M0Hz:
  10605                return DEVINFO->HFRCOCAL8;
  10606          
  10607              case cmuHFRCOFreq_26M0Hz:
  10608                return DEVINFO->HFRCOCAL10;
  10609          
  10610              case cmuHFRCOFreq_32M0Hz:
  10611                return DEVINFO->HFRCOCAL11;
  10612          
  10613              case cmuHFRCOFreq_38M0Hz:
  10614                return DEVINFO->HFRCOCAL12;
  10615          
  10616          #if defined(_DEVINFO_HFRCOCAL13_MASK)
  10617              case cmuHFRCOFreq_48M0Hz:
  10618                return DEVINFO->HFRCOCAL13;
  10619          #endif
  10620          
  10621          #if defined(_DEVINFO_HFRCOCAL14_MASK)
  10622              case cmuHFRCOFreq_56M0Hz:
  10623                return DEVINFO->HFRCOCAL14;
  10624          #endif
  10625          
  10626          #if defined(_DEVINFO_HFRCOCAL15_MASK)
  10627              case cmuHFRCOFreq_64M0Hz:
  10628                return DEVINFO->HFRCOCAL15;
  10629          #endif
  10630          
  10631          #if defined(_DEVINFO_HFRCOCAL16_MASK)
  10632              case cmuHFRCOFreq_72M0Hz:
  10633                return DEVINFO->HFRCOCAL16;
  10634          #endif
  10635          
  10636              default: /* cmuHFRCOFreq_UserDefined */
  10637                return 0;
  10638            }
  10639          }
  10640          
  10641          /***************************************************************************//**
  10642           * @brief
  10643           *   Get the current HFRCO frequency.
  10644           *
  10645           * @return
  10646           *   HFRCO frequency.
  10647           ******************************************************************************/
  10648          CMU_HFRCOFreq_TypeDef CMU_HFRCOBandGet(void)
  10649          {
  10650            return (CMU_HFRCOFreq_TypeDef)SystemHfrcoFreq;
  10651          }
  10652          
  10653          /***************************************************************************//**
  10654           * @brief
  10655           *   Set the HFRCO calibration for the selected target frequency.
  10656           *
  10657           * @note
  10658           *   HFCLKLE prescaler is automatically modified based on the maximum
  10659           *   HFLE frequency allowed.
  10660           *
  10661           * @param[in] setFreq
  10662           *   HFRCO frequency to set.
  10663           ******************************************************************************/
  10664          void CMU_HFRCOBandSet(CMU_HFRCOFreq_TypeDef setFreq)
  10665          {
  10666            uint32_t freqCal;
  10667            uint32_t sysFreq;
  10668            uint32_t prevFreq;
  10669          
  10670            /* Get the DEVINFO index and set the CMSIS frequency SystemHfrcoFreq. */
  10671            freqCal = CMU_HFRCODevinfoGet(setFreq);
  10672            EFM_ASSERT((freqCal != 0UL) && (freqCal != UINT_MAX));
  10673            prevFreq = SystemHfrcoFreq;
  10674            SystemHfrcoFreq = (uint32_t)setFreq;
  10675          
  10676            /* Set maximum wait-states and set safe HFPER clock-tree prescalers while
  10677               changing the core clock. */
  10678            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10679              flashWaitStateMax();
  10680              hfperClkSafePrescaler();
  10681            }
  10682          
  10683            /* Wait for any previous sync to complete and set calibration data
  10684               for the selected frequency.  */
  10685            while (BUS_RegBitRead(&CMU->SYNCBUSY, _CMU_SYNCBUSY_HFRCOBSY_SHIFT) != 0UL) {
  10686            }
  10687          
  10688            /* Check for valid calibration data. */
  10689            EFM_ASSERT(freqCal != UINT_MAX);
  10690          
  10691            /* Set divider in HFRCOCTRL for 1, 2, and 4 MHz. */
  10692            switch (setFreq) {
  10693              case cmuHFRCOFreq_1M0Hz:
  10694                freqCal = (freqCal & ~_CMU_HFRCOCTRL_CLKDIV_MASK)
  10695                          | CMU_HFRCOCTRL_CLKDIV_DIV4;
  10696                break;
  10697          
  10698              case cmuHFRCOFreq_2M0Hz:
  10699                freqCal = (freqCal & ~_CMU_HFRCOCTRL_CLKDIV_MASK)
  10700                          | CMU_HFRCOCTRL_CLKDIV_DIV2;
  10701                break;
  10702          
  10703              case cmuHFRCOFreq_4M0Hz:
  10704                freqCal = (freqCal & ~_CMU_HFRCOCTRL_CLKDIV_MASK)
  10705                          | CMU_HFRCOCTRL_CLKDIV_DIV1;
  10706                break;
  10707          
  10708              default:
  10709                break;
  10710            }
  10711          
  10712            /* Update HFLE configuration before updating HFRCO.
  10713               Use the new set frequency. */
  10714            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10715              /* setFreq is worst-case as dividers may reduce the HFLE frequency. */
  10716              setHfLeConfig((uint32_t)setFreq);
  10717            }
  10718          
  10719            if ((uint32_t)setFreq > prevFreq) {
  10720          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10721              /* When increasing frequency voltage scale must be done before the change. */
  10722              EMU_VScaleEM01ByClock((uint32_t)setFreq, true);
  10723          #endif
  10724            }
  10725          
  10726            CMU->HFRCOCTRL = freqCal;
  10727          
  10728            /* If HFRCO is selected as an HF clock, optimize the flash access wait-state configuration
  10729               for this frequency and update the CMSIS core clock variable. */
  10730            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10731              /* Call @ref SystemCoreClockGet() to update the CMSIS core clock variable. */
  10732              sysFreq = SystemCoreClockGet();
  10733              EFM_ASSERT(sysFreq <= (uint32_t)setFreq);
  10734              EFM_ASSERT(sysFreq <= SystemHfrcoFreq);
  10735              EFM_ASSERT((uint32_t)setFreq == SystemHfrcoFreq);
  10736              CMU_UpdateWaitStates(sysFreq, VSCALE_DEFAULT);
  10737            }
  10738          
  10739            /* Reduce HFLE frequency if possible. */
  10740            setHfLeConfig(SystemHFClockGet());
  10741          
  10742            if ((uint32_t)setFreq <= prevFreq) {
  10743          #if defined(_EMU_CMD_EM01VSCALE0_MASK)
  10744              /* When decreasing frequency voltage scale must be done after the change */
  10745              EMU_VScaleEM01ByClock(0, true);
  10746          #endif
  10747            }
  10748            if (CMU_ClockSelectGet(cmuClock_HF) == cmuSelect_HFRCO) {
  10749              /* Set optimized HFPER clock-tree prescalers. */
  10750              hfperClkOptimizedPrescaler();
  10751            }
  10752          }
  10753          #endif /* _CMU_HFRCOCTRL_FREQRANGE_MASK */
  10754          
  10755          #if defined(_CMU_HFRCOCTRL_SUDELAY_MASK)
  10756          /***************************************************************************//**
  10757           * @brief
  10758           *   Get the HFRCO startup delay.
  10759           *
  10760           * @details
  10761           *   See the reference manual for more details.
  10762           *
  10763           * @return
  10764           *   The startup delay in use.
  10765           ******************************************************************************/
  10766          uint32_t CMU_HFRCOStartupDelayGet(void)
  10767          {
  10768            return (CMU->HFRCOCTRL & _CMU_HFRCOCTRL_SUDELAY_MASK)
  10769                   >> _CMU_HFRCOCTRL_SUDELAY_SHIFT;
  10770          }
  10771          
  10772          /***************************************************************************//**
  10773           * @brief
  10774           *   Set the HFRCO startup delay.
  10775           *
  10776           * @details
  10777           *   See the reference manual for more details.
  10778           *
  10779           * @param[in] delay
  10780           *   The startup delay to set (<= 31).
  10781           ******************************************************************************/
  10782          void CMU_HFRCOStartupDelaySet(uint32_t delay)
  10783          {
  10784            EFM_ASSERT(delay <= 31);
  10785          
  10786            delay &= _CMU_HFRCOCTRL_SUDELAY_MASK >> _CMU_HFRCOCTRL_SUDELAY_SHIFT;
  10787            CMU->HFRCOCTRL = (CMU->HFRCOCTRL & ~(_CMU_HFRCOCTRL_SUDELAY_MASK))
  10788                             | (delay << _CMU_HFRCOCTRL_SUDELAY_SHIFT);
  10789          }
  10790          #endif
  10791          
  10792          #if defined(_CMU_USHFRCOCTRL_FREQRANGE_MASK)
  10793          /**************************************************************************//**
  10794           * @brief
  10795           *   Get the USHFRCO frequency calibration word in DEVINFO.
  10796           *
  10797           * @param[in] freq
  10798           *   Frequency in Hz.
  10799           *
  10800           * @return
  10801           *   USHFRCO calibration word for a given frequency.
  10802           *****************************************************************************/
  10803          static uint32_t CMU_USHFRCODevinfoGet(CMU_USHFRCOFreq_TypeDef freq)
  10804          {
  10805            switch (freq) {
  10806              case cmuUSHFRCOFreq_16M0Hz:
  10807                return DEVINFO->USHFRCOCAL7;
  10808          
  10809              case cmuUSHFRCOFreq_32M0Hz:
  10810                return DEVINFO->USHFRCOCAL11;
  10811          
  10812              case cmuUSHFRCOFreq_48M0Hz:
  10813                return DEVINFO->USHFRCOCAL13;
  10814          
  10815              case cmuUSHFRCOFreq_50M0Hz:
  10816                return DEVINFO->USHFRCOCAL14;
  10817          
  10818              default: /* cmuUSHFRCOFreq_UserDefined */
  10819                return 0;
  10820            }
  10821          }
  10822          
  10823          /***************************************************************************//**
  10824           * @brief
  10825           *   Get the current USHFRCO frequency.
  10826           *
  10827           * @return
  10828           *   HFRCO frequency.
  10829           ******************************************************************************/
  10830          CMU_USHFRCOFreq_TypeDef CMU_USHFRCOBandGet(void)
  10831          {
  10832            return (CMU_USHFRCOFreq_TypeDef) ushfrcoFreq;
  10833          }
  10834          
  10835          /***************************************************************************//**
  10836           * @brief
  10837           *   Get USHFRCO frequency.
  10838           *
  10839           * @return
  10840           *   USHFRCO frequency.
  10841           ******************************************************************************/
  10842          uint32_t CMU_USHFRCOFreqGet(void)
  10843          {
