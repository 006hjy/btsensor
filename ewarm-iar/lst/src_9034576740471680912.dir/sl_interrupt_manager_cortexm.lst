    414          #if defined(VECTOR_TABLE_IN_RAM)
    415          
    416            uint32_t interrupt_status;
    417            sl_interrupt_manager_irq_handler_t *table;
    418          
    419            CORE_DECLARE_IRQ_STATE;
    420          
    421            if ((irqn < 0) || (irqn >= EXT_IRQ_COUNT)) {
    422              return SL_STATUS_INVALID_PARAMETER;
    423            }
    424          
    425            CORE_ENTER_CRITICAL();
    426          
    427            interrupt_status = (uint32_t)(((NVIC->ISER[((uint32_t)irqn) >> 5UL] & (1UL << (((uint32_t)irqn) & 0x1FUL))) != 0UL) ? 1UL : 0UL);
    428          
    429            // Disable irqn interrupt while updating the handler's address
    430            sl_interrupt_manager_disable_irq(irqn);
    431          
