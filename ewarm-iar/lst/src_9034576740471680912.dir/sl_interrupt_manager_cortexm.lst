    170          /***************************************************************************//**
    171           * @brief
    172           *   Set a new RAM based interrupt vector table.
    173           ******************************************************************************/
    174          sl_interrupt_manager_irq_handler_t *sli_interrupt_manager_set_irq_table(sl_interrupt_manager_irq_handler_t *table,
    175                                                                                  uint32_t handler_count)
    176          {
    177            sl_interrupt_manager_irq_handler_t * current;
    178          
    179            // ASSERT if misaligned with respect to the VTOR register implementation.
    180            EFM_ASSERT(((uint32_t)table & ~SCB_VTOR_TBLOFF_Msk) == 0U);
    181          
    182            // ASSERT if misaligned with respect to the vector table size.
    183            // The vector table address must be aligned at its size rounded up to nearest 2^n.
    184            EFM_ASSERT(((uint32_t)table
    185                        & ((1UL << (32UL - __CLZ((handler_count * 4UL) - 1UL))) - 1UL))
    186                       == 0UL);
    187          
    188            // Disable all interrupts while updating the vector table
    189            sl_interrupt_manager_disable_interrupts();
    190          
    191            current = (sl_interrupt_manager_irq_handler_t*)SCB->VTOR;
    192          
    193            SCB->VTOR = (uint32_t)table;
    194          
    195            // Make sure all explicit memory access are complete before proceding.
    196            __DSB();
    197          
    198            sl_interrupt_manager_enable_interrupts();
    199          
    200            return current;
    201          }
    202          
    203          #endif /* VECTOR_TABLE_IN_RAM */
