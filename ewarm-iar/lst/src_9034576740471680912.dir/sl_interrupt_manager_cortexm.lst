    252          
    253            // Set RAM table as irq table.
    254            sli_interrupt_manager_set_irq_table(vector_table_ram, TOTAL_INTERRUPTS);
    255          
    256            CORE_EXIT_CRITICAL();
    257          
    258            #endif /* VECTOR_TABLE_IN_RAM */
