    117          SL_CODE_CLASSIFY(SL_CODE_COMPONENT_INTERRUPT_MANAGER, SL_CODE_CLASS_TIME_CRITICAL)
    118          #endif
    119          static void sli_interrupt_manager_isr_wrapper(void);
    120          #endif /* SL_INTERRUPT_MANAGER_ENABLE_HOOKS */
