    234            interrupt_nesting_counter = 0U;
    235          #endif
    236          
    237            current = (sl_interrupt_manager_irq_handler_t*)SCB->VTOR;
    238          
    239            // copy ROM vector table to RAM table
    240            for (uint32_t i = 0; i < TOTAL_INTERRUPTS; i++) {
    241              #if defined(SL_INTERRUPT_MANAGER_ENABLE_HOOKS)
