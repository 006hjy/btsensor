    440              CORE_EXIT_CRITICAL();
    441              return SL_STATUS_NOT_INITIALIZED;
    442            }
    443          
    444            table[irqn + 16] = handler;
    445          
    446            // Make sure all explicit memory access are complete before proceding.
    447            __DSB();
    448            __ISB();
    449          
    450            CORE_EXIT_CRITICAL();
    451          
    452            if (interrupt_status == 1) {
    453              sl_interrupt_manager_enable_irq(irqn);
    454            }
    455          
    456            return SL_STATUS_OK;
    457          #else
    458            (void) irqn;
    459            (void) handler;
    460            return SL_STATUS_INVALID_CONFIGURATION;
