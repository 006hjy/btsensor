    555           *   Enable an interrupts on the current core
    556           ******************************************************************************/
    557          static void enable_interrupt(int32_t irqn)
    558          {
    559            if (irqn >= 0) {
    560              __COMPILER_BARRIER();
    561              NVIC->ISER[((uint32_t)irqn) >> 5UL] = (uint32_t)(1UL << (((uint32_t)irqn) & 0x1FUL));
    562              __COMPILER_BARRIER();
    563            }
    564          }
    565          
    566          /***************************************************************************//**
    567           * @brief
    568           *   Disable an interrupts on the current core
    569           ******************************************************************************/
    570          static void disable_interrupt(int32_t irqn)
    571          {
    572            if (irqn >= 0) {
    573              NVIC->ICER[((uint32_t)irqn) >> 5UL] = (uint32_t)(1UL << (((uint32_t)irqn) & 0x1FUL));
    574              __DSB();
    575              __ISB();
    576            }
    577          }
