    212          /******************************************************************************
    213           * @brief Internal function used to aggregate driver, services stacks and internal apps
    214           * initialization function.
    215           *
    216           * @details If a kernel is present, these components init functions will be
    217           * executed in the start task.
    218           *****************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    219          void sl_main_second_stage_init(void)
    220          {
   \                     sl_main_second_stage_init: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    221            sl_platform_init();
   \        0x2   0x.... 0x....      BL       sl_platform_init
    222            sl_driver_init();
   \        0x6   0x.... 0x....      BL       sl_driver_init
    223            sl_service_init();
   \        0xA   0x.... 0x....      BL       sl_service_init
    224            app_init_post_platform();
   \        0xE   0x.... 0x....      BL       app_init_post_platform
    225            sl_stack_init();
   \       0x12   0x.... 0x....      BL       sl_stack_init
    226            sl_internal_app_init();
   \       0x16   0xE8BD 0x4001      POP      {R0,LR}
   \       0x1A   0x.... 0x....      B.W      sl_internal_app_init
    227          #if defined(SL_CATALOG_KERNEL_PRESENT) && (SL_MAIN_ENABLE_START_TASK_PRIORITY_CHANGE == 1)
    228            osThreadSetPriority(osThreadGetId(), SL_MAIN_START_TASK_PRIORITY);
    229          #endif
    230          }
