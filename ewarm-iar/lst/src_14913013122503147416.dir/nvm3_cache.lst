    129          #if defined(NVM3_OPTIMIZATION) && (NVM3_OPTIMIZATION == 1)
    130          /******************************************************************************************************//**
    131           * Find index of the key in cache using binary search.
    132           *
    133           * @param[in]  h      A pointer to NVM3 cache data.
    134           *
    135           * @param[in]  key    A 20-bit object identifier.
    136           *
    137           * @param[out] idx    A pointer to the location where key idx will be placed.
    138           *
    139           * @return            Returns SL_STATUS_OK on success or SL_STATUS_NOT_FOUND on failure.
    140           *********************************************************************************************************/
    141          static sl_status_t cacheSearch(nvm3_Cache_t *h, nvm3_ObjectKey_t key, size_t *idx)
    142          {
    143            if (h->usedCount <= 0U) {
    144              return SL_STATUS_NOT_FOUND;
    145            }
    146          
    147            size_t low = 0U;
    148            size_t high = h->usedCount - 1;
    149            size_t mid = 0U;
    150            while (low <= high) {
    151              mid = (low + high) / 2;
    152              if (entryGetKey(h, mid) == key) {
    153                *idx = mid;
    154                return SL_STATUS_OK;
    155              }
    156              if (entryGetKey(h, mid) < key) {
    157                low = mid + 1;
    158              } else {
    159                if (mid != 0U) {
    160                  high = mid - 1;
    161                } else {
    162                  return SL_STATUS_NOT_FOUND;
    163                }
    164              }
    165            }
    166            return SL_STATUS_NOT_FOUND;
    167          }
    168          
    169          /******************************************************************************************************//**
    170           * Merge two cache subarrays. Merges the two haves arr[low..mid] and arr[mid+1..high] of cache subarrays.
    171           *
    172           * @param[in]  h       A pointer to NVM3 cache data.
    173           *
    174           * @param[in]  low     Left index of cache subarray.
    175           *
    176           * @param[in]  mid     Mid index of cache subarray.
    177           *
    178           * @param[in]  high    Right index of cache subarray.
    179           *
    180           * @return             Returns SL_STATUS_OK on success or SL_STATUS_ALLOCATION_FAILED on failure.
    181           *********************************************************************************************************/
    182          static sl_status_t cacheMerge(nvm3_Cache_t *h, uint32_t low, uint32_t mid, uint32_t high)
    183          {
    184            sl_status_t status = SL_STATUS_OK;
    185          
    186            if ((low > mid) || (mid >= high)) {
    187              return SL_STATUS_INVALID_PARAMETER;
    188            }
    189          
    190            uint32_t i, j, k;
    191            uint32_t a1 = mid - low + 1;
    192            uint32_t a2 = high - mid;
    193          
    194            if ((L != NULL) && (H != NULL) && (P1 != NULL) && (P2 != NULL) && (K1 != NULL) && (K2 != NULL)) {
    195              // Copy cache key and pointer data into subarrays
    196              for (i = 0; i < a1; i++) {
    197                L[i] = entryGetKey(h, low + i);
    198                P1[i] = (uint32_t)h->entryPtr[low + i].ptr;
    199                K1[i] = h->entryPtr[low + i].key;
    200              }
    201              for (j = 0; j < a2; j++) {
    202                H[j] = entryGetKey(h, mid + 1 + j);
    203                P2[j] = (uint32_t)h->entryPtr[mid + 1 + j].ptr;
    204                K2[j] = h->entryPtr[mid + 1 + j].key;
    205              }
    206          
    207              // Index of first, second and merged subarrays
    208              i = 0;
    209              j = 0;
    210              k = low;
    211          
    212              // Merge cache subarrays
    213              while (i < a1 && j < a2) {
    214                if (L[i] <= H[j]) {
    215                  h->entryPtr[k].key = K1[i];
    216                  h->entryPtr[k].ptr = (uint32_t*)P1[i];
    217                  i++;
    218                } else {
    219                  h->entryPtr[k].key = K2[j];
    220                  h->entryPtr[k].ptr = (uint32_t*)P2[j];
    221                  j++;
    222                }
    223                k++;
    224              }
    225          
    226              // Copy remaining cache elements of L subarray
    227              while (i < a1) {
    228                h->entryPtr[k].key = K1[i];
    229                h->entryPtr[k].ptr = (uint32_t*)P1[i];
    230                i++;
    231                k++;
    232              }
    233          
    234              // Copy remaining cache elements of H subarray
    235              while (j < a2) {
    236                h->entryPtr[k].key = K2[j];
    237                h->entryPtr[k].ptr = (uint32_t*)P2[j];
    238                j++;
    239                k++;
    240              }
    241            } else {
    242              status = SL_STATUS_ALLOCATION_FAILED;
    243            }
    244          
    245            return status;
    246          }
    247          
    248          /******************************************************************************************************//**
    249           * Sort cache entries using merge sort.
    250           *
    251           * @param[in]  h   A pointer to NVM3 cache data.
    252           *
    253           * @return         Returns SL_STATUS_OK on success or SL_STATUS_ALLOCATION_FAILED on failure.
    254           *********************************************************************************************************/
    255          sl_status_t nvm3_cacheSort(nvm3_Cache_t *h)
    256          {
    257            sl_status_t status = SL_STATUS_OK;
    258            uint32_t cacheSize = h->usedCount;  // size of cache array
    259            uint32_t currSize;                  // current size of subarray
    260            uint32_t leftStart;                 // starting index of left subarray
    261          
    262            // Allocate memory for cache subarrays
    263            L = sl_malloc(cacheSize * sizeof(uint32_t));
    264            H = sl_malloc(cacheSize * sizeof(uint32_t));
    265            P1 = sl_malloc(cacheSize * sizeof(uint32_t));
    266            P2 = sl_malloc(cacheSize * sizeof(uint32_t));
    267            K1 = sl_malloc(cacheSize * sizeof(uint32_t));
    268            K2 = sl_malloc(cacheSize * sizeof(uint32_t));
    269          
    270            // Merge cache subarrays using bottom up approach.
    271            for (currSize = 1; currSize <= cacheSize - 1; currSize = (currSize * 2U)) {
    272              // Pick starting point of different subarrays of current size
    273              for (leftStart = 0; leftStart < cacheSize - 1; leftStart += (currSize * 2U)) {
    274                // Find ending point of left subarray. mid+1 is starting point of right
    275                uint32_t mid = SL_MIN(leftStart + currSize - 1, cacheSize - 1);
    276                uint32_t rightEnd = SL_MIN(leftStart + (2U * currSize - 1), cacheSize - 1);
    277                // Merge cache subarrays arr[leftStart...mid] & arr[mid+1...rightEnd]
    278                status = cacheMerge(h, leftStart, mid, rightEnd);
    279              }
    280            }
    281          
    282            sl_free(L);
    283            sl_free(H);
    284            sl_free(K1);
    285            sl_free(P1);
    286            sl_free(K2);
    287            sl_free(P2);
    288          
    289            return status;
    290          }
    291          
    292          /******************************************************************************************************//**
    293           * Update existing cache entry.
    294           *
    295           * @param[in]  h       A pointer to NVM3 cache data.
    296           *
    297           * @param[in]  key     A 20-bit object identifier.
    298           *
    299           * @param[in]  obj     A pointer to object struct.
    300           *
    301           * @param[in]  group   Object group.
    302           *
    303           * @return             Returns true on success or false on failure.
    304           *********************************************************************************************************/
    305          bool nvm3_cacheUpdateEntry(nvm3_Cache_t *h, nvm3_ObjectKey_t key, nvm3_ObjPtr_t obj, nvm3_ObjGroup_t group)
    306          {
    307            size_t idx = 0;
    308            bool res = false;
    309          
    310            if ((h->usedCount > 0U) && (h->usedCount <= h->entryCount)) {
    311              if (cacheSearch(h, key, &idx) == SL_STATUS_OK) {
    312                if (isValid(h, idx)) {
    313                  entrySetGroup(h, idx, group);
    314                  entrySetPtr(h, idx, obj);
    315                  res = true;
    316                }
    317              }
    318            }
    319            nvm3_tracePrint(TRACE_LEVEL, "nvm3_cacheUpdateEntry, key=%lu, grp=%u, obj=%p, idx=%u.\n", key, group, obj, idx);
    320            return res;
    321          }
    322          
    323          /******************************************************************************************************//**
    324           * Add new cache entry
    325           *
    326           * @param[in]  h       A pointer to NVM3 cache data.
    327           *
    328           * @param[in]  key     A 20-bit object identifier.
    329           *
    330           * @param[in]  obj     A pointer to object struct.
    331           *
    332           * @param[in]  group   Object type.
    333           *
    334           * @return             Returns SL_STATUS_OK on success or SL_STATUS_ALLOCATION_FAILED on failure.
    335           *********************************************************************************************************/
    336          sl_status_t nvm3_cacheAddEntry(nvm3_Cache_t *h, nvm3_ObjectKey_t key, nvm3_ObjPtr_t obj, nvm3_ObjGroup_t group)
    337          {
    338            sl_status_t status = SL_STATUS_OK;
    339            bool cacheSet = false;
    340          
    341            if (h->usedCount < h->entryCount) {
    342              size_t idx = 0;
    343              if (h->usedCount > 0U) {
    344                if (nvm3_cacheGetIdx(h, key, 0U, h->usedCount - 1, &idx) == SL_STATUS_OK) {
    345                  nvm3_cacheOrganize(h, idx);
    346                }
    347              }
    348              setInvalid(h, idx);
    349              entrySetKey(h, idx, key);
    350              entrySetGroup(h, idx, group);
    351              entrySetPtr(h, idx, obj);
    352              cacheSet = true;
    353              h->usedCount++;
    354              nvm3_tracePrint(TRACE_LEVEL, "nvm3_cacheAddEntry(1), key=%lu, grp=%u, obj=%p, idx=%u.\n", key, group, obj, idx);
    355            }
    356          
    357            // Prioritize data over deleted objects, force an overwrite if possible
    358            if ((!cacheSet) && (group != objGroupDeleted)) {
    359              for (size_t idx1 = 0; idx1 < h->entryCount; idx1++) {
    360                nvm3_ObjGroup_t cacheGroup = entryGetGroup(h, idx1);
    361                if (cacheGroup == objGroupDeleted) {
    362                  entrySetKey(h, idx1, key);
    363                  entrySetGroup(h, idx1, group);
    364                  entrySetPtr(h, idx1, obj);
    365                  cacheSet = true;
    366                  if (h->usedCount > 1U) {
    367                    status = nvm3_cacheSort(h);
    368                  }
    369                  nvm3_tracePrint(TRACE_LEVEL, "nvm3_cacheAddEntry(2), cache overflow for key=%lu, grp=%u, obj=%p, inserted at idx=%u.\n", key, group, obj, idx1);
    370                  break;
    371                }
    372              }
    373            }
    374          
    375            if (!cacheSet) {
    376              h->overflow = true;
    377              nvm3_tracePrint(TRACE_LEVEL, "nvm3_cacheAddEntry(3), cache overflow for key=%lu, grp=%u, obj=%p.\n", key, group, obj);
    378            }
    379          
    380            return status;
    381          }
    382          
    383          /******************************************************************************************************//**
    384           * Get cache idx to add new entry
    385           *
    386           * @param[in]  h       A pointer to NVM3 cache data.
    387           *
    388           * @param[in]  key     A 20-bit object identifier.
    389           *
    390           * @param[in]  low     Left index of cache subarray.
    391           *
    392           * @param[in]  high    Right index of cache subarray.
    393           *
    394           * @param[out] idx     A pointer to the location where key idx will be placed.
    395           *
    396           * @return             Returns SL_STATUS_OK on success or SL_STATUS_NOT_FOUND on failure.
    397           *********************************************************************************************************/
    398          sl_status_t nvm3_cacheGetIdx(nvm3_Cache_t *h, nvm3_ObjectKey_t key, size_t low, size_t high, size_t *idx)
    399          {
    400            if (high <= low) {
    401              *idx = (key > entryGetKey(h, low)) ? (low + 1) : low;
    402              return SL_STATUS_OK;
    403            }
    404            if (key > entryGetKey(h, high)) {
    405              *idx = high + 1;
    406              return SL_STATUS_OK;
    407            }
    408            if (key < entryGetKey(h, low)) {
    409              *idx = low;
    410              return SL_STATUS_OK;
    411            }
    412            size_t mid = (low + high) / 2;
    413            if (key == entryGetKey(h, mid)) {
    414              *idx = mid + 1;
    415              return SL_STATUS_OK;
    416            }
    417            if (key > entryGetKey(h, mid)) {
    418              return nvm3_cacheGetIdx(h, key, mid + 1, high, idx);
    419            }
    420            if (mid != 0U) {
    421              return nvm3_cacheGetIdx(h, key, low, mid - 1, idx);
    422            } else {
    423              return SL_STATUS_NOT_FOUND;
    424            }
    425          }
    426          
    427          /******************************************************************************************************//**
    428           * Arrange cache entries
    429           *
    430           * @param[in]  h       A pointer to NVM3 cache data.
    431           *
    432           * @param[in]  idx     Index of the key to arrange the cache entries.
    433           *
    434           *********************************************************************************************************/
    435          void nvm3_cacheOrganize(nvm3_Cache_t *h, size_t idx)
    436          {
    437            size_t lastIdx = h->usedCount - 1;
    438            // Move all cache entries from idx to end
    439            for (; (lastIdx >= idx) && (lastIdx != 0); lastIdx--) {
    440              h->entryPtr[lastIdx + 1].key = h->entryPtr[lastIdx].key;
    441              h->entryPtr[lastIdx + 1].ptr = h->entryPtr[lastIdx].ptr;
    442            }
    443            if ((lastIdx == 0) && (idx == 0)) {
    444              h->entryPtr[lastIdx + 1].key = h->entryPtr[lastIdx].key;
    445              h->entryPtr[lastIdx + 1].ptr = h->entryPtr[lastIdx].ptr;
    446            }
    447          }
    448          #endif
