    450          #if defined(NVM3_OPTIMIZATION) && (NVM3_OPTIMIZATION == 1)
    451          void nvm3_cacheDelete(nvm3_Cache_t *h, nvm3_ObjectKey_t key)
    452          {
    453            bool found = false;
    454            size_t idx = 0;
    455          
    456            if ((h->usedCount > 0U) && (h->usedCount <= h->entryCount)) {
    457              if (cacheSearch(h, key, &idx) == SL_STATUS_OK) {
    458                if (isValid(h, idx)) {
    459                  if (entryGetKey(h, idx) == key) {
    460                    setInvalid(h, idx);
    461                    found = true;
    462                    size_t lastIdx = h->usedCount - 1;
    463                    // Arrange cache entries after cache obj deletion
    464                    for (; idx < lastIdx; idx++) {
    465                      h->entryPtr[idx].key = h->entryPtr[idx + 1].key;
    466                      h->entryPtr[idx].ptr = h->entryPtr[idx + 1].ptr;
    467                    }
    468                    if (h->usedCount > 0) {
    469                      h->usedCount--;
    470                    }
    471                  }
    472                }
    473              }
    474            }
    475          
    476            nvm3_tracePrint(TRACE_LEVEL, "nvm3_cacheDelete, key=%lu, found=%d.\n", key, found ? 1 : 0);
    477            (void)found;
    478          }
