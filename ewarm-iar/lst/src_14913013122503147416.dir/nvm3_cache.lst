     63          static inline nvm3_ObjectKey_t entryGetKey(nvm3_Cache_t *h, size_t idx)
     64          {
     65            uint32_t tmp = h->entryPtr[idx].key;
     66            return (tmp & NVM3_KEY_MASK);
     67          }
