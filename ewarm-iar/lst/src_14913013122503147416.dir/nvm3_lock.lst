     94          /***************************************************************************//**
     95           * @details
     96           * The Mutex creation for lock enable and disable.
     97           *
     98           * It provides options for using "mutexes" for RTOS users
     99           * and "core_critical" APIs for bare-metal users.
    100           *
    101           * @note RTOS users should avoid invoking the nvm3_lock APIs from within
    102           *       critical sections, as this may result in unexpected behavior.
    103           *       Please, ensure that kernel has been initialized before this API call.
    104           ******************************************************************************/

   \                                 In section .text, align 2
    105          SL_WEAK void nvm3_lockCreateMutex(void)
    106          {
    107          #if defined(SL_CATALOG_KERNEL_PRESENT) && !defined(_SILICON_LABS_32B_SERIES_2)
    108            if (nvm3_mutex == NULL) {
    109              const osMutexAttr_t mutex_attr = {
    110                " NVM3 Mutex",
    111                osMutexRecursive | osMutexPrioInherit,
    112                NULL,
    113                0
    114              };
    115              nvm3_mutex = osMutexNew(&mutex_attr);
    116              if (nvm3_mutex == NULL) {
    117                NVM3_ERROR_ASSERT();
    118              }
    119            }
    120          #endif
    121          }
   \                     nvm3_lockCreateMutex: (+1)
   \        0x0   0x4770             BX       LR
    122          
    123          /***************************************************************************//**
    124           * @details
    125           * The default lock-begin implementation.
    126           * @note RTOS users should avoid invoking the nvm3_lock APIs from within
    127           *       critical sections, as this may result in unexpected behavior.
    128           *       Please, ensure that kernel has been initialized before this API call.
    129           ******************************************************************************/

   \                                 In section .text, align 4
    130          SL_WEAK void nvm3_lockBegin(void)
    131          {
   \                     nvm3_lockBegin: (+1)
   \        0x0   0xB580             PUSH     {R7,LR}
    132          #ifdef NVM3_HOST_BUILD
    133            lockCount++;
    134          // In apps running on micrium OS on Ser2, the app is acquiring the mutex within
    135          // a critical section while invoking bootloader APIs
    136          #elif defined(SL_CATALOG_KERNEL_PRESENT) && !defined(_SILICON_LABS_32B_SERIES_2)
    137          /// @cond DO_NOT_INCLUDE_WITH_DOXYGEN
    138            osStatus_t os_status = osError;
    139            // Bypass the lock if kernel is not running
    140            if (osKernelGetState() == osKernelRunning) {
    141              if (nvm3_mutex == NULL) {
    142                nvm3_lockCreateMutex();
    143              }
    144              os_status = osMutexAcquire(nvm3_mutex, osWaitForever);
    145              if (os_status != osErrorISR && os_status != osOK) {
    146                NVM3_ERROR_ASSERT();
    147              }
    148            }
    149          #else
    150          /// @cond DO_NOT_INCLUDE_WITH_DOXYGEN
    151            CORE_ENTER_CRITICAL();
   \        0x2   0x.... 0x....      BL       CORE_EnterCritical
   \        0x6   0x4901             LDR.N    R1,??nvm3_lockBegin_0
   \        0x8   0x6008             STR      R0,[R1, #+0]
    152          /// @endcond
    153          #endif
    154          }
   \        0xA   0xBD01             POP      {R0,PC}
   \                     ??nvm3_lockBegin_0:
   \        0xC   0x....'....        DC32     irqState
    155          
    156          /***************************************************************************//**
    157           * @details
    158           * The default lock-end implementation.
    159           * @note RTOS users should avoid invoking the nvm3_lock APIs from within
    160           *       critical sections, as this may result in unexpected behavior.
    161           *       Please, ensure that kernel has been initialized before this API call.
    162           ******************************************************************************/

   \                                 In section .text, align 4
    163          SL_WEAK void nvm3_lockEnd(void)
    164          {
    165          #ifdef NVM3_HOST_BUILD
    166            if (lockCount == 0) {
    167              nvm3_tracePrint(NVM3_TRACE_LEVEL_ERROR, "NVM3 ERROR - lockEnd: invalid lock count.\n");
    168            }
    169            lockCount--;
    170          #elif defined(SL_CATALOG_KERNEL_PRESENT) && !defined(_SILICON_LABS_32B_SERIES_2)
    171            osStatus_t os_status = osError;
    172            // Bypass the lock if kernel is not running
    173            if (osKernelGetState() == osKernelRunning) {
    174              os_status = osMutexRelease(nvm3_mutex);
    175              if (os_status != osErrorISR && os_status != osOK) {
    176                NVM3_ERROR_ASSERT();
    177              }
    178            }
    179          #else
    180            CORE_EXIT_CRITICAL();
   \                     nvm3_lockEnd: (+1)
   \        0x0   0x4901             LDR.N    R1,??nvm3_lockEnd_0
   \        0x2   0x6808             LDR      R0,[R1, #+0]
   \        0x4   0x.... 0x....      B.W      CORE_ExitCritical
   \                     ??nvm3_lockEnd_0:
   \        0x8   0x....'....        DC32     irqState
    181          #endif
    182          }
