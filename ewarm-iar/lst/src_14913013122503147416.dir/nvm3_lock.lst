    190           * @param[in]  size Size of memory range.
    191           ******************************************************************************/

   \                                 In section .text, align 2, keep-with-next
    192          void nvm3_lockDisableExecute(void *address, size_t size)
    193          {
    194          #if defined(__MPU_PRESENT) && (__MPU_PRESENT == 1U) \
    195            && defined(SL_CATALOG_MPU_PRESENT)                \
    196            && !defined(SL_TRUSTZONE_SECURE)
    197            // The memory range used by nvm3 may not be compatible with the mpu.
    198            // Just ignore errors.
    199            sl_mpu_disable_execute((uint32_t)address, (uint32_t)address + size - 1, size);
    200          #else
    201            (void)address;
    202            (void)size;
    203          #endif
    204          }
