     96          
     97          // Check if the page is erased.
     98          static bool isErased(void *adr, size_t len)
     99          {
    100            size_t cnt;
    101            uint32_t *dat = adr;
    102          
    103            cnt = len / sizeof(uint32_t);
    104            for (size_t i = 0U; i < cnt; i++) {
    105              if (*dat != 0xFFFFFFFFUL) {
    106                return false;
    107              }
    108              dat++;
    109            }
    110          
    111            return true;
    112          }
    113          
