     32          #include "nvm3_utils.h"
     33          #include <string.h>
     34          
     35          #define NVM3_OBJ_LEN_SIZE                7U          //  7 bits
     36          #define NVM3_OBJ_LEN_MASK                ((1U << NVM3_OBJ_LEN_SIZE) - 1U)
     37          #define NVM3_OBJ_LLEN_SIZE               26U         // 26 bits: large obj length
     38          #define NVM3_OBJ_LLEN_MASK               ((1U << NVM3_OBJ_LLEN_SIZE) - 1U)
     39          #define NVM3_OBJ_BCCB_SIZE               5U          //  5 bits: small obj berger code
     40          #define NVM3_OBJ_BCCB_MASK               ((1U << NVM3_OBJ_BCCB_SIZE) - 1U)
     41          #define NVM3_OBJ_LBCCB_SIZE              6U          //  6 bits: large obj berger code
     42          #define NVM3_OBJ_LBCCB_MASK              ((1U << NVM3_OBJ_LBCCB_SIZE) - 1U)
     43          #define NVM3_OBJ_F_SIZE                  2U          //  2 bits: fragment field
     44          #define NVM3_OBJ_F_MASK                  ((1U << NVM3_OBJ_F_SIZE) - 1U)
     45          #define NVM3_OBJ_U_SIZE                  3U          //  3 bits: unused field
     46          #define NVM3_OBJ_U_MASK                  ((1U << NVM3_OBJ_U_SIZE) - 1U)
     47          #define NVM3_OBJ_KEY_OFFSET              (NVM3_OBJ_LEN_SIZE)
     48          #define NVM3_OBJ_F_OFFSET                (NVM3_OBJ_LEN_SIZE + NVM3_KEY_SIZE)
     49          #define NVM3_OBJ_U_OFFSET                (NVM3_OBJ_LEN_SIZE + NVM3_KEY_SIZE + NVM3_OBJ_F_SIZE)
     50          #define NVM3_OBJ_BCCB_OFFSET             (NVM3_OBJ_LEN_SIZE + NVM3_KEY_SIZE)
     51          #define NVM3_OBJ_LBCCB_OFFSET            (NVM3_OBJ_LLEN_SIZE)
     52          
     53          //****************************************************************************
     54          
     55          __STATIC_INLINE uint32_t hdrSmallGetBergerCode(nvm3_ObjHdrSmall_t *oh)
     56          {
     57            return ((oh->oh1 >> NVM3_OBJ_BCCB_OFFSET) & NVM3_OBJ_BCCB_MASK);
     58          }
     59          
     60          __STATIC_INLINE uint32_t hdrLargeGetBergerCode(nvm3_ObjHdrLarge_t *oh)
     61          {
     62            return ((oh->oh2 >> NVM3_OBJ_LBCCB_OFFSET) & NVM3_OBJ_LBCCB_MASK);
     63          }
     64          
     65          __STATIC_INLINE nvm3_ObjType_t toObjType(uint32_t value)
     66          {
     67            int type = (int)value;
     68            return (nvm3_ObjType_t)type;
     69          }
     70          
     71          __STATIC_INLINE nvm3_ObjFragType_t toObjFragType(uint32_t value)
     72          {
     73            int type = (int)value;
     74            return (nvm3_ObjFragType_t)type;
     75          }
     76          
     77          __STATIC_INLINE nvm3_ObjType_t hdrGetType(nvm3_ObjHdrSmall_t *oh)
     78          {
     79            return toObjType(oh->oh1 & NVM3_OBJ_LEN_MASK);
     80          }
