     43          /// Define for supporting gpiointerrupt porting
     44          #define SL_GPIO_PORT_INTERRUPT  (0xFF)
     45          
     46          /// Pin direction validation.
     47          #define SL_GPIO_DIRECTION_IS_VALID(direction)  (direction <= SL_GPIO_PIN_DIRECTION_OUT)
     48          
     49          /*******************************************************************************
     50           *******************************   STRUCTS   ***********************************
     51           ******************************************************************************/
     52          
     53          typedef struct {
     54            void *callback;   // Pointer to callback function.
     55            void *context;    // Pointer to callback context.
     56          } sl_gpio_callback_desc_t;
     57          
     58          typedef struct {
     59            // An array of user callbacks for external interrupts.
     60            // We have external interrupts configured from 0 to 15 bits.
     61            sl_gpio_callback_desc_t callback_ext[SL_HAL_GPIO_NO_OF_EXT_INTERRUPTS];
     62            // An array of user callbacks for EM4 interrupts.
     63            // We have EM4 interrupts configured from 16 to 31 bits.
     64            sl_gpio_callback_desc_t callback_em4[SL_HAL_GPIO_NO_OF_EXT_INTERRUPTS];
     65          } sl_gpio_callbacks_t;
