   1474          static void populate_descriptor_fields(sl_dma_channel_xfer_descriptor_t *descriptor,
   1475                                                 const sl_dma_channel_transfer_t *transfer,
   1476                                                 void *source,
   1477                                                 void *destination,
   1478                                                 uint32_t xfer_unit_count)
   1479          {
   1480            sl_hal_ldma_descriptor_t* hw_desc = (sl_hal_ldma_descriptor_t*)descriptor;
   1481          
   1482            // Configure basic descriptor structure
   1483            hw_desc->xfer.struct_type = SL_HAL_LDMA_CTRL_STRUCT_TYPE_XFER;
   1484            hw_desc->xfer.struct_req = transfer->block_handshake_mode ? 0 : 1;
   1485            hw_desc->xfer.block_size = transfer->block_size;
   1486            hw_desc->xfer.done_ifs = 1;
   1487          
   1488            // Configure request mode and address increment behavior
   1489            hw_desc->xfer.req_mode = transfer->block_handshake_mode ? SL_HAL_LDMA_CTRL_REQ_MODE_BLOCK : SL_HAL_LDMA_CTRL_REQ_MODE_ALL;
   1490            hw_desc->xfer.src_inc = transfer->increment_source ? SL_HAL_LDMA_CTRL_SRC_INC_ONE : SL_HAL_LDMA_CTRL_SRC_INC_NONE;
   1491            hw_desc->xfer.dst_inc = transfer->increment_destination ? SL_HAL_LDMA_CTRL_DST_INC_ONE : SL_HAL_LDMA_CTRL_DST_INC_NONE;
   1492          
   1493            // Set transfer unit size and address modes
   1494            hw_desc->xfer.size = transfer->unit_size;
   1495            hw_desc->xfer.src_addr_mode = SL_HAL_LDMA_CTRL_SRC_ADDR_MODE_ABS;
   1496            hw_desc->xfer.dst_addr_mode = SL_HAL_LDMA_CTRL_DST_ADDR_MODE_ABS;
   1497          
   1498            // Set source and destination addresses
   1499            hw_desc->xfer.src_addr = (uint32_t)source;
   1500            hw_desc->xfer.dst_addr = (uint32_t)destination;
   1501          
   1502          #if defined(SL_DMA_CHANNEL_HAS_EXTENDED_DESCRIPTORS)
   1503            sl_hal_ldma_descriptor_extend_t* extend_desc = (sl_hal_ldma_descriptor_extend_t*)hw_desc;
   1504            extend_desc->extend = 1;
   1505          
   1506            // For extended descriptors, split the transfer count between CTRL and XCTRL registers
   1507          #if defined(_LDMA_CH_XCTRL_XFERCNT_MASK)
   1508            hw_desc->xfer.xfer_count = SL_HAL_LDMA_EXTEND_XFER_COUNT(xfer_unit_count);
   1509            extend_desc->xfer_count_high = SL_HAL_LDMA_EXTEND_XFER_COUNT_HIGH(xfer_unit_count);
   1510          #else
   1511            hw_desc->xfer.xfer_count = xfer_unit_count - 1UL;
   1512          #endif
   1513          #else
   1514            hw_desc->xfer.xfer_count = xfer_unit_count - 1UL;
   1515          #endif
   1516          }
   1517          
   1518          static sl_status_t build_descriptors_for_transfer(sl_dma_channel_transfer_t *current_transfer,
   1519                                                            const sl_dma_channel_transfer_t *previous_transfer,
   1520                                                            uint32_t xfer_unit_size,
   1521                                                            uint32_t xfer_unit_count,
   1522                                                            const sl_dma_channel_handle_t *handle)
   1523          {
   1524            sl_status_t status = SL_STATUS_OK;
   1525          
   1526            // Determine the number of transfer segments, and the number of units in the
   1527            // partial segment if there is a number of xfer units remaining.
   1528            uint32_t xfer_segment_count = xfer_unit_count / SL_DMA_CHANNEL_MAX_XFER_UNIT_COUNT;
   1529            uint32_t xfer_partial_segment_unit_count = xfer_unit_count % SL_DMA_CHANNEL_MAX_XFER_UNIT_COUNT;
   1530            if (xfer_partial_segment_unit_count > 0) {
   1531              xfer_segment_count += 1;
   1532            }
   1533          
   1534            // Then build and link descriptors for segments, allocating memory for
   1535            // descriptors if no pre-allocated descriptor structure is provided. For
   1536            // multi-segment transfers, only the last descriptor will trigger an
   1537            // interrupt if a callback on transfer complete was requested.
   1538            bool is_user_allocated = true;
   1539            sl_dma_channel_xfer_descriptor_t* current_descriptor = current_transfer->descriptor;
   1540            sl_dma_channel_xfer_descriptor_t* previous_descriptor = NULL;
   1541          
   1542            if (current_descriptor == NULL) {
   1543              // All descriptors will be internally allocated if the descriptor provided
   1544              // for the transfer is NULL ( the descriptor is not user-allocated ).
   1545              is_user_allocated = false;
   1546            }
   1547          
   1548            for ( uint32_t segment = 0; segment < xfer_segment_count; segment++ ) {
   1549              if ( !is_user_allocated ) {
   1550                status = sl_dma_channel_descriptor_alloc(handle,
   1551                                                         &current_descriptor);
   1552          
   1553                // Save pointer to first descriptor in the transfer structure
   1554                if ( segment == 0 ) {
   1555                  current_transfer->descriptor = current_descriptor;
   1556                }
   1557          
   1558                if (status != SL_STATUS_OK) {
   1559                  return status;
   1560                }
   1561          
   1562                // Indicate that the descriptor was allocated internally.
   1563                current_descriptor->flags.driver_allocated = 1;
   1564              } else {
   1565                // Make sure that the user-allocated descriptor buffer is zeroed before
   1566                // proceeding.
   1567                memset(current_descriptor, 0, sizeof(sl_dma_channel_xfer_descriptor_t));
   1568              }
   1569          
   1570              // Calculate source and destination addresses for this segment
   1571              uint32_t segment_offset = segment * SL_DMA_CHANNEL_MAX_XFER_UNIT_COUNT * xfer_unit_size;
   1572              void *segment_source = (void *)((uint32_t)(current_transfer->source) + segment_offset);
   1573              void *segment_destination = (void *)((uint32_t)(current_transfer->destination) + segment_offset);
   1574          
   1575              // Calculate transfer unit count for this segment
   1576              bool is_last_segment = (segment == (xfer_segment_count - 1));
   1577              uint32_t segment_unit_count;
   1578              if (is_last_segment && xfer_partial_segment_unit_count > 0) {
   1579                segment_unit_count = xfer_partial_segment_unit_count;
   1580              } else {
   1581                segment_unit_count = SL_DMA_CHANNEL_MAX_XFER_UNIT_COUNT;
   1582              }
   1583          
   1584              // Determine if done interrupt should be set (only on last segment if callback requested)
   1585              current_descriptor->flags.callback_on_complete = (current_transfer->callback_on_complete && is_last_segment) ? 1 : 0;
   1586          
   1587              // Populate hardware specific descriptor fields.
   1588              populate_descriptor_fields(current_descriptor,
   1589                                         current_transfer,
   1590                                         segment_source,
   1591                                         segment_destination,
   1592                                         segment_unit_count);
   1593          
   1594              // If there was a previous descriptor, link this current descriptor
   1595              // to it. Otherwise, if it's the first descriptor, link it to the
   1596              // previous DMA Channel Transfer's descriptor(s) if there was
   1597              // a previous transfer in the list.
   1598              if ( previous_descriptor != NULL ) {
   1599                link_descriptors(previous_descriptor, current_descriptor);
   1600              } else {
   1601                if ( previous_transfer != NULL ) {
   1602                  // Find the tail of the list of descriptors of the last DMA Channel
   1603                  // Transfer.
   1604                  sl_dma_channel_xfer_descriptor_t* prev_xfer_desc_tail = find_descriptor_by_link(previous_transfer->descriptor, NULL);
   1605                  link_descriptors(prev_xfer_desc_tail, current_descriptor);
   1606                }
   1607              }
   1608          
   1609              previous_descriptor = current_descriptor;
   1610            }
   1611          
   1612            return status;
   1613          }
