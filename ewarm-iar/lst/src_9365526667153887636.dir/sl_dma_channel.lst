   1412          static bool is_transfer_buffer_aligned(const sl_dma_channel_transfer_t *transfer)
   1413          {
   1414            EFM_ASSERT(transfer != NULL);
   1415          
   1416            // Validate buffer alignment based on unit size
   1417            // HALF requires 2-byte alignment, WORD requires 4-byte alignment
   1418            switch (transfer->unit_size) {
   1419              case SL_DMA_CTRL_SIZE_HALF:
   1420                if (!TRANSFER_BUFFER_IS_ALIGNED(transfer->source, 2)
   1421                    || !TRANSFER_BUFFER_IS_ALIGNED(transfer->destination, 2)) {
   1422                  return false;
   1423                }
   1424                break;
   1425              case SL_DMA_CTRL_SIZE_WORD:
   1426                if (!TRANSFER_BUFFER_IS_ALIGNED(transfer->source, 4)
   1427                    || !TRANSFER_BUFFER_IS_ALIGNED(transfer->destination, 4)) {
   1428                  return false;
   1429                }
   1430                break;
   1431              case SL_DMA_CTRL_SIZE_BYTE:
   1432                // BYTE unit size has no alignment requirement
   1433                break;
   1434              default:
   1435                // Unknown unit size, consider as misaligned
   1436                return false;
   1437            }
   1438          
   1439            return true;
   1440          }
