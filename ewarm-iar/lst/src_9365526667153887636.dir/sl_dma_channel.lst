     49          
     50          /// Check if a transfer buffer pointer is aligned to the specified alignment boundary
     51          /// @param ptr Pointer to check
     52          /// @param align Alignment boundary (must be a power of 2)
     53          /// @return true if aligned, false otherwise
     54          #define TRANSFER_BUFFER_IS_ALIGNED(ptr, align) (((uintptr_t)(ptr) & ((align) - 1)) == 0)
     55          
