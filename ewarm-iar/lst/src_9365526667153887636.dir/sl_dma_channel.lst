     57           ***************************   LOCAL FUNCTIONS   *******************************
     58           ******************************************************************************/
     59          
     60          /***************************************************************************//**
     61           * @brief Find a descriptor in a linked list by its link target.
     62           *
     63           * This function walks through a linked list of DMA descriptors starting from
     64           * list_head and returns the descriptor whose link_addr field points to the
     65           * specified link parameter. When link is NULL, the function returns the tail
     66           * descriptor (the last descriptor in the list with no link).
     67           *
     68           * @param[in] list_head Pointer to the first descriptor in the linked list
     69           *                      (must not be NULL).
     70           * @param[in] link      Pointer to the target descriptor to search for, or NULL
     71           *                      to find the tail descriptor.
     72           *
     73           * @return Pointer to the descriptor that links to the specified link parameter.
     74           *         Returns the tail descriptor if link is NULL.
     75           *
     76           * @note The function returns a non-const pointer to allow the caller to modify
     77           *       the returned descriptor (e.g., via link_descriptors), even though the
     78           *       function itself does not modify the descriptors during traversal.
     79           ******************************************************************************/
     80          static sl_dma_channel_xfer_descriptor_t* find_descriptor_by_link(sl_dma_channel_xfer_descriptor_t* list_head,
     81                                                                           sl_dma_channel_xfer_descriptor_t* link);
     82          
     83          /***************************************************************************//**
     84           * @brief Link two DMA channel transfer descriptors together.
     85           *
     86           * Sets up the link field in the source descriptor to point to the destination
     87           * descriptor using absolute addressing mode.
     88           *
     89           * @param[in] from Pointer to the source descriptor (must not be NULL).
     90           * @param[in] to   Pointer to the destination descriptor, or NULL to unlink.
     91           ******************************************************************************/
     92          static void link_descriptors(sl_dma_channel_xfer_descriptor_t* from,
     93                                       sl_dma_channel_xfer_descriptor_t* to);
     94          
     95          /***************************************************************************//**
     96           * @brief Validate buffer alignment for a DMA transfer based on unit size.
     97           *
     98           * This function checks that source and destination buffers are properly aligned
     99           * according to the transfer unit size. HALF word transfers require 2-byte
    100           * alignment, WORD transfers require 4-byte alignment, and BYTE transfers have
    101           * no alignment requirement.
    102           *
    103           * @param[in] transfer Pointer to the DMA transfer structure. Must not be NULL.
    104           *
    105           * @return true if buffers are properly aligned for the specified unit size.
    106           * @return false if source or destination buffers are misaligned for the specified unit size.
    107           *         Specifically:
    108           *         - SL_DMA_CTRL_SIZE_HALF: buffers must be 2-byte aligned
    109           *         - SL_DMA_CTRL_SIZE_WORD: buffers must be 4-byte aligned
    110           *         - SL_DMA_CTRL_SIZE_BYTE: no alignment requirement
    111           ******************************************************************************/
    112          static bool is_transfer_buffer_aligned(const sl_dma_channel_transfer_t *transfer);
    113          
    114          /***************************************************************************//**
    115           * @brief Check whether a descriptor is the currently active descriptor in
    116           *        a DMA channel.
    117           *
    118           * Compares the descriptor's link address against the hardware channel's
    119           * active LINK register value to determine if the descriptor is the one
    120           * currently being processed (or about to be processed) by the LDMA engine.
    121           *
    122           * @param[in] ldma Pointer to the LDMA peripheral register block.
    123           * @param[in] ch   Channel number to inspect.
    124           * @param[in] desc Pointer to the descriptor to check.
    125           *
    126           * @return true if @p desc is the active descriptor on the given channel.
    127           * @return false otherwise.
    128           ******************************************************************************/
    129          SL_CODE_CLASSIFY(SL_CODE_COMPONENT_DMA_CHANNEL, SL_CODE_CLASS_DMA_CHANNEL_PERFORMANCE)
    130          static bool is_active_descriptor(const LDMA_TypeDef *ldma,
    131                                           uint8_t ch,
    132                                           const sl_dma_channel_xfer_descriptor_t* desc);
    133          
    134          /***************************************************************************//**
    135           * @brief Retrieve the next descriptor linked from a given descriptor.
    136           *
    137           * Reads the hardware link bit and link address from the descriptor to
    138           * determine the next descriptor in the chain. Returns NULL if the
    139           * descriptor has no link (i.e., it is the last in the chain).
    140           *
    141           * @param[in] desc Pointer to the descriptor whose successor is queried.
    142           *
    143           * @return Pointer to the next descriptor, or NULL if there is no linked
    144           *         successor.
    145           ******************************************************************************/
    146          SL_CODE_CLASSIFY(SL_CODE_COMPONENT_DMA_CHANNEL, SL_CODE_CLASS_DMA_CHANNEL_PERFORMANCE)
    147          static sl_dma_channel_xfer_descriptor_t * get_next_descriptor(sl_dma_channel_xfer_descriptor_t * desc);
    148          
    149          /***************************************************************************//**
    150           * @brief Populate hardware descriptor fields for a DMA transfer.
    151           *
    152           * This function configures all hardware-specific fields in a DMA descriptor
    153           * based on the transfer configuration. The source, destination and
    154           * xfer_unit_count, parameters are provided separately to support transfer
    155           * segmentation and looping transfers where these values may differ from the
    156           * transfer struct.
    157           *
    158           * @param[in] descriptor Pointer to the descriptor to populate.
    159           * @param[in] transfer Pointer to the transfer configuration containing unit_size,
    160           *                     block_size, increment flags, and handshake mode.
    161           * @param[in] source Source address for this descriptor (may be segment-adjusted).
    162           * @param[in] destination Destination address for this descriptor (may be segment-adjusted).
    163           * @param[in] xfer_unit_count Number of transfer units for this descriptor.
    164           ******************************************************************************/
    165          static void populate_descriptor_fields(sl_dma_channel_xfer_descriptor_t *descriptor,
    166                                                 const sl_dma_channel_transfer_t *transfer,
    167                                                 void *source,
    168                                                 void *destination,
    169                                                 uint32_t xfer_unit_count);
    170          
    171          /***************************************************************************//**
    172           * @brief Build descriptors for a single transfer.
    173           *
    174           * This function builds and links all descriptors needed for a single transfer,
    175           * handling both internally allocated and user-provided descriptors. Large
    176           * transfers may be segmented into multiple descriptors if they exceed the
    177           * maximum transfer size per descriptor.
    178           *
    179           * @param[in] current_transfer Pointer to the transfer to build descriptors for.
    180           * @param[in] previous_transfer Pointer to the previous transfer in the list,
    181           *                               or NULL if this is the first transfer.
    182           * @param[in] xfer_unit_size Transfer unit size in bytes.
    183           * @param[in] xfer_unit_count Total number of transfer units for this transfer.
    184           * @param[in] handle Pointer to the DMA channel handle.
    185           *
    186           * @return SL_STATUS_OK if descriptors were built successfully.
    187           * @return SL_STATUS_INVALID_PARAMETER if transfer parameters are invalid.
    188           * @return SL_STATUS_ALLOCATION_FAILED if memory allocation failed.
    189           ******************************************************************************/
    190          static sl_status_t build_descriptors_for_transfer(sl_dma_channel_transfer_t *current_transfer,
    191                                                            const sl_dma_channel_transfer_t *previous_transfer,
    192                                                            uint32_t xfer_unit_size,
    193                                                            uint32_t xfer_unit_count,
    194                                                            const sl_dma_channel_handle_t *handle);
    195          
    196          /***************************************************************************//**
    197           * @brief Clean up internally allocated descriptors on error.
    198           *
    199           * This function frees all descriptors that were internally allocated by the
    200           * DMA Channel driver when an error occurs during descriptor building. The
    201           * function iterates through the linked list of descriptors starting from
    202           * list_head until it reaches a descriptor with no link (link bit = 0).
    203           *
    204           * @param[in] handle Pointer to the dma channel handle.
    205           * @param[in] list_head Pointer to the first descriptor in the linked list.
    206           ******************************************************************************/
    207          static void cleanup_allocated_descriptors(const sl_dma_channel_handle_t *handle,
    208                                                    sl_dma_channel_xfer_descriptor_t *list_head);
    209          
    210          /***************************************************************************//**
    211           * @brief Process a completed descriptor by invoking callback and freeing if needed.
    212           *
    213           * This function processes a completed descriptor by invoking the user callback
    214           * (if present and requested) and freeing the descriptor if it was internally
    215           * allocated. It returns a pointer to the next descriptor in the chain.
    216           *
    217           * @param[in] handle     Pointer to the DMA channel handle.
    218           * @param[in] descriptor Pointer to the descriptor to process.
    219           * @param[in] error      Error flag to pass to callback.
    220           * @param[in] aborted    Aborted flag to pass to callback.
    221           *
    222           * @return Pointer to the next descriptor in the chain, or NULL if this was the last.
    223           ******************************************************************************/
    224          static sl_dma_channel_xfer_descriptor_t* process_descriptor(sl_dma_channel_handle_t* handle,
    225                                                                      sl_dma_channel_xfer_descriptor_t* descriptor,
    226                                                                      bool error,
    227                                                                      bool aborted);
    228          
    229          /***************************************************************************//**
    230           * @brief Process completed descriptors.
    231           *
    232           * This function processes completed descriptors in the channel's queue by
    233           * invoking user callbacks and freeing internally allocated descriptors. It
    234           * walks the descriptor list and uses is_active_descriptor() to determine
    235           * which descriptors have completed. If all descriptors are consumed, the
    236           * channel is disabled and its state is set to SL_DMA_CHANNEL_STATE_DISABLED.
    237           *
    238           * @param[in] handle         Pointer to the DMA channel handle.
    239           ******************************************************************************/
    240          static void process_completed_descriptors(sl_dma_channel_handle_t* handle);
    241          
    242          /***************************************************************************//**
    243           * @brief Internal function to submit a list of transfers with optional looping mode.
    244           *
    245           * This internal function submits a list of transfers to the specified DMA channel
    246           * with the ability to transition the channel into looping mode. It is used by
    247           * both the public API (which never uses looping mode) and by specialized APIs
    248           * like ping_pong and triple_buffered transfers that require looping mode.
    249           *
    250           * When begin_looping_mode is true the channel must be in the
    251           * SL_DMA_CHANNEL_STATE_DISABLED state; otherwise SL_STATUS_INVALID_STATE is
    252           * returned. On successful submission the channel state is set to
    253           * SL_DMA_CHANNEL_STATE_ENABLED. If the hardware CHDONE flag indicates a
    254           * completed transfer, the DMA engine is restarted automatically so that
    255           * the newly submitted descriptors begin executing.
    256           *
    257           * @param[in] handle              Pointer to the DMA channel handle.
    258           * @param[in] list_head           Pointer to the head of the transfer list.
    259           * @param[in] begin_looping_mode  If true, transitions the channel to looping mode
    260           *                                after submitting the transfers. This should only
    261           *                                be true when the transfer list forms a loop
    262           *                                (circular linked list) and is submitted by
    263           *                                ping_pong or triple_buffered APIs.
    264           *
    265           * @return SL_STATUS_OK on success.
    266           * @return SL_STATUS_INVALID_PARAMETER if any transfer validation fails.
    267           * @return SL_STATUS_INVALID_STATE if channel is already in looping mode, or if
    268           *         begin_looping_mode is true and the channel is not disabled.
    269           * @return SL_STATUS_ALLOCATION_FAILED if descriptor allocation fails.
    270           *
    271           * @note This function is for internal use only. External code should use the
    272           *       public API sl_dma_channel_submit_transfer_list() or specialized APIs
    273           *       like sl_dma_channel_submit_transfer_m2p_pingpong().
    274           ******************************************************************************/
    275          static sl_status_t sli_dma_channel_submit_transfer_list(sl_dma_channel_handle_t *handle,
    276                                                                  sl_dma_channel_transfer_t *list_head,
    277                                                                  bool begin_looping_mode);
    278          
    279          /***************************************************************************//**
    280           * @brief Common DMA channel interrupt handler for all channels.
    281           *
    282           * Retrieves the active channel and user data (handle) from the DMA Manager via
    283           * sl_dma_manager_retrieve_current_channel_user_data(), then processes the
    284           * interrupt. Responsibilities:
    285           *  - Detect channel error (CHERROR) and, if present, abort all queued work
    286           *    reporting (error=true, aborted=true) for each descriptor.
    287           *  - Pop and free one or more completed descriptors, invoking the user
    288           *    callback for each with (error=false, aborted=false).
    289           *  - Handle scenarios where multiple descriptors completed while interrupts
    290           *    were masked or delayed by walking the software queue until the currently
    291           *    active hardware descriptor is reached.
    292           *
    293           * The function intentionally operates without holding a long critical section
    294           * (hardware has already signalled completion) and relies on single context
    295           * invocation per hardware channel IRQ.
    296           ******************************************************************************/
    297          static void sl_dma_channel_common_irq_handler(void);
